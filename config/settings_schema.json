  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_width",
        "label": "Container width",
        "min": 1000,
        "max": 2000,
        "step": 10,
        "default": 1920,
        "unit": "px"
      },
      {
        "type": "header",
        "content": "Grid spacing"
      },
      {
        "type": "range",
        "id": "column_spacing",
        "label": "Column spacing",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 15,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "row_spacing",
        "label": "Row spacing",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 15,
        "unit": "px"
      }
