{%- style -%}
  /* --- Custom Font Setup --- */
  @font-face {
    font-family: 'Elza';
    font-weight: 400;
    font-style: normal;
  }

  .marquee-slider-{{ section.id }} {
    padding-top: 70px;
    padding-bottom: 70px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  /* --- Text Container Styles --- */
  .marquee-slider-{{ section.id }} .text-container {
    text-align: center;
    margin: 0 auto;
    max-width: 620px;
    box-sizing: border-box;
  }

  .marquee-slider-{{ section.id }} .marquee-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    color: #000000;
    margin: 0 0 20px 0; /* Gap between heading and paragraph: 20px */
    padding: 0;
    font-size: 60px;
    line-height: 1.1;
    letter-spacing: 0%;
  }

  .marquee-slider-{{ section.id }} .marquee-paragraph {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 120%; /* 24px */
    letter-spacing: 0%;
    color: #000000;
    margin: 0 0 40px 0; /* Gap between text container and slider: 40px */
    padding: 0;
  }

  /* --- Slider Container & Infinite Track Styles --- */
  .marquee-slider-{{ section.id }} .slider-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    display: flex;
  }

  .marquee-slider-{{ section.id }} .marquee-track {
    display: flex;
    user-select: none;
    gap: 17.92px; /* Precision gap between slider cards */
    animation: smoothMarquee {{ section.settings.speed }}s linear infinite;
    will-change: transform; 
  }

  {% if section.settings.pause_on_hover %}
  .marquee-slider-{{ section.id }} .slider-container:hover .marquee-track {
    animation-play-state: paused;
  }
  {% endif %}

  /* --- Desktop Precision Sizing (1440px Framework) --- */
  .marquee-slider-{{ section.id }} .slider-card {
    flex-shrink: 0;
    height: 346px;  /* Exact height requested for 1440px */
    width: 346.5px; /* Perfect split to show exactly 4 cards clean on 1440px viewport */
    overflow: hidden;
  }

  .marquee-slider-{{ section.id }} .slider-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Infinite Loop Keyframe */
  @keyframes smoothMarquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(calc(-50% - 8.96px));
    }
  }

  /* --- Mobile Precision Sizing (360px Framework) --- */
  @media screen and (max-width: 767px) {
    .marquee-slider-{{ section.id }} {
      padding-top: 70px;
      padding-bottom: 70px;
    }
    
    .marquee-slider-{{ section.id }} .text-container {
      padding-left: 38px;  /* Text container boundary tracking */
      padding-right: 38px; 
    }

    .marquee-slider-{{ section.id }} .marquee-heading {
      margin-bottom: 20px; 
      font-size: 30px;
    }

    .marquee-slider-{{ section.id }} .marquee-paragraph {
      font-size: 15px;      
      line-height: 120%;    
      margin-bottom: 40px;  /* Mobile text container to slider gap: 40px */
    }

    .marquee-slider-{{ section.id }} .marquee-track {
      gap: 17.92px;        
    }

    .marquee-slider-{{ section.id }} .slider-card {
      height: 268px;        /* Changed to exact 268px square height */
      width: 268px;         /* Changed to exact 268px square width */
    }
  }
{%- endstyle -%}

<div class="marquee-slider-{{ section.id }} section-{{ section.id }}-padding">
  <div class="text-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="marquee-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.paragraph != blank -%}
      <p class="marquee-paragraph">{{ section.settings.paragraph | escape }}</p>
    {%- endif -%}
  </div>

  <div class="slider-container">
    <div class="marquee-track">
      {%- for i in (1..2) -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'image_card' -%}
            <div class="slider-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.image.alt | escape
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Infinite Marquee Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We get outside."
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph Text",
      "default": "We ride, run, climb, and race trails and backcountry — and we built a tag we'd trust with our own families out there."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "s",
      "label": "Animation Duration (Speed)",
      "default": 26
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause marquee on hover",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Slider Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infinite Marquee Slider",
      "blocks": [
        { "type": "image_card" },
        { "type": "image_card" },
        { "type": "image_card" },
        { "type": "image_card" }
      ]
    }
  ]
}
{% endschema %}