{%- style -%}
  @font-face {
    font-family: 'Elza';
    font-weight: 400;
    font-style: normal;
  }

  .marquee-slider-{{ section.id }} {
    padding-top: 70px;
    padding-bottom: 70px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  /* --- Text Container Styles --- */
  .marquee-slider-{{ section.id }} .text-container {
    text-align: center;
    margin: 0 auto;
    max-width: 1440px;
    box-sizing: border-box;
  }

  .marquee-slider-{{ section.id }} .marquee-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    color: #000000;
    margin: 0 0 20px 0; /* Gap between heading and paragraph: 20px */
    padding: 0;
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: 0%;
  }

  .marquee-slider-{{ section.id }} .marquee-paragraph {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 120%; /* 24px */
    letter-spacing: 0%;
    color: #000000;
    margin: 0 0 40px 0; /* Gap between text container and slider: 40px */
    padding: 0;
  }

  /* --- Slider Container & Infinite Track Styles --- */
  .marquee-slider-{{ section.id }} .slider-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    display: flex;
  }

  .marquee-slider-{{ section.id }} .marquee-track {
    display: flex;
    user-select: none;
    gap: 17.92px; /* Precision gap between slider cards */
    animation: smoothMarquee {{ section.settings.speed }}s linear infinite;
    will-change: transform; 
  }

  {% if section.settings.pause_on_hover %}
  .marquee-slider-{{ section.id }} .slider-container:hover .marquee-track {
    animation-play-state: paused;
  }
  {% endif %}

  /* --- Desktop Precision Sizing (1440px Framework) --- */
  .marquee-slider-{{ section.id }} .slider-card {
    flex-shrink: 0;
    height: 346px;  /* Exact min-height requested for 1440px */
    width: 346.5px; /* Perfect mathematical split to show exactly 4 cards clean on 1440px viewport */
    overflow: hidden;
  }

  .marquee-slider-{{ section.id }} .slider-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Infinite Loop Keyframe */
  @keyframes smoothMarquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(calc(-50% - 8.96px));
    }
  }

  /* --- Mobile Precision Sizing (360px Framework) --- */
  @media screen and (max-width: 767px) {
    .marquee-slider-{{ section.id }} {
      padding-top: 70px;
      padding-bottom: 70px;
    }
    
    .marquee-slider-{{ section.id }} .text-container {
      padding-left: 38px;  /* Text container boundary tracking */
      padding-right: 38px; 
    }

    .marquee-slider-{{ section.id }} .marquee-heading {
      margin-bottom: 20px; /* Mobile heading to paragraph gap: 20px */
      font-size: 32px;
    }

    .marquee-slider-{{ section.id }} .marquee-paragraph {
      font-size: 15px;      
      line-height: 120%;    
      margin-bottom: 40px;  /* Mobile text container to slider gap: 40px */
    }

    .marquee-slider-{{ section.id }} .marquee-track {
      gap: 17.92px;        
    }

    .marquee-slider-{{ section.id }} .slider-card {
      height: 268px;        /* Exact min-height requested for mobile 360px */
      width: 165px;         /* Portrait scaling to beautifully frame exactly 2 cards side-by-side */
    }
  }
{%- endstyle -%}