{% style %}
/* --- YouTube Background Iframe Fix --- */
.kopilot-hero2--{{ section.id }} .kopilot-hero2__bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none !important;
}

.kopilot-hero2--{{ section.id }} .kopilot-hero2__yt-wrap {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: auto;
}

.kopilot-hero2--{{ section.id }} .kopilot-hero2__yt-wrap iframe,
.kopilot-hero2--{{ section.id }} #KopilotHero2Yt-{{ section.id }} {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100vw;
  height: 56.25vw; /* 16:9 */
  min-height: 100%;
  min-width: 177.77vh;
  border: none;
  pointer-events: none !important;
  transform: translate(-50%, -50%) scale(1.5);
}

.kopilot-hero2--{{ section.id }} .kopilot-hero2__yt-shield {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: auto;
  background: transparent;
}
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-hero2.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-hero2 kopilot-hero2--{{ section.id }} color-{{ section.settings.color_scheme }}">

  <!-- Background: video or image -->
  <div class="kopilot-hero2__bg">
    {% if section.settings.video != blank %}
      <video
        autoplay
        muted
        loop
        playsinline
        poster="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 1440 }}{% endif %}"
      >
        <source src="{{ section.settings.video }}" type="video/mp4">
      </video>
    {% elsif section.settings.video_url != blank and section.settings.video_url.type == 'youtube' %}
      {%- comment -%}
        Do NOT use playlist= for looping — that is what shows the center prev/pause/next controls.
        Loop is handled by the YouTube IFrame API on ENDED below.
      {%- endcomment -%}
      <div class="kopilot-hero2__yt-wrap">
        <div
          id="KopilotHero2Yt-{{ section.id }}"
          data-youtube-id="{{ section.settings.video_url.id }}"
        ></div>
        <div class="kopilot-hero2__yt-shield" aria-hidden="true"></div>
      </div>
      <script>
        (function () {
          var sectionId = {{ section.id | json }};
          var videoId = {{ section.settings.video_url.id | json }};
          var playerId = 'KopilotHero2Yt-' + sectionId;

          function createPlayer() {
            if (!window.YT || !window.YT.Player) return;
            var mount = document.getElementById(playerId);
            if (!mount || mount.dataset.ytReady === '1') return;
            mount.dataset.ytReady = '1';

            var player = new YT.Player(playerId, {
              videoId: videoId,
              playerVars: {
                autoplay: 1,
                mute: 1,
                controls: 0,
                disablekb: 1,
                fs: 0,
                iv_load_policy: 3,
                modestbranding: 1,
                playsinline: 1,
                rel: 0,
                cc_load_policy: 0,
                showinfo: 0
              },
              events: {
                onReady: function (event) {
                  event.target.mute();
                  event.target.playVideo();
                  var iframe = event.target.getIframe && event.target.getIframe();
                  if (iframe) {
                    iframe.setAttribute('tabindex', '-1');
                    iframe.style.pointerEvents = 'none';
                  }
                },
                onStateChange: function (event) {
                  if (event.data === YT.PlayerState.PAUSED) {
                    event.target.playVideo();
                  }
                  if (event.data === YT.PlayerState.ENDED) {
                    event.target.seekTo(0);
                    event.target.playVideo();
                  }
                }
              }
            });

            setInterval(function () {
              try {
                if (player && typeof player.getPlayerState === 'function') {
                  if (player.getPlayerState() === YT.PlayerState.PAUSED) {
                    player.playVideo();
                  }
                }
              } catch (e) {}
            }, 1000);
          }

          if (window.YT && window.YT.Player) {
            createPlayer();
          } else {
            var previous = window.onYouTubeIframeAPIReady;
            window.onYouTubeIframeAPIReady = function () {
              if (typeof previous === 'function') previous();
              createPlayer();
            };
            if (!document.getElementById('youtube-iframe-api')) {
              var tag = document.createElement('script');
              tag.id = 'youtube-iframe-api';
              tag.src = 'https://www.youtube.com/iframe_api';
              document.head.appendChild(tag);
            }
          }
        })();
      </script>
    {% else %}
      {% assign mobile_img = section.settings.background_image_mobile %}
      {% assign desktop_img = section.settings.background_image %}
      {% if desktop_img != blank %}
        {{ desktop_img | image_url: width: 1920 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.heading,
          width: desktop_img.width,
          height: desktop_img.height,
          class: 'kopilot-hero2__bg-desktop'
        }}
      {% else %}
        <img
          src="{{ 'ba364058e14ab9f73dd4f65ee4e8e3b8ae77a58f.jpg' | asset_url }}"
          alt="{{ section.settings.heading }}"
          loading="eager"
          fetchpriority="high"
          width="1440"
          height="659"
          class="kopilot-hero2__bg-desktop"
        >
      {% endif %}
      {% if mobile_img != blank %}
        {{ mobile_img | image_url: width: 767 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.heading,
          width: mobile_img.width,
          height: mobile_img.height,
          class: 'kopilot-hero2__bg-mobile'
        }}
      {% endif %}
    {% endif %}
  </div>

  <div class="kopilot-hero2__inner">

    <!-- Left content -->
    <div class="kopilot-hero2__content">
      <div class="kopilot-hero2__text-group">
        {% if section.settings.heading != blank %}
          <h1 class="kopilot-hero2__heading">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.body != blank %}
          <p class="kopilot-hero2__body">{{ section.settings.body }}</p>
        {% endif %}
      </div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_url | default: '#' }}" class="kopilot-hero2__btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <!-- Right product image -->
    {% if section.settings.product_image != blank %}
      <div class="kopilot-hero2__product">
        {{ section.settings.product_image | image_url: width: 430 | image_tag:
          loading: 'eager',
          alt: section.settings.product_image.alt | default: 'KOPILOT.ID',
          width: section.settings.product_image.width,
          height: section.settings.product_image.height
        }}
      </div>
    {% else %}
      <div class="kopilot-hero2__product">
        <img
          src="{{ 'Mask group.png' | asset_url }}"
          alt="KOPILOT.ID"
          loading="eager"
          width="214"
          height="237"
        >
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Hero 2",
  "tag": "section",
  "class": "kopilot-hero2-section",
  "disabled_on": { "groups": ["footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Shown on screens ≤767px. Falls back to desktop image if left empty."
    },
    {
      "type": "text",
      "id": "video",
      "label": "Background video URL (.mp4)",
      "info": "Paste a direct .mp4 URL. Video overrides the background image."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "YouTube Background Video",
      "accept": ["youtube"],
      "info": "Upload Yt Video Link Here."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This could help someone save your life."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "You could be unconscious or unable to speak. Would responders know your allergies, medications, medical conditions, or who to contact? KOPILOT.ID keeps that information with you."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "GET KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (right side)",
      "info": "Defaults to Mask group.png if left empty."
    }
  ],
  "presets": [
    {
      "name": "Hero 2",
      "settings": {
        "heading": "This could help someone save your life.",
        "body": "You could be unconscious or unable to speak. Would responders know your allergies, medications, medical conditions, or who to contact? KOPILOT.ID keeps that information with you.",
        "button_label": "GET KOPILOT.ID"
      }
    }
  ]
}
{% endschema %}
