{% style %}
.dual-banner-{{ section.id }} {
  padding-top: {{ section.settings.top_spacing }}px; 
  padding-bottom : {{ section.settings.bottom_spacing }}px;
}


@media(max-width: 989px){
  .dual-banner-{{ section.id }} {
    padding-top: {{ section.settings.top_spacing_mobile }}px; 
    padding-bottom : {{ section.settings.bottom_spacing_mobile }}px;
  }

}

{% endstyle %}

{% style %}
.dual-banner-{{ section.id }} .wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 40px;
  padding-bottom: 40px;
}

.dual-banner-{{ section.id }} .img-left {
  width: 25%;
  max-width: 25%;
  transform: translateY(-40px);
}

.dual-banner-{{ section.id }} .content {
  width: 40%;
  max-width: 50%;
  text-align: center;
}

.dual-banner-{{ section.id }} .img-right {
  width: 25%;
  max-width: 25%;
  transform: translateY(40px);
}


.dual-banner-{{ section.id }} p {
  font-size: 14px;
  color: #666;
  margin-bottom: 40px;
  margin-top: 20px;
}


/* IMAGE STYLE */
.dual-banner-{{ section.id }} img {
  width: 100%;
  border-radius: 10px;
}

.dual-banner-{{ section.id }} .img-left img,
.dual-banner-{{ section.id }} .img-right img {
  transition: transform 0.7s ease, box-shadow 0.5s ease;
}

.dual-banner-{{ section.id }} .img-left:hover img {
  transform: scale(1.06) rotate(-2deg);
  box-shadow: 0 20px 40px rgba(0,0,0,0.12);
}

.dual-banner-{{ section.id }} .img-right:hover img {
  transform: scale(1.06) rotate(2deg);
  box-shadow: 0 20px 40px rgba(0,0,0,0.12);
}
@keyframes floatingLeft {
  0% {
    transform: translateY(-40px);
  }
  50% {
    transform: translateY(-50px);
  }
  100% {
    transform: translateY(-40px);
  }
}

@keyframes floatingRight {
  0% {
    transform: translateY(40px);
  }
  50% {
    transform: translateY(50px);
  }
  100% {
    transform: translateY(40px);
  }
}

.dual-banner-{{ section.id }} .img-left {
  animation: floatingLeft 4s ease-in-out infinite;
}

.dual-banner-{{ section.id }} .img-right {
  animation: floatingRight 4s ease-in-out infinite;
}
/* MOBILE */
@media(max-width: 768px){
  .dual-banner-{{ section.id }} .wrapper {
    flex-direction: column;
    gap: 20px;
  }

  .dual-banner-{{ section.id }} .img-left,
  .dual-banner-{{ section.id }} .img-right {
    transform: none;
    width: 80%;
  }
}

@media (max-width: 768px) {
  .dual-banner-{{ section.id }} .wrapper {
    flex-direction: column;
    padding-top: 20px;
    padding-bottom: 20px;
    gap: 24px;
    text-align: center;
  }

  .dual-banner-{{ section.id }} .img-left,
  .dual-banner-{{ section.id }} .img-right,
  .dual-banner-{{ section.id }} .content {
    width: 100%;
    max-width: 100%;
    transform: none;
  }

  .dual-banner-{{ section.id }} .img-left,
  .dual-banner-{{ section.id }} .img-right {
    max-width: 100%;
    margin: 0 auto;
  }

  .dual-banner-{{ section.id }} .content {
    order: 2;
    padding: 0 10px;
  }

  .dual-banner-{{ section.id }} .img-left {
    order: 1;
  }

  .dual-banner-{{ section.id }} .img-right {
    order: 3;
  }

  .dual-banner-{{ section.id }} .content h1 {
    font-size: 24px;
    line-height: 1.3;
  }

  .dual-banner-{{ section.id }} p {
    font-size: 14px;
    margin-bottom: 20px;
  }

  .dual-banner-{{ section.id }} .btn {
    width: fit-content;
    margin: 0 auto;
  }
}

{% endstyle %}

<div class="dual-banner-{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="container wrapper">

    <!-- LEFT IMAGE -->
    <div class="img-left">
      {% if section.settings.left_image != blank %}
        {{ section.settings.left_image | image_url: width: 400 | image_tag }}
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder_svg' }}
      {% endif %}
    </div>

    <!-- CENTER CONTENT -->
    <div class="content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>

      {% if section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <!-- RIGHT IMAGE -->
    <div class="img-right">
      {% if section.settings.right_image != blank %}
        {{ section.settings.right_image | image_url: width: 400 | image_tag }}
    {% else %}
        {{ 'collection-2' | placeholder_svg_tag: 'placeholder_svg' }}
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Dual image banner",
  "disabled_on": {
      "groups": ["header", "footer"]
    },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ENJOY 25% OFF ON HANDCRAFTED ART FOR YOUR BEAUTIFUL HOME"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Bring life to your walls with beautifully handcrafted art that inspires and elevates your space."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
       "type": "header",
       "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "default": 50
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "default": 50
    },
    {
      "type": "range",
      "id": "top_spacing_mobile",
      "label": "Top spacing (Mobile)",
      "min": 0,
      "max": 100,
      "default": 30
    },
    {
      "type": "range",
      "id": "bottom_spacing_mobile",
      "label": "Bottom spacing (Mobile)",
      "min": 0,
      "max": 100,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Dual image banner"
    }
  ]
}
{% endschema %}