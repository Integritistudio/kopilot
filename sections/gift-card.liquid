{% style %}
  .gift_card_wrapper--{{ section.id }} {
    padding-top: {{ section.settings.top_spacing }}px;
    padding-bottom: {{ section.settings.bottom_spacing }}px;
    height: 100%;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .gift_card_wrapper--{{ section.id }}
  .container {
    width: 100%;
  }

  @media screen and (max-width: 640px) {
    .gift_card_wrapper--{{ section.id }} {
      padding-top: {{ section.settings.top_spacing | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.bottom_spacing | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{{ 'gift-card.css' | asset_url | stylesheet_tag }}

<div class="gift_card_wrapper--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="container">
    <div class="gift_card_section_inner">
      <div class="gift_card_section_img_wrapper" style="--object-fit: {{ section.settings.img_object_fit }};">
        <p>
          {% if section.settings.img != blank %}
            {{ section.settings.img | image_url: width: 1200 | image_tag }}
          {% else %}
            <img
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.card' | t }}"
              width="100%"
              height="344px">
          {% endif %}
        </p>
      </div>

      <div class="gift_card_content_wrapper">
        <div class="gift_card_qr_code_wrapper" data-identifier="{{ gift_card.qr_identifier }}"></div>

        <div
          class="gift_card_logo_wrapper"
          {% if section.settings.logo != blank %}
          style="--logo-width: {{ section.settings.logo_size }}px;"
          {% endif %}>
          {% if section.settings.logo != blank %}
            <h1>
            <a href="{{ routes.root_url }}" aria-label="{{ 'general.home' | t }}">
              {{ section.settings.logo | image_url: width: section.settings.logo_size | image_tag: class: 'gift_card_logo' }}
            </a>
            </h1>
          {% else %}
            <h1>
              <a aria-label="{{ 'general.home' | t }}" href="{{ routes.root_url }}">
                {{ shop.name }}
              </a>
            </h1>
          {% endif %}
        </div>

        <div class="gift_card_section_header">
          {% if settings.currency_code_enabled %}
            <h2 class="xxl">{{ gift_card.balance | money_with_currency }}</h2>
          {% else %}
            <h2 class="xxl">{{ gift_card.balance | money }}</h2>
          {% endif %}

          {% if gift_card.enabled == false or gift_card.expired %}
            <p>{{ 'gift_card.expired' | t }}</p>
          {% endif %}

          {% if gift_card.expires_on %}
            {% assign expires_on = gift_card.expires_on | date: '%B %e, %Y' %}
            <p>
              {{ 'gift_card.expires_on' | t: expires_on: expires_on }}
            </p>
          {% endif %}
        </div>

        <div class="gift_card_section_info_wrapper">


          <p class="use_at_checkout">{{ 'gift_card.use_at_checkout' | t }}</p>

          <p class="gift_card_code">{{ gift_card.code | format_code }}</p>


          {%- if gift_card.pass_url -%}
            <a href="{{ gift_card.pass_url }}" class="gift_card__apple-wallet no-print">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                width="120"
                height="40"
                alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}"
                loading="lazy">
            </a>
          {%- endif -%}

          {% if gift_card.pass_url %}
            <a href="{{ gift_card.pass_url }}">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
                width="200"
                height="60">
            </a>
          {% endif %}
        </div>

        <div class="gift-card_btns_wrapper">
          <span class="gift_card_copy_success form__message" role="status"></span>
          <template>
            <span class="icon_wrapper">
              {{- 'icon-success.svg' | inline_asset_content -}}
            </span>
            {{ 'gift_cards.issued.copy_code_success' | t }}
          </template>
          <button class="btn gift_card_copy_btn">{{ 'gift_cards.issued.copy_code' | t }}</button>
          <a
            href="{{ shop.url }}"
            class="visit_online_store"
            target="_blank"
            rel="noopener">
            {{ 'gift_cards.issued.shop_link' | t }}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Gift card",
    "settings": [
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "scheme-3"
      },
      {
        "type": "image_picker",
        "id": "img",
        "label": "Select gift card image"
      },
      {
        "type": "select",
        "id": "img_object_fit",
        "label": "Image object fit",
        "options": [
          {
            "value": "contain",
            "label": "Contain"
          }, {
            "value": "cover",
            "label": "Cover"
          }
        ],
        "default": "contain"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      }, {
        "type": "range",
        "id": "logo_size",
        "label": "Logo width",
        "min": 10,
        "max": 600,
        "step": 10,
        "default": 90
      }, {
        "type": "header",
        "content": "Section spacing"
      }, {
        "type": "range",
        "id": "top_spacing",
        "label": "Top spacing",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 40,
        "unit": "px"
      }, {
        "type": "range",
        "id": "bottom_spacing",
        "label": "Bottom spacing",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 40,
        "unit": "px"
      }
    ]
  }
{% endschema %}