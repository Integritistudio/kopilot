{% style %}
  .kopilot-faq--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .kopilot-faq--{{ section.id }} .kopilot-faq__heading {
    {% if section.settings.heading_font_size != blank %}font-size: {{ section.settings.heading_font_size }}px !important;{% endif %}
    {% if section.settings.heading_font_weight != blank %}font-weight: {{ section.settings.heading_font_weight }} !important;{% endif %}
    {% if section.settings.heading_line_height != blank %}line-height: {{ section.settings.heading_line_height }} !important;{% endif %}
  }

  @media screen and (max-width: 767px) {
    .kopilot-faq--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .kopilot-faq--{{ section.id }} .kopilot-faq__heading {
      {% if section.settings.heading_font_size_mobile != blank %}font-size: {{ section.settings.heading_font_size_mobile }}px !important;{% endif %}
      {% if section.settings.heading_font_weight_mobile != blank %}font-weight: {{ section.settings.heading_font_weight_mobile }} !important;{% endif %}
      {% if section.settings.heading_line_height_mobile != blank %}line-height: {{ section.settings.heading_line_height_mobile }} !important;{% endif %}
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-faq.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-faq kopilot-faq--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <faq-section>
    <div class="kopilot-faq__inner">
      {% if section.settings.heading != blank %}
        <h2 class="kopilot-faq__heading kopilot-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="kopilot-faq__list faq_inner">
        {% for block in section.blocks %}
          <div class="faq_item" {{ block.shopify_attributes }}>
            <button type="button" class="faq_question{% if forloop.first %} active{% endif %}">
              <h3 class="h6 kopilot-body">{{ block.settings.question }}</h3>
              <span class="faq_arrow" aria-hidden="true">
                <span class="faq_hori"></span>
                <span class="faq_vert"></span>
              </span>
            </button>
            <div class="faq_answer"{% if forloop.first %} style="height: auto;"{% endif %}>
              <div class="faq_answer_inner kopilot-body rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </faq-section>
</section>

{% schema %}
{
  "name": "Kopilot FAQ",
  "tag": "section",
  "class": "kopilot-faq-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions"
    },
    {
      "type": "header",
      "content": "Heading typography — Desktop"
    },
    {
      "type": "number",
      "id": "heading_font_size",
      "label": "Font size (px)",
      "info": "Leave blank to use theme default"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": ""
    },
    {
      "type": "text",
      "id": "heading_line_height",
      "label": "Line height",
      "info": "e.g. 1.2 or 6rem — leave blank to use theme default"
    },
    {
      "type": "header",
      "content": "Heading typography — Mobile"
    },
    {
      "type": "number",
      "id": "heading_font_size_mobile",
      "label": "Font size (px)",
      "info": "Leave blank to use theme default"
    },
    {
      "type": "select",
      "id": "heading_font_weight_mobile",
      "label": "Font weight",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": ""
    },
    {
      "type": "text",
      "id": "heading_line_height_mobile",
      "label": "Line height",
      "info": "e.g. 2 or 3rem — leave blank to use theme default"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is an NFC tag and how does it work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>An NFC tag is a small chip that can be scanned by most smartphones. When someone taps your KOPILOT.ID tag, it instantly opens your digital medical ID profile with your critical information—no app or signal required.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What is an NFC tag and how does it work?",
            "answer": "<p>An NFC tag is a small chip that can be scanned by most smartphones. When someone taps your KOPILOT.ID tag, it instantly opens your digital medical ID profile with your critical information—no app or signal required.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do NFC tags work without cell service?",
            "answer": "<p>Yes. Once your profile is set up, the tag works without cell service or battery power on the tag itself.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "What information can I store on my NFC medical ID?",
            "answer": "<p>You control what you share — medical conditions, allergies, medications, emergency contacts, and more.</p>"
          }
        },
        {
          "type": "question",
