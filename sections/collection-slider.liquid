{% style %}
    .cs-slider--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .cs-slider__wrapper {
      display: flex;
      gap: {{ section.settings.gap }}px;
      align-items: center;
    }

     .cs-slider__wrapper .cs-slider__content {
      width: 25%;
      flex-shrink: 0;
    }

     .cs-slider__wrapper .cs-slider__slider {
      flex: 1;
      min-width: 0;
    }

   .cs-slider__wrapper .cs-card {
      text-align: center;
      position: relative;
    }

  .cs-slider__wrapper .cs-count {
    position: absolute;
    top: 35%;
    right: 38%;
    background: var(--color-secondary-button-background);
    color: var(--color-secondary-button-text);
    font-size: 14px;
    padding: 14px 20px;
    border-radius: 30px;

    transform: translateY(0) scale(1);
    transition:
      background-color 0.5s ease,
      color 0.5s ease,
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.6s cubic-bezier(0.22, 1, 0.36, 1);

    will-change: transform;
  }

  .cs-slider__wrapper .cs-card:hover .cs-count {
    background: var(--color-secondary-button-hover-background);
    color: var(--color-secondary-button-hover-text);

    transform: translateY(-6px) scale(1.08);

    box-shadow:
      0 10px 25px rgba(0,0,0,0.12),
      0 4px 10px rgba(0,0,0,0.08);
  }


     .cs-slider__wrapper .cs-img-wrap {
      width: 100%;
      aspect-ratio: 1/1;
      overflow: hidden;
      border-radius: 50%;
      background: var(--color-secondary-background);
      display: flex;
      align-items: center;
      justify-content: center;
          margin-bottom: 10px;
    }

     .cs-slider__wrapper .cs-img-wrap svg {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    
    .cs-slider__slider a {
      text-decoration: none;
    }

    @media(max-width: 767px){
       .cs-slider__wrapper .cs-slider__wrapper {
        flex-direction: column;
        align-items: flex-start;
      }
      
    }

    @media (max-width: 767px){
      .cs-slider__wrapper {
        flex-direction: column;
      }
      .cs-slider__wrapper .cs-slider__content {
        width: 100%;
        flex-shrink: 0;
      }
      .cs-slider__wrapper .cs-slider__slider {
          flex: 1;
          min-width: 0;
          width: 100%;
      }
      .cs-slider--{{ section.id }} {
        padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
        padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
      }
      
    }

    @media (max-width: 500px){
      .cs-slider__wrapper .cs-count {
        position: absolute;
        top: 30%;
        right: 36%;
        font-size: 12px;
        padding: 10px 16px;
      }
      
    }

{% endstyle %}

<div class="cs-slider--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="container">
    <div class="cs-slider__wrapper {% unless section.settings.show_block %}no-block{% endunless %}">
      {% if section.settings.show_block %}
        <div class="cs-slider__content">
          <h1>{{ section.settings.heading }}</h1>
          <p>{{ section.settings.text }}</p>
        </div>
      {% endif %}

      <div class="cs-slider__slider">
        <swiper-section
          data-slides-desktop="{{ section.settings.slides_desktop }}"
          data-slides-mobile="2.2"
          data-slides-tablet="3"
          data-gap="{{ section.settings.gap }}"
        >
          <div class="swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                {% assign col = block.settings.collection %}

                <div class="swiper-slide">
                <a href="{{ col.url }}">
                  <div class="cs-card">
                    <span class="cs-count">
                      {% if col != blank %}
                        {{ col.products_count }}
                      {% else %}
                        0
                      {% endif %}
                    </span>

                    <div class="cs-img-wrap">
                      {% comment %} CUSTOM IMAGE {% endcomment %}
                      {% if block.settings.col_image != blank %}
                        {{
                          block.settings.col_image
                          | image_url: width: 400
                          | image_tag: loading: 'lazy', alt: block.settings.collection_name
                        }}

                      {% elsif col.featured_image != blank %}
                        {{ col.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: col.title }}

                      {% else %}
                        {{ 'collection-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>

                    <h6>
                      {% if block.settings.collection_name != blank %}
                        {{ block.settings.collection_name }}
                      {% else %}
                        {{ col.title }}
                      {% endif %}
                    </h6>
                  </div>
                </a>
                </div>
              {% endfor %}
            </div>
          </div>
        </swiper-section>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection slider",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },

    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_block",
      "label": "Show content block",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading",
      "visible_if": "{{ section.settings.show_block }}"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "visible_if": "{{ section.settings.show_block }}"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection item",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "col_image",
          "label": "Collection image"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection name"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Collection slider",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
