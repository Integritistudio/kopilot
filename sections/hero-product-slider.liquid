{% style %}

  .nxpsx-wrapper-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  
@media screen and (max-width: 749px){
  .nxpsx-wrapper-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
}
{% endstyle %}

{{ 'hero-product-slider.css' | asset_url | stylesheet_tag }}

<div class="nxpsx-wrapper-{{ section.id }} nxpsx-wrapper color-{{ section.settings.color_scheme }}">
  <div class="swiper nxpsx-swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}

        <div class="swiper-slide">
          <div class="nxpsx-slide nxpsx-size-{{ section.settings.image_size }} ">
            <!-- IMAGE -->
            <div class="nxpsx-left">
              <div class="nxpsx-image">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 1500 | image_tag }}
                {% else %}
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder_svg' }}
                {% endif %}
              </div>

              <div class="nxpsx-content {{ block.settings.content_position }}">
                <h1 class="nxpsx-title xl">
                  {{ block.settings.heading | default: 'NATURE’S ESSENCE IN EVERY FRAME' }}
                </h1>
                <p class="nxpsx-sub">
                  {{ block.settings.subheading | default: 'Capturing beauty in every moment' }}
                </p>
              </div>
            </div>

            <!-- PRODUCT -->
            <div class="nxpsx-right">
              <div class="nxpsx-product-box">
                {% if product != blank %}
                  <a href="{{ product.url }}">
                    {% if product.featured_image != blank %}
                      {{ product.featured_image | image_url: width: 500 | image_tag }}
                    {% else %}
                      <div class="product-placeholder">
                        {% assign placeholder_index = forloop.index | modulo: 6 %}
                        {% if placeholder_index == 0 %}
                          {% assign placeholder_index = 6 %}
                        {% endif %}
                        {{ 'collection-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {% endif %}

                    <h5 class="product-title-ss">{{ product.title }}</h5>

                    <span class="product_card_price">
                      {{ product.price | money }}
                    </span>
                  </a>

                {% else %}
                  <!-- DUMMY PRODUCT (preview / no product selected) -->
                  <div class="product-placeholder">
                    {% assign img_index = forloop.index | modulo: 2 %}
                    {% if img_index == 1 %}
                      {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>

                  <h5 class="product-title-ss">{{ 'onboarding.product_title' | t }}</h5>

                  <span class="product_card_price">{{ 'onboarding.product_price' | t | money }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="nxpsx-controls container right-only{% if section.settings.show_pagination == false %} no_pagination{% endif %}">
      <!-- PAGINATION (NUMBER + PROGRESS) -->
      {% if section.settings.show_pagination and section.blocks.size > 1 %}
        <div class="nxpsx-progress pagination-right">
          <span class="nxpsx-current">01</span>

          <div class="nxpsx-bar">
            <div class="nxpsx-bar-inner"></div>
          </div>

          <span class="nxpsx-total">0{{ section.blocks.size }}</span>
        </div>
      {% endif %}

      <!-- ARROWS -->
      {% if section.settings.show_arrows and section.blocks.size > 1 %}
        <div class="nxpsx-arrows">
          <button class="swiper-button-prev">
            <span class="svg_wrapper">{{ 'left-arrow.svg' | inline_asset_content }}</span>
          </button>

          <button class="swiper-button-next">
            <span class="svg_wrapper">{{ 'right-arrow.svg' | inline_asset_content }}</span>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function(){

    const swiper = new Swiper('.nxpsx-swiper', {
      loop: false,
      speed: 800,
      autoplay: {{ section.settings.autoplay }} ? {
        delay: 3000
      } : false,

      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev'
      }
    });

    const pagination = document.querySelector('.nxpsx-progress');
    const currentEl = document.querySelector('.nxpsx-current');
    const progressEl = document.querySelector('.nxpsx-bar-inner');
    const total = {{ section.blocks.size }};

    if(pagination) {
      function updatePagination() {
      let current = swiper.realIndex + 1;

      currentEl.textContent = current < 10 ? '0' + current : current;

      let percent = (current / total) * 100;
      progressEl.style.width = percent + '%';
    }

      updatePagination();
    }

    swiper.on('slideChange', updatePagination);

  });
</script>

{% schema %}
{
  "name": "Product hero slider",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "Image size",
      "options": [
        { "value": "full", "label": "Full screen" },
        { "value": "half", "label": "Half screen" },
        { "value": "adapt", "label": "Adapt to image" }
      ],
      "default": "full"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": true
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Subheading"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        
      ]
    }
  ],
  "presets": [
    {
      "name": "Product hero slider",
      "blocks": [{ "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
