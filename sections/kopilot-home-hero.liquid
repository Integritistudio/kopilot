{%- liquid
  assign yt_id = blank
  assign raw_video = section.settings.video

  if raw_video != blank
    if raw_video contains 'youtube.com' or raw_video contains 'youtu.be'
      if raw_video contains 'youtu.be/'
        assign yt_id = raw_video | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first | strip
      elsif raw_video contains 'v='
        assign yt_id = raw_video | split: 'v=' | last | split: '&' | first | split: '?' | first | strip
      elsif raw_video contains 'embed/'
        assign yt_id = raw_video | split: 'embed/' | last | split: '?' | first | split: '&' | first | strip
      endif
    endif
  endif

  assign has_youtube = false
  if yt_id != blank
    assign has_youtube = true
  endif

  assign has_mp4 = false
  if raw_video != blank and has_youtube == false
    assign has_mp4 = true
  endif
-%}

{% style %}
.kopilot-home-hero--{{ section.id }} .kopilot-home-hero__yt-wrap {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.kopilot-home-hero--{{ section.id }} .kopilot-home-hero__yt-wrap iframe,
.kopilot-home-hero--{{ section.id }} #KopilotHomeHeroYt-{{ section.id }} {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100vw;
  height: 56.25vw;
  min-height: 100%;
  min-width: 177.77vh;
  border: none;
  pointer-events: none !important;
  transform: translate(-50%, -50%) scale(1.5);
}

.kopilot-home-hero--{{ section.id }} .kopilot-home-hero__yt-shield {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: auto;
  background: transparent;
}
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-home-hero.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-home-hero kopilot-home-hero--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-home-hero__bg" aria-hidden="true">
    {% if has_youtube %}
      <div class="kopilot-home-hero__yt-wrap">
        <div
          id="KopilotHomeHeroYt-{{ section.id }}"
          data-youtube-id="{{ yt_id }}"
        ></div>
        <div class="kopilot-home-hero__yt-shield" aria-hidden="true"></div>
      </div>
      <script>
        (function () {
          var videoId = {{ yt_id | json }};
          var playerId = 'KopilotHomeHeroYt-{{ section.id }}';

          function createPlayer() {
            if (!window.YT || !window.YT.Player) return;
            var mount = document.getElementById(playerId);
            if (!mount || mount.dataset.ytReady === '1') return;
            mount.dataset.ytReady = '1';

            var player = new YT.Player(playerId, {
              videoId: videoId,
              playerVars: {
                autoplay: 1,
                mute: 1,
                controls: 0,
                disablekb: 1,
                fs: 0,
                iv_load_policy: 3,
                modestbranding: 1,
                playsinline: 1,
                rel: 0,
                cc_load_policy: 0,
                showinfo: 0
              },
              events: {
                onReady: function (event) {
                  event.target.mute();
                  event.target.playVideo();
                  var iframe = event.target.getIframe && event.target.getIframe();
                  if (iframe) {
                    iframe.setAttribute('tabindex', '-1');
                    iframe.style.pointerEvents = 'none';
                  }
                },
                onStateChange: function (event) {
                  if (event.data === YT.PlayerState.PAUSED) {
                    event.target.playVideo();
                  }
                  if (event.data === YT.PlayerState.ENDED) {
                    event.target.seekTo(0);
                    event.target.playVideo();
                  }
                }
              }
            });

            setInterval(function () {
              try {
                if (player && typeof player.getPlayerState === 'function') {
                  if (player.getPlayerState() === YT.PlayerState.PAUSED) {
                    player.playVideo();
                  }
                }
              } catch (e) {}
            }, 1000);
          }

          if (window.YT && window.YT.Player) {
            createPlayer();
          } else {
            var previous = window.onYouTubeIframeAPIReady;
            window.onYouTubeIframeAPIReady = function () {
              if (typeof previous === 'function') previous();
              createPlayer();
            };
            if (!document.getElementById('youtube-iframe-api')) {
              var tag = document.createElement('script');
              tag.id = 'youtube-iframe-api';
              tag.src = 'https://www.youtube.com/iframe_api';
              document.head.appendChild(tag);
            }
          }
        })();
      </script>
    {% elsif has_mp4 %}
      <video
        class="kopilot-home-hero__media kopilot-home-hero__media--video"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.background_image != blank %}
          poster="{{ section.settings.background_image | image_url: width: 1920 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video }}" type="video/mp4">
      </video>
    {% else %}
      <div class="kopilot-home-hero__media kopilot-home-hero__media--desktop">
        {% render 'kopilot-image',
          image: section.settings.background_image,
          fallback: 'kopilot-hero-desktop.png',
          alt: '',
          width: 2924,
          loading: 'eager',
          widths: '1100,1500,2000,2400,2924',
          sizes: '100vw'
        %}
      </div>
      <div class="kopilot-home-hero__media kopilot-home-hero__media--mobile">
        {% render 'kopilot-image',
          image: section.settings.background_image_mobile,
          fallback: 'kopilot-home-hero-bg-mobile.jpg',
          alt: '',
          width: 2078,
          loading: 'eager',
          widths: '360,540,750,1039,2078',
          sizes: '100vw'
        %}
      </div>
    {% endif %}
    <div class="kopilot-home-hero__overlay"></div>
  </div>

  <div class="kopilot-home-hero__inner">
    <div class="kopilot-home-hero__content">
      <div class="kopilot-home-hero__copy">
        {% if section.settings.heading_desktop != blank %}
          <div class="kopilot-home-hero__heading kopilot-home-hero__heading--desktop">
            {{ section.settings.heading_desktop }}
          </div>
        {% endif %}
        {% if section.settings.heading_mobile != blank %}
          <div class="kopilot-home-hero__heading kopilot-home-hero__heading--mobile">
            {{ section.settings.heading_mobile }}
          </div>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="kopilot-home-hero__description">{{ section.settings.description }}</p>
        {% endif %}
      </div>

      <div class="kopilot-home-hero__actions">
        {% if section.settings.button_primary_label != blank %}
          <a
            href="{{ section.settings.button_primary_link | default: '#' }}"
            class="kopilot-home-hero__btn kopilot-home-hero__btn--primary"
          >
            {{ section.settings.button_primary_label }}
          </a>
        {% endif %}
        {% if section.settings.button_secondary_label != blank %}
          <a
            href="{{ section.settings.button_secondary_link | default: '#' }}"
            class="kopilot-home-hero__btn kopilot-home-hero__btn--secondary"
          >
            {{ section.settings.button_secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Home Hero",
  "tag": "section",
  "class": "kopilot-home-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Shown on screens ≤767px. Falls back to bundled mobile image if empty."
    },
    {
      "type": "text",
      "id": "video",
      "label": "Background video URL",
      "info": "Optional. Paste a YouTube link or a direct .mp4 URL. Overrides background images when set."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "heading_desktop",
      "label": "Heading (desktop)",
      "default": "<p>Your Critical Emergency<br>Information<br><span>Just A Tap Away</span></p>"
    },
    {
      "type": "html",
      "id": "heading_mobile",
      "label": "Heading (mobile)",
      "default": "<p>Your Critical Emergency Information <span>Just A Tap Away</span></p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "KOPILOT.ID emergency medical ID uses NFC technology to store your medical + emergency contact information and make it easily accessible in the event of an emergency."
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Primary button label",
      "default": "Get KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Secondary button label",
      "default": "See how it works"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Kopilot Home Hero",
      "settings": {
        "heading_desktop": "<p>Your Critical Emergency<br>Information<br><span>Just A Tap Away</span></p>",
        "heading_mobile": "<p>Your Critical Emergency Information <span>Just A Tap Away</span></p>",
        "description": "KOPILOT.ID emergency medical ID uses NFC technology to store your medical + emergency contact information and make it easily accessible in the event of an emergency.",
        "button_primary_label": "Get KOPILOT.ID",
        "button_secondary_label": "See how it works"
      }
    }
  ]
}
{% endschema %}
