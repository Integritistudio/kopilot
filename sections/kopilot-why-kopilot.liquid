{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-why-kopilot.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-why-kopilot kopilot-why-kopilot--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-why-kopilot__inner">
    <div class="kopilot-why-kopilot__cards">
      {% for block in section.blocks %}
        <div class="kopilot-why-kopilot__card" {{ block.shopify_attributes }}>
          <div class="kopilot-why-kopilot__icon">
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 134 }}"
                alt=""
                width="44"
                height="44"
                loading="lazy"
              >
            {% else %}
              <img
                src="{{ 'Group2106667242.svg' | asset_url }}"
                alt=""
                width="44"
                height="44"
                loading="lazy"
              >
            {% endif %}
          </div>
          {% if block.settings.label != blank %}
            <p class="kopilot-why-kopilot__label">{{ block.settings.label }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Kopilot",
  "tag": "section",
  "class": "kopilot-why-kopilot-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional, defaults to Group2106667242.svg)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Peace of mind for the people who love you"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Kopilot",
      "blocks": [
        { "type": "card", "settings": { "label": "Peace of mind for the people who love you" } },
        { "type": "card", "settings": { "label": "Available for anyone to help" } },
        { "type": "card", "settings": { "label": "Go further and worry less" } },
        { "type": "card", "settings": { "label": "Ready the second something happens" } }
      ]
    }
  ]
}
{% endschema %}
