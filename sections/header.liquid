        {
          "type": "text",
          "id": "parent_menu_title",
          "label": "Menu item",
          "info": "Enter the name of the parent level menu item to apply the mega menu."
        },
        {
          "type": "link_list",
          "id": "side_menu",
          "label": "Select side menu",
          "info": "Displays only 4 menu items"
        },
        {
          "type": "select",
          "id": "coll1_ratio",
          "label": "Image ratio",
          "options": [
            { "value": "landscape", "label": "Landscape " },
            { "value": "square", "label": "Square " },
            { "value": "portrait", "label": "Portrait " }
          ],
          "default": "landscape"
        },
        {
          "type": "header",
          "content": "Collection 01"
        },
        {
          "type": "collection",
          "id": "collection1",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "coll1_img",
          "label": "Select collection image (optional)",
          "info": "If left blank, it will display the collection featured image"
        },
        {
          "type": "header",
          "content": "Collection 02"
        },
        {
          "type": "collection",
          "id": "collection2",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "coll2_img",
          "label": "Select collection image (optional)",
          "info": "If left blank, it will display the collection featured image"
        },
        {
          "type": "header",
          "content": "Collection 03"
        },
        {
          "type": "collection",
          "id": "collection3",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "coll3_img",
          "label": "Select collection image (optional)",
          "info": "If left blank, it will display the collection featured image"
        },
        {
          "type": "header",
          "content": "Collection 04"
        },
        {
          "type": "collection",
          "id": "collection4",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "coll4_img",
          "label": "Select collection image (optional)",
          "info": "If left blank, it will display the collection featured image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
