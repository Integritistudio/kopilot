{% style %}
  .trust-highlights-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .trust-highlights-{{ section.id }} .trust-highlights__grid {
    grid-template-columns: repeat({{ section.settings.desktop_columns }}, 1fr);
    gap: {{ section.settings.column_gap }}px;
  }

  @media screen and (max-width: 989px) {
    .trust-highlights-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .trust-highlights-{{ section.id }} .trust-highlights__grid {
      grid-template-columns: repeat({{ section.settings.mobile_columns }}, 1fr);
    }
  }
{% endstyle %}

{{ 'trust-highlights.css' | asset_url | stylesheet_tag }}

<section class="trust-highlights trust-highlights-{{ section.id }} color-{{ section.settings.color_scheme }}">
 <div class="{% if section.settings.full_width %}
            trust-highlights__full
        {% else %}
            container
        {% endif %}" >

    <div class="trust-highlights__grid trust-highlights--{{ section.settings.content_alignment }}">

      {% for block in section.blocks %}
        <div
          class="trust-highlights__item"
          style="background: {{ block.settings.bg_color }};"
          {{ block.shopify_attributes }}
        >

          {% if block.settings.icon != blank %}
            <div class="trust-highlights__icon">
              {{
                block.settings.icon
                | image_url: width: 120
                | image_tag:
                  loading: 'lazy',
                  class: 'trust-highlights__icon-image'
              }}
            </div>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h5 class="trust-highlights__heading">
              {{ block.settings.heading }}
            </h5>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="trust-highlights__text rte">
              {{ block.settings.text }}
            </p>
          {% endif %}

        </div>
      {% endfor %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Trust highlights",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Enable full width",
      "default": true
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        {
          "value": "1",
          "label": "1 Column"
        },
        {
          "value": "2",
          "label": "2 Columns"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 32
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Content",
          "default": "Place content here."
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Block background",
          "default": "#2b2b2b"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust highlights",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ]
}
{% endschema %}