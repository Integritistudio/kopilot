{% style %}
  .kopilot-cta-banner--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 989px) {
    .kopilot-cta-banner--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-cta-banner.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-cta-banner kopilot-cta-banner--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-cta-banner__intro">
    {% if section.settings.heading != blank %}
      <h2 class="kopilot-cta-banner__heading kopilot-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link | default: '#' }}" class="kopilot-btn kopilot-cta-banner__btn">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="kopilot-cta-banner__trust">
      {% assign trust_fallbacks = 'kopilot-guarantee-moneyback.png,kopilot-guarantee-works.png' | split: ',' %}
      {% for block in section.blocks %}
        <div class="kopilot-cta-banner__trust-item" {{ block.shopify_attributes }}>
          <span class="kopilot-cta-banner__trust-icon">
            {% render 'kopilot-image',
              image: block.settings.icon,
              fallback: trust_fallbacks[forloop.index0],
              alt: block.settings.label,
              width: 64
            %}
          </span>
          {% if block.settings.label != blank %}
            <span class="kopilot-cta-banner__trust-label">{{ block.settings.label }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <div class="kopilot-cta-banner__media">
    {% render 'kopilot-image',
      image: section.settings.image,
      fallback: 'kopilot-cta-banner.jpg',
      alt: section.settings.heading,
      width: 2000,
      sizes: '100vw'
    %}
  </div>
</section>

{% schema %}
{
  "name": "Kopilot CTA banner",
  "tag": "section",
  "class": "kopilot-cta-banner-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bottom image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wherever you ride, KOPILOT.ID has your back."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "label", "label": "Label", "default": "Money-back guarantee" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot CTA banner",
      "blocks": [
        { "type": "trust", "settings": { "label": "Money-back guarantee" } },
        { "type": "trust", "settings": { "label": "Works anywhere" } }
      ]
    }
  ]
}
{% endschema %}
