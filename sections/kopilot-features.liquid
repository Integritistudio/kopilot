{% style %}
  /* ==========================================================================
     SCOPED DESKTOP DESIGN RULES (Figma Exacts)
     ========================================================================== */
  @media screen and (min-width: 768px) {
    /* Main Parent Component Container Framework (Frame 1984077277) */
    .kopilot-features--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      width: 100%;
      max-width: 1440px;
      height: 710px; /* Locked strict height */
      margin: 0 auto;
      box-sizing: border-box;
      overflow: hidden;
    }

    /* Inner Flex Alignment Layout Flow (Row Layout) */
    .kopilot-features--{{ section.id }} .kopilot-features__inner {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      width: 100% !important;
      height: 100% !important;
      gap: 73px !important; /* Fixed spacing gap between left text block and right image */
    }

    /* Left Content Column Layout (Frame 1597885210) */
    .kopilot-features--{{ section.id }} .kopilot-features__content_pdp {
      display: flex !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      width: 634px !important; /* Strict fixed width layout */
      height: 563.14px !important; /* Exact blueprint height */
      padding: 72px 9px 72px 72px !important; /* Exact padding: Top 72, Right 9, Bottom 72, Left 72 */
      box-sizing: border-box !important;
    }

    /* Headline Element Dimensioning Specs */
    .kopilot-features--{{ section.id }} .kopilot-features__heading {
      font-size: {{ section.settings.heading_font_size }}px;
      line-height: {{ section.settings.heading_line_height | default: 110.0 }}%;
      font-weight: {{ section.settings.heading_font_weight | default: 300 }};
      width: 571px !important; /* Precise text element bounding width */
      margin: 0 !important;
    }

    /* Item Grid Element Spacing Controls */
    .kopilot-features--{{ section.id }} .kopilot-features__content_pdp > .kopilot-features__grid {
      margin-top: 60px !important; /* Exact gap between heading element and icons list */
    }

    /* Right Media Block Container Specs */
    .kopilot-features--{{ section.id }} .kopilot-features__media {
      width: 733px !important; /* Absolute layout fixed width */
      height: 710px !important; /* Absolute layout fixed height */
      min-width: 733px !important;
      max-width: 733px !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* Nested Production Image Aspect Ratio Crop Fitting */
    .kopilot-features--{{ section.id }} .kopilot-features__media img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important; /* Forces layout to standard "Scale Crop / Fill" layout rule */
    }
  }

  /* ==========================================================================
     PRE-EXISTING GLOBAL / MOBILE DEFINITIONS (Untouched)
     ========================================================================== */
  .kopilot-features--{{ section.id }} .kopilot-features__text {
    padding-top: {{ section.settings.text_padding_top }}px;
    padding-bottom: {{ section.settings.text_padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-features--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .kopilot-features--{{ section.id }} .kopilot-features__heading {
      padding-top: 37px;
      font-size: 30px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-features.css' | asset_url | stylesheet_tag }}

<section id="kopilot-how-it-works" class="kopilot-section kopilot-features kopilot-features--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-features__inner{% if section.settings.image_position == 'left' %} kopilot-features__inner--image-left{% endif %}">
    <div class="kopilot-features__content_pdp">
      {% if section.settings.heading_rt != blank %}
        <div class="kopilot-features__heading kopilot-heading">{{ section.settings.heading_rt }}</div>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="kopilot-features__text kopilot-body">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.blocks.size > 0 %}
        {% assign feature_icon_fallbacks = 'kopilot-icon-durable.png,kopilot-icon-battery.png,kopilot-icon-subscription.png,kopilot-icon-medical.png,kopilot-icon-languages.png,kopilot-icon-works.png' | split: ',' %}
        <div class="kopilot-features__grid">
          {% for block in section.blocks %}
            <div class="kopilot-features__item" {{ block.shopify_attributes }}>
              <div class="kopilot-features__icon">
                {% render 'kopilot-image',
                  image: block.settings.icon,
                  fallback: feature_icon_fallbacks[forloop.index0],
                  alt: block.settings.label,
                  width: 120
                %}
              </div>
              {% if block.settings.label != blank %}
                <div class="kopilot-features__label kopilot-body rte">{{ block.settings.label }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="kopilot-features__media">
      {% render 'kopilot-image',
        image: section.settings.image,
        fallback: 'kopilot-features-main.jpg',
        alt: section.settings.heading,
        width: 1600,
        widths: '550,750,1100,1600'
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Features",
  "tag": "section",
  "class": "kopilot-features-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "richtext",
      "id": "heading_rt",
      "label": "Heading",
      "default": "<p>The details that matter.</p>"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Heading Line Height",
      "min": 90,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 110
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "100", "label": "Thin" },
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "300"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Not every emergency happens deep in remote terrain. Sometimes it's a quick ride, a normal trail, or a familiar road. Waterproof and battery-free, KOPILOT.ID is designed to stay with your gear every time you head out."
    },
    {
      "type": "header",
      "content": "Text Padding"
    },
    {
      "type": "range",
      "id": "text_padding_top",
      "label": "Text top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_padding_bottom",
      "label": "Text bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "richtext", "id": "label", "label": "Label", "default": "<p>Feature label</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Features",
      "blocks": [
        { "type": "feature", "settings": { "label": "<p>Durable and waterproof</p>" } },
        { "type": "feature", "settings": { "label": "<p>No battery / No charging</p>" } },
        { "type": "feature", "settings": { "label": "<p>No subscription required</p>" } },
        { "type": "feature", "settings": { "label": "<p>Instantly access emergency info</p>" } },
        { "type": "feature", "settings": { "label": "<p>Translates into 24 languages</p>" } },
        { "type": "feature", "settings": { "label": "<p>Works everywhere</p>" } }
      ]
    }
  ]
}
{% endschema %}