{% style %}
  .kopilot-features--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 989px) {
    .kopilot-features--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-features.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-features kopilot-features--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-features__inner{% if section.settings.image_position == 'left' %} kopilot-features__inner--image-left{% endif %}">
    <div class="kopilot-features__content">
      {% if section.settings.heading != blank %}
        <h2 class="kopilot-features__heading kopilot-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="kopilot-features__text kopilot-body">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.blocks.size > 0 %}
        {% assign feature_icon_fallbacks = 'kopilot-icon-durable.png,kopilot-icon-battery.png,kopilot-icon-subscription.png,kopilot-icon-medical.png,kopilot-icon-languages.png,kopilot-icon-works.png' | split: ',' %}
        <div class="kopilot-features__grid">
          {% for block in section.blocks %}
            <div class="kopilot-features__item" {{ block.shopify_attributes }}>
              <div class="kopilot-features__icon">
                {% render 'kopilot-image',
                  image: block.settings.icon,
                  fallback: feature_icon_fallbacks[forloop.index0],
                  alt: block.settings.label,
                  width: 120
                %}
              </div>
              {% if block.settings.label != blank %}
                <p class="kopilot-features__label kopilot-body">{{ block.settings.label }}</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="kopilot-features__media">
      {% render 'kopilot-image',
        image: section.settings.image,
        fallback: 'kopilot-features-main.jpg',
        alt: section.settings.heading,
        width: 1600,
        widths: '550,750,1100,1600'
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Features",
  "tag": "section",
  "class": "kopilot-features-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For the rides you plan and the moments you don't."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Not every emergency happens deep in remote terrain. Sometimes it's a quick ride, a normal trail, or a familiar road. Waterproof and battery-free, KOPILOT.ID is designed to stay with your gear every time you head out."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "label", "label": "Label", "default": "Feature label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Features",
      "blocks": [
        { "type": "feature", "settings": { "label": "Durable and waterproof" } },
        { "type": "feature", "settings": { "label": "No battery/ charging needed" } },
        { "type": "feature", "settings": { "label": "No subscription required" } },
        { "type": "feature", "settings": { "label": "Instant medical & contact info" } },
        { "type": "feature", "settings": { "label": "Translates into 24 languages" } },
        { "type": "feature", "settings": { "label": "Works everywhere" } }
      ]
    }
  ]
}
{% endschema %}
