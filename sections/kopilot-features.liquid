{% style %}
  .kopilot-features--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    overflow: hidden;
  }

  /* Pixel Perfect Layout Specifications (Desktop) */
  @media screen and (min-width: 768px) {
    .kopilot-features--{{ section.id }} .kopilot-features__inner {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      max-width: 1440px !important;
      height: 704px !important;
      margin: 0 auto !important;
      padding: 0 !important;
    }

    /* Sets up structural alignment tracking the exact left gap grids */
    .kopilot-features--{{ section.id }} .kopilot-features__content {
      flex: 1 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      justify-content: center !important;
      padding-left: 94px !important; /* Exact structural spacing alignment */
      padding-right: 90px !important; /* Fixed inner content boundary spacer */
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      box-sizing: border-box !important;
    }

    /* Fixed Media Dimensions tracking design layout */
    .kopilot-features--{{ section.id }} .kopilot-features__media {
      flex: 0 0 696px !important;
      width: 696px !important;
      height: 704px !important;
      min-width: 696px !important;
      max-width: 696px !important;
      padding: 0 !important;
      margin: 0 !important;
      overflow: hidden !important;
    }

    /* Reverse variation handling safely */
    .kopilot-features--{{ section.id }} .kopilot-features__inner--image-left {
      flex-direction: row-reverse !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__inner--image-left .kopilot-features__content {
      padding-left: 90px !important;
      padding-right: 94px !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__media img,
    .kopilot-features--{{ section.id }} .kopilot-features__media svg,
    .kopilot-features--{{ section.id }} .kopilot-features__media picture {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center !important;
      display: block !important;
    }

    /* Desktop Typography Updates (Figma Specifications) */
    .kopilot-features--{{ section.id }} .kopilot-features__heading,
    .kopilot-features--{{ section.id }} .kopilot-features__heading * {
      font-family: 'Elza', sans-serif !important;
      font-size: 60px !important;
      font-weight: 300 !important;
      line-height: 1.1 !important;
      letter-spacing: -1px !important;
      margin-top: 0 !important;
      margin-bottom: 24px !important;
      display: block !important;
      max-width: 561px !important;
      width: auto !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__text {
      font-family: 'Figtree', sans-serif !important;
      font-size: 20px !important;
      font-weight: 400 !important;
      line-height: 1.2 !important;
      letter-spacing: 0 !important;
      margin-top: 0 !important;
      margin-bottom: 40px !important; /* Controlled gap before features grid start */
      max-width: 450px !important;
      width: auto !important;
    }

    /* Features Grid Alignments */
    .kopilot-features--{{ section.id }} .kopilot-features__grid {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 24px 32px !important;
      max-width: 480px !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__item {
      display: flex !important;
      align-items: center !important;
      gap: 12px !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__icon {
      width: 32px !important;
      height: 32px !important;
      flex: 0 0 32px !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__icon img {
      width: 100% !important;
      height: 100% !important;
      object-fit: contain !important;
    }

    .kopilot-features--{{ section.id }} .kopilot-features__label,
    .kopilot-features--{{ section.id }} .kopilot-features__label * {
      font-family: 'Figtree', sans-serif !important;
      font-size: 16px !important;
      font-weight: 400 !important;
      line-height: 1.2 !important;
      margin: 0 !important;
    }
  }

  /* Isolated Mobile Block (Completely Untouched as Requested) */
  @media screen and (max-width: 767px) {
    .kopilot-features--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-features.css' | asset_url | stylesheet_tag }}

<section id="kopilot-how-it-works" class="kopilot-section kopilot-features kopilot-features--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-features__inner{% if section.settings.image_position == 'left' %} kopilot-features__inner--image-left{% endif %}">
    <div class="kopilot-features__content">
      {% if section.settings.heading_rt != blank %}
        <div class="kopilot-features__heading kopilot-heading">{{ section.settings.heading_rt }}</div>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="kopilot-features__text kopilot-body">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.blocks.size > 0 %}
        {% assign feature_icon_fallbacks = 'kopilot-icon-durable.png,kopilot-icon-battery.png,kopilot-icon-subscription.png,kopilot-icon-medical.png,kopilot-icon-languages.png,kopilot-icon-works.png' | split: ',' %}
        <div class="kopilot-features__grid">
          {% for block in section.blocks %}
            <div class="kopilot-features__item" {{ block.shopify_attributes }}>
              <div class="kopilot-features__icon">
                {% render 'kopilot-image',
                  image: block.settings.icon,
                  fallback: feature_icon_fallbacks[forloop.index0],
                  alt: block.settings.label,
                  width: 120
                %}
              </div>
              {% if block.settings.label != blank %}
                <div class="kopilot-features__label kopilot-body rte">{{ block.settings.label }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="kopilot-features__media">
      {% render 'kopilot-image',
        image: section.settings.image,
        fallback: 'kopilot-features-main.jpg',
        alt: section.settings.heading,
        width: 1600,
        widths: '550,750,1100,1600'
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Features",
  "tag": "section",
  "class": "kopilot-features-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "richtext",
      "id": "heading_rt",
      "label": "Heading",
      "default": "<p>For the rides you plan and the moments you don't.</p>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Not every emergency happens deep in remote terrain. Sometimes it's a quick ride, a normal trail, or a familiar road. Waterproof and battery-free, KOPILOT.ID is designed to stay with your gear every time you head out."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "richtext", "id": "label", "label": "Label", "default": "<p>Feature label</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Features",
      "blocks": [
        { "type": "feature", "settings": { "label": "<p>Durable and waterproof</p>" } },
        { "type": "feature", "settings": { "label": "<p>No battery/ charging needed</p>" } },
        { "type": "feature", "settings": { "label": "<p>No subscription required</p>" } },
        { "type": "feature", "settings": { "label": "<p>Instant medical &amp; contact info</p>" } },
        { "type": "feature", "settings": { "label": "<p>Translates into 24 languages</p>" } },
        { "type": "feature", "settings": { "label": "<p>Works everywhere</p>" } }
      ]
    }
  ]
}
{% endschema %}