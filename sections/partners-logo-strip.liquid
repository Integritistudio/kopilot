{%- style -%}
  .ppls-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    padding: 30px 0;
    box-sizing: border-box;
  }

  .ppls-{{ section.id }} *,
  .ppls-{{ section.id }} *::before,
  .ppls-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .ppls-{{ section.id }} .ppls-inner {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    gap: 30px;
    width: 100%;
    max-width: 1144px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ppls-{{ section.id }} .ppls-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    height: 82px;
    max-height: 82px;
  }

  .ppls-{{ section.id }} .ppls-item img {
    display: block;
    width: auto;
    max-width: 165px;
    height: auto;
    max-height: 82px;
    object-fit: contain;
  }

  .ppls-{{ section.id }} .ppls-link {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    text-decoration: none;
  }

  .ppls-{{ section.id }} .ppls-placeholder {
    display: block;
    width: 68px;
    height: 82px;
    background-color: transparent;
  }

  .ppls-{{ section.id }} .ppls-break {
    display: none;
  }

  /* Tablet */
  @media screen and (min-width: 768px) and (max-width: 1439px) {
    .ppls-{{ section.id }} .ppls-inner {
      flex-wrap: wrap;
      gap: clamp(16px, 2.083vw, 30px);
      max-width: min(1144px, 100%);
    }

    .ppls-{{ section.id }} .ppls-item {
      height: clamp(56px, 5.694vw, 82px);
      max-height: clamp(56px, 5.694vw, 82px);
    }

    .ppls-{{ section.id }} .ppls-item img {
      max-height: clamp(56px, 5.694vw, 82px);
      max-width: clamp(90px, 11.458vw, 165px);
    }
  }

  /* Mobile — pixel perfect at 360px: 4 + 3 + 3 */
  @media screen and (max-width: 767px) {
    .ppls-{{ section.id }} {
      padding: 30px 0;
    }

    .ppls-{{ section.id }} .ppls-inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      column-gap: 20px;
      row-gap: 0;
      width: 279px;
      max-width: 279px;
      margin-left: auto;
      margin-right: auto;
      padding: 0;
    }

    .ppls-{{ section.id }} .ppls-break {
      display: block;
      flex-basis: 100%;
      width: 100%;
      height: 0;
      margin: 0;
      padding: 0;
      overflow: hidden;
      border: 0;
    }

    /* 20px between row 1 and row 2 */
    .ppls-{{ section.id }} .ppls-break--after-4 {
      margin-bottom: 20px;
    }

    /* 15px between row 2 and row 3 */
    .ppls-{{ section.id }} .ppls-break--after-7 {
      margin-bottom: 15px;
    }

    .ppls-{{ section.id }} .ppls-item {
      height: auto;
      max-height: none;
    }

    /* Row 1 — 4 logos */
    .ppls-{{ section.id }} .ppls-item--row-1 {
      height: 47.47px;
    }

    .ppls-{{ section.id }} .ppls-item--row-1 img {
      width: auto;
      height: 100%;
      max-height: 47.47px;
      max-width: 71px;
      object-fit: contain;
    }

    /* Row 2 — 3 logos */
    .ppls-{{ section.id }} .ppls-item--row-2 {
      height: 53px;
    }

    .ppls-{{ section.id }} .ppls-item--row-2 img {
      width: auto;
      height: 100%;
      max-height: 53px;
      max-width: 105px;
      object-fit: contain;
    }

    /* Row 3 — 3 logos */
    .ppls-{{ section.id }} .ppls-item--row-3 {
      height: 70.38px;
    }

    .ppls-{{ section.id }} .ppls-item--row-3 img {
      width: auto;
      height: 100%;
      max-height: 70.38px;
      max-width: 63.52px;
      object-fit: contain;
    }

    /* Row 3 horizontal gap ≈ 12.875px */
    .ppls-{{ section.id }} .ppls-break--after-7 ~ .ppls-item--row-3 + .ppls-item--row-3 {
      margin-left: -7.125px;
    }

    .ppls-{{ section.id }} .ppls-placeholder {
      width: 52px;
      height: 47px;
      background-color: transparent;
    }
  }
{%- endstyle -%}

<div class="ppls-{{ section.id }}">
  <div class="ppls-inner">
    {%- assign ppls_logo_index = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'logo' -%}
        {%- assign ppls_logo_index = ppls_logo_index | plus: 1 -%}
        {%- liquid
          assign ppls_row_class = 'ppls-item--row-1'
          if ppls_logo_index > 7
            assign ppls_row_class = 'ppls-item--row-3'
          elsif ppls_logo_index > 4
            assign ppls_row_class = 'ppls-item--row-2'
          endif
        -%}
        <div class="ppls-item {{ ppls_row_class }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {%- assign ppls_alt = block.settings.image.alt | default: block.settings.alt_text | default: 'Partner logo' -%}
            {%- if block.settings.link != blank -%}
              <a
                class="ppls-link"
                href="{{ block.settings.link }}"
                {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              >
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag: loading: 'lazy', alt: ppls_alt
                }}
              </a>
            {%- else -%}
              {{
                block.settings.image
                | image_url: width: 400
                | image_tag: loading: 'lazy', alt: ppls_alt
              }}
            {%- endif -%}
          {%- else -%}
            <span class="ppls-placeholder" aria-hidden="true"></span>
          {%- endif -%}
        </div>
        {%- if ppls_logo_index == 4 -%}
          <div class="ppls-break ppls-break--after-4" aria-hidden="true"></div>
        {%- elsif ppls_logo_index == 7 -%}
          <div class="ppls-break ppls-break--after-7" aria-hidden="true"></div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Partners Logo Strip",
  "tag": "section",
  "class": "section-partners-logo-strip",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Partner logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partners Logo Strip",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
