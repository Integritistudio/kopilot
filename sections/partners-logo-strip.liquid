{%- style -%}
  .ppls-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    padding: 30px 0;
    box-sizing: border-box;
  }

  .ppls-{{ section.id }} *,
  .ppls-{{ section.id }} *::before,
  .ppls-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .ppls-{{ section.id }} .ppls-inner {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    gap: 30px;
    width: 100%;
    max-width: 1144px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Desktop: rows dissolve so all logos sit in one horizontal line */
  .ppls-{{ section.id }} .ppls-row {
    display: contents;
  }

  .ppls-{{ section.id }} .ppls-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    height: 82px;
    max-height: 82px;
  }

  .ppls-{{ section.id }} .ppls-item img {
    display: block;
    width: auto;
    max-width: 130px;
    height: auto;
    max-height: 82px;
    object-fit: contain;
  }

  .ppls-{{ section.id }} .ppls-link {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    text-decoration: none;
  }

  .ppls-{{ section.id }} .ppls-placeholder {
    display: block;
    width: 68px;
    height: 82px;
    background-color: transparent;
  }

  /* Tablet */
  @media screen and (min-width: 768px) and (max-width: 1439px) {
    .ppls-{{ section.id }} .ppls-inner {
      flex-wrap: wrap;
      gap: clamp(16px, 2.083vw, 30px);
      max-width: min(1144px, 100%);
    }

    .ppls-{{ section.id }} .ppls-item {
      height: clamp(56px, 5.694vw, 82px);
      max-height: clamp(56px, 5.694vw, 82px);
    }

    .ppls-{{ section.id }} .ppls-item img {
      max-height: clamp(56px, 5.694vw, 82px);
      max-width: clamp(90px, 11.458vw, 165px);
    }
  }

  /* Mobile — pixel perfect at 360px: forced rows 4 + 3 + 3 */
  @media screen and (max-width: 767px) {
    .ppls-{{ section.id }} {
      padding: 30px 0;
    }

    .ppls-{{ section.id }} .ppls-inner {
      display: flex;
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      gap: 20px;
      width: 279px;
      max-width: 279px;
      margin-left: auto;
      margin-right: auto;
      padding: 0;
    }

    .ppls-{{ section.id }} .ppls-row {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      width: 100%;
      gap: 20px;
    }

    /* 15px between row 2 and row 3 (Figma) */
    .ppls-{{ section.id }} .ppls-row--3 {
      margin-top: -5px; /* 20px column gap above → net 15px */
      gap: 12.875px;
      width: auto;
    }

    .ppls-{{ section.id }} .ppls-item {
      flex: 0 0 auto;
      height: auto;
      max-height: none;
      min-width: 0;
    }

    .ppls-{{ section.id }} .ppls-item img {
      display: block;
      width: auto;
      height: auto;
      object-fit: contain;
    }

    /* Row 1 — exactly 4 logos, sized to fit 279px with 20px gaps */
    .ppls-{{ section.id }} .ppls-row--1 .ppls-item {
      height: 47.47px;
    }

    .ppls-{{ section.id }} .ppls-row--1 .ppls-item:nth-child(1) img,
    .ppls-{{ section.id }} .ppls-row--1 .ppls-item:nth-child(2) img {
      width: 52.52px;
      max-width: 52.52px;
      height: 47.47px;
      max-height: 47.47px;
    }

    .ppls-{{ section.id }} .ppls-row--1 .ppls-item:nth-child(3) img {
      width: 42.7px;
      max-width: 42.7px;
      height: 42.7px;
      max-height: 42.7px;
    }

    .ppls-{{ section.id }} .ppls-row--1 .ppls-item:nth-child(4) img {
      width: 71px;
      max-width: 71px;
      height: 38px;
      max-height: 38px;
    }

    /* Row 2 — 3 logos */
    .ppls-{{ section.id }} .ppls-row--2 .ppls-item {
      height: 53px;
    }

    .ppls-{{ section.id }} .ppls-row--2 .ppls-item:nth-child(1) img {
      width: 105.1px;
      max-width: 105.1px;
      height: 38.11px;
      max-height: 38.11px;
    }

    .ppls-{{ section.id }} .ppls-row--2 .ppls-item:nth-child(2) img {
      width: 56px;
      max-width: 56px;
      height: 47px;
      max-height: 47px;
    }

    .ppls-{{ section.id }} .ppls-row--2 .ppls-item:nth-child(3) img {
      width: 43px;
      max-width: 43px;
      height: 53px;
      max-height: 53px;
    }

    /* Row 3 — 3 logos */
    .ppls-{{ section.id }} .ppls-row--3 .ppls-item {
      height: 70.38px;
    }

    .ppls-{{ section.id }} .ppls-row--3 .ppls-item:nth-child(1) img {
      width: 63.52px;
      max-width: 63.52px;
      height: 70.38px;
      max-height: 70.38px;
    }

    .ppls-{{ section.id }} .ppls-row--3 .ppls-item:nth-child(2) img,
    .ppls-{{ section.id }} .ppls-row--3 .ppls-item:nth-child(3) img {
      width: 58.37px;
      max-width: 58.37px;
      height: 70.38px;
      max-height: 70.38px;
    }

    .ppls-{{ section.id }} .ppls-placeholder {
      width: 52px;
      height: 47px;
      background-color: transparent;
    }
  }
{%- endstyle -%}

{%- liquid
  assign ppls_logos = section.blocks | where: 'type', 'logo'
-%}

<div class="ppls-{{ section.id }}">
  <div class="ppls-inner">
    <div class="ppls-row ppls-row--1">
      {%- for block in ppls_logos -%}
        {%- if forloop.index <= 4 -%}
          <div class="ppls-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign ppls_alt = block.settings.image.alt | default: block.settings.alt_text | default: 'Partner logo' -%}
              {%- if block.settings.link != blank -%}
                <a
                  class="ppls-link"
                  href="{{ block.settings.link }}"
                  {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag: loading: 'lazy', alt: ppls_alt
                  }}
                </a>
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag: loading: 'lazy', alt: ppls_alt
                }}
              {%- endif -%}
            {%- else -%}
              <span class="ppls-placeholder" aria-hidden="true"></span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ppls-row ppls-row--2">
      {%- for block in ppls_logos -%}
        {%- if forloop.index > 4 and forloop.index <= 7 -%}
          <div class="ppls-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign ppls_alt = block.settings.image.alt | default: block.settings.alt_text | default: 'Partner logo' -%}
              {%- if block.settings.link != blank -%}
                <a
                  class="ppls-link"
                  href="{{ block.settings.link }}"
                  {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag: loading: 'lazy', alt: ppls_alt
                  }}
                </a>
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag: loading: 'lazy', alt: ppls_alt
                }}
              {%- endif -%}
            {%- else -%}
              <span class="ppls-placeholder" aria-hidden="true"></span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ppls-row ppls-row--3">
      {%- for block in ppls_logos -%}
        {%- if forloop.index > 7 -%}
          <div class="ppls-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign ppls_alt = block.settings.image.alt | default: block.settings.alt_text | default: 'Partner logo' -%}
              {%- if block.settings.link != blank -%}
                <a
                  class="ppls-link"
                  href="{{ block.settings.link }}"
                  {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag: loading: 'lazy', alt: ppls_alt
                  }}
                </a>
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag: loading: 'lazy', alt: ppls_alt
                }}
              {%- endif -%}
            {%- else -%}
              <span class="ppls-placeholder" aria-hidden="true"></span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Partners Logo Strip",
  "tag": "section",
  "class": "section-partners-logo-strip",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Partner logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partners Logo Strip",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
