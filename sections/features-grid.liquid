{{ 'section-kopilot-features-grid.css' | asset_url | stylesheet_tag }}

<div class="kopilot-features-section" id="kopilot-features-section-{{ section.id }}">
  <div class="kopilot-features-container">
    
    <!-- LEFT: TEXT AND GRID -->
    <div class="kopilot-features-text-col">
      <h2 class="kopilot-features-heading">{{ section.settings.heading }}</h2>
      
      <div class="kopilot-features-grid">
        {% for block in section.blocks %}
          <div class="kopilot-feature-item">
            <div class="kopilot-feature-icon">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | img_url: '150x' }}" alt="{{ block.settings.title }}">
              {% endif %}
            </div>
            <p class="kopilot-feature-text">{{ block.settings.title }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- RIGHT: IMAGE -->
    <div class="kopilot-features-media-col">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: '1600x' }}" class="kopilot-features-hero-img" loading="lazy">
      {% endif %}
    </div>

  </div>
</div>

{% style %}
  /* --- DESKTOP 1440px PIXEL PERFECT --- */
  #kopilot-features-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  .kopilot-features-container {
    display: flex;
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 72px;
    gap: 73px;
    align-items: center;
  }

  .kopilot-features-text-col { width: 635px; }

  .kopilot-features-heading {
    font-family: "Elza", sans-serif;
    font-size: 60px;
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 40px;
    letter-spacing: -1px;
    color: #000000;
  }

  .kopilot-features-grid {
    display: grid;
    grid-template-columns: repeat(3, 147px);
    gap: 20px;
    justify-content: start; /* Ensures grid starts at the left */
  }

  .kopilot-feature-item { 
    width: 147px; 
    display: flex;
    flex-direction: column;
    align-items: center; /* Centers icon and text */
    text-align: center; 
  }

  .kopilot-feature-text {
    font-family: "Elza", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.0;
    margin-top: 12px;
    color: #000000;
  }

  .kopilot-features-media-col { width: 733px; height: 710px; flex-shrink: 0; }
  .kopilot-features-hero-img { width: 100%; height: 100%; object-fit: cover; }

  /* --- RESPONSIVE / MOBILE 360px PIXEL PERFECT --- */
  @media screen and (max-width: 1024px) {
    #kopilot-features-section-{{ section.id }} {
      padding-top: 37px;
    }
    .kopilot-features-container {
      flex-direction: column;
      padding-left: 0;
      padding-right: 0;
      gap: 41px;
    }
    .kopilot-features-text-col { 
      width: 100%; 
      padding-left: 20px;
      padding-right: 20px;
    }
    .kopilot-features-heading {
      text-align: center;
      font-size: 40px;
      margin-bottom: 30px;
    }
    .kopilot-features-grid { 
      grid-template-columns: repeat(2, 1fr);
      justify-items: center;
      gap: 28px; /* Mobile Specific Gap */
    }
    .kopilot-feature-item { width: 100%; }
    .kopilot-features-media-col { 
      width: 100%;
      height: auto;
      aspect-ratio: 733/710;
    }
  }

  @media screen and (max-width: 360px) {
    .kopilot-features-heading {
      font-size: 32px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Kopilot Features Grid",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "title", "label": "Text" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The details that matter." },
    { "type": "image_picker", "id": "image", "label": "Right Image" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Kopilot Features Grid" }]
}
{% endschema %}