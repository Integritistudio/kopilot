    },
    {
      "type": "header",
      "content": "Instagram block settings"
    },
    {
      "type": "text",
      "id": "instagram_block_heading",
      "label": "Block heading",
      "default": "kopilot.ID"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram link"
    },
    {
      "type": "header",
      "content": "Contact block settings"
    },
    {
      "type": "text",
      "id": "contact_block_heading",
      "label": "Block heading",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "email us"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info.kopilot.id"
    },
    {
      "type": "text",
      "id": "contact_link_label",
      "label": "Contact link label",
      "default": "Our contacts"
    },
    {
      "type": "url",
      "id": "contact_link_url",
      "label": "Contact link url"
    },
    {
      "type": "header",
      "content": "Contact logo list settings"
    },
    {
      "type": "text",
      "id": "logo_list_label",
      "label": "Logo list label",
      "default": "App stores"
    },
    {
      "type": "url",
      "id": "google_play_link",
      "label": "Google play link"
    },
    {
      "type": "image_picker",
      "id": "google_play_logo",
      "label": "Google play logo"
    },
    {
      "type": "url",
      "id": "apple_store_link",
      "label": "Apple store link"
    },
    {
      "type": "image_picker",
      "id": "apple_store_logo",
      "label": "Apple store logo"
    },
    {
      "type": "header",
      "content": "Corporate block settings"
    },
    {
      "type": "text",
      "id": "corporate_block_heading",
      "label": "Block heading",
      "default": "Corporate"
    },
    {
      "type": "link_list",
      "id": "corporate_menu",
      "label": "Menu"
    },
    {
      "type": "text",
      "id": "contact_us_label",
      "label": "Contact us label",
      "default": "Contact us"
    },
    {
      "type": "text",
      "id": "wholesale_label",
      "label": "Wholesale label",
      "default": "Wholesale"
    },
    {
      "type": "url",
      "id": "wholesale_url",
      "label": "Wholesale link"
    },
    {
      "type": "header",
      "content": "Social block settings"
    },
    {
      "type": "text",
      "id": "social_block_heading",
      "label": "Block heading",
      "default": "Social Media"
    },
    {
      "type": "header",
      "content": "Privacy block settings"
    },
    {
      "type": "url",
      "id": "privacy_policy_url",
      "label": "Privacy policy URL"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms and conditions URL"
    },
    {
      "type": "url",
      "id": "cookie_policy_url",
