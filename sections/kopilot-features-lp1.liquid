{{ 'section-kopilot-features.css' | asset_url | stylesheet_tag }}

<div class="kopilot-section" id="kopilot-section-{{ section.id }}">
  <div class="kopilot-container">
    
    <!-- LEFT SIDE: CONTENT BLOCK -->
    <div class="kopilot-content-col">
      <div class="kopilot-text-stack">
        <h2 class="kopilot-heading">{{ section.settings.heading }}</h2>
        <p class="kopilot-paragraph">{{ section.settings.paragraph }}</p>
      </div>

      <!-- FEATURE GRID -->
      <div class="kopilot-feature-grid">
        {% for block in section.blocks %}
          <div class="kopilot-grid-item" {{ block.shopify_attributes }}>
            <div class="kopilot-icon-wrapper">
              {% if block.settings.icon_svg != blank %}
                {{ block.settings.icon_svg }}
              {% elsif block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | img_url: '40x40' }}" alt="{{ block.settings.text | escape }}" loading="lazy">
              {% else %}
                <span class="kopilot-icon-placeholder"></span>
              {% endif %}
            </div>
            <p class="kopilot-grid-label">{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- RIGHT SIDE: HERO CROP IMAGE -->
    <div class="kopilot-image-col">
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | img_url: '1500x' }}" 
          alt="{{ section.settings.heading | escape }}" 
          loading="lazy"
          class="kopilot-split-img"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'kopilot-split-img placeholder-svg' }}
      {% endif %}
    </div>

  </div>
</div>

{% style %}
  /* --- MASTER TYPOGRAPHY & DESIGN TOKENS --- */
  #kopilot-section-{{ section.id }} {
    --font-family: "Elza", -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: {{ section.settings.bg_color }};
  }

  .kopilot-section {
    width: 100%;
    margin: 0 auto;
    font-family: var(--font-family);
    overflow: hidden;
  }

  .kopilot-container {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    justify-content: space-between;
    width: 100%;
    max-width: 1440px;
    height: 711px;
    margin: 0 auto;
  }

  /* Left Side Setup */
  .kopilot-content-col {
    width: calc(1440px - 744px - 64px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 61px;
    box-sizing: border-box;
  }

  .kopilot-text-stack {
    width: 562px;
    display: flex;
    flex-direction: column;
    gap: 50px;
    margin-bottom: 73px;
  }

  .kopilot-heading {
    font-family: var(--font-family);
    font-size: 60px;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
    text-align: left;
  }

  .kopilot-paragraph {
    font-family: var(--font-family);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
    max-width: 536px;
    text-align: left;
  }

  /* Grid Layout (3x2 Desktop) */
  .kopilot-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 147px);
    column-gap: 20px; 
    row-gap: 35px;
    max-width: 481px;
  }

  .kopilot-grid-item {
    width: 147px;
    min-height: 107px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 15px;
    text-align: center;
  }

  .kopilot-icon-wrapper {
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kopilot-icon-wrapper svg {
    width: auto;
    height: 32px;
    display: block;
  }

  .kopilot-grid-label {
    font-family: var(--font-family);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
    width: 148px;
    word-wrap: break-word;
  }

  .kopilot-icon-placeholder {
    width: 12px;
    height: 12px;
    background-color: #000;
    border-radius: 50%;
    display: inline-block;
  }

  /* Right Side Image Setup */
  .kopilot-image-col {
    width: 744px;
    height: 711px;
    overflow: hidden;
  }

  .kopilot-split-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* --- STRETCH TABLET RESPONSIVENESS (426px to 1199px Viewports) --- */
  @media screen and (min-width: 426px) and (max-width: 1199px) {
    .kopilot-container {
      height: auto;
      flex-direction: column; /* Fixed: Image drops nicely to the bottom of the content layout */
      padding: 40px 24px;
      gap: 48px;
      align-items: center;
    }
    
    .kopilot-content-col {
      width: 100%;
      padding-left: 0;
      align-items: center;
    }

    .kopilot-text-stack {
      width: 100%;
      max-width: 562px;
      align-items: center;
      text-align: center;
    }

    .kopilot-heading {
      font-size: 44px;
      text-align: center;
    }

    .kopilot-paragraph {
      text-align: center;
    }

    .kopilot-feature-grid {
      grid-template-columns: repeat(3, 147px); /* Forces exactly 3 per row as requested */
      justify-content: center;
    }

    .kopilot-image-col {
      width: 100%;
      max-width: 744px;
      height: 450px;
    }
  }

  /* --- PIXEL PERFECT RESPONSIVE BREAKPOINT (At or Beneath 425px Boundary) --- */
  @media screen and (max-width: 425px) {
    .kopilot-container {
      flex-direction: column;
      height: auto;
      max-width: 360px;
      padding: 5.7rem 0 0 0;
      gap: 41px;
    }

    .kopilot-content-col {
      width: 100%;
      padding: 0 14px;
      align-items: center;
    }

    .kopilot-text-stack {
      width: 332px;
      margin-bottom: 41px;
      gap: 16px;
      align-items: center;
    }

    .kopilot-heading {
      font-size: 30px;
      line-height: 1.03;
      text-align: center;
      max-width: 332px;
    }

    .kopilot-paragraph {
      font-size: 15px;
      line-height: 1.3; 
      text-align: center;
      max-width: 310px;
    }

    /* Converts to exactly 2-Column inline layout at or beneath 425px */
    .kopilot-feature-grid {
      grid-template-columns: repeat(2, 104px);
      column-gap: 40px;
      row-gap: 24px;
      justify-content: center;
      max-width: 100%;
    }

    .kopilot-grid-item {
      width: 104px;
      min-height: 107px;
      gap: 15px;
    }

    .kopilot-grid-label {
      font-size: 15px;
      width: 105px;
      line-height: 1.1;
    }

    .kopilot-image-col {
      width: 100%;
      height: 344px;
      order: 2; /* Keeps image firmly at the bottom */
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Kopilot Split Grid Block",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For the rides you plan and the moments you don't."
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph Copy",
      "default": "Not every emergency happens deep in remote terrain. Sometimes it’s a quick ride, a normal trail, or a familiar road. Waterproof and battery-free, KOPILOT.ID is designed to stay with your gear every time you head out."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Split Crop Image Right"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Grid Item Element",
      "limit": 6,
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon Inline SVG Code"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Custom Image Asset (Alternative)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Item Feature Tagline",
          "default": "Durable and waterproof"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Split Grid Block",
      "blocks": [
        { "type": "feature", "settings": { "text": "Durable and waterproof" } },
        { "type": "feature", "settings": { "text": "No battery/charging needed" } },
        { "type": "feature", "settings": { "text": "No subscription required" } },
        { "type": "feature", "settings": { "text": "Instant medical & contact info" } },
        { "type": "feature", "settings": { "text": "Translates into 24 languages" } },
        { "type": "feature", "settings": { "text": "Works everywhere" } }
      ]
    }
  ]
}
{% endschema %}