{{ 'section-kopilot-features.css' | asset_url | stylesheet_tag }}

<div class="kopilot-section" id="kopilot-section-{{ section.id }}">
  <div class="kopilot-container">
    
    <!-- LEFT SIDE: CONTENT BLOCK -->
    <div class="kopilot-content-col">
      <div class="kopilot-text-stack">
        <h2 class="kopilot-heading">{{ section.settings.heading }}</h2>
        <p class="kopilot-paragraph">{{ section.settings.paragraph }}</p>
      </div>

      <!-- FEATURE GRID (3x2 Desktop, 2x3 Mobile) -->
      <div class="kopilot-feature-grid">
        {% for block in section.blocks %}
          <div class="kopilot-grid-item" {{ block.shopify_attributes }}>
            <div class="kopilot-icon-wrapper">
              {% if block.settings.icon_svg != blank %}
                {{ block.settings.icon_svg }}
              {% elsif block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | img_url: '40x40' }}" alt="{{ block.settings.text | escape }}" loading="lazy">
              {% else %}
                <!-- Fallback/Placeholder Dot if no asset provided -->
                <span class="kopilot-icon-placeholder"></span>
              {% endif %}
            </div>
            <p class="kopilot-grid-label">{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- RIGHT SIDE: HERO CROP IMAGE -->
    <div class="kopilot-image-col">
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | img_url: '1500x' }}" 
          alt="{{ section.settings.heading | escape }}" 
          loading="lazy"
          class="kopilot-split-img"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'kopilot-split-img placeholder-svg' }}
      {% endif %}
    </div>

  </div>
</div>

{% style %}
  /* --- MASTER TYPOGRAPHY & DESIGN TOKENS --- */
  #kopilot-section-{{ section.id }} {
    --font-family: "Elza", -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: {{ section.settings.bg_color }};
  }

  .kopilot-section {
    width: 100%;
    margin: 0 auto;
    font-family: var(--font-family);
    overflow: hidden;
  }

  .kopilot-container {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    justify-content: space-between;
    width: 100%;
    max-width: 1440px;
    height: 711px; /* Fixed Desktop Height per Spec */
    margin: 0 auto;
  }

  /* Left Side Setup */
  .kopilot-content-col {
    width: calc(1440px - 744px - 64px); /* Dynamically maintains exactly 64px gap to image layout */
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 61px; /* Fixed from 100px to exactly 61px */
    box-sizing: border-box;
  }

  .kopilot-text-stack {
    width: 562px; /* Strict Desktop Text Width Bound */
    display: flex;
    flex-direction: column;
    gap: 50px; /* Improved Gap: Exactly 50px between heading and paragraph */
    margin-bottom: 73px; /* Improved Gap: Exactly 73px between paragraph and icon grid */
  }

  .kopilot-heading {
    font-family: var(--font-family);
    font-size: 60px;
    font-weight: 300; /* Light */
    line-height: 1.1; /* 110% Line Height */
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
    text-align: left;
  }

  .kopilot-paragraph {
    font-family: var(--font-family);
    font-size: 20px;
    font-weight: 400; /* Regular */
    line-height: 1.3; /* 130% Line Height */
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
    max-width: 536px; /* Bound box constraints */
    text-align: left;
  }

  /* Grid Layout (3x2 Desktop) */
  .kopilot-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 147px); /* 147px Exact Box Fixed Width */
    column-gap: 20px; 
    row-gap: 35px;
    max-width: 481px;
  }

  .kopilot-grid-item {
    width: 147px;
    min-height: 107px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 15px; /* Exact inner space between icon and text */
    text-align: center;
  }

  .kopilot-icon-wrapper {
    height: 40px; /* Proportional visual grid icon footprint */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kopilot-icon-wrapper svg {
    width: auto;
    height: 32px;
    display: block;
  }

  .kopilot-grid-label {
    font-family: var(--font-family);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.0; /* 100% Line Height Tight Wrap */
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
    width: 147px;
    word-wrap: break-word;
  }

  .kopilot-icon-placeholder {
    width: 12px;
    height: 12px;
    background-color: #000;
    border-radius: 50%;
    display: inline-block;
  }

  /* Right Side Image Setup */
  .kopilot-image-col {
    width: 744px; /* Pure split half width allocation */
    height: 711px;
    overflow: hidden;
  }

  .kopilot-split-img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Crop match image layout */
    object-position: center;
    display: block;
  }

  /* --- FLUID TABLET RESPONSIVENESS OVERRIDE (768px to 1199px Viewports) --- */
  @media screen and (min-width: 768px) and (max-width: 1199px) {
    .kopilot-container {
      height: auto;
      flex-direction: row;
      padding: 40px 24px;
      gap: 32px;
    }
    
    .kopilot-content-col {
      width: 55%;
      padding-left: 0;
    }

    .kopilot-text-stack {
      width: 100%;
      gap: 30px;
      margin-bottom: 40px;
    }

    .kopilot-heading {
      font-size: 44px;
    }

    .kopilot-feature-grid {
      grid-template-columns: repeat(2, 147px); /* Dropping nicely to 2 columns on tablets */
      column-gap: 24px;
    }

    .kopilot-image-col {
      width: 45%;
      height: auto;
      min-height: 500px;
    }
  }

  /* --- PIXEL PERFECT RESPONSIVE BREAKPOINT (360px Mobile Spec Boundary) --- */
  @media screen and (max-width: 767px) {
    .kopilot-container {
      flex-direction: column;
      height: auto; /* Expand vertically */
      max-width: 360px;
      padding: 20px 0 0 0; /* 20px Top Padding Spec */
      gap: 41px; /* Explicit Layout Flow Stack Gap */
    }

    .kopilot-content-col {
      width: 100%;
      padding: 0 14px; /* Centers the 332px bounding containers */
      align-items: center;
    }

    .kopilot-text-stack {
      width: 332px; /* Perfect Mobile Heading Box Layout Bound */
      margin-bottom: 41px; /* Uniform section gap stack flow */
      gap: 16px;
      align-items: center;
    }

    .kopilot-heading {
      font-size: 30px; /* Spec exact scale down */
      line-height: 1.03; /* 103% Line Height */
      text-align: center;
      max-width: 332px;
    }

    .kopilot-paragraph {
      font-size: 15px; /* Spec exact body match */
      line-height: 1.3; 
      text-align: center;
      max-width: 310px; /* Target Paragraph Envelope Box */
    }

    /* Converts to 2-Column Vertical Layout on Mobile */
    .kopilot-feature-grid {
      grid-template-columns: repeat(2, 104px); /* 104px Individual Mobile Cell Boundaries */
      column-gap: 40px;
      row-gap: 24px;
      justify-content: center;
      max-width: 100%;
    }

    .kopilot-grid-item {
      width: 104px;
      min-height: 107px;
      gap: 15px; /* Maintained layout gap spec */
    }

    .kopilot-grid-label {
      font-size: 15px; /* Scaling legibility shift */
      width: 104px;
      line-height: 1.1;
    }

    /* Drops Image Element perfectly to the absolute layout bottom */
    .kopilot-image-col {
      width: 100%;
      height: 344px; /* Matches Mobile Screenshot dimension output */
      order: 2;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Kopilot Split Grid Block",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For the rides you plan and the moments you don't."
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph Copy",
      "default": "Not every emergency happens deep in remote terrain. Sometimes it’s a quick ride, a normal trail, or a familiar road. Waterproof and battery-free, KOPILOT.ID is designed to stay with your gear every time you head out."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Split Crop Image Right"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Grid Item Element",
      "limit": 6,
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon Inline SVG Code"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Custom Image Asset (Alternative)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Item Feature Tagline",
          "default": "Durable and waterproof"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Split Grid Block",
      "blocks": [
        { "type": "feature", "settings": { "text": "Durable and waterproof" } },
        { "type": "feature", "settings": { "text": "No battery/charging needed" } },
        { "type": "feature", "settings": { "text": "No subscription required" } },
        { "type": "feature", "settings": { "text": "Instant medical & contact info" } },
        { "type": "feature", "settings": { "text": "Translates into 24 languages" } },
        { "type": "feature", "settings": { "text": "Works everywhere" } }
      ]
    }
  ]
}
{% endschema %}