<section class="about-hero-banner" id="HeroBanner-{{ section.id }}">
  <div class="about-hero-banner__container">
    <div class="about-hero-banner__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="about-hero-banner__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.description != blank -%}
        <div class="about-hero-banner__description">{{ section.settings.description }}</div>
      {%- endif -%}
      
      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="about-hero-banner__button">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* --- Base & Desktop Styles (Pixel-Perfect 1440px Optimization) --- */
  .about-hero-banner {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    position: relative;
    background-color: #1a1a1a; /* Fallback background */
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2880 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .about-hero-banner__container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding-top: 171px;
    padding-bottom: 171px;
    padding-left: 111px;
    padding-right: 111px; /* Balanced layout boundary */
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .about-hero-banner__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .about-hero-banner__heading {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    font-size: 48px;
    line-height: 1.1; /* 110% */
    letter-spacing: -1px;
    color: #FFFFFF;
    margin: 0 0 25px 0; /* Exact 25px layout gap */
    max-width: 490px;
    width: 100%;
  }

  .about-hero-banner__description {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.2; /* 120% */
    letter-spacing: 0%;
    color: #FFFFFF;
    margin: 0 0 70px 0; /* Exact 70px layout gap */
    max-width: 433px;
    width: 100%;
  }

  .about-hero-banner__description p {
    color: #FFFFFF;
    margin: 0;
  }

  .about-hero-banner__button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background-color: #EF0008;
    color: #FFFFFF;
    font-family: 'Elza', sans-serif;
    font-weight: 600;
    font-size: 20.38px;
    line-height: 1.0; /* 100% */
    text-transform: uppercase;
    text-decoration: none;
    padding: 18.34px 64px;
    width: max-content;
    box-sizing: border-box;
    transition: background-color 0.2s ease;
  }

  .about-hero-banner__button:hover {
    background-color: #cc0007;
  }

  /* --- Fluid Responsiveness for Intermediate Breakpoints --- */
  @media (max-width: 1439px) and (min-width: 768px) {
    .about-hero-banner__container {
      padding-left: calc(35px + (111 - 35) * ((100vw - 360px) / (1440 - 360)));
      padding-right: calc(35px + (111 - 35) * ((100vw - 360px) / (1440 - 360)));
      padding-top: calc(79px + (171 - 79) * ((100vw - 360px) / (1440 - 360)));
      padding-bottom: calc(146px + (171 - 146) * ((100vw - 360px) / (1440 - 360)));
    }
    .about-hero-banner__heading {
      font-size: calc(30px + (48 - 30) * ((100vw - 360px) / (1440 - 360)));
    }
    .about-hero-banner__description {
      font-size: calc(15px + (20 - 15) * ((100vw - 360px) / (1440 - 360)));
      margin-bottom: calc(71px + (70 - 71) * ((100vw - 360px) / (1440 - 360)));
    }
    .about-hero-banner__button {
      font-size: calc(15px + (20.38 - 15) * ((100vw - 360px) / (1440 - 360)));
      padding-top: calc(15.88px + (18.34 - 15.88) * ((100vw - 360px) / (1440 - 360)));
      padding-bottom: calc(15.88px + (18.34 - 15.88) * ((100vw - 360px) / (1440 - 360)));
      padding-left: calc(61.76px + (64 - 61.76) * ((100vw - 360px) / (1440 - 360)));
      padding-right: calc(61.76px + (64 - 61.76) * ((100vw - 360px) / (1440 - 360)));
    }
  }

  /* --- Mobile Styles (Pixel-Perfect 360px Optimization) --- */
  @media (max-width: 767px) {
    .about-hero-banner {
      {% if section.settings.background_image_mobile != blank %}
        background-image: url('{{ section.settings.background_image_mobile | image_url: width: 750 }}');
      {% else if section.settings.background_image != blank %}
        background-image: url('{{ section.settings.background_image | image_url: width: 750 }}');
      {% endif %}
    }

    .about-hero-banner__container {
      padding-top: 79px;
      padding-bottom: 146px;
      padding-left: 35px;
      padding-right: 35px;
    }

    .about-hero-banner__content {
      align-items: center;
      text-align: center;
      margin: 0 auto;
    }

    .about-hero-banner__heading {
      font-size: 30px;
      line-height: 1.04; /* 104% */
      letter-spacing: -1px;
      margin: 0 0 25px 0; /* Exact 25px layout gap */
      max-width: 290px;
    }

    .about-hero-banner__description {
      font-size: 15px;
      line-height: 1.2; /* 120% */
      margin: 0 0 71px 0; /* Exact 71px layout gap */
      max-width: 290px;
    }

    .about-hero-banner__button {
      font-size: 15px;
      line-height: 1.0; /* 100% */
      padding: 15.88px 61.76px;
    }
  }
</style>

{% schema %}
{
  "name": "About Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for real-world adventures."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Created by outdoor and powersports veterans, KOPILOT.ID was built to make medical information and emergency contacts accessible when they matter most.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "WHO WE ARE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "About Hero Banner"
    }
  ]
}
{% endschema %}