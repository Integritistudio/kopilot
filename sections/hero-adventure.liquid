{%- liquid
  assign has_uploaded_video = false
  if section.settings.background_video != blank
    assign has_uploaded_video = true
  endif

  assign has_video_url = false
  if section.settings.video_url != blank
    assign has_video_url = true
  endif

  assign has_video = false
  if has_uploaded_video or has_video_url
    assign has_video = true
  endif

  assign poster_image = section.settings.background_image
  if poster_image == blank
    assign poster_image = section.settings.image_desktop
  endif
  if poster_image == blank
    assign poster_image = section.settings.image_mobile
  endif

  assign shared_bg_image = section.settings.background_image
  if shared_bg_image == blank
    assign shared_bg_image = section.settings.image_desktop
  endif

  assign mobile_bg_image = section.settings.image_mobile
  if mobile_bg_image == blank
    assign mobile_bg_image = shared_bg_image
  endif

  assign use_shared_image_only = false
  if shared_bg_image != blank and section.settings.image_mobile == blank
    assign use_shared_image_only = true
  endif
-%}

{%- style -%}
  @font-face {
    font-family: 'Elza';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  .adventure-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    min-height: 856px;
    padding-top: 77px;
    padding-bottom: 538px;
    box-sizing: border-box;
    overflow: hidden;
  }

  .adventure-hero-{{ section.id }}__bg {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 62%;
    z-index: 0;
    pointer-events: none;
  }

  .adventure-hero-{{ section.id }}__media {
    display: block;
    width: 100%;
    height: 100%;
    background-repeat: no-repeat;
    background-position: center bottom;
    background-size: cover;
  }

  .adventure-hero-{{ section.id }}__media--video {
    object-fit: cover;
    object-position: center bottom;
  }

  .adventure-hero-{{ section.id }}__media--mobile {
    display: none;
  }

  .adventure-hero-{{ section.id }}__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 40px;
    text-align: center;
  }

  .adventure-hero-{{ section.id }} .hero-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 60px;
    line-height: 1.2;
    letter-spacing: 0px;
    color: {{ section.settings.color_text }};
    margin: 0;
    max-width: 800px;
  }

  .adventure-hero-{{ section.id }} .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.color_button_bg }};
    color: {{ section.settings.color_button_text }};
    text-decoration: none;
    height: 61px;
    min-width: 239px;
    border-radius: 2px;
    padding-top: 20.5px;
    padding-right: 54px;
    padding-bottom: 16px;
    padding-left: 54px;
    font-family: inherit;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
    box-sizing: border-box;
    transition: opacity 0.2s ease-in-out;
  }

  .adventure-hero-{{ section.id }} .hero-button:hover {
    opacity: 0.9;
  }

  {% unless has_video %}
    {% if shared_bg_image != blank and use_shared_image_only %}
      .adventure-hero-{{ section.id }}__media--shared {
        background-image: url('{{ shared_bg_image | image_url: width: 1440 }}');
      }
    {% elsif shared_bg_image != blank %}
      .adventure-hero-{{ section.id }}__media--desktop {
        background-image: url('{{ shared_bg_image | image_url: width: 1440 }}');
      }
    {% endif %}
  {% endunless %}

  /* Tablet: 768px–1439px */
  @media screen and (min-width: 768px) and (max-width: 1439px) {
    .adventure-hero-{{ section.id }} {
      min-height: clamp(600px, 70vh, 820px);
      padding-top: clamp(48px, 6vw, 77px);
      padding-bottom: clamp(360px, 38vw, 520px);
    }

    .adventure-hero-{{ section.id }}__content {
      gap: clamp(24px, 3vw, 40px);
    }

    .adventure-hero-{{ section.id }} .hero-heading {
      font-size: clamp(32px, 4.5vw, 52px);
      max-width: min(800px, 90%);
      padding-left: clamp(16px, 3vw, 20px);
      padding-right: clamp(16px, 3vw, 20px);
    }

    .adventure-hero-{{ section.id }} .hero-button {
      min-width: clamp(200px, 28vw, 239px);
      height: auto;
      min-height: clamp(48px, 5vw, 61px);
      padding: clamp(14px, 2vw, 20.5px) clamp(32px, 5vw, 54px);
      font-size: clamp(13px, 1.4vw, 14px);
    }
  }

  /* Desktop pinned: 1440px+ */
  @media screen and (min-width: 1440px) {
    .adventure-hero-{{ section.id }} {
      min-height: 856px;
      padding-top: 77px;
      padding-bottom: 538px;
    }

    .adventure-hero-{{ section.id }}__content {
      gap: 36px;
    }

    .adventure-hero-{{ section.id }} .hero-heading {
      font-size: 60px;
      line-height: 1.2;
      max-width: 592px;
      padding-left: 0;
      padding-right: 0;
    }

    .adventure-hero-{{ section.id }} .hero-button {
      height: 61px;
      min-width: 239px;
      padding-top: 20.5px;
      padding-right: 54px;
      padding-bottom: 16px;
      padding-left: 54px;
      font-size: 14px;
      letter-spacing: 1px;
    }
  }

  @media screen and (max-width: 767px) {
    .adventure-hero-{{ section.id }} {
      min-height: 700px;
      padding-top: 60px;
      padding-bottom: 350px;
    }

    .adventure-hero-{{ section.id }}__content {
      gap: 30px;
    }

    .adventure-hero-{{ section.id }} .hero-button {
      padding-top: 15.88px;
      padding-right: 61.76px;
      padding-bottom: 15.88px;
      padding-left: 61.76px;
      font-family: inherit;
      font-weight: 600;
      font-size: 15px;
      letter-spacing: 0px;
    }

    .adventure-hero-{{ section.id }} .hero-heading {
      font-size: 30px;
      padding-left: 20px;
      padding-right: 20px;
    }

    {% unless has_video %}
      {% if use_shared_image_only == false %}
        .adventure-hero-{{ section.id }}__media--desktop {
          display: none;
        }

        .adventure-hero-{{ section.id }}__media--mobile {
          display: block;
          {% if mobile_bg_image != blank %}
            background-image: url('{{ mobile_bg_image | image_url: width: 1000 }}');
          {% endif %}
        }
      {% endif %}
    {% endunless %}
  }
{%- endstyle -%}

<div class="adventure-hero-{{ section.id }}">
  <div class="adventure-hero-{{ section.id }}__bg" aria-hidden="true">
    {% if has_uploaded_video %}
      {% capture adventure_video_class %}adventure-hero-{{ section.id }}__media adventure-hero-{{ section.id }}__media--video{% endcapture %}
      {{
        section.settings.background_video
        | video_tag:
          class: adventure_video_class,
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          image_size: '1440x',
          preload: 'metadata'
      }}
    {% elsif has_video_url %}
      <video
        class="adventure-hero-{{ section.id }}__media adventure-hero-{{ section.id }}__media--video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        {% if poster_image != blank %}
          poster="{{ poster_image | image_url: width: 1440 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% else %}
      {% if shared_bg_image != blank and use_shared_image_only %}
        <div class="adventure-hero-{{ section.id }}__media adventure-hero-{{ section.id }}__media--shared"></div>
      {% else %}
        <div class="adventure-hero-{{ section.id }}__media adventure-hero-{{ section.id }}__media--desktop"></div>
        <div class="adventure-hero-{{ section.id }}__media adventure-hero-{{ section.id }}__media--mobile"></div>
      {% endif %}
    {% endif %}
  </div>

  <div class="adventure-hero-{{ section.id }}__content">
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-heading">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      {%- assign adventure_button_link = section.settings.button_link | default: routes.root_url -%}
      <a href="{{ adventure_button_link }}" class="hero-button">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Adventure Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background video (upload)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background video URL (.mp4)",
      "info": "External MP4 link. Used only when no uploaded video is set."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (upload)",
      "info": "Shown on mobile and desktop when no video is set. Also used as video poster."
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop background image",
      "info": "Optional. Used when Background image is empty."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile background image (optional)",
      "info": "Optional. Different image on mobile only."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Don't let your next adventure be your last."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "GET KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Heading Color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "color_button_bg",
      "label": "Button Background Color",
      "default": "#EF0008"
    },
    {
      "type": "color",
      "id": "color_button_text",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Adventure Hero"
    }
  ]
}
{% endschema %}
