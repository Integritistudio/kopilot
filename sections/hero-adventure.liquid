{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-home-closing.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* Container Overrides to ensure pixel-perfect aspect ratio scaling */
  .kopilot-home-closing--{{ section.id }} {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
    overflow: hidden;

    /* Scheme Override to intercept and kill external background color interference */
    {%- if section.settings.force_custom_bg -%}
      background-color: {{ section.settings.custom_bg_color }} !important;
    {%- endif -%}
  }

  /* RESET: Neutralize external theme rules breaking container flow */
  .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__inner {
    min-height: auto !important;
    height: auto !important;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  /* Desktop Settings (Figma 1440px Specification) */
  @media screen and (min-width: 768px) {
    .kopilot-home-closing--{{ section.id }} {
      height: 856px !important; /* Fixed frame constraint only for desktop layout */
      justify-content: flex-start;
      padding-top: {{ section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom }}px !important;
    }
    .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image--desktop {
      display: block !important;
    }
    .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image--mobile {
      display: none !important;
    }
  }

  /* Mobile Settings (Figma 360px Specification) - Natural flow to prevent asset cutting */
  @media screen and (max-width: 767px) {
    .kopilot-home-closing--{{ section.id }} {
      height: auto !important; /* Kill the fixed height constraint pushing image away */
      min-height: 480px !important; 
      justify-content: flex-start;
      padding-top: 40px !important;
      padding-bottom: 20px !important; /* Closes gap nicely to reveal bicyclist asset */
    }
    .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image--desktop {
      display: none !important;
    }
    .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image--mobile {
      display: block !important;
    }
  }

  /* Enforce Absolute Layout on Background Layer */
  .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    z-index: 1;
    margin: 0;
    padding: 0;
  }

  .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image {
    width: 100%;
    height: 100%;
  }

  /* Target the image asset inside the custom render snippet rendering block */
  .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image img,
  .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__bg-image picture {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: bottom center !important;
  }

  /* Dynamic Customizer Content Element Layout Flow */
  .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin: 0 auto;
    gap: {{ section.settings.element_gap }}px;
  }
  
  @media screen and (max-width: 767px) {
    .kopilot-home-closing--{{ section.id }} .kopilot-home-closing__content {
      gap: {{ section.settings.element_gap_mobile }}px;
    }
  }
{%- endstyle -%}

{% liquid
  if section.settings.image_mobile != blank
    assign closing_mobile_image = section.settings.image_mobile
  else
    assign closing_mobile_image = section.settings.image
  endif
%}

<section class="kopilot-section kopilot-home-closing kopilot-home-closing--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-home-closing__bg" aria-hidden="true">
    <div class="kopilot-home-closing__bg-image kopilot-home-closing__bg-image--desktop">
      {% render 'kopilot-image',
        image: section.settings.image,
        fallback: 'bad64fb19fb42742653b28527e5a419202fe681f.png',
        alt: '',
        width: 2880,
        widths: '1100,1440,1889,2880',
        sizes: '100vw',
        loading: 'lazy'
      %}
    </div>
    <div class="kopilot-home-closing__bg-image kopilot-home-closing__bg-image--mobile">
      {% render 'kopilot-image',
        image: closing_mobile_image,
        fallback: 'kopilot-home-closing-hero.jpg',
        alt: '',
        width: 1734,
        widths: '360,750,867,1734',
        sizes: '(max-width: 767px) 867px, 0px',
        loading: 'lazy'
      %}
    </div>
  </div>

  <div class="kopilot-home-closing__inner">
    <div class="kopilot-home-closing__content">
      {% if section.settings.heading != blank %}
        <div class="kopilot-home-closing__heading rte">
          {{ section.settings.heading }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="kopilot-home-closing__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

      {% if section.settings.tagline != blank %}
        <p class="kopilot-home-closing__tagline">{{ section.settings.tagline }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Home Closing",
  "tag": "section",
  "class": "kopilot-home-closing-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color Configuration Schemes"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "force_custom_bg",
      "label": "Override with custom background color",
      "default": true
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Custom Canvas Background",
      "default": "#FDFDFD"
    },
    {
      "type": "header",
      "content": "Image Assets"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)"
    },
    {
      "type": "header",
      "content": "Content Strings"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Don't let your next<br>adventure be your last.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "The tag that brings you home."
    },
    {
      "type": "header",
      "content": "Desktop Spacing Controls (Figma 1440px)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 76
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 800,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 536
    },
    {
      "type": "range",
      "id": "element_gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Element Gap (Text to Button)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile Spacing Controls"
    },
    {
      "type": "range",
      "id": "element_gap_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Element Gap",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Kopilot Home Closing",
      "settings": {
        "heading": "<p>Don't let your next<br>adventure be your last.</p>",
        "button_label": "Get KOPILOT.ID",
        "tagline": "The tag that brings you home."
      }
    }
  ]
}
{% endschema %}