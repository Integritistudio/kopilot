{%- style -%}
  @font-face {
    font-family: 'Elza';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  .adventure-hero-{{ section.id }} {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    min-height: 856px;
    padding-top: 77px;
    padding-bottom: 538px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 40px;
    text-align: center;
    background-repeat: no-repeat;
    background-position: center bottom;
    box-sizing: border-box;
    {% if section.settings.image_desktop != blank %}
      background-image: url('{{ section.settings.image_desktop | image_url: width: 1440 }}');
    {% endif %}
  }

  .adventure-hero-{{ section.id }} .hero-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 60px;
    line-height: 1.2;
    letter-spacing: 0px;
    color: {{ section.settings.color_text }};
    margin: 0;
    max-width: 800px;
  }

  .adventure-hero-{{ section.id }} .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.color_button_bg }};
    color: {{ section.settings.color_button_text }};
    text-decoration: none;
    height: 61px;
    min-width: 239px;
    border-radius: 2px;
    padding-top: 9px;
    padding-right: 54px;
    padding-bottom: 5px;
    padding-left: 54px;
    font-family: inherit;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
    box-sizing: border-box;
    transition: opacity 0.2s ease-in-out;
  }

  .adventure-hero-{{ section.id }} .hero-button:hover {
    opacity: 0.9;
  }

  @media screen and (max-width: 767px) {
    .adventure-hero-{{ section.id }} {
      min-height: 700px;
      padding-top: 60px;
      padding-bottom: 350px;
      gap: 30px;
      {% if section.settings.image_mobile != blank %}
        background-image: url('{{ section.settings.image_mobile | image_url: width: 750 }}');
      {% elsif section.settings.image_desktop != blank %}
        background-image: url('{{ section.settings.image_desktop | image_url: width: 1000 }}');
      {% endif %}
    }

    .adventure-hero-{{ section.id }} .hero-heading {
      font-size: 36px;
      padding-left: 20px;
      padding-right: 20px;
    }
  }
{%- endstyle -%}

<div class="adventure-hero-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="hero-heading">
      {{ section.settings.heading | escape }}
    </h2>
  {%- endif -%}

  {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
    <a href="{{ section.settings.button_link }}" class="hero-button">
      {{ section.settings.button_label | escape }}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Adventure Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Don't let your next adventure be your last."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "GET KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Background Assets"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Background Image",
      "info": "Leave blank to use the desktop background image on mobile devices."
    },
    {
      "type": "header",
      "content": "Color Profiles"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Heading Color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "color_button_bg",
      "label": "Button Background Color",
      "default": "#EF0008"
    },
    {
      "type": "color",
      "id": "color_button_text",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Adventure Hero"
    }
  ]
}
{% endschema %}