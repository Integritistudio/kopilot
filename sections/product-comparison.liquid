{% style %}
  .comparison-section-{{ section.id }} {
     padding-top: {{ section.settings.padding_top }}px;
     padding-bottom: {{ section.settings.padding_bottom }}px;
     --price-col: {{ section.settings.price-col }};
     --in-stock: {{ section.settings.in-stock-col }};
     --out-stock: {{ section.settings.out-stock-col }}
  }
{% endstyle %}

{{ 'section-product-comparison.css' | asset_url | stylesheet_tag }}

<section
  class="comparison-section-{{ section.id }} comparison-section color-{{ section.settings.color_scheme }}"
>
  <div class="container">
    {% if section.settings.heading != blank %}
      <div class="comparison-heading">
        <h1>{{ section.settings.heading }}</h1>
      </div>
    {% endif %}

    <div class="comparison-scroll-wrapper">
      <div class="comparison-wrapper">
        <!-- TOP SECTION -->
        <div class="comparison-top-section">
          <!-- LEFT IMAGE -->
          <div class="comparison-side-image">
            {% if section.settings.side_image != blank %}
              {{
                section.settings.side_image
                | image_url: width: 800
                | image_tag: loading: 'lazy', widths: '400,600,800', alt: 'comparison-image'
              }}

            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder_svg' }}
            {% endif %}
          </div>

          <!-- PRODUCT CARDS -->
          <div class="comparison-products-grid-img">
            {% for i in (1..4) %}
              {% assign product_key = 'product_' | append: i %}
              {% assign badge_key = 'badge_' | append: i %}

              {% assign product = section.settings[product_key] %}
              {% assign badge = section.settings[badge_key] %}

              {% comment %} {% if product != blank %} {% endcomment %}
                <div class="comparison-product-column">
                  <a href="{{ product.url }}" >
                    <div class="comparison-card">
                      {% if badge != blank %}
                        <span class="comparison-badge">
                          {{ badge }}
                        </span>
                      {% endif %}

                      <div class="comparison-image">
                        {% if product.featured_image %}
                          {{
                            product.featured_image
                            | image_url: width: 500
                            | image_tag: loading: 'lazy', widths: '250,400,500', alt: product.title
                          }}

                        {% else %}
                          {% assign index = forloop.index | modulo: 2 %}
                          {% if index == 1 %}
                            {{ 'collection-2' | placeholder_svg_tag: 'placeholder_svg' }}
                          {% else %}
                            {{ 'collection-1' | placeholder_svg_tag: 'placeholder_svg' }}
                          {% endif %}
                        {% endif %}
                      </div>

                      <h6 class="comparison-title">
                        {{ product.title }}
                      </h6>
                    </div>
                  </a>
                </div>
              {% comment %} {% endif %} {% endcomment %}
            {% endfor %}
          </div>
        </div>

        <!-- BOTTOM TABLE -->
        <div class="comparison-table">
          <!-- PRICE ROW -->
          <div class="comparison-row">
            <div class="comparison-label">Price</div>

            {% for i in (1..4) %}
              {% assign product_key = 'product_' | append: i %}
              {% assign product = section.settings[product_key] %}

              {% if product != blank %}
                <div class="comparison-cell price">
                  {{ product.price | money }}
                </div>
              {% endif %}
            {% endfor %}
          </div>

          <!-- STOCK ROW -->
          <div class="comparison-row">
            <div class="comparison-label">Stock Availability</div>

            {% for i in (1..4) %}
              {% assign product_key = 'product_' | append: i %}
              {% assign product = section.settings[product_key] %}

              {% comment %} {% if product != blank %} {% endcomment %}
                <div class="comparison-cell">
                  {% if product.available %}
                    <span class="in-stock">IN STOCK</span>
                  {% else %}
                    <span class="out-stock">OUT OF STOCK</span>
                  {% endif %}
                </div>
              {% comment %} {% endif %} {% endcomment %}
            {% endfor %}
          </div>

          <!-- DYNAMIC ROWS -->
          {% for block in section.blocks %}
            <div class="comparison-row">
              <div class="comparison-label">
                {{ block.settings.label }}
              </div>

              {% for i in (1..4) %}
                {% assign value_key = 'value_' | append: i %}
                {% assign product_key = 'product_' | append: i %}
                {% assign product = section.settings[product_key] %}

                {% comment %} {% if product != blank %} {% endcomment %}
                  <div class="comparison-cell">
                    {{ block.settings[value_key] }}
                  </div>
                {% comment %} {% endif %} {% endcomment %}
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product comparison",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,

  "settings": [

    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "price-col",
      "label": "Price color",
      "default": "#E32E31"
    },
    {
      "type": "color",
      "id": "in-stock-col",
      "label": "In stock color",
      "default": "#22AD27"
    },
    {
      "type": "color",
      "id": "out-stock-col",
      "label": "Out of stock color",
      "default": "#242422"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Left side image"
    },

    {
      "type": "header",
      "content": "Products"
    },

    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "NEW"
    },

    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2"
    },

    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3"
    },

    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "text",
      "id": "badge_4",
      "label": "Badge 4"
    },

    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },

    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],

  "blocks": [
    {
      "type": "field",
      "name": "Comparison field",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Field label",
          "default": "Voltage"
        },

        {
          "type": "text",
          "id": "value_1",
          "label": "Product 1 value",
          "default": "text1"
        },

        {
          "type": "text",
          "id": "value_2",
          "label": "Product 2 value",
          "default": "text2"
        },

        {
          "type": "text",
          "id": "value_3",
          "label": "Product 3 value",
          "default": "text3"
        },

        {
          "type": "text",
          "id": "value_4",
          "label": "Product 4 value",
          "default": "text4"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Product comparison",
      "blocks": [
        {
          "type": "field"
          
        },
        {
          "type": "field"
        },
        {
          "type": "field"
        }
      ]
    }
  ]
}
{% endschema %}
