{% style %}
  .password_header_section_wrapper--{{ section.id }} {
      padding-top: {{ section.settings.top_spacing }}px;
      padding-bottom: {{ section.settings.bottom_spacing }}px;
  }
{% endstyle %}

{{ 'password-header-section.css' | asset_url | stylesheet_tag }}

<div class="password_header_section_wrapper--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="container">
    <div class="password_header_section_inner">
      <div class="password_header_section_logo" style="--logo-width: {{ section.settings.logo_width }}px;">
        {% if section.settings.logo != blank %}
          {% assign width = section.settings.logo_width %}
          <h1 class="h4">
            {{ section.settings.logo | image_url: width: width | image_tag }}
          </h1>
        {% else %}
          <h1 class="h4">
            {{ shop.name }}
          </h1>
        {% endif %}

        {%- if shop.password_message != blank -%}
          <div class="password_header_section_text">
            {{ shop.password_message }}
          </div>
        {%- endif -%}
      </div>
      <div class="password_header_section_icon_text">
        <span>{{ 'icon-lock.svg' | inline_asset_content }}</span>
        <span>{{ 'general.password_page.login_password_button' | t }}</span>
      </div>
    </div>
  </div>
</div>

<div class="password_header_section_popup color-{{ section.settings.popup_color_scheme }}">
  <div class="password_header_section_popup_inner">
    <div class="password_header_section_popup_head">
      <h4>{{ 'general.password_page.popup_header' | t }}</h4>
      <button aria-label="{{ 'accessibility.close' | t }}">
        <div class="svg_wrapper">{{ 'icon-close.svg' | inline_asset_content }}</div>
      </button>
    </div>

    <div class="password_header_section_popup_form">
      {% form 'storefront_password', id: 'password_page_form' %}
        {% if form.errors %}
          <div class="form_error_msg">
            <p class="form_message" role="alert" tabindex="-1" autofocus>
              <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
                <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
              </svg>
              {{ 'general.form.error_heading' | t }}
            </p>
          </div>
          <div class="form_errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="input_field_wrapper">
          <input
            type="password"
            name="password"
            id="input_password"
            required
            autocomplete="current-password"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="main_password_page_form_errors_wrapper"
            {%- endif -%}
            placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
          >
          <label for="input_password">
            {{- 'general.password_page.login_form_password_placeholder' | t | append: ' *' -}}
          </label>
          {{ 'icon-lock.svg' | inline_asset_content }}
        </div>

        <div class="password_header_form_btn">
          <button name="commit" class="btn">
            {{ 'general.password_page.login_form_submit' | t }}
          </button>
        </div>
      {% endform %}

      <div class="password_header_section_admin_link">
        <span>{{ 'general.password_page.admin_link_html' | t }}</span>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggerBtn = document.querySelector('.password_header_section_icon_text');
    const closeBtn = document.querySelector('.password_header_section_popup_head button');
    const wrapper = document.querySelector('.password_header_section_popup');
    const inner = wrapper?.querySelector('.password_header_section_popup_inner');
    const input = wrapper?.querySelector('#input_password');
    const form = wrapper?.querySelector('form');

    if (!triggerBtn || !wrapper || !inner) return;

    const DURATION = 300; 

    function resetPasswordPopup() {
      if (input) {
        input.value = '';
        input.removeAttribute('aria-invalid');
      }

      wrapper.querySelectorAll('.form_error_msg, .form_errors').forEach(el => {
        el.remove();
      });

      if (form) {
        form.reset();
      }
    }

    function closePasswordPopup() {
      wrapper.removeAttribute('open');

      setTimeout(resetPasswordPopup, DURATION);
    }

    triggerBtn.addEventListener('click', (e) => {
      e.preventDefault();
      wrapper.setAttribute('open', '');
    });

    wrapper.addEventListener('click', () => {
      closePasswordPopup();
    });

    inner.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        closePasswordPopup();
      });
    }

    if (input?.hasAttribute('aria-invalid')) {
      wrapper.setAttribute('open', '');
    }
  });
</script>

{% schema %}
{
  "name": "Password header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "color_scheme",
      "id": "popup_color_scheme",
      "label": "Popup color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Select logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 10,
      "max": 600,
      "step": 10,
      "default": 90
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20,
      "unit": "px"
    }
  ]
}
{% endschema %}