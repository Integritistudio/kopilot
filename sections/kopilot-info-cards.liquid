{% style %}
  .kopilot-info-cards--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 989px) {
    .kopilot-info-cards--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-info-cards.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-info-cards kopilot-info-cards--{{ section.id }} color-{{ section.settings.color_scheme }}">
  {% if section.settings.background_image != blank %}
    <div class="kopilot-info-cards__bg">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '100vw' }}
    </div>
  {% endif %}

  <div class="kopilot-info-cards__inner">
    {% if section.settings.heading != blank %}
      <h2 class="kopilot-info-cards__heading kopilot-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="kopilot-info-cards__grid">
      {% for block in section.blocks %}
        <article class="kopilot-info-cards__card" {{ block.shopify_attributes }}>
          <div class="kopilot-info-cards__card-media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder_svg' }}
            {% endif %}
          </div>
          <div class="kopilot-info-cards__card-body">
            {% if block.settings.title != blank %}
              <h3 class="kopilot-info-cards__card-title kopilot-body">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="kopilot-info-cards__card-text kopilot-body rte">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Info cards",
  "tag": "section",
  "class": "kopilot-info-cards-section",
  "max_blocks": 3,
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The information they need when every second counts."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Your Information, Ready in Seconds"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Your profile stores your medical information and emergency contacts. Anyone with a smartphone can access it in an emergency.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Info cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Your Information, Ready in Seconds",
            "text": "<p>Your profile stores your medical information and emergency contacts. Anyone with a smartphone can access it in an emergency.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Quick to Set Up & Easy to Attach",
            "text": "<p>Setup takes a minute, and you only need to add the information you're willing to share. Then, attach it to your gear with one of the included mounts.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Everything Managed in One App",
            "text": "<p>Manage tags, gear setups, family members, and receive scan notifications with location — all in one free, easy-to-use app.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
