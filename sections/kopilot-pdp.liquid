{% style %}
  .kopilot-pdp--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
.kopilot-pdp__tier-title-pdp{
    margin: 0;
    font-family:'Elza';
    font-size: 20px;
    font-weight: 700;
    line-height: 130%;
    letter-spacing: 0px;
    text-transform: uppercase;
    color: #000;
}
.kopilot-pdp__tier-price-pdp {
    margin: 0;
    font-family: var(--kopilot-font-family);
    font-size: 20px;
    font-weight: 700;
    line-height: 130%;
    color: #000;
    letter-spacing: 0%;
}
.kopilot-pdp__tier-compare-pdp{
    margin: 0;
    font-family: var(--kopilot-font-family);
    font-size: 20px;
    line-height: 1;
    color: #767676;
    text-decoration: line-through;
}

  @media screen and (max-width: 767px) {
    .kopilot-pdp--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    
    /* Remove slider pagination indicators on mobile layout per image_8259ff.png */
    .kopilot-pdp__carousel-dots {
      display: none !important;
    }

    /* Clean transparent layout structure for mobile gallery wrappers */
    .kopilot-pdp__gallery-mobile {
      background: transparent !important;
      padding: 0 !important;
    }

    /* Standardizes exact layout spacing gap above the banner header */
    .kopilot-pdp__special-banner {
      margin-top: 12px !important;
      position: relative !important;
    }
  }

  /* Description Typography Setup */
  .kopilot-pdp__description_pdp p {
    font-size: 20px !important;
    line-height: 1.30 !important;
    font-family: "Elza" !important;
    max-width: 382px;
  }

  .kopilot-pdp__description_pdp--mobile {
    display: none;
    margin: 0 auto;
    padding: 18px 0px;
    max-width: 298px;
    font-size:15px !important;

  }

  @media screen and (max-width: 767px) {
    .kopilot-pdp__description_pdp--mobile {
      display: block;
    }

    .kopilot-pdp__description_pdp p,
    .kopilot-pdp__description_pdp--mobile,
    .kopilot-pdp__description_pdp--mobile p {
      max-width: 298px !important;
      width: 100% !important;
      box-sizing: border-box;
      font-size: 15px !important;
    }

    .kopilot-pdp__included-heading {
      font-size: 15px !important;
    }
  }

  @media screen and (max-width: 360px) {
    .kopilot-pdp__description_pdp p {
      max-width: 298px !important;
      width: 100% !important;
      box-sizing: border-box;
      font-size:15px !important;
    }
    .kopilot-pdp__included-heading{
      font-size:15px !important;
    }
  }

  .kopilot-pdp__description strong, 
  .kopilot-pdp__description b {
    font-weight: 700;
  }

  /* Core Layout Custom Colors */
  .kopilot-pdp__tier-badge {
    /* background-color: #F20008;
    color: #ffffff; */
    font-weight: bold;
    text-transform: uppercase;
    font-size: 16px;
    padding: 8.63px 22px;
    letter-spacing: 0.05em;
    display: inline-block;
  }

.kopilot-pdp__tier-save {
    color: #F20008 ;
    background-color: rgba(254, 206, 206, 0.57) ;
}
@media screen and (max-width: 767px) {
  .kopilot-pdp__tier-price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    row-gap: 4px;
    column-gap: 8px;
  }

  .kopilot-pdp__tier-price-pdp {
    flex-basis: 100%;
    width: 100%;
  }
}
  .kopilot-pdp__tier-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 2px solid #141416;
    border-radius: 50%;
    background-color: #ffffff;
    position: relative;
    flex-shrink: 0;
  }

  .kopilot-pdp__tier-dot::before {
    content: '';
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: transparent;
    transition: background-color 0.2s ease;
  }

  .kopilot-pdp__tier.is-selected .kopilot-pdp__tier-dot::before {
    background-color: #141416;
  }

  .kopilot-pdp__tier-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Add to Cart Button Optimization Specs */
  .kopilot-pdp__add {
    background-color: #141416 !important;
    font-size: 20px !important;
    line-height: 25.3px !important;
    font-weight: 600 !important;
  }

  /* Order & Delivery Typography Row Rules */
  .kopilot-pdp__delivery-line {
    font-size: 20px !important;
    line-height: 1.30 !important;
  }
  .kopilot-pdp__delivery-label {
    font-weight: 700 !important;
    color: #141416 !important;
    text-transform: uppercase;
  }
  .kopilot-pdp__delivery-value {
    font-weight: 400 !important;
  }

  /* Included Items Pill UI Optimization */
  .kopilot-pdp__included-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 7.5px !important;
  }
  .kopilot-pdp__included-pill {
    background-color: #EEEEEE !important;
    color: #000000 !important;
    border-radius: 0px !important;
    border: none !important;
    padding: 8.25px 12.75px !important;
    font-size: 16px;
    display: inline-block;
  }

  /* Gallery Overlay Typography Setup */
  .kopilot-pdp__gallery-cell {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }
  
  .kopilot-pdp__gallery-text-container {
    position: absolute;
    left: 0;
    right: 0;
    padding: 24px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    z-index: 2;
    pointer-events: none;
  }
  
  /* Precision positions: top, bottom, top-center, bottom-center */
  .kopilot-pdp__gallery-text-container--top {
    top: 0;
    bottom: auto;
    align-items: flex-start;
    text-align: left;
  }
  .kopilot-pdp__gallery-text-container--bottom {
    bottom: 0;
    top: auto;
    align-items: flex-start;
    text-align: left;
  }
  .kopilot-pdp__gallery-text-container--top-center {
    top: 0;
    bottom: auto;
    align-items: center;
    text-align: center;
  }
  .kopilot-pdp__gallery-text-container--bottom-center {
    bottom: 0;
    top: auto;
    align-items: center;
    text-align: center;
  }

  /* Content Text Engine */
  .kopilot-pdp__gallery-text-line {
    font-family: 'elza', sans-serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.26;
    margin: 0;
  }
  .kopilot-pdp__gallery-text-line--uppercase {
    text-transform: uppercase;
  }
  .kopilot-pdp__gallery-text-line--normal {
    text-transform: none;
  }
  .kopilot-pdp__gallery-text-line--white {
    color: #ffffff;
  }
  .kopilot-pdp__gallery-text-line--red {
    color: #F20008;
  }

  /* Special Top Ribbon Offer */
  .kopilot-pdp__special-banner {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: #F20008;
    color: #ffffff;
    font-family: 'elza', sans-serif;
    font-size: 12.78px;
    font-weight: 500;
    line-height: 1.30;
    text-transform: uppercase;
    text-align: center;
    padding: 6.39px 10px;
    letter-spacing: 0.05em;
    z-index: 3;
  }
   @media screen and (max-width: 767px) {
    .kopilot-pdp__special-banner{
      display:none;
    }
   }
  
  /* Text container offsets if top red banner ribbon is enabled */
  .kopilot-pdp__special-banner + .kopilot-pdp__gallery-text-container--top,
  .kopilot-pdp__special-banner + .kopilot-pdp__gallery-text-container--top-center {
    padding-top: 45px;
  }
  .kopilot-pdp__tier-subtitle-pdp {
    font-weight: 400;
    margin: 0 0 10px;
    font-family: 'Elza';
    font-size: 20px;
    line-height: 130%;
    color: #000;
}
.kopilot-pdp__tier-head>span{
font-size:16px;
}
/* Reviews Row & Count Styles */
.kopilot-pdp__reviews-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.kopilot-pdp__reviews-row svg {
  transform: scaleX(0.85);
  transform-origin: center;
}

.kopilot-pdp__stars-image {
  height: auto;
  display: block;
}

.kopilot-pdp__reviews-row > p {
  font-family: 'Rubik', sans-serif;
  font-size: 15px;
  font-weight: 400;
  line-height: 25px;
  letter-spacing: 0;
  margin: 0;
  color: #545454;
}

@media screen and (max-width: 1024px) {
  .kopilot-pdp__tier-title-pdp {
    font-size: 19px;
  }
  .kopilot-pdp__tier-subtitle-pdp {
    font-size: 15.25px;
  }
  .kopilot-pdp__tier-price-pdp {
    font-size: 19px;
  }
  .kopilot-pdp__tier-compare-pdp {
    font-size: 19px;
  }
  .kopilot-pdp__tier-save {
    font-size: 14.39px;
  }
  .kopilot-pdp__delivery-label,
  .kopilot-pdp__delivery-value{
    font-size:16px;
  }
.kopilot-pdp__tier-head>span{
font-size:12.47px;
padding:7.25px 18.29px;
}
    .kopilot-pdp__reviews-row > p{
      font-size:13px;
    }
  }

  /* Gallery images height adjustments */
  @media screen and (min-width: 768px) {
    .kopilot-pdp__gallery-image,
    .kopilot-pdp__gallery-image img,
    .kopilot-pdp__gallery-grid img {
      height: 410px !important;
      min-height: 410px !important;
      object-fit: cover !important;
      width: 100% !important;
    }
  }

  @media screen and (max-width: 767px) {
    .kopilot-pdp__gallery-image,
    .kopilot-pdp__gallery-image img,
    .kopilot-pdp__gallery-mobile img,
    .kopilot-pdp__carousel-slide img {
      height: 360px !important;
      min-height: 360px !important;
      object-fit: cover !important;
      width: 100% !important;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-pdp.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kopilot-pdp.js' | asset_url }}" defer></script>

{% liquid
  if section.settings.product != blank
    assign pdp_product = section.settings.product
  elsif product != blank
    assign pdp_product = product
  endif

  if pdp_product != blank
    assign current_variant = pdp_product.selected_or_first_available_variant
  endif

  assign gallery_fallbacks = 'kopilot-pdp-gallery-1.jpg,kopilot-pdp-gallery-2.jpg,kopilot-pdp-gallery-3.jpg,kopilot-pdp-gallery-4.jpg,kopilot-pdp-gallery-5.jpg,kopilot-pdp-gallery-6.jpg' | split: ','

  assign gallery_blocks = section.blocks | where: "type", "gallery_slide"
  if gallery_blocks.size > 0
    assign use_product_images = false
    assign gallery_items = gallery_blocks
  else
    assign use_product_images = true
    assign gallery_items = pdp_product.images
  endif
  assign image_limit = section.settings.gallery_image_limit | default: 6

  assign global_has_special_banner = false
  assign global_special_banner_text = ''
  if use_product_images
    if section.settings.promo_text != blank
      assign global_has_special_banner = true
      assign global_special_banner_text = section.settings.promo_text
    endif
  else
    for item in gallery_items limit: image_limit
      if item.settings.show_special_banner
        assign global_has_special_banner = true
        assign global_special_banner_text = item.settings.special_banner_text
        break
      endif
    endfor
  endif
%}

{% if pdp_product == blank %}
  <div class="kopilot-section kopilot-pdp kopilot-pdp--{{ section.id }}">
    <p class="kopilot-pdp__missing-product">Select a product in the Kopilot PDP section settings.</p>
  </div>
{% else %}
<kopilot-pdp
  class="kopilot-section kopilot-pdp kopilot-pdp--{{ section.id }} color-{{ section.settings.color_scheme }}"
  data-product-id="{{ pdp_product.id }}"
  data-variant-id="{{ current_variant.id }}"
  data-default-button-label="{{ section.settings.button_label | default: 'ADD TO CART - 1 TAG' }}"
>
  <div class="kopilot-pdp__inner">
    <div class="kopilot-pdp__mobile-head">
      <h1 class="kopilot-pdp__title">
        {% if section.settings.title != blank %}
          {{ section.settings.title }}
        {% else %}
          {{ pdp_product.title }}
        {% endif %}
      </h1>
      {% if section.settings.show_reviews %}
        <div class="kopilot-pdp__reviews-row">
          {% if section.settings.stars_image %}
            {% render 'kopilot-image', image: section.settings.stars_image, alt: 'Star rating', width: 100, class: 'kopilot-pdp__stars-image' %}
          {% else %}
            {% render 'kopilot-review-stars', rating: section.settings.star_rating, size: 'lg', filled_color: '#FF0000' %}
          {% endif %}
          <p class="kopilot-pdp__review-count">{{ section.settings.review_count }} Reviews</p>
        </div>
      {% endif %}
    </div>

    <div class="kopilot-pdp__layout">
      <div class="kopilot-pdp__gallery">
        <div class="kopilot-pdp__gallery-grid">
          {% for item in gallery_items limit: image_limit %}
            {% liquid
              if use_product_images
                assign slide_image = item
                assign show_special_banner = false
                assign special_banner_text = ''
                assign slide_alt = item.alt | default: pdp_product.title
                assign text_line_1 = ''
                assign text_line_2 = ''
                assign text_position = 'bottom'
                assign shopify_attributes = ''
              else
                assign slide_image = item.settings.image
                assign show_special_banner = item.settings.show_special_banner
                assign special_banner_text = item.settings.special_banner_text
                assign slide_alt = item.settings.text_line_1 | default: pdp_product.title
                assign text_line_1 = item.settings.text_line_1
                assign color_line_1 = item.settings.color_line_1
                assign transform_line_1 = item.settings.transform_line_1
                assign text_line_2 = item.settings.text_line_2
                assign color_line_2 = item.settings.color_line_2
                assign transform_line_2 = item.settings.transform_line_2
                assign text_position = item.settings.text_position | default: 'bottom'
                assign shopify_attributes = item.shopify_attributes
              endif
            %}
            <article
              class="kopilot-pdp__gallery-cell"
              {{ shopify_attributes }}
            >
              {% if forloop.first and global_has_special_banner %}
                <div class="kopilot-pdp__special-banner">{{ global_special_banner_text }}</div>
              {% endif %}

              {% render 'kopilot-image',
                image: slide_image,
                fallback: gallery_fallbacks[forloop.index0],
                alt: slide_alt,
                width: 800,
                class: 'kopilot-pdp__gallery-image'
              %}
              
              {% if text_line_1 != blank or text_line_2 != blank %}
                <div class="kopilot-pdp__gallery-text-container kopilot-pdp__gallery-text-container--{{ text_position }}">
                  {% if text_line_1 != blank %}
                    <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ color_line_1 }} kopilot-pdp__gallery-text-line--{{ transform_line_1 }}">{{ text_line_1 | newline_to_br }}</p>
                  {% endif %}
                  {% if text_line_2 != blank %}
                    <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ color_line_2 }} kopilot-pdp__gallery-text-line--{{ transform_line_2 }}">{{ text_line_2 | newline_to_br }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>

        <div class="kopilot-pdp__gallery-mobile" data-kopilot-carousel>
          <div class="kopilot-pdp__carousel-viewport">
            <div class="kopilot-pdp__carousel-track" data-kopilot-carousel-track>
              {% for item in gallery_items limit: image_limit %}
                {% liquid
                  if use_product_images
                    assign slide_image = item
                    assign show_special_banner = false
                    assign special_banner_text = ''
                    assign slide_alt = item.alt | default: pdp_product.title
                    assign text_line_1 = ''
                    assign text_line_2 = ''
                    assign text_position = 'bottom'
                    assign shopify_attributes = ''
                  else
                    assign slide_image = item.settings.image
                    assign show_special_banner = item.settings.show_special_banner
                    assign special_banner_text = item.settings.special_banner_text
                    assign slide_alt = item.settings.text_line_1 | default: pdp_product.title
                    assign text_line_1 = item.settings.text_line_1
                    assign color_line_1 = item.settings.color_line_1
                    assign transform_line_1 = item.settings.transform_line_1
                    assign text_line_2 = item.settings.text_line_2
                    assign color_line_2 = item.settings.color_line_2
                    assign transform_line_2 = item.settings.transform_line_2
                    assign text_position = item.settings.text_position | default: 'bottom'
                    assign shopify_attributes = item.shopify_attributes
                  endif
                %}
                <div class="kopilot-pdp__carousel-slide" data-kopilot-slide {{ shopify_attributes }}>
                  {% comment %} Special banner omitted on mobile per user request {% endcomment %}

                  {% render 'kopilot-image',
                    image: slide_image,
                    fallback: gallery_fallbacks[forloop.index0],
                    alt: slide_alt,
                    width: 800,
                    loading: forloop.first,
                    class: 'kopilot-pdp__gallery-image'
                  %}
                  
                  {% if text_line_1 != blank or text_line_2 != blank %}
                    <div class="kopilot-pdp__gallery-text-container kopilot-pdp__gallery-text-container--{{ text_position }}">
                      {% if text_line_1 != blank %}
                        <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ color_line_1 }} kopilot-pdp__gallery-text-line--{{ transform_line_1 }}">{{ text_line_1 | newline_to_br }}</p>
                      {% endif %}
                      {% if text_line_2 != blank %}
                        <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ color_line_2 }} kopilot-pdp__gallery-text-line--{{ transform_line_2 }}">{{ text_line_2 | newline_to_br }}</p>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </div>
          <div class="kopilot-pdp__carousel-dots">
            {% for item in gallery_items limit: image_limit %}
              <button
                type="button"
                class="kopilot-pdp__carousel-dot{% if forloop.first %} is-active{% endif %}"
                data-kopilot-carousel-dot
                data-index="{{ forloop.index0 }}"
                aria-label="Show slide {{ forloop.index }}"
                {% if forloop.first %}aria-current="true"{% endif %}
              ></button>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="kopilot-pdp__description_pdp kopilot-pdp__description_pdp--mobile">
        {% if section.settings.description != blank %}
          {{ section.settings.description }}
        {% elsif pdp_product.description != blank %}
          {{ pdp_product.description | strip_html | truncate: 320 }}
        {% endif %}
      </div>

      <div class="kopilot-pdp__buy">
        <div class="kopilot-pdp__head kopilot-pdp__desktop-head">
          <h1 class="kopilot-pdp__title">
            {% if section.settings.title != blank %}
              {{ section.settings.title }}
            {% else %}
              {{ pdp_product.title }}
            {% endif %}
          </h1>

          {% if section.settings.show_reviews %}
            <div class="kopilot-pdp__reviews-row">
              {% if section.settings.stars_image %}
                {% render 'kopilot-image', image: section.settings.stars_image, alt: 'Star rating', width: 100, class: 'kopilot-pdp__stars-image' %}
              {% else %}
                {% render 'kopilot-review-stars', rating: section.settings.star_rating, size: 'lg', filled_color: '#FF0000' %}
              {% endif %}
              <p class="kopilot-pdp__review-count">{{ section.settings.review_count }} Reviews</p>
            </div>
          {% endif %}
          {% if section.settings.description != blank %}
  <div class="kopilot-pdp__description_pdp">
    {{ section.settings.description }}
  </div>
{% elsif pdp_product.description != blank %}
  <div class="kopilot-pdp__description rte">
    {{ pdp_product.description | strip_html | truncate: 320 }}
  </div>
{% endif %}
        </div>

        <div class="kopilot-pdp__tiers" role="group" aria-label="Choose quantity">
          {% assign tier_index = 0 %}
          {% for variant in pdp_product.variants %}
            {% liquid
              assign is_default_tier = false
              if variant.id == current_variant.id
                assign is_default_tier = true
              endif

              assign badge_val = ''
              if variant.metafields.custom.badge.value != blank
                assign badge_val = variant.metafields.custom.badge.value
              elsif variant.metafields.custom.badge != blank
                assign badge_val = variant.metafields.custom.badge
              endif
              assign badge_downcase = badge_val | downcase | strip

              assign tier_price = variant.price | money
              assign tier_compare_price = variant.compare_at_price | money
              
              assign discount_percent_round = 0
              if variant.compare_at_price > variant.price
                assign diff = variant.compare_at_price | minus: variant.price
                assign discount_percent_round = diff | times: 100.0 | divided_by: variant.compare_at_price | round
              endif

              assign variant_qty = 1
              if variant.metafields.custom.quantity != blank
                assign variant_qty = variant.metafields.custom.quantity
              else
                assign title_downcase = variant.title | downcase
                if title_downcase contains '3'
                  assign variant_qty = 3
                elsif title_downcase contains '2'
                  assign variant_qty = 2
                elsif title_downcase contains '4'
                  assign variant_qty = 4
                elsif title_downcase contains '5'
                  assign variant_qty = 5
                endif
              endif

              assign variant_subtitle = ''
              if variant.metafields.custom.subtitle.value != blank
                assign variant_subtitle = variant.metafields.custom.subtitle.value
              elsif variant.metafields.custom.subtitle != blank
                assign variant_subtitle = variant.metafields.custom.subtitle
              endif

              assign tier_title = variant.title | replace: 'product', 'TAG' | replace: 'Product', 'TAG' | upcase
            %}

            <button
              type="button"
              class="kopilot-pdp__tier{% if is_default_tier %} is-selected{% endif %}"
              data-kopilot-tier
              data-quantity="{{ variant_qty }}"
              data-tier-title="{{ tier_title }}"
              data-variant-id="{{ variant.id }}"
              data-selected="{{ is_default_tier }}"
              aria-pressed="{% if is_default_tier %}true{% else %}false{% endif %}"
            >
              <div class="kopilot-pdp__tier-inner">
                <div class="kopilot-pdp__tier-head">
                  <div class="kopilot-pdp__tier-title-row">
                    <span class="kopilot-pdp__tier-dot" aria-hidden="true"></span>
                    <p class="kopilot-pdp__tier-title-pdp">{{ tier_title }}</p>
                  </div>
                  {% if badge_val != blank and badge_downcase != 'default' %}
                    <span class="kopilot-pdp__tier-badge" style="background-color: #F20008;">{{ badge_val }}</span>
                  {% endif %}
                </div>

                {% if variant_subtitle != blank %}
                  <p class="kopilot-pdp__tier-subtitle-pdp">{{ variant_subtitle }}</p>
                {% endif %}

                <div class="kopilot-pdp__tier-price-row">
                  <p class="kopilot-pdp__tier-price-pdp">{{ tier_price }} USD</p>
                  {% if variant.compare_at_price > variant.price %}
                    <p class="kopilot-pdp__tier-compare-pdp">{{ tier_compare_price }}</p>
                    <span class="kopilot-pdp__tier-save">SAVE {{ discount_percent_round }}%</span>
                  {% endif %}
                </div>
              </div>
            </button>

            {% assign tier_index = tier_index | plus: 1 %}
          {% endfor %}
        </div>

        <div class="kopilot-pdp__included">
          <p class="kopilot-pdp__included-heading">{{ section.settings.included_heading }}</p>
          
          {% capture newline %}
{% endcapture %}
          {% assign tier_index = 0 %}
          {% for variant in pdp_product.variants %}
            {% liquid
              assign is_default_tier = false
              if variant.id == current_variant.id
                assign is_default_tier = true
              endif

              assign raw_items = variant.metafields.custom.included_items
              assign items_array = blank
              if variant.metafields.custom.included_items.value != blank
                assign items_array = variant.metafields.custom.included_items.value
              elsif raw_items != blank
                if raw_items contains newline
                  assign items_array = raw_items | split: newline
                else
                  assign items_array = raw_items | split: ','
                endif
              endif
            %}
            
            {% if items_array != blank %}
              <div
                class="kopilot-pdp__included-pills"
                data-kopilot-included-pills
                data-tier-index="{{ tier_index }}"
                {% unless is_default_tier %}style="display: none;"{% endunless %}
              >
                {% for item in items_array %}
                  {% assign clean_item = item | strip %}
                  {% if clean_item != blank %}
                    <span class="kopilot-pdp__included-pill">{{ clean_item }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            {% else %}
              <div
                class="kopilot-pdp__included-pills"
                data-kopilot-included-pills
                data-tier-index="{{ tier_index }}"
                {% unless is_default_tier %}style="display: none;"{% endunless %}
              >
                {% for g_block in section.blocks %}
                  {% if g_block.type == 'included_item' %}
                    <span class="kopilot-pdp__included-pill" {{ g_block.shopify_attributes }}>{{ g_block.settings.label }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            
            {% assign tier_index = tier_index | plus: 1 %}
          {% endfor %}
        </div>

        <button type="button" class="kopilot-pdp__add" data-kopilot-add>
          <span data-kopilot-add-label>{{ section.settings.button_label | default: 'ADD TO CART - 1 TAG' }}</span>
        </button>

        <div class="kopilot-pdp__delivery">
          <div class="kopilot-pdp__delivery-line">
            <span class="kopilot-pdp__delivery-label">Order by</span>
            <span class="kopilot-pdp__delivery-value" data-kopilot-delivery-order>[time today]</span>
          </div>
          <div class="kopilot-pdp__delivery-line">
            <span class="kopilot-pdp__delivery-label">arrives by</span>
            <span class="kopilot-pdp__delivery-value" data-kopilot-delivery-arrives>[date]</span>
          </div>
        </div>

        {% if section.settings.shipping_heading != blank %}
          <div class="kopilot-pdp__accordion">
            <button
              type="button"
              class="kopilot-pdp__accordion-trigger"
              data-kopilot-accordion-trigger
              aria-expanded="false"
            >
              <span>{{ section.settings.shipping_heading }}</span>
              <span class="kopilot-pdp__accordion-icon" aria-hidden="true"></span>
            </button>
            <div class="kopilot-pdp__accordion-panel rte" data-kopilot-accordion-panel hidden>
              {{ section.settings.shipping_content }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</kopilot-pdp>
{% endif %}

{% schema %}
{
  "name": "Kopilot PDP",
  "tag": "section",
  "class": "kopilot-pdp-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Required on page templates. On product templates, leave empty to use the current product."
    },
    {
      "type": "range",
      "id": "gallery_image_limit",
      "label": "Gallery images limit",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6,
      "info": "Maximum number of gallery images or cards to display."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo ribbon",
      "default": "Special offer. Save up to 20% on multi-packs."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title override",
      "default": "The piece of gear you don't think about until you need it."
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show reviews",
      "default": true
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "image_picker",
      "id": "stars_image",
      "label": "Stars image"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "8"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "included_heading",
      "label": "Included heading",
      "default": "What's included:"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to cart label (tier 1)",
      "default": "ADD TO CART - 1 TAG"
    },
    {
      "type": "text",
      "id": "shipping_heading",
      "label": "Shipping accordion heading",
      "default": "Shipping & Returns"
    },
    {
      "type": "richtext",
      "id": "shipping_content",
      "label": "Shipping accordion content",
      "default": "<p>Free standard shipping on all orders. Returns accepted within 30 days if the product is unused and in original packaging.</p>"
    },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_top_mobile", "label": "Top padding (mobile)", "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Bottom padding (mobile)", "min": 0, "max": 80, "step": 4, "default": 0 }
  ],
  "blocks": [
    {
      "type": "gallery_slide",
      "name": "Gallery slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "checkbox",
          "id": "show_special_banner",
          "label": "Show Top Red Offer Ribbon",
          "default": false
        },
        {
          "type": "textarea",
          "id": "special_banner_text",
          "label": "Offer Ribbon Text",
          "default": "SPECIAL OFFER. SAVE UP TO 20% ON MULTI-PACKS."
        },
        { "type": "header", "content": "Overlay Text Line 1" },
        {
          "type": "textarea",
          "id": "text_line_1",
          "label": "Text Line 1 (Supports line breaks)"
        },
        {
          "type": "select",
          "id": "color_line_1",
          "label": "Color Line 1",
          "options": [
            { "value": "white", "label": "White" },
            { "value": "red", "label": "Red (#F20008)" }
          ],
          "default": "white"
        },
        {
          "type": "select",
          "id": "transform_line_1",
          "label": "Case Style Line 1",
          "options": [
            { "value": "normal", "label": "Normal Case" },
            { "value": "uppercase", "label": "ALL CAPS" }
          ],
          "default": "uppercase"
        },
        { "type": "header", "content": "Overlay Text Line 2" },
        {
          "type": "textarea",
          "id": "text_line_2",
          "label": "Text Line 2 (Supports line breaks)"
        },
        {
          "type": "select",
          "id": "color_line_2",
          "label": "Color Line 2",
          "options": [
            { "value": "white", "label": "White" },
            { "value": "red", "label": "Red (#F20008)" }
          ],
          "default": "red"
        },
        {
          "type": "select",
          "id": "transform_line_2",
          "label": "Case Style Line 2",
          "options": [
            { "value": "normal", "label": "Normal Case" },
            { "value": "uppercase", "label": "ALL CAPS" }
          ],
          "default": "uppercase"
        },
        { "type": "header", "content": "Layout Position" },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text Container Position",
          "options": [
            { "value": "top", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "bottom", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" }
          ],
          "default": "bottom"
        }
      ]
    },
    {
      "type": "tier",
      "name": "Quantity tier",
      "settings": [
        { "type": "range", "id": "quantity", "label": "Cart quantity", "min": 1, "max": 10, "step": 1, "default": 1 },
        { "type": "text", "id": "title", "label": "Title", "default": "1 TAG" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Just for you." },
        { "type": "text", "id": "badge", "label": "Badge (DEFAULT / BEST VALUE)" },
        { "type": "text", "id": "price", "label": "Price display", "default": "$39.99" },
        { "type": "text", "id": "compare_price", "label": "Compare-at price" },
        { "type": "text", "id": "save_label", "label": "Save badge" },
        { "type": "textarea", "id": "included_items", "label": "Included items (comma or line-separated)" }
      ]
    },
    {
      "type": "included_item",
      "name": "Included item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "KOPILOT.ID NFC tag" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot PDP",
      "blocks": [
        { 
          "type": "gallery_slide", 
          "settings": { 
            "show_special_banner": true,
            "special_banner_text": "SPECIAL OFFER. SAVE UP TO 20% ON MULTI-PACKS.",
            "text_line_1": "THE INFORMATION THEY\nNEED AFTER A CRASH.", 
            "color_line_1": "white",
            "text_position": "bottom" 
          } 
        },
        { 
          "type": "gallery_slide", 
          "settings": { 
            "text_line_1": "TRUSTED BY THOUSANDS. USED AT\nEVENTS, RACE SERIES, & GEAR BRANDS.", 
            "color_line_1": "white",
            "text_position": "bottom" 
          } 
        }
      ]
    }
  ]
}
{% endschema %}
