{% style %}
  .kopilot-pdp--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-pdp--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    
    /* Remove slider pagination indicators on mobile layout per image_8259ff.png */
    .kopilot-pdp__carousel-dots {
      display: none !important;
    }

    /* Clean transparent layout structure for mobile gallery wrappers */
    .kopilot-pdp__gallery-mobile {
      background: transparent !important;
      padding: 0 !important;
    }

    /* Standardizes exact layout spacing gap above the banner header */
    .kopilot-pdp__special-banner {
      margin-top: 12px !important;
      position: relative !important;
    }
  }

  /* Description Typography Setup */
  .kopilot-pdp__description_pdp p {
  font-size: 20px !important;
  line-height: 1.30 !important;
  font-family :"Elza" !important;
}
  .kopilot-pdp__description strong, 
  .kopilot-pdp__description b {
    font-weight: 700;
  }

  /* Core Layout Custom Colors */
  .kopilot-pdp__tier-badge {
    background-color: #F20008;
    color: #ffffff;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 11px;
    padding: 6px 12px;
    letter-spacing: 0.05em;
    display: inline-block;
  }

  /* Tier Save Badge Specific Custom Styles */
  .kopilot-pdp__tier-save {
    color: #F20008 !important;
    background-color: #FECECE !important;
  }

  .kopilot-pdp__tier-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 2px solid #141416;
    border-radius: 50%;
    background-color: #ffffff;
    position: relative;
    flex-shrink: 0;
  }

  .kopilot-pdp__tier-dot::before {
    content: '';
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: transparent;
    transition: background-color 0.2s ease;
  }

  .kopilot-pdp__tier.is-selected .kopilot-pdp__tier-dot::before {
    background-color: #141416;
  }

  .kopilot-pdp__tier-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Add to Cart Button Optimization Specs */
  .kopilot-pdp__add {
    background-color: #141416 !important;
    font-size: 20px !important;
    line-height: 25.3px !important;
    font-weight: 600 !important;
  }

  /* Order & Delivery Typography Row Rules */
  .kopilot-pdp__delivery-line {
    font-size: 20px !important;
    line-height: 1.30 !important;
  }
  .kopilot-pdp__delivery-label {
    font-weight: 700 !important;
    color: #141416 !important;
    text-transform: uppercase;
  }
  .kopilot-pdp__delivery-value {
    font-weight: 400 !important;
  }

  /* Included Items Pill UI Optimization */
  .kopilot-pdp__included-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 7.5px !important;
  }
  .kopilot-pdp__included-pill {
    background-color: #EEEEEE !important;
    color: #000000 !important;
    border-radius: 0px !important;
    border: none !important;
    padding: 8.25px 12.75px !important;
    font-size: 16px;
    display: inline-block;
  }

  /* Gallery Overlay Typography Setup */
  .kopilot-pdp__gallery-cell {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }
  
  .kopilot-pdp__gallery-text-container {
    position: absolute;
    left: 0;
    right: 0;
    padding: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    z-index: 2;
    pointer-events: none;
  }
  
  /* Precision positions: top, bottom, top-center, bottom-center */
  .kopilot-pdp__gallery-text-container--top {
    top: 0;
    bottom: auto;
    align-items: flex-start;
    text-align: left;
  }
  .kopilot-pdp__gallery-text-container--bottom {
    bottom: 0;
    top: auto;
    align-items: flex-start;
    text-align: left;
  }
  .kopilot-pdp__gallery-text-container--top-center {
    top: 0;
    bottom: auto;
    align-items: center;
    text-align: center;
  }
  .kopilot-pdp__gallery-text-container--bottom-center {
    bottom: 0;
    top: auto;
    align-items: center;
    text-align: center;
  }

  /* Content Text Engine */
  .kopilot-pdp__gallery-text-line {
    font-family: 'elza', sans-serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.26;
    margin: 0;
  }
  .kopilot-pdp__gallery-text-line--uppercase {
    text-transform: uppercase;
  }
  .kopilot-pdp__gallery-text-line--normal {
    text-transform: none;
  }
  .kopilot-pdp__gallery-text-line--white {
    color: #ffffff;
  }
  .kopilot-pdp__gallery-text-line--red {
    color: #F20008;
  }

  /* Special Top Ribbon Offer */
  .kopilot-pdp__special-banner {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: #F20008;
    color: #ffffff;
    font-family: 'elza', sans-serif;
    font-size: 12.78px;
    font-weight: 500;
    line-height: 1.30;
    text-transform: uppercase;
    text-align: center;
    padding: 6.39px 10px;
    letter-spacing: 0.05em;
    z-index: 3;
  }
  
  /* Text container offsets if top red banner ribbon is enabled */
  .kopilot-pdp__special-banner + .kopilot-pdp__gallery-text-container--top,
  .kopilot-pdp__special-banner + .kopilot-pdp__gallery-text-container--top-center {
    padding-top: 45px;
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-pdp.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kopilot-pdp.js' | asset_url }}" defer></script>

{% liquid
  if section.settings.product != blank
    assign pdp_product = section.settings.product
  elsif product != blank
    assign pdp_product = product
  endif

  if pdp_product != blank
    assign current_variant = pdp_product.selected_or_first_available_variant
  endif

  assign gallery_fallbacks = 'kopilot-pdp-gallery-1.jpg,kopilot-pdp-gallery-2.jpg,kopilot-pdp-gallery-3.jpg,kopilot-pdp-gallery-4.jpg,kopilot-pdp-gallery-5.jpg,kopilot-pdp-gallery-6.jpg' | split: ','
%}

{% if pdp_product == blank %}
  <div class="kopilot-section kopilot-pdp kopilot-pdp--{{ section.id }}">
    <p class="kopilot-pdp__missing-product">Select a product in the Kopilot PDP section settings.</p>
  </div>
{% else %}
<kopilot-pdp
  class="kopilot-section kopilot-pdp kopilot-pdp--{{ section.id }} color-{{ section.settings.color_scheme }}"
  data-product-id="{{ pdp_product.id }}"
  data-variant-id="{{ current_variant.id }}"
>
  <div class="kopilot-pdp__inner">
    <div class="kopilot-pdp__mobile-head">
      <h1 class="kopilot-pdp__title">
        {% if section.settings.title != blank %}
          {{ section.settings.title }}
        {% else %}
          {{ pdp_product.title }}
        {% endif %}
      </h1>
      {% if section.settings.show_reviews %}
        <div class="kopilot-pdp__reviews-row">
          {% render 'kopilot-review-stars', rating: section.settings.star_rating, size: 'lg', filled_color: '#FF0000' %}
          <p class="kopilot-pdp__review-count">{{ section.settings.review_count }} Reviews</p>
        </div>
      {% endif %}
    </div>

    <div class="kopilot-pdp__layout">
      <div class="kopilot-pdp__gallery">
        <div class="kopilot-pdp__gallery-grid">
          {% for block in section.blocks %}
            {% if block.type == 'gallery_slide' %}
              <article
                class="kopilot-pdp__gallery-cell"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.show_special_banner %}
                  <div class="kopilot-pdp__special-banner">{{ block.settings.special_banner_text }}</div>
                {% endif %}

                {% render 'kopilot-image',
                  image: block.settings.image,
                  fallback: gallery_fallbacks[forloop.index0],
                  alt: block.settings.text_line_1,
                  width: 800,
                  class: 'kopilot-pdp__gallery-image'
                %}
                
                {% if block.settings.text_line_1 != blank or block.settings.text_line_2 != blank %}
                  <div class="kopilot-pdp__gallery-text-container kopilot-pdp__gallery-text-container--{{ block.settings.text_position | default: 'bottom' }}">
                    {% if block.settings.text_line_1 != blank %}
                      <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ block.settings.color_line_1 }} kopilot-pdp__gallery-text-line--{{ block.settings.transform_line_1 }}">{{ block.settings.text_line_1 | newline_to_br }}</p>
                    {% endif %}
                    {% if block.settings.text_line_2 != blank %}
                      <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ block.settings.color_line_2 }} kopilot-pdp__gallery-text-line--{{ block.settings.transform_line_2 }}">{{ block.settings.text_line_2 | newline_to_br }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              </article>
            {% endif %}
          {% endfor %}
        </div>

        <div class="kopilot-pdp__gallery-mobile" data-kopilot-carousel>
          <div class="kopilot-pdp__carousel-viewport">
            <div class="kopilot-pdp__carousel-track" data-kopilot-carousel-track>
              {% for block in section.blocks %}
                {% if block.type == 'gallery_slide' %}
                  <div class="kopilot-pdp__carousel-slide" data-kopilot-slide {{ block.shopify_attributes }}>
                    {% if block.settings.show_special_banner %}
                      <div class="kopilot-pdp__special-banner">{{ block.settings.special_banner_text }}</div>
                    {% endif %}

                    {% render 'kopilot-image',
                      image: block.settings.image,
                      fallback: gallery_fallbacks[forloop.index0],
                      alt: block.settings.text_line_1,
                      width: 800,
                      loading: forloop.first
                    %}
                    
                    {% if block.settings.text_line_1 != blank or block.settings.text_line_2 != blank %}
                      <div class="kopilot-pdp__gallery-text-container kopilot-pdp__gallery-text-container--{{ block.settings.text_position | default: 'bottom' }}">
                        {% if block.settings.text_line_1 != blank %}
                          <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ block.settings.color_line_1 }} kopilot-pdp__gallery-text-line--{{ block.settings.transform_line_1 }}">{{ block.settings.text_line_1 | newline_to_br }}</p>
                        {% endif %}
                        {% if block.settings.text_line_2 != blank %}
                          <p class="kopilot-pdp__gallery-text-line kopilot-pdp__gallery-text-line--{{ block.settings.color_line_2 }} kopilot-pdp__gallery-text-line--{{ block.settings.transform_line_2 }}">{{ block.settings.text_line_2 | newline_to_br }}</p>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          <div class="kopilot-pdp__carousel-dots">
            {% assign slide_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'gallery_slide' %}
                <button
                  type="button"
                  class="kopilot-pdp__carousel-dot{% if slide_index == 0 %} is-active{% endif %}"
                  data-kopilot-carousel-dot
                  data-index="{{ slide_index }}"
                  aria-label="Show slide {{ slide_index | plus: 1 }}"
                  {% if slide_index == 0 %}aria-current="true"{% endif %}
                ></button>
                {% assign slide_index = slide_index | plus: 1 %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="kopilot-pdp__buy">
        <div class="kopilot-pdp__head kopilot-pdp__desktop-head">
          <h1 class="kopilot-pdp__title">
            {% if section.settings.title != blank %}
              {{ section.settings.title }}
            {% else %}
              {{ pdp_product.title }}
            {% endif %}
          </h1>

          {% if section.settings.show_reviews %}
            <div class="kopilot-pdp__reviews-row">
              {% render 'kopilot-review-stars', rating: section.settings.star_rating, size: 'lg', filled_color: '#FF0000' %}
              <p class="kopilot-pdp__review-count">{{ section.settings.review_count }} Reviews</p>
            </div>
          {% endif %}
          {% if section.settings.description != blank %}
  <div class="kopilot-pdp__description_pdp">
    {{ section.settings.description }}
  </div>
{% elsif pdp_product.description != blank %}
  <div class="kopilot-pdp__description rte">
    {{ pdp_product.description | strip_html | truncate: 320 }}
  </div>
{% endif %}
        </div>

        <div class="kopilot-pdp__tiers" role="group" aria-label="Choose quantity">
          {% assign tier_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'tier' %}
              {% liquid
                assign tier_qty = block.settings.quantity | default: 1
                assign is_default_tier = false
                if block.settings.badge != blank
                  assign badge_downcase = block.settings.badge | downcase | strip
                  if badge_downcase == 'default'
                    assign is_default_tier = true
                  endif
                elsif tier_index == 0
                  assign is_default_tier = true
                endif

                assign tier_price = block.settings.price
                if tier_price == blank and current_variant.price
                  assign unit_cents = current_variant.price
                  assign tier_price_cents = unit_cents | times: tier_qty
                  assign tier_price = tier_price_cents | money
                endif

                assign tier_variant_id = pdp_product.variants[tier_index].id | default: current_variant.id
              %}

              <button
                type="button"
                class="kopilot-pdp__tier{% if is_default_tier %} is-selected{% endif %}"
                data-kopilot-tier
                data-quantity="{{ tier_qty }}"
                data-variant-id="{{ tier_variant_id }}"
                data-selected="{{ is_default_tier }}"
                aria-pressed="{% if is_default_tier %}true{% else %}false{% endif %}"
                {{ block.shopify_attributes }}
              >
                <div class="kopilot-pdp__tier-inner">
                  <div class="kopilot-pdp__tier-head">
                    <div class="kopilot-pdp__tier-title-row">
                      <span class="kopilot-pdp__tier-dot" aria-hidden="true"></span>
                      <p class="kopilot-pdp__tier-title">{{ block.settings.title }}</p>
                    </div>
                    {% if block.settings.badge != blank and badge_downcase != 'default' %}
                      <span class="kopilot-pdp__tier-badge" style="background-color: #F20008;">{{ block.settings.badge }}</span>
                    {% endif %}
                  </div>

                  {% if block.settings.subtitle != blank %}
                    <p class="kopilot-pdp__tier-subtitle">{{ block.settings.subtitle }}</p>
                  {% endif %}

                  <div class="kopilot-pdp__tier-price-row">
                    <p class="kopilot-pdp__tier-price">{{ tier_price }} USD</p>
                    {% if block.settings.compare_price != blank %}
                      <p class="kopilot-pdp__tier-compare">{{ block.settings.compare_price }}</p>
                    {% endif %}
                    {% if block.settings.save_label != blank %}
                      <span class="kopilot-pdp__tier-save">{{ block.settings.save_label }}</span>
                    {% endif %}
                  </div>
                </div>
              </button>

              {% assign tier_index = tier_index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>

        <div class="kopilot-pdp__included">
          <p class="kopilot-pdp__included-heading">{{ section.settings.included_heading }}</p>
          
          {% capture newline %}
{% endcapture %}
          {% assign tier_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'tier' %}
              {% liquid
                assign is_default_tier = false
                if block.settings.badge != blank
                  assign badge_downcase = block.settings.badge | downcase | strip
                  if badge_downcase == 'default'
                    assign is_default_tier = true
                  endif
                elsif tier_index == 0
                  assign is_default_tier = true
                endif

                assign raw_items = block.settings.included_items
                if raw_items contains newline
                  assign items_array = raw_items | split: newline
                else
                  assign items_array = raw_items | split: ','
                endif
              %}
              
              {% if raw_items != blank %}
                <div
                  class="kopilot-pdp__included-pills"
                  data-kopilot-included-pills
                  data-tier-index="{{ tier_index }}"
                  {% unless is_default_tier %}style="display: none;"{% endunless %}
                >
                  {% for item in items_array %}
                    {% assign clean_item = item | strip %}
                    {% if clean_item != blank %}
                      <span class="kopilot-pdp__included-pill">{{ clean_item }}</span>
                    {% endif %}
                  {% endfor %}
                </div>
              {% else %}
                <div
                  class="kopilot-pdp__included-pills"
                  data-kopilot-included-pills
                  data-tier-index="{{ tier_index }}"
                  {% unless is_default_tier %}style="display: none;"{% endunless %}
                >
                  {% for g_block in section.blocks %}
                    {% if g_block.type == 'included_item' %}
                      <span class="kopilot-pdp__included-pill" {{ g_block.shopify_attributes }}>{{ g_block.settings.label }}</span>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
              
              {% assign tier_index = tier_index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>

        <button type="button" class="kopilot-pdp__add" data-kopilot-add>
          <span data-kopilot-add-label>{{ section.settings.button_label | default: 'ADD TO CART - 1 TAG' }}</span>
        </button>

        <div class="kopilot-pdp__delivery">
          <div class="kopilot-pdp__delivery-line">
            <span class="kopilot-pdp__delivery-label">Order by</span>
            <span class="kopilot-pdp__delivery-value" data-kopilot-delivery-order>[time today]</span>
          </div>
          <div class="kopilot-pdp__delivery-line">
            <span class="kopilot-pdp__delivery-label">arrives by</span>
            <span class="kopilot-pdp__delivery-value" data-kopilot-delivery-arrives>[date]</span>
          </div>
        </div>

        {% if section.settings.shipping_heading != blank %}
          <div class="kopilot-pdp__accordion">
            <button
              type="button"
              class="kopilot-pdp__accordion-trigger"
              data-kopilot-accordion-trigger
              aria-expanded="false"
            >
              <span>{{ section.settings.shipping_heading }}</span>
              <span class="kopilot-pdp__accordion-icon" aria-hidden="true"></span>
            </button>
            <div class="kopilot-pdp__accordion-panel rte" data-kopilot-accordion-panel hidden>
              {{ section.settings.shipping_content }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</kopilot-pdp>
{% endif %}

{% schema %}
{
  "name": "Kopilot PDP",
  "tag": "section",
  "class": "kopilot-pdp-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Required on page templates. On product templates, leave empty to use the current product."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo ribbon",
      "default": "Special offer. Save up to 20% on multi-packs."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title override",
      "default": "The piece of gear you don't think about until you need it."
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show reviews",
      "default": true
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "8"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "included_heading",
      "label": "Included heading",
      "default": "What's included:"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to cart label (tier 1)",
      "default": "ADD TO CART - 1 TAG"
    },
    {
      "type": "text",
      "id": "shipping_heading",
      "label": "Shipping accordion heading",
      "default": "Shipping & Returns"
    },
    {
      "type": "richtext",
      "id": "shipping_content",
      "label": "Shipping accordion content",
      "default": "<p>Free standard shipping on all orders. Returns accepted within 30 days if the product is unused and in original packaging.</p>"
    },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_top_mobile", "label": "Top padding (mobile)", "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Bottom padding (mobile)", "min": 0, "max": 80, "step": 4, "default": 0 }
  ],
  "blocks": [
    {
      "type": "gallery_slide",
      "name": "Gallery slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "checkbox",
          "id": "show_special_banner",
          "label": "Show Top Red Offer Ribbon",
          "default": false
        },
        {
          "type": "textarea",
          "id": "special_banner_text",
          "label": "Offer Ribbon Text",
          "default": "SPECIAL OFFER. SAVE UP TO 20% ON MULTI-PACKS."
        },
        { "type": "header", "content": "Overlay Text Line 1" },
        {
          "type": "textarea",
          "id": "text_line_1",
          "label": "Text Line 1 (Supports line breaks)"
        },
        {
          "type": "select",
          "id": "color_line_1",
          "label": "Color Line 1",
          "options": [
            { "value": "white", "label": "White" },
            { "value": "red", "label": "Red (#F20008)" }
          ],
          "default": "white"
        },
        {
          "type": "select",
          "id": "transform_line_1",
          "label": "Case Style Line 1",
          "options": [
            { "value": "normal", "label": "Normal Case" },
            { "value": "uppercase", "label": "ALL CAPS" }
          ],
          "default": "uppercase"
        },
        { "type": "header", "content": "Overlay Text Line 2" },
        {
          "type": "textarea",
          "id": "text_line_2",
          "label": "Text Line 2 (Supports line breaks)"
        },
        {
          "type": "select",
          "id": "color_line_2",
          "label": "Color Line 2",
          "options": [
            { "value": "white", "label": "White" },
            { "value": "red", "label": "Red (#F20008)" }
          ],
          "default": "red"
        },
        {
          "type": "select",
          "id": "transform_line_2",
          "label": "Case Style Line 2",
          "options": [
