{% style %}
  .kopilot-reviews--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 989px) {
    .kopilot-reviews--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-reviews.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-reviews kopilot-reviews--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-reviews__header">
    {% if section.settings.heading != blank %}
      <h2 class="kopilot-reviews__heading kopilot-heading">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  <div class="kopilot-reviews__summary">
    <div class="kopilot-reviews__rating-block">
      <div class="kopilot-reviews__rating-score kopilot-body">
        <span class="kopilot-reviews__stars" aria-hidden="true">★★★★★</span>
        <span>{{ section.settings.average_rating }} out of 5</span>
      </div>
      <p class="kopilot-reviews__based-on kopilot-body">Based on {{ section.settings.total_reviews }} reviews</p>
    </div>

    <div class="kopilot-reviews__distribution">
      {% for i in (1..5) reversed %}
        {% assign star_key = 'star_' | append: i | append: '_count' %}
        {% assign count = section.settings[star_key] | default: 0 %}
        {% assign percent = 0 %}
        {% if section.settings.total_reviews > 0 %}
          {% assign percent = count | times: 100 | divided_by: section.settings.total_reviews %}
        {% endif %}
        <div class="kopilot-reviews__dist-row">
          <span class="kopilot-reviews__dist-stars" aria-hidden="true">
            {% for s in (1..5) %}{% if s <= i %}★{% else %}☆{% endif %}{% endfor %}
          </span>
          <div class="kopilot-reviews__dist-bar">
            <div class="kopilot-reviews__dist-fill" style="width: {{ percent }}%;"></div>
          </div>
          <span class="kopilot-reviews__dist-count kopilot-body">{{ count }}</span>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.write_review_url != blank %}
      <a href="{{ section.settings.write_review_url }}" class="kopilot-reviews__write-btn kopilot-body" target="_blank" rel="noopener">
        Write a review
      </a>
    {% endif %}
  </div>

  <div class="kopilot-reviews__list">
    {% for block in section.blocks %}
      <article class="kopilot-reviews__item" {{ block.shopify_attributes }}>
        <div class="kopilot-reviews__item-header">
          <span class="kopilot-reviews__item-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% assign rating = block.settings.rating | default: 5 %}
            {% for s in (1..5) %}{% if s <= rating %}★{% else %}☆{% endif %}{% endfor %}
          </span>
          {% if block.settings.date != blank %}
            <time class="kopilot-reviews__item-date kopilot-body">{{ block.settings.date }}</time>
          {% endif %}
        </div>
        <div class="kopilot-reviews__item-author">
          {% if block.settings.author != blank %}
            <p class="kopilot-reviews__item-name kopilot-body">{{ block.settings.author }}</p>
          {% endif %}
          {% if block.settings.verified %}
            <span class="kopilot-reviews__verified kopilot-body">Verified</span>
          {% endif %}
        </div>
        {% if block.settings.text != blank %}
          <p class="kopilot-reviews__item-body kopilot-body">{{ block.settings.text }}</p>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Reviews",
  "tag": "section",
  "class": "kopilot-reviews-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "average_rating",
      "label": "Average rating",
      "default": "5.00"
    },
    {
      "type": "number",
      "id": "total_reviews",
      "label": "Total reviews",
      "default": 8
    },
    {
      "type": "number",
      "id": "star_5_count",
      "label": "5 star count",
      "default": 8
    },
    {
      "type": "number",
      "id": "star_4_count",
      "label": "4 star count",
      "default": 0
    },
    {
      "type": "number",
      "id": "star_3_count",
      "label": "3 star count",
      "default": 0
    },
    {
      "type": "number",
      "id": "star_2_count",
      "label": "2 star count",
      "default": 0
    },
    {
      "type": "number",
      "id": "star_1_count",
      "label": "1 star count",
      "default": 0
    },
    {
      "type": "url",
      "id": "write_review_url",
      "label": "Write a review URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "author", "label": "Author name" },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true },
        { "type": "text", "id": "date", "label": "Date" },
        { "type": "textarea", "id": "text", "label": "Review text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author": "Don M",
            "date": "04/16/2026",
            "text": "Easy to set up and mount on my helmet",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "author": "Richard",
            "date": "03/24/2026",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
