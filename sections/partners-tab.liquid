<section class="kopilot-partnership">
  <div class="partnership-container">
    <h2 class="section-heading">What a KOPILOT.ID partnership delivers.</h2>
    
    <div class="content-wrapper">
      <!-- Left Column: Image -->
      <div class="left-col" id="image-viewer">
        {% for block in section.blocks %}
          <div class="feature-image-wrapper {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}">
          </div>
        {% endfor %}
      </div>

      <!-- Right Column: Interactive Cards -->
      <div class="right-col">
        {% for block in section.blocks %}
          <div class="feature-card {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
    
    <div class="mobile-pagination">
      <button class="nav-btn prev-btn" aria-label="Previous">&lt;</button>
      <button class="nav-btn next-btn" aria-label="Next">&gt;</button>
    </div>
  </div>
</section>

<style>
  /* --- Section Container --- */
  .kopilot-partnership {
    background-color: #F1F1F1;
    padding: 80px 0;
  }

  .partnership-container {
    max-width: 1148px;
    margin: 0 auto;
    padding: 0 166px;
  }

  /* --- Desktop Layout: Equal Height Logic --- */
  .content-wrapper {
    display: grid;
    grid-template-columns: 632px 485px;
    gap: 31px;
    align-items: stretch; /* Forces equal height */
  }

  /* Left Column fills container height */
  .left-col {
    position: relative;
    width: 100%;
  }

  .feature-image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: none;
  }

  .feature-image-wrapper.active {
    display: block;
  }

  .feature-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  /* Right Column */
  .right-col {
    display: flex;
    flex-direction: column;
    justify-content: space-between; /* Ensures cards fill vertical space */
    gap: 21px;
  }

  .feature-card {
    padding: 35px 40px;
    cursor: pointer;
    transition: background 0.3s ease;
    flex: 1; /* Equalize card heights */
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* --- Mobile Responsive --- */
  @media (max-width: 767px) {
    .content-wrapper {
      display: flex;
      flex-direction: column;
    }
    
    .left-col {
      position: relative;
      height: 214px; /* Fixed height for mobile image */
    }
    
    .feature-image-wrapper {
      position: relative;
    }
    
    .feature-card {
      display: none;
    }
    
    .feature-card.active {
      display: flex;
    }
  }
</style>

 <script>
  const cards = document.querySelectorAll('.feature-card');
  const images = document.querySelectorAll('.feature-image-wrapper');
  let currentIndex = 0;

  function updateView(index) {
    cards.forEach((c, i) => {
      c.classList.toggle('active', i === index);
      images[i].classList.toggle('active', i === index);
    });
    currentIndex = index;
  }

  cards.forEach(card => {
    card.addEventListener('click', () => updateView(parseInt(card.dataset.index)));
  });

  document.querySelector('.prev-btn')?.addEventListener('click', () => {
    updateView(currentIndex === 0 ? cards.length - 1 : currentIndex - 1);
  });

  document.querySelector('.next-btn')?.addEventListener('click', () => {
    updateView(currentIndex === cards.length - 1 ? 0 : currentIndex + 1);
  });
</script>