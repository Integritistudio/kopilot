{% comment %}
  KOPILOT.ID Partnership Section
  - Responsive: 360px to 1440px
  - Desktop: 2-column with equal height synchronization
  - Mobile: Stacked with arrow-based pagination
{% endcomment %}

<section class="kopilot-partnership">
  <div class="partnership-container">
    <h2 class="section-heading">What a KOPILOT.ID partnership delivers.</h2>
    
    <div class="content-wrapper">
      <div class="left-col" id="image-viewer">
        {% for block in section.blocks %}
          <div class="feature-image-wrapper {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}">
          </div>
        {% endfor %}
      </div>

      <div class="right-col">
        {% for block in section.blocks %}
          <div class="feature-card {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
    
    <div class="mobile-pagination">
      <button class="nav-btn prev-btn" aria-label="Previous">&lt;</button>
      <button class="nav-btn next-btn" aria-label="Next">&gt;</button>
    </div>
  </div>
</section>

<style>
  /* --- Section Defaults --- */
  .kopilot-partnership {
    background-color: #F1F1F1;
    padding: 80px 0;
  }

  .partnership-container {
    max-width: 1148px;
    margin: 0 auto;
    padding: 0 166px;
  }

  .section-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 60px;
    line-height: 106%;
    letter-spacing: -1px;
    margin-bottom: 60px;
    color: #000;
  }

  /* --- Desktop Equal Height Grid --- */
  .content-wrapper {
    display: grid;
    grid-template-columns: 632px 1fr;
    gap: 31px;
    align-items: stretch;
  }

  .left-col {
    position: relative;
    width: 100%;
  }

  .feature-image-wrapper {
    display: none;
    height: 100%;
  }

  .feature-image-wrapper.active {
    display: block;
  }

  .feature-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  .right-col {
    display: flex;
    flex-direction: column;
    gap: 21px;
  }

  .feature-card {
    padding: 35px 40px;
    cursor: pointer;
    transition: background 0.3s ease;
    flex: 1;
    background: #fff;
  }

  .feature-card.active {
    background: #D6D6D6;
  }

  .feature-card h3 {
    font-family: 'Elza', sans-serif;
    font-weight: 500;
    font-size: 20px;
    margin-bottom: 11px;
  }

  .feature-card p {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 20px;
    line-height: 120%;
  }

  /* --- Responsive Styles --- */
  @media (max-width: 1024px) {
    .partnership-container { padding: 0 40px; }
    .content-wrapper { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 767px) {
    .partnership-container { padding: 50px 20px; }
    .section-heading { font-size: 30px; text-align: center; margin-bottom: 30px; }
    .content-wrapper { display: flex; flex-direction: column; gap: 30px; }
    
    .left-col { height: 214px; }
    .feature-image-wrapper img { width: 326px; height: 214px; margin: 0 auto; display: block; }
    
    .right-col { width: 100%; gap: 0; }
    .feature-card { display: none; padding: 35px 20px; }
    .feature-card.active { display: block; }
    .feature-card h3 { font-size: 15px; }
    
    .mobile-pagination { display: flex; justify-content: center; gap: 10.57px; margin-top: 20px; }
    .nav-btn { width: 44px; height: 44px; background: #fff; border: 1px solid #ccc; cursor: pointer; }
  }
</style>

<script>
  (function() {
    const cards = document.querySelectorAll('.feature-card');
    const images = document.querySelectorAll('.feature-image-wrapper');
    let currentIndex = 0;

    function updateView(index) {
      cards.forEach((c, i) => {
        c.classList.toggle('active', i === index);
        images[i].classList.toggle('active', i === index);
      });
      currentIndex = index;
    }

    cards.forEach(card => {
      card.addEventListener('click', () => updateView(parseInt(card.dataset.index)));
    });

    document.querySelector('.prev-btn')?.addEventListener('click', () => {
      updateView(currentIndex === 0 ? cards.length - 1 : currentIndex - 1);
    });

    document.querySelector('.next-btn')?.addEventListener('click', () => {
      updateView(currentIndex === cards.length - 1 ? 0 : currentIndex + 1);
    });
  })();
</script>

{% schema %}
{
  "name": "Partnership Section",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Heading" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "Partnership Section" }]
}
{% endschema %}