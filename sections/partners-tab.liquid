{%- style -%}

  /* ============================================================
     PARTNERSHIP SHOWCASE — pixel-perfect at 1440px & 360px
  ============================================================ */

  @font-face { font-family: 'Elza'; font-weight: 300; font-style: normal; }
  @font-face { font-family: 'Elza'; font-weight: 500; font-style: normal; }

  /* ── SECTION WRAPPER ─────────────────────────────────────────
     1440px: padding 80px top/bottom · 166px left/right
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} {
    width: 100%;
    padding: 80px 166px;
    background-color: {{ section.settings.bg_color }};
    box-sizing: border-box;
  }

  /* ── DESKTOP LAYOUT WRAPPER ──────────────────────────────────
     Horizontal flex: left (flex:1) | 60px gap | right (485px)
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} .ps-wrapper {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 60px;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── LEFT COLUMN ─────────────────────────────────────────────
     Hug: fills remaining space after right col + gap
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} .ps-left {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Heading: Elza Light 300 · 60px · 106% lh · -1px tracking */
  .ps-{{ section.id }} .ps-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 60px;
    line-height: 106%;
    letter-spacing: -1px;
    color: #000000;
    margin: 0 0 31px 0;
    padding: 0;
  }

  /* ── IMAGE CROSSFADE FRAME ───────────────────────────────────
     Fills left column width; stretches to match right col height
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} .ps-img-frame {
    width: 100%;
    flex: 1 1 auto;
    position: relative;
    overflow: hidden;
    background-color: #D6D6D6;
    min-height: 396px;
  }

  .ps-{{ section.id }} .ps-img-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }

  .ps-{{ section.id }} .ps-img-frame img.ps-img-active {
    opacity: 1;
  }

  /* ── RIGHT COLUMN — CARDS STACK ─────────────────────────────
     Fixed 485px · Vertical flow · 21px gap between cards
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} .ps-cards {
    width: 485px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 21px;
    box-sizing: border-box;
  }

  /* ── INFO CARD ───────────────────────────────────────────────
     Figma spec:
       width 485 · min-height 177
       padding: 35px 40px
       internal gap: 11px
       background: #D6D6D6 (same rest & hover — only image changes)

     INACTIVE (default): text at 35% opacity  ← faded look
     ACTIVE (.ps-card-active): text at 100%   ← full read
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} .ps-card {
    width: 485px;
    min-height: 177px;
    padding: 35px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 11px;
    background: #D6D6D6;
    box-sizing: border-box;
    cursor: pointer;
    /* no background change — image on left swaps instead */
  }

  /* Inactive text: dimmed to ~35% */
  .ps-{{ section.id }} .ps-card .ps-card-title,
  .ps-{{ section.id }} .ps-card .ps-card-body {
    transition: opacity 0.3s ease, color 0.3s ease;
    opacity: 0.35;
  }

  /* Active card: full-opacity text */
  .ps-{{ section.id }} .ps-card.ps-card-active .ps-card-title,
  .ps-{{ section.id }} .ps-card.ps-card-active .ps-card-body {
    opacity: 1;
  }

  /* Card title: Elza Medium 500 · 20px · 120% lh · 0 tracking */
  .ps-{{ section.id }} .ps-card-title {
    font-family: 'Elza', sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 120%;
    letter-spacing: 0;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  /* Card body: Elza Light 300 · 20px · 120% lh · 0 tracking */
  .ps-{{ section.id }} .ps-card-body {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 20px;
    line-height: 120%;
    letter-spacing: 0;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  /* ── DESKTOP DOT PAGINATION ──────────────────────────────────
     Row of dots below the right cards column.
     Figma: 13.07 × 13.07px ellipses · inactive #A5A5A5 · active #000
  ──────────────────────────────────────────────────────────── */
  .ps-{{ section.id }} .ps-dots {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    margin-top: 20px;
    /* Align dots under the right cards column:
       left offset = flex:1 left col + 60px gap
       We achieve this by making the dots row sit inside a wrapper
       that mirrors the two-column layout */
  }

  /* Dot wrapper mirrors the desktop two-column layout so dots
     align directly under the 485px cards column               */
  .ps-{{ section.id }} .ps-dots-row {
    display: flex;
    flex-direction: row;
    width: 100%;
    box-sizing: border-box;
  }

  /* Spacer on the left — same flex:1 as the image column */
  .ps-{{ section.id }} .ps-dots-spacer {
    flex: 1 1 0;
    min-width: 0;
  }

  /* Gap between spacer and dots — same 60px as main wrapper */
  .ps-{{ section.id }} .ps-dots-gap {
    width: 60px;
    flex-shrink: 0;
  }

  /* The dots container itself — same 485px as cards column */
  .ps-{{ section.id }} .ps-dots {
    width: 485px;
    flex-shrink: 0;
  }

  /* Individual dot */
  .ps-{{ section.id }} .ps-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: #A5A5A5;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s ease;
    flex-shrink: 0;
  }

  .ps-{{ section.id }} .ps-dot.ps-dot-active {
    background: #000000;
  }

  /* ── TABLET (768–1199px) ─────────────────────────────────── */
  @media screen and (min-width: 768px) and (max-width: 1199px) {
    .ps-{{ section.id }} { padding: 60px 40px; }
    .ps-{{ section.id }} .ps-wrapper { gap: 31px; }
    .ps-{{ section.id }} .ps-heading { font-size: 44px; }
    .ps-{{ section.id }} .ps-img-frame { min-height: 300px; }
    .ps-{{ section.id }} .ps-cards { width: 340px; }
    .ps-{{ section.id }} .ps-card { width: 340px; min-height: auto; padding: 28px; }
    .ps-{{ section.id }} .ps-card-title,
    .ps-{{ section.id }} .ps-card-body { font-size: 17px; }
    /* Tablet: adjust dots-gap to match wrapper gap */
    .ps-{{ section.id }} .ps-dots-gap { width: 31px; }
    .ps-{{ section.id }} .ps-dots { width: 340px; }
  }

  /* ── MOBILE (≤ 767px) — 360px target ────────────────────────

     Layout: SLIDER / CAROUSEL
       [  Heading centered                ]
       [  Card: image / text on #D6D6D6   ]
       [  ←─────────────── →  nav pill    ]

     Desktop columns & stacked cards are HIDDEN on mobile.
     The slider is shown instead.
  ──────────────────────────────────────────────────────────── */
  @media screen and (max-width: 767px) {

    /* Hide the desktop 2-column wrapper */
    .ps-{{ section.id }} .ps-wrapper { display: none; }

    /* Section: 19px side padding → 322px content at 360px viewport */
    .ps-{{ section.id }} {
      padding: 40px 19px 50px;
    }

    /* ── Mobile slider root ── */
    .ps-{{ section.id }} .ps-mobile {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }

    /* Heading: centered, Elza Light 300, 32px */
    .ps-{{ section.id }} .ps-mobile-heading {
      font-family: 'Elza', sans-serif;
      font-weight: 300;
      font-size: 32px;
      line-height: 106%;
      letter-spacing: -0.5px;
      color: #000000;
      text-align: center;
      margin: 0 0 24px;
      padding: 0;
      width: 100%;
      box-sizing: border-box;
    }

    /* ── CARD CONTAINER ─────────────────────────────────────────
       Single block that wraps image + text, contained within
       the 19px section padding → no extra margins needed here.
    ──────────────────────────────────────────────────────────── */

    /* Image area — 100% of the padded container width */
    .ps-{{ section.id }} .ps-mobile-img {
      width: 100%;
      height: 280px;
      position: relative;
      overflow: hidden;
      background: #D6D6D6;
    }

    .ps-{{ section.id }} .ps-mobile-img img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
    }

    .ps-{{ section.id }} .ps-mobile-img img.ps-img-active {
      opacity: 1;
    }

    /* Text content — same #D6D6D6 as the card background,
       sits directly below the image as a continuous block     */
    .ps-{{ section.id }} .ps-mobile-content {
      width: 100%;
      padding: 24px 20px 28px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: 11px;
      background: #D6D6D6;         /* ← matches card bg */
      min-height: 110px;
    }

    .ps-{{ section.id }} .ps-mobile-title {
      font-family: 'Elza', sans-serif;
      font-weight: 500;
      font-size: 20px;
      line-height: 120%;
      letter-spacing: 0;
      color: #000000;
      margin: 0;
    }

    .ps-{{ section.id }} .ps-mobile-body {
      font-family: 'Elza', sans-serif;
      font-weight: 300;
      font-size: 18px;
      line-height: 120%;
      letter-spacing: 0;
      color: #000000;
      margin: 0;
    }

    /* ── NAV ARROWS — bordered pill box ─────────────────────── */
    .ps-{{ section.id }} .ps-mobile-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      margin-top: 28px;
      border: 1px solid #000000;
      width: auto;
      padding: 0;
    }

    .ps-{{ section.id }} .ps-nav-btn {
      width: 56px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      color: #000000;
      -webkit-tap-highlight-color: transparent;
    }

    /* Custom icon image inside nav button */
    .ps-{{ section.id }} .ps-nav-btn img.ps-nav-icon {
      width: 20px;
      height: 20px;
      object-fit: contain;
      display: block;
      pointer-events: none;
    }

    /* Fallback SVG (shown when no image uploaded) */
    .ps-{{ section.id }} .ps-nav-btn svg.ps-nav-svg {
      width: 20px;
      height: 20px;
    }

    /* Hide dots row on mobile */
    .ps-{{ section.id }} .ps-dots-row { display: none; }

    /* Divider line between the two arrow buttons */
    .ps-{{ section.id }} .ps-nav-divider {
      width: 1px;
      height: 24px;
      background: #000000;
      flex-shrink: 0;
    }

    .ps-{{ section.id }} .ps-nav-btn svg {
      width: 20px;
      height: 20px;
    }

    .ps-{{ section.id }} .ps-nav-btn:disabled {
      opacity: 0.25;
      cursor: default;
    }
  }

  /* Hide mobile slider on desktop */
  @media screen and (min-width: 768px) {
    .ps-{{ section.id }} .ps-mobile { display: none; }
  }

  /* Hide dot row on mobile (mobile uses the nav pill) */
  @media screen and (max-width: 767px) {
    .ps-{{ section.id }} .ps-dots-row { display: none; }
  }

{%- endstyle -%}


{%- comment -%} Collect info_card blocks into accessible data {%- endcomment -%}

<div class="ps-{{ section.id }}">

  <!-- ══ DESKTOP: 2-column layout ══════════════════════════════ -->
  <div class="ps-wrapper">

    <!-- Left: heading + crossfade image frame -->
    <div class="ps-left">
      {%- if section.settings.heading != blank -%}
        <h2 class="ps-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="ps-img-frame" id="ps-frame-{{ section.id }}">
        {%- assign img_idx = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'info_card' -%}
            {%- if block.settings.card_image != blank -%}
              <img
                src="{{ block.settings.card_image | image_url: width: 900 }}"
                alt="{{ block.settings.card_image.alt | default: block.settings.card_title | escape }}"
                loading="lazy"
                class="{% if img_idx == 0 %}ps-img-active{% endif %}"
                data-ps-img="{{ img_idx }}"
              >
            {%- endif -%}
            {%- assign img_idx = img_idx | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Right: stacked info cards -->
    <div class="ps-cards" id="ps-cards-{{ section.id }}">
      {%- assign card_idx = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'info_card' -%}
          <div
            class="ps-card {% if card_idx == 0 %}ps-card-active{% endif %}"
            data-ps-card="{{ card_idx }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.card_title != blank -%}
              <p class="ps-card-title">{{ block.settings.card_title | escape }}</p>
            {%- endif -%}
            {%- if block.settings.card_body != blank -%}
              <p class="ps-card-body">{{ block.settings.card_body }}</p>
            {%- endif -%}
          </div>
          {%- assign card_idx = card_idx | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div><!-- /ps-wrapper -->

  <!-- ══ DESKTOP DOT PAGINATION ════════════════════════════════ -->
  <div class="ps-dots-row">
    <div class="ps-dots-spacer"></div>
    <div class="ps-dots-gap"></div>
    <div class="ps-dots" id="ps-dots-{{ section.id }}">
      {%- assign dot_idx = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'info_card' -%}
          <button
            class="ps-dot {% if dot_idx == 0 %}ps-dot-active{% endif %}"
            data-ps-dot="{{ dot_idx }}"
            aria-label="Go to slide {{ dot_idx | plus: 1 }}"
          ></button>
          {%- assign dot_idx = dot_idx | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- ══ MOBILE: full-screen slider carousel ════════════════════ -->
  <div class="ps-mobile" id="ps-mobile-{{ section.id }}">

    {%- if section.settings.heading != blank -%}
      <h2 class="ps-mobile-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <!-- Crossfade image -->
    <div class="ps-mobile-img" id="ps-mobile-img-{{ section.id }}">
      {%- assign img_idx = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'info_card' and block.settings.card_image != blank -%}
          <img
            src="{{ block.settings.card_image | image_url: width: 800 }}"
            alt="{{ block.settings.card_image.alt | default: block.settings.card_title | escape }}"
            loading="lazy"
            class="{% if img_idx == 0 %}ps-img-active{% endif %}"
            data-ps-mob-img="{{ img_idx }}"
          >
          {%- assign img_idx = img_idx | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Text content for active slide -->
    <div class="ps-mobile-content" id="ps-mobile-content-{{ section.id }}">
      <p class="ps-mobile-title" id="ps-mob-title-{{ section.id }}"></p>
      <p class="ps-mobile-body"  id="ps-mob-body-{{ section.id }}"></p>
    </div>

    <!-- Prev / Next arrows -->
    <div class="ps-mobile-nav">
      <button class="ps-nav-btn" id="ps-prev-{{ section.id }}" aria-label="Previous" disabled>
        {%- if section.settings.prev_icon != blank -%}
          <img
            class="ps-nav-icon"
            src="{{ section.settings.prev_icon | image_url: width: 60 }}"
            alt="Previous"
          >
        {%- else -%}
          <svg class="ps-nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        {%- endif -%}
      </button>
      <span class="ps-nav-divider" aria-hidden="true"></span>
      <button class="ps-nav-btn" id="ps-next-{{ section.id }}" aria-label="Next">
        {%- if section.settings.next_icon != blank -%}
          <img
            class="ps-nav-icon"
            src="{{ section.settings.next_icon | image_url: width: 60 }}"
            alt="Next"
          >
        {%- else -%}
          <svg class="ps-nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 6 15 12 9 18"/>
          </svg>
        {%- endif -%}
      </button>
    </div>

  </div><!-- /ps-mobile -->

</div><!-- /section -->


<script>
(function () {
  'use strict';

  /* ─── Card data from Liquid ─────────────────────────────── */
  var CARDS = [
    {%- assign first = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'info_card' -%}
        {%- unless first -%},{%- endunless -%}
        {
          "title": {{ block.settings.card_title | json }},
          "body":  {{ block.settings.card_body  | json }},
          "hasImg": {%- if block.settings.card_image != blank -%}true{%- else -%}false{%- endif -%}
        }
        {%- assign first = false -%}
      {%- endif -%}
    {%- endfor -%}
  ];

  var TOTAL = CARDS.length;
  var current = 0;

  /* ─── Element refs ──────────────────────────────────────── */
  var root       = document.querySelector('.ps-{{ section.id }}');
  if (!root) return;

  /* Desktop */
  var deskCards  = root.querySelectorAll('.ps-card');
  var deskImages = root.querySelectorAll('.ps-img-frame img');
  var deskDots   = root.querySelectorAll('.ps-dot');

  /* Mobile */
  var mobImages  = root.querySelectorAll('.ps-mobile-img img');
  var mobTitle   = root.querySelector('#ps-mob-title-{{ section.id }}');
  var mobBody    = root.querySelector('#ps-mob-body-{{ section.id }}');
  var prevBtn    = root.querySelector('#ps-prev-{{ section.id }}');
  var nextBtn    = root.querySelector('#ps-next-{{ section.id }}');

  /* ─── Activate by index ─────────────────────────────────── */
  function activate(idx) {
    current = idx;

    /* Desktop: toggle active class on cards */
    deskCards.forEach(function (c) { c.classList.remove('ps-card-active'); });
    if (deskCards[idx]) deskCards[idx].classList.add('ps-card-active');

    /* Desktop: crossfade images */
    deskImages.forEach(function (img) { img.classList.remove('ps-img-active'); });
    if (deskImages[idx]) deskImages[idx].classList.add('ps-img-active');

    /* Desktop: update dots */
    deskDots.forEach(function (d) { d.classList.remove('ps-dot-active'); });
    if (deskDots[idx]) deskDots[idx].classList.add('ps-dot-active');

    /* Mobile: crossfade images */
    mobImages.forEach(function (img) { img.classList.remove('ps-img-active'); });
    if (mobImages[idx]) mobImages[idx].classList.add('ps-img-active');

    /* Mobile: update text */
    if (mobTitle && CARDS[idx]) mobTitle.textContent = CARDS[idx].title;
    if (mobBody  && CARDS[idx]) mobBody.textContent  = CARDS[idx].body;

    /* Mobile: button states */
    if (prevBtn) prevBtn.disabled = (idx === 0);
    if (nextBtn) nextBtn.disabled = (idx === TOTAL - 1);
  }

  /* ─── Initial state ─────────────────────────────────────── */
  activate(0);

  /* ─── Desktop: hover + click on cards ──────────────────── */
  deskCards.forEach(function (card) {
    card.addEventListener('mouseenter', function () {
      activate(parseInt(card.dataset.psCard, 10));
    });
    card.addEventListener('click', function () {
      activate(parseInt(card.dataset.psCard, 10));
    });
  });

  /* Restore first card when mouse leaves the cards column */
  var col = root.querySelector('.ps-cards');
  if (col) {
    col.addEventListener('mouseleave', function () {
      activate(0);
    });
  }

  /* ─── Desktop: dot clicks ───────────────────────────────── */
  deskDots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      activate(parseInt(dot.dataset.psDot, 10));
    });
  });

  /* ─── Mobile: arrow navigation ──────────────────────────── */
  if (prevBtn) {
    prevBtn.addEventListener('click', function () {
      if (current > 0) activate(current - 1);
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      if (current < TOTAL - 1) activate(current + 1);
    });
  }

  /* ─── Mobile: swipe support ─────────────────────────────── */
  var mobImgFrame = root.querySelector('.ps-mobile-img');
  if (mobImgFrame) {
    var touchStartX = 0;
    mobImgFrame.addEventListener('touchstart', function (e) {
      touchStartX = e.changedTouches[0].clientX;
    }, { passive: true });
    mobImgFrame.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) < 40) return;           /* ignore micro-swipes */
      if (dx < 0 && current < TOTAL - 1) activate(current + 1);
      if (dx > 0 && current > 0)         activate(current - 1);
    }, { passive: true });
  }

}());
</script>


{% schema %}
{
  "name": "Partnership Showcase",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#F1F1F1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What a KOPILOT.ID partnership delivers."
    },
    {
      "type": "header",
      "content": "Mobile Nav Arrow Icons"
    },
    {
      "type": "paragraph",
      "content": "Upload custom arrow images. If left empty, default SVG chevrons are used."
    },
    {
      "type": "image_picker",
      "id": "prev_icon",
      "label": "Previous Arrow Icon"
    },
    {
      "type": "image_picker",
      "id": "next_icon",
      "label": "Next Arrow Icon"
    }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image (shown on left on desktop / full-width on mobile)"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title (Elza Medium 500)",
          "default": "Support your community."
        },
        {
          "type": "textarea",
          "id": "card_body",
          "label": "Card Body Text (Elza Light 300)",
          "default": "Give participants and customers a practical safety tool they can carry every day, showing their wellbeing matters to your organization."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partnership Showcase",
      "blocks": [
        {
