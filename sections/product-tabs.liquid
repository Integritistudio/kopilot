{% style %}
  .product_tabs_wrapper--{{ section.id }} {
    padding-top: {{ section.settings.top_spacing }}px;
    padding-bottom: {{ section.settings.bottom_spacing }}px;
    background: transparent;
  }

  @media screen and (max-width: 640px) {
    .product_tabs_wrapper--{{ section.id }} {
      padding-top: {{ section.settings.top_spacing | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.bottom_spacing | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{{ 'product-tabs.css' | asset_url | stylesheet_tag }}

<div class="product_tabs_wrapper--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="container">
    <product-tabs>
      <div class="product_tabs_inner" style="--max-width: {{ section.settings.max_width }}px;">
        <div class="product_tabs_container">
          <!-- Headings on the left -->
          <div class="product_tabs_headings">
            {% for block in section.blocks %}
              <button
                class="product_tabs_heading {% if forloop.first %}is_active{% endif %}"
                data-tab-id="{{ block.id }}"
                data-block-index="{{ forloop.index0 }}"
                aria-label="{{ block.settings.heading }}"
              >
                {{ block.settings.heading }}
                <span class="icon_wrapper">{{ 'icon-chevron-up.svg' | inline_asset_content }}</span>
              </button>
            {% endfor %}

            {% if section.settings.show_payment_icons %}
              <div class="product_tabs_payment_icons__wrapper" style="--payment-bg: {{ section.settings.payment_bg }}; --payment-head: {{ section.settings.payment_head }};">
                {% if section.settings.payment_icons_heading != blank %}
                  <h4 class="small-text">{{ section.settings.payment_icons_heading }}</h4>
                {% endif %}

                <div class="product_tabs_payment_icons">
                  <ul class="product_tabs_payment_icons_ul" role="list">
                    {%- for type in shop.enabled_payment_types -%}
                      <li class="product_tabs_payment_icon_item">
                        {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            {% endif %}
          </div>

          <!-- Content on the right -->
          <div class="product_tabs_content_wrapper">
            {% for block in section.blocks %}
              <div
                class="product_tabs_content {% if forloop.first %}is_active{% endif %}"
                data-tab-id="{{ block.id }}"
                data-block-index="{{ forloop.index0 }}"
              >
                {% if block.settings.heading != blank %}
                  <h3 class="content_head">{{ block.settings.heading }}</h3>
                {% endif %}

                <div class="product_tabs_content_inner rte">
                  {% if block.settings.show_description %}
                    {% if product.description != blank %}
                      {{ product.description }}
                    {% else %}
                      <p>No description available for this product.</p>
                    {% endif %}
                  {% else %}
                    {{ block.settings.content }}
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </product-tabs>
  </div>
</div>

{% schema %}
{
  "name": "Product tabs",
  "enabled_on": {
    "templates": ["product"]
  },
  "max_blocks": 5,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_icons_heading",
      "label": "Payment icons heading",
      "default": "Payment & Security",
      "info": "Displayed above the payment icons",
      "visible_if": "{{ section.settings.show_payment_icons }}"
    },
    {
        "type": "color",
        "id": "payment_bg",
        "label": "Payment icons background",
        "default": "#DEEFDD",
        "visible_if": "{{ section.settings.show_payment_icons }}"
    },
    {
        "type": "color",
        "id": "payment_head",
        "label": "Payment icons heading color",
        "default": "#180D05",
        "visible_if": "{{ section.settings.show_payment_icons }}"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "name": "Tab",
      "type": "tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Tab heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Display product description, features, and details here.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show product description",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "heading": "Specifications",
            "content": "<p>Add product specifications here.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "heading": "Materials & Care",
            "content": "<p>Add materials and care instructions here.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "heading": "Shipping & Returns",
            "content": "<p>Add shipping and returns information here.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
