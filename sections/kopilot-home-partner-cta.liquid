{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-home-partner-cta.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kopilot-home-partner-cta.js' | asset_url }}" defer></script>

<style>
  /* 1. Remove grey background from the media area behind PNG logos */
  .kopilot-home-partner-cta--{{ section.id }} .kopilot-home-partner-cta__card-media,
  .kopilot-home-partner-cta--{{ section.id }} .kopilot-home-partner-cta__card-media-bg {
    background-color: transparent !important;
  }

  /* 2. Force equal heights on Swiper slides and Grid items */
  .kopilot-home-partner-cta--{{ section.id }} .swiper-slide {
    height: auto !important; /* Crucial for Swiper to match the tallest slide */
    display: flex;
  }
  .kopilot-home-partner-cta--{{ section.id }} .kopilot-home-partner-cta__grid {
    align-items: stretch;
  }

  /* 3. Card layout: Stretch to full height of parent */
  .kopilot-home-partner-cta--{{ section.id }} .kopilot-home-partner-cta__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }

  /* 4. Body layout: Fill remaining space */
  .kopilot-home-partner-cta--{{ section.id }} .kopilot-home-partner-cta__card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  /* 5. Align stat line boxes to the bottom */
  .kopilot-home-partner-cta--{{ section.id }} .kopilot-home-partner-cta__card-stat {
    margin-top: auto !important; /* Pushes the stat block to the very bottom */
  }
</style>

<section class="kopilot-section kopilot-home-partner-cta kopilot-home-partner-cta--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-home-partner-cta__inner">
    <div class="kopilot-home-partner-cta__layout">
      <div class="kopilot-home-partner-cta__intro">
        <div class="kopilot-home-partner-cta__copy">
          {% if section.settings.heading != blank %}
            <div class="kopilot-home-partner-cta__heading rte">
              {{ section.settings.heading }}
            </div>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="kopilot-home-partner-cta__text rte">
              {{ section.settings.text }}
            </div>
          {% endif %}
        </div>

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="kopilot-home-partner-cta__btn"
          >
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="kopilot-home-partner-cta__cards">
          <div class="kopilot-home-partner-cta__grid">
            {% for block in section.blocks %}
              <article class="kopilot-home-partner-cta__card" {{ block.shopify_attributes }}>
                <div class="kopilot-home-partner-cta__card-media">
                  <div
                    class="kopilot-home-partner-cta__card-media-bg"
                    {% if block.settings.image != blank %}
                      style="background-image: url('{{ block.settings.image | image_url: width: 800 }}');"
                    {% endif %}
                  >
                    {% if block.settings.image != blank %}
                      <img
                        class="kopilot-home-partner-cta__card-media-img"
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        alt="{{ block.settings.image_alt | escape }}"
                        width="800"
                        height="400"
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                </div>

                <div class="kopilot-home-partner-cta__card-body">
                  <div class="kopilot-home-partner-cta__card-copy">
                    {% if block.settings.name != blank or block.settings.role != blank %}
                      <div class="kopilot-home-partner-cta__card-meta">
                        {% if block.settings.name != blank %}
                          <span class="kopilot-home-partner-cta__card-name">{{ block.settings.name }}</span>
                        {% endif %}
                        {% if block.settings.role != blank %}
                          <span class="kopilot-home-partner-cta__card-role">{{ block.settings.role }}</span>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if block.settings.quote != blank %}
                      <p class="kopilot-home-partner-cta__card-quote">{{ block.settings.quote }}</p>
                    {% endif %}
                  </div>

                  {% if block.settings.stat != blank %}
                    <p class="kopilot-home-partner-cta__card-stat">{{ block.settings.stat }}</p>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>

          <div class="kopilot-home-partner-cta__slider-wrap" data-kopilot-home-partner-cta>
            <div class="kopilot-home-partner-cta__slider">
              <div class="swiper kopilot-home-partner-cta__swiper">
                <div class="swiper-wrapper">
                  {% for block in section.blocks %}
                    <div class="swiper-slide">
                      <article class="kopilot-home-partner-cta__card" {{ block.shopify_attributes }}>
                        <div class="kopilot-home-partner-cta__card-media">
                          <div
                            class="kopilot-home-partner-cta__card-media-bg"
                            {% if block.settings.image != blank %}
                              style="background-image: url('{{ block.settings.image | image_url: width: 800 }}');"
                            {% endif %}
                          >
                            {% if block.settings.image != blank %}
                              <img
                                class="kopilot-home-partner-cta__card-media-img"
                                src="{{ block.settings.image | image_url: width: 800 }}"
                                alt="{{ block.settings.image_alt | escape }}"
                                width="800"
                                height="400"
                                loading="lazy"
                              >
                            {% endif %}
                          </div>
                        </div>

                        <div class="kopilot-home-partner-cta__card-body">
                          <div class="kopilot-home-partner-cta__card-copy">
                            {% if block.settings.name != blank or block.settings.role != blank %}
                              <div class="kopilot-home-partner-cta__card-meta">
                                {% if block.settings.name != blank %}
                                  <span class="kopilot-home-partner-cta__card-name">{{ block.settings.name }}</span>
                                {% endif %}
                                {% if block.settings.role != blank %}
                                  <span class="kopilot-home-partner-cta__card-role">{{ block.settings.role }}</span>
                                {% endif %}
                              </div>
                            {% endif %}

                            {% if block.settings.quote != blank %}
                              <p class="kopilot-home-partner-cta__card-quote">{{ block.settings.quote }}</p>
                            {% endif %}
                          </div>

                          {% if block.settings.stat != blank %}
                            <p class="kopilot-home-partner-cta__card-stat">{{ block.settings.stat }}</p>
                          {% endif %}
                        </div>
                      </article>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>

            <div class="kopilot-home-partner-cta__nav" aria-label="Partner cards slider navigation">
              <button type="button" class="kopilot-home-partner-cta__nav-btn kopilot-home-partner-cta__nav-btn--prev" aria-label="Previous partner">
                <img src="{{ 'vl.svg' | asset_url }}" alt="" width="11" height="17" loading="lazy">
              </button>
              <button type="button" class="kopilot-home-partner-cta__nav-btn kopilot-home-partner-cta__nav-btn--next" aria-label="Next partner">
                <img src="{{ 'vr.svg' | asset_url }}" alt="" width="11" height="17" loading="lazy">
              </button>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Home Partner CTA",
  "tag": "section",
  "class": "kopilot-home-partner-cta-section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Partner with KOPILOT.ID.</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Integrate custom digital emergency ID's with your event, brand, or organization.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Become a partner"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "Partner card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Fills the media area. No logo overlay."
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Role at partner organization"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "One-line testimonial from the partner (quote about what KOPILOT.ID does for their event or gear)"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Stat line",
          "default": "Embedded into 5,000 race bibs across the 2025 series"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Home Partner CTA",
      "settings": {
        "heading": "<p>Partner with KOPILOT.ID.</p>",
        "text": "<p>Integrate custom digital emergency ID's with your event, brand, or organization.</p>",
        "button_label": "Become a partner"
      },
      "blocks": [
        {
          "type": "partner",
          "settings": {
            "name": "Name",
            "role": "Role at partner organization",
            "quote": "One-line testimonial from the partner (quote about what KOPILOT.ID does for their event or gear)",
            "stat": "Embedded into 5,000 race bibs across the 2025 series"
          }
        },
        {
          "type": "partner",
          "settings": {
            "name": "Name",
            "role": "Role at partner organization",
            "quote": "One-line testimonial from the partner (quote about what KOPILOT.ID does for their event or gear)",
            "stat": "Embedded into 5,000 race bibs across the 2025 series"
          }
        }
      ]
    }
  ]
}
{% endschema %}