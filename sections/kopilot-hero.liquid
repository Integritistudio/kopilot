{% style %}
  .kopilot-hero--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

@media screen and (max-width: 1024px) {
  .kopilot-hero--{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .kopilot-hero--{{ section.id }} .kopilot-hero__title-group .left1-text {
    text-align: left;
  }
}

/* Fix text wrapping and layout breaking on viewport widths from 425px up to 767px */
@media screen and (min-width: 425px) and (max-width: 767px) {
  .kopilot-hero--{{ section.id }} {
    min-height: auto;
    --kopilot-hero-content-w: min(40rem, calc(100vw - (var(--kopilot-hero-pad-x) * 2)));
    --kopilot-hero-btn-w: min(28rem, var(--kopilot-hero-content-w));
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__inner {
    min-height: auto;
    padding-top: 4rem;
    padding-bottom: 4rem;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 5.4rem;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__content {
    width: 100%;
    max-width: none;
    gap: 1.6rem;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__copy {
    gap: 1.6rem;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__title-group {
    max-width: none;
    gap: 1.2rem;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__title.kopilot-heading--medium {
    max-width: none;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__title--light {
    max-width: none;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__description,
  .kopilot-hero--{{ section.id }} .kopilot-hero__description.kopilot-body {
    max-width: none;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__cta {
    align-self: flex-start;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__product-mobile {
    align-self: center;
  }
  .kopilot-hero--{{ section.id }} .kopilot-hero__logos--mobile {
    align-self: center;
    justify-content: center;
  }
}
/* --- YouTube Background Iframe Fix --- */
.kopilot-hero--{{ section.id }} .kopilot-hero__bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none !important;
}

.kopilot-hero--{{ section.id }} .kopilot-hero__yt-wrap {
  position: absolute;
  inset: 0;
  overflow: hidden;
  /* Allow the shield above the iframe to catch hover (re-enabled on child) */
  pointer-events: auto;
}

.kopilot-hero--{{ section.id }} .kopilot-hero__yt-wrap iframe,
.kopilot-hero--{{ section.id }} #KopilotHeroYt-{{ section.id }} {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100vw;
  height: 56.25vw; /* 16:9 */
  min-height: 100%;
  min-width: 177.77vh;
  border: none;
  pointer-events: none !important;
  /* Crop top title / bottom branding YouTube still draws at the edges */
  transform: translate(-50%, -50%) scale(1.5);
}

/* Blocks hover so YouTube never paints the center pause button */
.kopilot-hero--{{ section.id }} .kopilot-hero__yt-shield {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: auto;
  background: transparent;
}
{% endstyle %}

{%- liquid
  assign has_uploaded_video = false
  if section.settings.background_video != blank
    assign has_uploaded_video = true
  endif

  assign has_video_url = false
  if section.settings.video_url != blank
    assign has_video_url = true
  endif

  assign has_video = false
  if has_uploaded_video or has_video_url
    assign has_video = true
  endif

  assign hero_video_poster = section.settings.background_image
  if hero_video_poster == blank
    assign hero_video_poster = section.settings.background_image_mobile
  endif
-%}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kopilot-hero.js' | asset_url }}" defer></script>

<section class="kopilot-section kopilot-hero kopilot-hero--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-hero__bg">
    {% if has_uploaded_video %}
      {% capture kopilot_hero_video_class %}kopilot-hero__bg-video{% endcapture %}
      {{
        section.settings.background_video
        | video_tag:
          class: kopilot_hero_video_class,
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          image_size: '1920x',
          preload: 'metadata'
      }}
   {% elsif has_video_url %}
      {% if section.settings.video_url.type == 'youtube' %}
        {%- comment -%}
          Do NOT use playlist= for looping — that is what shows the center prev/pause/next controls.
          Loop is handled by the YouTube IFrame API on ENDED below.
        {%- endcomment -%}
        <div class="kopilot-hero__yt-wrap">
          <div
            id="KopilotHeroYt-{{ section.id }}"
            data-youtube-id="{{ section.settings.video_url.id }}"
          ></div>
          <div class="kopilot-hero__yt-shield" aria-hidden="true"></div>
        </div>
        <script>
          (function () {
            var sectionId = {{ section.id | json }};
            var videoId = {{ section.settings.video_url.id | json }};
            var playerId = 'KopilotHeroYt-' + sectionId;

            function createPlayer() {
              if (!window.YT || !window.YT.Player) return;
              var mount = document.getElementById(playerId);
              if (!mount || mount.dataset.ytReady === '1') return;
              mount.dataset.ytReady = '1';

              var player = new YT.Player(playerId, {
                videoId: videoId,
                playerVars: {
                  autoplay: 1,
                  mute: 1,
                  controls: 1,
                  disablekb: 1,
                  fs: 0,
                  iv_load_policy: 3,
                  modestbranding: 1,
                  playsinline: 1,
                  rel: 0,
                  cc_load_policy: 0,
                  showinfo: 0
                },
                events: {
                  onReady: function (event) {
                    event.target.mute();
                    event.target.playVideo();
                    var iframe = event.target.getIframe && event.target.getIframe();
                    if (iframe) {
                      iframe.setAttribute('tabindex', '-1');
                      iframe.style.pointerEvents = 'none';
                    }
                  },
                  onStateChange: function (event) {
                    /* Keep playing — pause state shows the big center button */
                    if (event.data === YT.PlayerState.PAUSED) {
                      event.target.playVideo();
                    }
                    if (event.data === YT.PlayerState.ENDED) {
                      event.target.seekTo(0);
                      event.target.playVideo();
                    }
                  }
                }
              });

              /* Safety: if YouTube pauses itself, resume */
              /* Safety & Seamless Loop: resume on pause, and seek before ENDED state */
setInterval(function () {
  try {
    if (player && typeof player.getPlayerState === 'function') {
      // 1. Force play if paused
      if (player.getPlayerState() === YT.PlayerState.PAUSED) {
        player.playVideo();
      }
      
      // 2. Seamless manual looping
      var duration = player.getDuration();
      var currentTime = player.getCurrentTime();
      // If within 0.3 seconds of the end, restart to avoid the "Ended" pause state
      if (duration > 0 && currentTime >= (duration - 0.3)) {
        player.seekTo(0);
        player.playVideo();
      }
    }
  } catch (e) {}
}, 250); /* Sped up interval for accurate time checking */
            }

            if (window.YT && window.YT.Player) {
              createPlayer();
            } else {
              var previous = window.onYouTubeIframeAPIReady;
              window.onYouTubeIframeAPIReady = function () {
                if (typeof previous === 'function') previous();
                createPlayer();
              };
              if (!document.getElementById('youtube-iframe-api')) {
                var tag = document.createElement('script');
                tag.id = 'youtube-iframe-api';
                tag.src = 'https://www.youtube.com/iframe_api';
                document.head.appendChild(tag);
              }
            }
          })();
        </script>
      {% endif %}
    {% else %}
      <div class="kopilot-hero__bg-image kopilot-hero__bg-image--desktop">
        {% render 'kopilot-image',
          image: section.settings.background_image,
          fallback: 'kopilot-hero-bg.jpg',
          alt: section.settings.heading_line_1,
          width: 2400,
          loading: 'eager',
          widths: '750,1100,1500,2000,2400',
          sizes: '100vw'
        %}
      </div>
      <div class="kopilot-hero__bg-image kopilot-hero__bg-image--mobile">
        {% render 'kopilot-image',
          image: section.settings.background_image_mobile,
          fallback: '534e09e74dba5f2840077260761a394727c97e76.png',
          alt: section.settings.heading_line_1,
          width: 800,
          loading: 'eager',
          widths: '360,540,750',
          sizes: '100vw'
        %}
      </div>
    {% endif %}
    {% if section.settings.show_overlay %}
      <div class="kopilot-hero__overlay"></div>
    {% endif %}
  </div>

  <div class="kopilot-hero__inner">
    <div class="kopilot-hero__product-mobile" aria-hidden="true">
      {% render 'kopilot-image',
        image: section.settings.product_image,
        fallback: 'Mask group.png',
        alt: '',
        width: 500,
        loading: 'eager'
      %}
    </div>

    <div class="kopilot-hero__content-column">
      <div class="kopilot-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="kopilot-hero__eyebrow kopilot-body">{{ section.settings.eyebrow }}</p>
        {% endif %}

        <div class="kopilot-hero__copy">
          <div class="kopilot-hero__title-group">
            {% if section.settings.heading_line_1 != blank %}
              <h1 class="kopilot-hero__title kopilot-heading kopilot-heading--medium left1-text ">
                {{ section.settings.heading_line_1 }}
              </h1>
            {% endif %}
            {% if section.settings.heading_line_2 != blank %}
              <p class="kopilot-hero__title kopilot-hero__title--light kopilot-heading left1-text">
                {{ section.settings.heading_line_2 }}
              </p>
            {% endif %}
          </div>

          {% if section.settings.description != blank %}
            <p class="kopilot-hero__description kopilot-body">{{ section.settings.description }}</p>
          {% endif %}
        </div>
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="kopilot-btn kopilot-hero__cta">
          {{ section.settings.button_label }}
        </a>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="kopilot-hero__logos kopilot-hero__logos--mobile">
          {% assign hero_logo_fallbacks = 'kopilot-hero-logo-1.png,kopilot-hero-logo-2.png' | split: ',' %}
          {% for block in section.blocks %}
            <div class="kopilot-hero__logo" {{ block.shopify_attributes }}>
              {% render 'kopilot-image',
                image: block.settings.logo,
                fallback: hero_logo_fallbacks[forloop.index0],
                alt: block.settings.logo_alt,
                width: 200
              %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="kopilot-hero__product">
      <div class="kopilot-hero__product-img">
        {% render 'kopilot-image',
          image: section.settings.product_image,
          fallback: 'Mask group.png',
          alt: 'KOPILOT.ID product',
          width: 500,
          loading: 'eager'
        %}
      </div>
      {% if section.blocks.size > 0 %}
        <div class="kopilot-hero__logos kopilot-hero__logos--desktop">
          {% assign hero_logo_fallbacks = 'kopilot-hero-logo-1.png,kopilot-hero-logo-2.png' | split: ',' %}
          {% for block in section.blocks %}
            <div class="kopilot-hero__logo" {{ block.shopify_attributes }}>
              {% render 'kopilot-image',
                image: block.settings.logo,
                fallback: hero_logo_fallbacks[forloop.index0],
                alt: block.settings.logo_alt,
                width: 200
              %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Hero",
  "tag": "section",
  "class": "kopilot-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background video"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background video (upload)"
    },
{
      "type": "video_url",
      "id": "video_url",
      "label": "YouTube Background Video",
      "accept": ["youtube"],
      "info": "Upload Yt Video Link Here"
    },
    {
      "type": "header",
      "content": "Background images (fallback)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)",
      "info": "Used when no video is set. Also used as video poster while loading."
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Used when no video is set. Leave blank to use desktop image on mobile."
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show gradient overlay",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Off-Road Motorcycle Riders"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Accidents happen fast."
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2",
      "default": "Be prepared with KOPILOT.ID."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Stay prepared with our durable, waterproof NFC tag that makes your medical details instantly accessible, even in remote terrain—no signal or battery needed."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get KOPILOT.ID"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Partner logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Logo alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Hero",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
