{% style %}
  .kopilot-partners--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-partners--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-partners.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-partners kopilot-partners--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-partners__inner">
    <div class="kopilot-partners__logos">
      {% assign partner_fallbacks = 'kopilot-partner-1.png,kopilot-partner-2.png,kopilot-partner-3.png,kopilot-partner-4.png,kopilot-partner-5.png,kopilot-partner-6.png' | split: ',' %}
      {% for block in section.blocks %}
        {% assign row_index = forloop.index0 | divided_by: 3 %}
        {% assign col_index = forloop.index0 | modulo: 3 %}
        {% if col_index == 0 %}
          <div class="kopilot-partners__logos-row kopilot-partners__logos-row--{{ row_index | plus: 1 }}">
        {% endif %}
        <div
          class="kopilot-partners__logo{% if block.settings.logo_width > 0 %} kopilot-partners__logo--custom-desktop{% endif %}{% if block.settings.logo_width_mobile > 0 %} kopilot-partners__logo--custom-mobile{% endif %}"
          {% if block.settings.logo_width > 0 or block.settings.logo_width_mobile > 0 %}
            style="{% if block.settings.logo_width > 0 %}--kopilot-partner-logo-width-desktop: {{ block.settings.logo_width }}px;{% endif %}{% if block.settings.logo_width_mobile > 0 %}--kopilot-partner-logo-width-mobile: {{ block.settings.logo_width_mobile }}px;{% endif %}"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          {% render 'kopilot-image',
            image: block.settings.logo,
            fallback: partner_fallbacks[forloop.index0],
            alt: block.settings.logo_alt,
            width: 300
          %}
        </div>
        {% if col_index == 2 or forloop.last %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.text != blank %}
      <p class="kopilot-partners__text">{{ section.settings.text }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Partners",
  "tag": "section",
  "class": "kopilot-partners-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Trusted by the biggest names in off-road racing. An official safety partner for riders and race series nationwide."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "text", "id": "logo_alt", "label": "Alt text" },
        {
          "type": "range",
          "id": "logo_width",
          "label": "Logo width (desktop)",
          "info": "Set to 0 to use the default size.",
          "min": 0,
          "max": 300,
          "step": 5,
          "default": 0,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "logo_width_mobile",
          "label": "Logo width (mobile)",
          "info": "Set to 0 to use the default size.",
          "min": 0,
          "max": 200,
          "step": 4,
          "default": 0,
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Partners",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
