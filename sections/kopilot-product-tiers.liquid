{% style %}
  .kopilot-product-tiers--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-product-tiers--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  {% for block in section.blocks %}
    {% if block.settings.list_icon_mobile != blank %}
      .kopilot-product-tiers--{{ section.id }} .kopilot-product-tiers__card[data-block-id="{{ block.id }}"] .kopilot-product-tiers__features.rte li::before {
        content: '';
        width: clamp(0.9rem, 2.8vw, 1rem);
        height: clamp(0.9rem, 2.8vw, 1rem);
        flex-shrink: 0;
        margin-top: 0.2rem;
        border: none;
        transform: none;
        background: url('{{ block.settings.list_icon_mobile | image_url: width: 40 }}') no-repeat center / contain;
      }
    {% endif %}
  {% endfor %}
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-product-tiers.css' | asset_url | stylesheet_tag }}

{% liquid
  assign default_images = 'Screenshot 2026-04-21 at 17.17.14 5.png|Group 2106667226.png|Group 2106667227.png' | split: '|'
  assign hover_images = 'Group 2106667225.png|ccde2c0b8a273159116b272ed4a979affb3da026.jpg|ccde2c0b8a273159116b272ed4a979affb3da026.jpg' | split: '|'
%}

<section id="kopilot-product-tiers" class="kopilot-section kopilot-product-tiers kopilot-product-tiers--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-product-tiers__inner">
    {% if section.settings.heading != blank %}
      <div class="kopilot-product-tiers__header">
        <div class="kopilot-product-tiers__heading rte">{{ section.settings.heading }}</div>
      </div>
    {% endif %}

    <div class="kopilot-product-tiers__grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% assign card_index = forloop.index0 %}
        {% assign is_best_value = false %}
        {% if block.settings.badge != blank %}
          {% assign badge_label = block.settings.badge | downcase | strip %}
          {% if badge_label == 'best value' %}
            {% assign is_best_value = true %}
          {% endif %}
        {% endif %}

        <article
          class="kopilot-product-tiers__card{% if block.settings.card_style == 'bordered' %} kopilot-product-tiers__card--bordered{% endif %}{% if block.settings.card_style == 'gray' %} kopilot-product-tiers__card--gray{% endif %}{% if is_best_value %} kopilot-product-tiers__card--best-value{% endif %}"
          data-block-id="{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.badge != blank %}
            <span class="kopilot-product-tiers__card-badge">{{ block.settings.badge }}</span>
          {% endif %}

          <div class="kopilot-product-tiers__card-inner">
            <div class="kopilot-product-tiers__card-media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'kopilot-product-tiers__card-image kopilot-product-tiers__card-image--default',
                    loading: 'lazy',
                    alt: block.settings.title
                }}
              {% else %}
                <img
                  class="kopilot-product-tiers__card-image kopilot-product-tiers__card-image--default"
                  src="{{ default_images[card_index] | asset_url }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="379"
                  height="220"
                >
              {% endif %}

              {% if block.settings.image_hover != blank %}
                {{
                  block.settings.image_hover
                  | image_url: width: 800
                  | image_tag:
                    class: 'kopilot-product-tiers__card-image kopilot-product-tiers__card-image--hover',
                    loading: 'lazy',
                    alt: ''
                }}
              {% elsif hover_images[card_index] != blank %}
                <img
                  class="kopilot-product-tiers__card-image kopilot-product-tiers__card-image--hover"
                  src="{{ hover_images[card_index] | asset_url }}"
                  alt=""
                  loading="lazy"
                  width="379"
                  height="220"
                >
              {% endif %}
            </div>

            <div class="kopilot-product-tiers__card-body">
              <div class="kopilot-product-tiers__card-head">
                <div class="kopilot-product-tiers__card-title-row">
                  <h3 class="kopilot-product-tiers__card-title">
                    {% if block.settings.title != blank %}
                      {{ block.settings.title }}
                    {% elsif product != blank %}
                      {{ product.title }}
                    {% endif %}
                  </h3>
                  {% if block.settings.save_badge != blank %}
                    <span class="kopilot-product-tiers__save-badge">{{ block.settings.save_badge }}</span>
                  {% endif %}
                </div>

                <div class="kopilot-product-tiers__meta">
                  {% if block.settings.show_reviews %}
                    <div class="kopilot-product-tiers__reviews">
                      <span>{{ block.settings.review_count }} Reviews</span>
                      {% render 'kopilot-review-stars', rating: 5, size: 'tier', filled_color: '#000000', empty_color: '#000000' %}
                    </div>
                  {% endif %}
                  <p class="kopilot-product-tiers__price">
                    {% if block.settings.price != blank %}
                      {{ block.settings.price }}
                    {% elsif product != blank %}
                      {{ product.price | money }}
                    {% endif %}
                  </p>
                </div>
              </div>

              <div class="kopilot-product-tiers__card-copy">
                {% if block.settings.description != blank %}
                  <div class="kopilot-product-tiers__description rte">{{ block.settings.description }}</div>
                {% endif %}

                {% if block.settings.features != blank %}
                  <div class="kopilot-product-tiers__features rte">{{ block.settings.features }}</div>
                {% endif %}
              </div>

              {% if block.settings.button_label != blank %}
                <a
                  href="{% if product != blank %}{{ product.url }}{% else %}{{ block.settings.button_link | default: '#' }}{% endif %}"
                  class="kopilot-product-tiers__btn"
                >
                  {{ block.settings.button_label }}
                </a>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Product tiers",
  "tag": "section",
  "class": "kopilot-product-tiers-section",
  "max_blocks": 3,
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Be prepared on every ride.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Product tier",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Default image" },
        { "type": "image_picker", "id": "image_hover", "label": "Hover image" },
        { "type": "text", "id": "badge", "label": "Badge (e.g. Best Value)" },
        {
          "type": "select",
          "id": "card_style",
          "label": "Card style",
          "options": [
            { "value": "bordered", "label": "White with border" },
            { "value": "gray", "label": "Gray background" }
          ],
          "default": "gray"
        },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "text", "id": "save_badge", "label": "Save badge (e.g. SAVE 10%)" },
        { "type": "checkbox", "id": "show_reviews", "label": "Show reviews", "default": true },
        { "type": "text", "id": "review_count", "label": "Review count", "default": "47" },
        { "type": "text", "id": "price", "label": "Price override" },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Get started with one tag for your most-used piece of gear.</p>"
        },
        {
          "type": "richtext",
          "id": "features",
          "label": "Features",
          "default": "<ul><li>Attach it to your helmet or gear with any of the three included mounts</li><li>A simple, reliable solution for riders who stick to one setup</li></ul>"
        },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "GET 1 TAG" },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "outline", "label": "Red outline" },
            { "value": "solid", "label": "Red solid" }
          ],
          "default": "outline"
        },
        { "type": "url", "id": "button_link", "label": "Button link (if no product)" },
        { "type": "image_picker", "id": "list_icon_mobile", "label": "List icon — Mobile (SVG/PNG)", "info": "Replaces the default chevron on mobile. Upload a square SVG or PNG." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Product tiers",
      "blocks": [
        {
          "type": "tier",
          "settings": {
            "card_style": "bordered",
            "title": "1 TAG",
            "price": "$39.99",
            "description": "<p>Get started with one tag for your most-used piece of gear.</p>",
            "features": "<ul><li>Attach it to your helmet or gear with any of the three included mounts</li><li>A simple, reliable solution for riders who stick to one setup</li></ul>",
            "button_label": "GET 1 TAG",
            "button_style": "solid"
          }
        },
        {
          "type": "tier",
          "settings": {
            "card_style": "gray",
            "title": "2 TAGS",
            "save_badge": "SAVE 10%",
            "price": "$71.99",
            "description": "<p>Save with an additional tag for equipping more gear, or share one with a friend or family member.</p>",
            "features": "<ul><li>Multiple mounting solutions for various gear</li><li>Second tag makes a great gift</li></ul>",
            "button_label": "GET 2 TAGS",
            "button_style": "outline"
          }
        },
        {
          "type": "tier",
          "settings": {
            "card_style": "gray",
            "title": "3 TAGS",
            "badge": "Best Value",
            "save_badge": "SAVE 20%",
            "price": "$95.99",
            "description": "<p>Extensive coverage for your gear, or your crew.</p>",
            "features": "<ul><li>Equip multiple helmets, gear setups, or friends and family members</li><li>Greatest savings, most coverage</li></ul>",
            "button_label": "GET 3 TAGS",
            "button_style": "outline"
          }
        }
      ]
    }
  ]
}
{% endschema %}
