{% style %}
  .kopilot-pdp-tap--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .kopilot-pdp-tap__heading_pdp {
    margin: 0;
    max-width: 629px;
    font-family: var(--kopilot-font-family);
    font-weight: 300;
    font-size: 60px;
    line-height: 1.2;
    letter-spacing: -1px;
    color: #000;
  }

  /* Pixel Perfect Mobile Implementations */
  @media screen and (max-width: 767px) {
    .kopilot-pdp-tap--{{ section.id }} {
      padding-top: 0 !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
      background: transparent !important; /* Removes unwanted grey backgrounds */
    }

    .kopilot-pdp-tap--{{ section.id }} .kopilot-pdp-tap__inner {
      display: flex !important;
      flex-direction: column !important; /* Forces vertical stacked order flow */
      background: transparent !important;
    }

    /* Target heading wrapper directly to isolate container grid constraints */
    .kopilot-pdp-tap--{{ section.id }} .kopilot-pdp-tap__heading-wrapper {
      order: 1 !important; /* Pulls heading to the top of the stack layout */
      padding-top: 50px !important; /* Exact Figma Top Spacing */
      padding-left: 33px !important; /* Exact Figma Side Margins */
      padding-right: 33px !important;
      padding-bottom: 0 !important;
      text-align: center !important;
      background: transparent !important;
    }

    .kopilot-pdp-tap--{{ section.id }} .kopilot-pdp-tap__heading_pdp {
      font-family: 'Elza', sans-serif !important;
      font-size: 30px !important; /* Exact Typography Spec */
      font-weight: 300 !important;
      line-height: 1.04 !important; /* 104% Custom Figma Line-Height */
      letter-spacing: -1px !important;
      text-align: center !important;
      margin: 0 auto !important;
      max-width: 294px !important; /* Matches exactly 294px layout bounding box */
      display: inline-block !important;
    }

    .kopilot-pdp-tap--{{ section.id }} .kopilot-pdp-tap__media {
      order: 2 !important; /* Pushes image element seamlessly to the bottom */
      width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      background: transparent !important;
    }

    .kopilot-pdp-tap--{{ section.id }} .kopilot-pdp-tap__media img {
      width: 100% !important;
      height: 312px !important;
      display: block !important;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-pdp-tap.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-pdp-tap kopilot-pdp-tap--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-pdp-tap__inner">
    {% if section.settings.heading != blank %}
      <div class="kopilot-pdp-tap__heading-wrapper">
        <h2 class="kopilot-pdp-tap__heading_pdp">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="kopilot-pdp-tap__media">
      {% render 'kopilot-image',
        image: section.settings.image,
        fallback: 'kopilot-pdp-tap.jpg',
        alt: section.settings.heading,
        width: 1400,
        widths: '550,750,1100,1400'
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot PDP tap",
  "tag": "section",
  "class": "kopilot-pdp-tap-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your critical emergency information in one tap."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [{ "name": "Kopilot PDP tap" }]
}
{% endschema %}