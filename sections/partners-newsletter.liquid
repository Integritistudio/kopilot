<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;600&display=swap" rel="stylesheet">

{%- style -%}
  @font-face {
    font-family: 'Elza';
    font-weight: 600;
    font-style: normal;
  }

  .ppnl-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    padding: 46px 281px;
    box-sizing: border-box;
  }

  .ppnl-{{ section.id }} *,
  .ppnl-{{ section.id }} *::before,
  .ppnl-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .ppnl-{{ section.id }} .ppnl-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 21px;
    width: 100%;
    max-width: 878px;
    margin: 0 auto;
  }

  .ppnl-{{ section.id }} .ppnl-intro {
    margin: 0;
    padding: 0;
    max-width: 422px;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.2;
    color: #000000;
    text-align: center;
    word-break: break-word;
  }

  .ppnl-{{ section.id }} .ppnl-intro strong {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 20px;
    line-height: 1.2;
    color: #000000;
  }

  .ppnl-{{ section.id }} .ppnl-form {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 13px;
    width: 100%;
  }

  .ppnl-{{ section.id }} .ppnl-field-wrap {
    flex: 0 0 561px;
    width: 561px;
    max-width: 561px;
  }

  .ppnl-{{ section.id }} .ppnl-field {
    width: 100%;
    height: 61px;
    margin: 0;
    padding: 15px 20px;
    border: 1px solid #959595;
    border-radius: 0;
    background: transparent;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.2;
    color: #000000;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
  }

  .ppnl-{{ section.id }} .ppnl-field::placeholder {
    color: #959595;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.2;
  }

  .ppnl-{{ section.id }} .ppnl-field:focus {
    border-color: #000000;
  }

  .ppnl-{{ section.id }} .ppnl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    min-width: 304px;
    height: 60.69px;
    margin: 0;
    padding: 18.344px 64px;
    border: 0;
    border-radius: 0;
    background-color: {{ section.settings.button_color }};
    cursor: pointer;
    transition: opacity 0.25s ease;
  }

  .ppnl-{{ section.id }} .ppnl-btn:hover {
    opacity: 0.88;
  }

  .ppnl-{{ section.id }} .ppnl-btn-text {
    font-family: 'Elza', sans-serif;
    font-weight: 600;
    font-size: 20.383px;
    line-height: normal;
    letter-spacing: 0;
    text-transform: uppercase;
    color: {{ section.settings.button_text_color }};
    white-space: nowrap;
  }

  .ppnl-{{ section.id }} .ppnl-message {
    margin: 0;
    padding: 0;
    width: 100%;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.2;
    text-align: center;
    color: #000000;
  }

  .ppnl-{{ section.id }} .ppnl-message--error {
    color: #b00020;
  }

  /* Tablet */
  @media screen and (min-width: 768px) and (max-width: 1439px) {
    .ppnl-{{ section.id }} {
      padding: 46px clamp(24px, 19.514vw, 281px);
    }

    .ppnl-{{ section.id }} .ppnl-form {
      flex-wrap: wrap;
      justify-content: center;
    }

    .ppnl-{{ section.id }} .ppnl-field-wrap {
      flex: 1 1 320px;
      width: auto;
      max-width: 561px;
    }

    .ppnl-{{ section.id }} .ppnl-btn {
      min-width: min(304px, 100%);
    }
  }

  /* Mobile — pixel perfect at 360px */
  @media screen and (max-width: 767px) {
    .ppnl-{{ section.id }} {
      padding: 46px 0;
    }

    .ppnl-{{ section.id }} .ppnl-inner {
      gap: 21px;
      max-width: 277px;
    }

    .ppnl-{{ section.id }} .ppnl-intro {
      max-width: 270px;
      font-size: 15px;
      line-height: 1.2;
    }

    .ppnl-{{ section.id }} .ppnl-intro strong {
      font-size: 15px;
      line-height: 1.2;
    }

    .ppnl-{{ section.id }} .ppnl-form {
      flex-direction: column;
      align-items: center;
      gap: 13px;
      width: 277px;
    }

    .ppnl-{{ section.id }} .ppnl-field-wrap {
      flex: none;
      width: 277px;
      max-width: 277px;
    }

    .ppnl-{{ section.id }} .ppnl-field {
      height: 55px;
      font-size: 15px;
      padding: 15px 20px;
    }

    .ppnl-{{ section.id }} .ppnl-field::placeholder {
      font-size: 15px;
    }

    .ppnl-{{ section.id }} .ppnl-btn {
      min-width: 186px;
      width: 186px;
      height: 54.69px;
      padding: 18.344px 28.5px;
    }

    .ppnl-{{ section.id }} .ppnl-btn-text {
      font-size: 15px;
    }
  }
{%- endstyle -%}

<div class="ppnl-{{ section.id }}">
  <div class="ppnl-inner">
    {%- if section.settings.heading_bold != blank or section.settings.heading_regular != blank -%}
      <p class="ppnl-intro">
        {%- if section.settings.heading_bold != blank -%}
          <strong>{{ section.settings.heading_bold | escape }}</strong>
        {%- endif -%}
        {%- if section.settings.heading_regular != blank -%}
          <br aria-hidden="true">
          {{ section.settings.heading_regular | escape }}
        {%- endif -%}
      </p>
    {%- endif -%}

    {%- assign ppnl_form_id = 'ppnl-form-' | append: section.id -%}
    {%- form 'customer', id: ppnl_form_id, class: 'ppnl-form' -%}
      <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tag | escape }}">

      {%- if form.posted_successfully? -%}
        <p class="ppnl-message">{{ section.settings.success_message | escape }}</p>
      {%- else -%}
        {%- if form.errors -%}
          <p class="ppnl-message ppnl-message--error">{{ form.errors | default_errors }}</p>
        {%- endif -%}

        <div class="ppnl-field-wrap">
          <label class="visually-hidden" for="ppnl-email-{{ section.id }}">{{ section.settings.email_placeholder | escape }}</label>
          <input
            id="ppnl-email-{{ section.id }}"
            class="ppnl-field"
            type="email"
            name="contact[email]"
            autocomplete="email"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            required
            value="{% if form.email %}{{ form.email }}{% endif %}"
          >
        </div>

        <button type="submit" class="ppnl-btn" aria-label="{{ section.settings.button_label | escape }}">
          <span class="ppnl-btn-text">{{ section.settings.button_label | escape }}</span>
        </button>
      {%- endif -%}
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Partners Newsletter",
  "tag": "section",
  "class": "section-partners-newsletter",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F1F1F1"
    },
    {
      "type": "text",
      "id": "heading_bold",
      "label": "Heading (bold line)",
      "default": "Not ready to reach out?"
    },
    {
      "type": "text",
      "id": "heading_regular",
      "label": "Heading (regular line)",
      "default": "Stay in the loop on program updates and perks."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Keep me posted"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "customer_tag",
      "label": "Customer tag",
      "default": "partners-newsletter",
      "info": "Used to tag newsletter signups in Shopify Customers."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks — you're on the list."
    }
  ],
  "presets": [
    {
      "name": "Partners Newsletter"
    }
  ]
}
{% endschema %}
