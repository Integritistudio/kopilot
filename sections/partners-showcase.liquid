<section class="partners-showcase partners-showcase--{{ section.id }}">
  <div class="partners-showcase__inner">
    <div class="partners-showcase__heading">
      {% if section.settings.heading != blank %}
        <h2 class="partners-showcase__title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="partners-showcase__content">
      <div class="partners-showcase__track-wrap">
        <div class="partners-showcase__track" role="list" aria-label="{{ section.settings.heading | escape }}">
          {% for block in section.blocks %}
            <article class="partners-showcase__card" role="listitem" {{ block.shopify_attributes }}>
              {% assign card_alt = block.settings.image.alt | default: block.settings.title %}
              <div class="partners-showcase__media">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'partners-showcase__image',
                      loading: 'lazy',
                      widths: '320, 480, 640, 800, 960, 1200',
                      sizes: '(min-width: 990px) 400px, 319px',
                      alt: card_alt
                  }}
                {% else %}
                  <div class="partners-showcase__image partners-showcase__image--placeholder" aria-hidden="true"></div>
                {% endif %}

                <div class="partners-showcase__logo-badge">
                  <span class="partners-showcase__logo-text">
                    {{ block.settings.logo_text | default: 'Logo' | escape }}
                  </span>
                </div>
              </div>

              <div class="partners-showcase__body">
                <div class="partners-showcase__copy">
                  {% if block.settings.title != blank %}
                    <h3 class="partners-showcase__card-title">{{ block.settings.title | escape }}</h3>
                  {% endif %}

                  {% if block.settings.subtitle != blank %}
                    <p class="partners-showcase__subtitle">{{ block.settings.subtitle | escape }}</p>
                  {% endif %}
                </div>

                {% if block.settings.people_count != blank %}
                  <div class="partners-showcase__pill" aria-label="{{ block.settings.people_count | escape }} people">
                    <span class="partners-showcase__pill-text">{{ block.settings.people_count | escape }} people</span>
                  </div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>

        <div class="partners-showcase__progress" aria-hidden="true">
          <span class="partners-showcase__progress-fill"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .partners-showcase--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    overflow: hidden;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 50px 61px 0;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__content {
    display: grid;
    grid-template-columns: minmax(240px, 413px) minmax(0, 1fr);
    gap: 61px;
    align-items: center;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__heading {
    min-width: 0;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__title {
    margin: 0;
    max-width: 413px;
    font-size: clamp(34px, 3.5vw, 54px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    font-weight: 500;
    color: inherit;
    text-wrap: balance;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__track-wrap {
    min-width: 0;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__track {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    padding-bottom: 16px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__track::-webkit-scrollbar {
    display: none;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__card {
    flex: 0 0 auto;
    width: 400px;
    scroll-snap-align: start;
    border-radius: 0;
    overflow: hidden;
    background: transparent;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__media {
    position: relative;
    width: 100%;
    aspect-ratio: 400 / 254.1536;
    overflow: hidden;
    border-radius: 0;
    background:
      linear-gradient(135deg, rgba(25, 25, 25, 0.12), rgba(255, 255, 255, 0.02)),
      linear-gradient(180deg, #d7d7d7 0%, #bfbfbf 100%);
  }

  .partners-showcase--{{ section.id }} .partners-showcase__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__image--placeholder {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)),
      linear-gradient(180deg, #d6d6d6 0%, #b7b7b7 100%);
  }

  .partners-showcase--{{ section.id }} .partners-showcase__logo-badge {
    position: absolute;
    top: 13px;
    left: 13px;
    min-width: 84px;
    height: 31px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(8px);
  }

  .partners-showcase--{{ section.id }} .partners-showcase__logo-text {
    font-size: 11px;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #111111;
    white-space: nowrap;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__body {
    min-height: 128px;
    padding: 20px 40px 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 18px;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__copy {
    display: grid;
    gap: 12px;
    min-width: 0;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__card-title {
    margin: 0;
    font-size: 14px;
    line-height: 1;
    letter-spacing: -0.01em;
    font-weight: 500;
    color: inherit;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__subtitle {
    margin: 0;
    font-size: 11px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: rgba(17, 17, 17, 0.72);
  }

  .partners-showcase--{{ section.id }} .partners-showcase__pill {
    width: fit-content;
    min-width: 97px;
    height: 21px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.16);
    background: rgba(255, 255, 255, 0.72);
  }

  .partners-showcase--{{ section.id }} .partners-showcase__pill-text {
    font-size: 11px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: #111111;
    white-space: nowrap;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__progress {
    width: 100%;
    height: 5px;
    margin-top: 18px;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.1);
    overflow: hidden;
  }

  .partners-showcase--{{ section.id }} .partners-showcase__progress-fill {
    display: block;
    width: 48%;
    height: 100%;
    border-radius: inherit;
    background: #111111;
  }

  @media screen and (max-width: 989px) {
    .partners-showcase--{{ section.id }} .partners-showcase__inner {
      padding: 50px 20px 0;
    }

    .partners-showcase--{{ section.id }} .partners-showcase__content {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .partners-showcase--{{ section.id }} .partners-showcase__title {
      max-width: 288px;
      font-size: clamp(30px, 8.5vw, 40px);
      line-height: 1.02;
    }

    .partners-showcase--{{ section.id }} .partners-showcase__track {
      gap: 30px;
    }

    .partners-showcase--{{ section.id }} .partners-showcase__card {
      width: 319px;
    }

    .partners-showcase--{{ section.id }} .partners-showcase__body {
      min-height: 128px;
      padding: 20px 40px 0;
    }
  }

  @media screen and (max-width: 749px) {
    .partners-showcase--{{ section.id }} .partners-showcase__title {
      max-width: 258px;
    }
  }
</style>

{% schema %}
{
  "name": "Partners showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See how our partners use KOPILOT.ID."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "logo_text",
          "label": "Logo text",
          "default": "Logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Name of the Event"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "One-line story context"
        },
        {
          "type": "text",
          "id": "people_count",
          "label": "People count",
          "default": "240"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partners showcase",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}

