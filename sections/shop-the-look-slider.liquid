{% style %}
    .stl-{{ section.id }} {
      padding-top: {{ section.settings.top_spacing }}px; 
      padding-bottom : {{ section.settings.bottom_spacing }}px;
    }

    .stl-{{ section.id }}
    .heading {
      margin-bottom: 30px;
    }

    .stl-{{ section.id }}
    .card {
      position: relative;
      border-radius: 16px;
      width: 100%;
      aspect-ratio: {% if section.settings.image_ratio == 'auto' %}unset{% else %}{{ section.settings.image_ratio }}
  {% endif %};
  }

  .stl-{{ section.id }} .card-media {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    overflow: hidden;
    z-index: 0;
  }

  .stl-{{ section.id }}
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stl-{{ section.id }}
  .hotspot {
    position: absolute;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    transform: translate(-50%, -50%);
    z-index: 2;
    background: rgb(255 255 255 / 54%);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(6px);

    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  /* center dot */
  .stl-{{ section.id }} .hotspot::before {
    content: "";
    position: absolute;
    width: 8px;
    height: 8px;
    background: #fff;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* soft outer glow ring */
  .stl-{{ section.id }} .hotspot::after {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    animation: mirrorPulse 2.5s infinite ease-out;
  }

  /* pulse animation */
  .stl-{{ section.id }} .hotspot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    animation: pulse 2s infinite;
    border: 2px solid #fff;
  }

  @keyframes mirrorPulse {
    0% {
      transform: scale(0.9);
      opacity: 0.6;
    }
    70% {
      transform: scale(1.6);
      opacity: 0.2;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* popup: sits to the RIGHT of hotspot by default */
  .stl-{{ section.id }} .product-popup {
    position: absolute;
    left: calc(100% + 10px);
    top: 50%;
    transform: translateY(calc(-50% + var(--popup-offset, 0px))) scale(0.95);
    background: var(--color-secondary-background);
    padding: 15px;
    border-radius: 12px;
    width: 210px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 999;
    will-change: transform, opacity;
  }

  /* flip to the LEFT when near right edge */
  .stl-{{ section.id }} .product-popup.go-left {
    left: auto;
    right: calc(100% + 10px);
  }

  .stl-{{ section.id }} .hotspot.active {
    z-index: 10;
  }

  /* active / visible state */
  .stl-{{ section.id }} .hotspot.active .product-popup {
    opacity: 1;
    transform: translateY(calc(-50% + var(--popup-offset, 0px))) scale(1);
    pointer-events: auto;
  }

  .stl-{{ section.id }}
  .product-popup img {
    width: 170px;
    margin-bottom: 8px;
  }

  .stl-{{ section.id }}
  .product-title {
    font-size: 13px;
    font-family: var(--font-heading-family);
  }

  .stl-{{ section.id }}
  .product-title + small {
    margin-top: 4px;
  }

  .stl-inner {
    margin: 0 0 0 5rem;
    padding: 0 0 0 5rem;
  }


  .stl-{{ section.id }}
  .product-popup a {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-flow: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    cursor: pointer;
  }
  .stl-{{ section.id }}.product-popup a:hover {
    text-decoration: none;
    color: inherit;
  }

  /* full width wrapper */
  .stl-{{ section.id }} .slider-full {
    width: 100%;
    overflow: hidden;
  }

  /* left spacing only */
  .stl-{{ section.id }} .left-only {
    /* margin-right: 0; */
    padding-right: 0;
    /* max-width: none; */
  }

  .stl-{{ section.id }}
  .container {
    overflow: visible;
  }

  .stl-{{ section.id }}
  .swiper {
    overflow: visible;
  }

  .stl-{{ section.id }}
  .swiper-slide {
    height: auto;
    display: flex;
    overflow: visible;
  }
.stl-{{ section.id }} .hotspot:focus {
  outline: 2px solid #000;
  outline-offset: 4px;
}

/* Better modern focus */
.stl-{{ section.id }} .hotspot:focus-visible {
  outline: 3px solid #000;
  outline-offset: 5px;
  box-shadow: 0 0 0 4px rgba(0,0,0,0.2);
  background: #fff;
}

  @media(max-width: 767px) {
    .stl-{{ section.id }} .product-popup {
      width: 140px;
      padding: 10px;
    }
    .stl-{{ section.id }}
    .hotspot::before {
      width: 6px;
      height: 6px;
    }
    .stl-{{ section.id }}
    .hotspot {
      position: absolute;
      width: 25px;
      height: 25px;
    }
  }

  @media(max-width: 767px) {
    .stl-{{ section.id }} {
      padding-top: {{ section.settings.top_spacing_mobile }}px; 
      padding-bottom : {{ section.settings.bottom_spacing_mobile }}px;
  }
}
{% endstyle %}

<div class="stl-{{ section.id }} color-{{section.settings.color_scheme }}">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h1 class="heading">{{ section.settings.heading }}</h1>
    {% endif %}
  </div>
  <div class="slider-full">
    <div class="container left-only">
      <swiper-section
        data-slides-desktop="{{ section.settings.slides_desktop }}"
        data-slides-tablet="2"
        data-slides-mobile="1.2"
        data-gap="20"
        data-loop="false"
      >
        <div class="swiper">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide">
                <div class="card">
                  <!-- IMAGE -->
                  <div class="card-media">
                    {% if block.settings.image %}
                      {{ block.settings.image | image_url: width: 1000 | image_tag }}
                    {% else %}
                      {{ 'collection-1' | placeholder_svg_tag: 'placeholder_svg' }}
                    {% endif %}
                  </div>

                  <!-- HOTSPOTS -->
                  {% for i in (1..3) %}
                    {% assign product_key = 'product_' | append: i %}
                    {% assign top_key = 'top_' | append: i %}
                    {% assign left_key = 'left_' | append: i %}

                    {% assign product = block.settings[product_key] %}
                    {% assign top = block.settings[top_key] %}
                    {% assign left = block.settings[left_key] %}

                    {% if product != blank and product.id %}
                      <div 
                        class="hotspot" 
                        style="top: {{ top }}%; left: {{ left }}%;" 
                        tabindex="0" 
                        role="button"
                        aria-label="View product {{ product.title }}"
                      >
                        <div class="product-popup{% if section.settings.show_product_img_bg %} show_bg{% endif %}"{% if section.settings.show_product_img_bg %} style="--bg: {{ section.settings.product_img_bg }};"{% endif %}>
                          <a href="{{ product.url }}">
                            {{ product.featured_image | image_url: width: 200 | image_tag }}
                            <div class="product-title">{{ product.title }}</div>
                            <small>{{ product.price | money }}</small>
                          </a>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </swiper-section>
    </div>
  </div>
</div>

<script>
(function () {
  const EDGE_GAP = 10;

  function isTouchDevice() {
    return window.matchMedia("(hover: none) and (pointer: coarse)").matches;
  }

  function positionPopup(hotspot) {
    const popup = hotspot.querySelector('.product-popup');
    if (!popup) return;

    const card = hotspot.closest('.card');

    popup.classList.remove('go-left');
    popup.style.removeProperty('--popup-offset');

    const hotspotRect = hotspot.getBoundingClientRect();
    const cardRect = card.getBoundingClientRect();

    popup.style.visibility = 'hidden';
    popup.style.display = 'block';
    const popupRect = popup.getBoundingClientRect();
    popup.style.visibility = '';
    popup.style.display = '';

    // Horizontal flip
    const spaceRight = cardRect.right - hotspotRect.right;
    if (spaceRight < popupRect.width + 10) {
      popup.classList.add('go-left');
    }

    // Vertical adjust
    const hotspotCenterY = hotspotRect.top + hotspotRect.height / 2;
    const halfH = popupRect.height / 2;
    let offset = 0;

    if (hotspotCenterY - halfH < cardRect.top + EDGE_GAP) {
      offset = cardRect.top + EDGE_GAP - (hotspotCenterY - halfH);
    } else if (hotspotCenterY + halfH > cardRect.bottom - EDGE_GAP) {
      offset = cardRect.bottom - EDGE_GAP - (hotspotCenterY + halfH);
    }

    if (offset !== 0) {
      popup.style.setProperty('--popup-offset', offset + 'px');
    }
  }

  document.querySelectorAll('.stl-{{ section.id }} .hotspot').forEach((hotspot) => {
    let closeTimeout;
    const popup = hotspot.querySelector('.product-popup');

    if (isTouchDevice()) {
  
      hotspot.addEventListener('click', function (e) {
        e.stopPropagation();

        document.querySelectorAll('.stl-{{ section.id }} .hotspot').forEach((h) => {
          if (h !== this) h.classList.remove('active');
        });

        const isActive = this.classList.contains('active');
        this.classList.toggle('active');

        if (!isActive) {
          positionPopup(this);

          clearTimeout(closeTimeout);
          closeTimeout = setTimeout(() => {
            this.classList.remove('active');
          }, 3000);
        }
      });

    } else {
      
      hotspot.addEventListener('mouseenter', function () {
        clearTimeout(closeTimeout);

        document.querySelectorAll('.stl-{{ section.id }} .hotspot').forEach((h) => {
          if (h !== this) h.classList.remove('active');
        });

        positionPopup(this);
        this.classList.add('active');
      });

      hotspot.addEventListener('mouseleave', function () {
        closeTimeout = setTimeout(() => {
          this.classList.remove('active');
        }, 200);
      });
    }

    // Keep open on popup hover
    popup.addEventListener('mouseenter', () => {
      clearTimeout(closeTimeout);
    });

    popup.addEventListener('mouseleave', () => {
      hotspot.classList.remove('active');
    });
  });

  // Outside click close (mobile only useful)
  document.addEventListener('click', () => {
    if (isTouchDevice()) {
      document.querySelectorAll('.stl-{{ section.id }} .hotspot').forEach((h) => {
        h.classList.remove('active');
      });
    }
  });

  // Resize fix
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const activeHotspot = document.querySelector('.stl-{{ section.id }} .hotspot.active');
      if (activeHotspot) positionPopup(activeHotspot);
    }, 100);
  });


})();
</script>

{% schema %}
{
