{% style %}
  .kopilot-image-text--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-image-text--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-image-text.css' | asset_url | stylesheet_tag }}

<section id="kopilot-why-kopilot" class="kopilot-section kopilot-image-text kopilot-image-text--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="{% unless section.settings.full_width %}container{% endunless %}">
    <div class="kopilot-image-text__inner{% if section.settings.image_position == 'right' %} kopilot-image-text__inner--image-right{% endif %}">
      <div class="kopilot-image-text__media">
        {% render 'kopilot-image',
          image: section.settings.image,
          fallback: 'kopilot-image-text.jpg',
          alt: section.settings.heading,
          width: 1400,
          widths: '375,550,750,1100,1400'
        %}
      </div>

      <div class="kopilot-image-text__content">
        {% if section.settings.heading != blank %}
          <h2 class="kopilot-image-text__heading kopilot-heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="kopilot-image-text__text kopilot-body rte">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Image with text",
  "tag": "section",
  "class": "kopilot-image-text-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "If something goes wrong, first responders need more than your name."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>After a crash, you could be unconscious, disoriented, or unable to speak. The people helping you may not know about your allergies, medical conditions, medications, or who to contact when every minute matters. KOPILOT.ID exists for exactly that moment.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Kopilot Image with text"
    }
  ]
}
{% endschema %}
