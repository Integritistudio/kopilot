{% style %}
  .kopilot-image-text--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* Structural layout adjustments for pixel perfection (Desktop) */
  @media screen and (min-width: 768px) {
    .kopilot-image-text--{{ section.id }} {
      max-width: 1440px;
      margin: 0 auto;
      width: 100%;
    }

    .kopilot-image-text--{{ section.id }} .kopilot-image-text__inner {
      display: flex;
      align-items: center;
      justify-content: flex-end; /* Aligns content clean to the edges */
      gap: 90px; /* Locked exactly to Figma spec */
      height: 704px;
    }

    .kopilot-image-text--{{ section.id }} .kopilot-image-text__content {
      flex: 1;
      max-width: 561px; /* Figma specification box width */
    }

    .kopilot-image-text--{{ section.id }} .kopilot-image-text__media {
      flex: 0 0 696px;
      width: 696px;
      height: 704px;
      overflow: hidden;
    }

    /* Force inside elements/images to crop and fill container pixel perfectly */
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__media img,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__media svg,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__media picture {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }
    
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__inner--image-right {
      flex-direction: row-reverse;
      justify-content: flex-start;
    }

    /* Target heading structure to drop down seamlessly onto exactly 2 lines */
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__heading,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__heading * {
      font-family: 'Elza', sans-serif;
      font-size: 60px;
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -1px;
      margin-bottom: 24px;
      max-width: 540px; /* Constraints width to break perfectly onto 2 lines */
    }

    .kopilot-image-text--{{ section.id }} .kopilot-image-text__text.kopilot-body.rte,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__text.kopilot-body.rte * {
      font-family: 'Figtree', sans-serif;
      font-size: 20px;
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: 0;
      max-width: 480px; /* Clean line breaking for paragraph text */
    }
  }

  /* Mobile Specification Overrides */
  @media screen and (max-width: 767px) {
    .kopilot-image-text--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    /* Force image on top, content below, with spacing between them */
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__inner {
      display: flex;
      flex-direction: column-reverse;
      gap: 40px; 
    }

    /* Constrain text wrapper content width exactly to Figma spec */
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__content {
      display: flex;
      flex-direction: column;
      max-width: 288px;
      margin-left: auto;
      margin-right: auto;
      gap: 25px; 
      align-items: {% if section.settings.text_alignment_mobile == 'left' %}flex-start{% elsif section.settings.text_alignment_mobile == 'right' %}flex-end{% else %}center{% endif %};
      text-align: {{ section.settings.text_alignment_mobile }};
    }

    /* Heading Mobile Styles */
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__heading,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__heading * {
      font-family: 'Elza', sans-serif;
      font-size: 30px;
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -1px;
      text-align: {{ section.settings.text_alignment_mobile }};
      margin: 0;
    }

    /* Paragraph Body Mobile Styles */
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__text.kopilot-body.rte,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__text.kopilot-body.rte p,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__text.kopilot-body.rte ul li,
    .kopilot-image-text--{{ section.id }} .kopilot-image-text__text.kopilot-body.rte ol li {
      font-family: 'Figtree', sans-serif;
      font-size: 15px;
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: 0;
      text-align: {{ section.settings.text_alignment_mobile }};
      margin: 0;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-image-text.css' | asset_url | stylesheet_tag }}

<section id="kopilot-why-kopilot" class="kopilot-section kopilot-image-text kopilot-image-text--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="{% unless section.settings.full_width %}container{% endunless %}">
    <div class="kopilot-image-text__inner{% if section.settings.image_position == 'right' %} kopilot-image-text__inner--image-right{% endif %}">
      <div class="kopilot-image-text__content">
        {% if section.settings.heading != blank %}
          <div class="kopilot-image-text__heading kopilot-heading rte">
            {{ section.settings.heading }}
          </div>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="kopilot-image-text__text kopilot-body rte">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>

      <div class="kopilot-image-text__media">
        {% render 'kopilot-image',
          image: section.settings.image,
          fallback: 'kopilot-image-text.jpg',
          alt: section.settings.heading,
          width: 1400,
          widths: '375,550,750,1100,1400'
        %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Image with text",
  "tag": "section",
  "class": "kopilot-image-text-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_font_family",
      "label": "Text font family",
      "options": [
        { "value": "Elza", "label": "Elza" },
        { "value": "Figtree", "label": "Figtree" },
        { "value": "Inter", "label": "Inter" },
        { "value": "Roboto", "label": "Roboto" },
        { "value": "Open Sans", "label": "Open Sans" },
        { "value": "Lato", "label": "Lato" }
      ],
      "default": "Elza"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>If something goes wrong, first responders need more than your name.</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>After a crash, you could be unconscious, disoriented, or unable to speak. The people helping you may not know about your allergies, medical conditions, medications, or who to contact when every minute matters. KOPILOT.ID exists for exactly that moment.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Kopilot Image with text"
    }
  ]
}
{% endschema %}