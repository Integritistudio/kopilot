{% style %}
.kopilot-home-video--{{ section.id }} .kopilot-home-video__yt-wrap {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  background: #000;
}

.kopilot-home-video--{{ section.id }} .kopilot-home-video__yt-wrap iframe,
.kopilot-home-video--{{ section.id }} #KopilotHomeYt-{{ section.id }} {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
}

.kopilot-home-video--{{ section.id }}.is-playing .kopilot-home-video__poster,
.kopilot-home-video--{{ section.id }} .kopilot-home-video__frame.is-playing .kopilot-home-video__poster {
  display: none !important;
}
{% endstyle %}

{%- liquid
  assign yt_id = blank

  if section.settings.youtube_video_url != blank and section.settings.youtube_video_url.type == 'youtube'
    assign yt_id = section.settings.youtube_video_url.id
  elsif section.settings.video_url != blank
    assign raw_url = section.settings.video_url
    if raw_url contains 'youtube.com' or raw_url contains 'youtu.be'
      if raw_url contains 'youtu.be/'
        assign yt_id = raw_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
      elsif raw_url contains 'v='
        assign yt_id = raw_url | split: 'v=' | last | split: '&' | first | split: '?' | first
      elsif raw_url contains 'embed/'
        assign yt_id = raw_url | split: 'embed/' | last | split: '?' | first | split: '&' | first
      endif
    endif
  endif

  assign has_youtube = false
  if yt_id != blank
    assign has_youtube = true
  endif

  assign has_mp4_url = false
  if section.settings.video_url != blank and has_youtube == false
    assign has_mp4_url = true
  endif

  assign has_video = false
  if section.settings.video != blank or has_youtube or has_mp4_url
    assign has_video = true
  endif
-%}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-home-video.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kopilot-home-video.js' | asset_url }}" defer></script>

<section class="kopilot-section kopilot-home-video kopilot-home-video--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-home-video__inner">
    <div class="kopilot-home-video__frame" data-kopilot-home-video>
      {% if section.settings.video != blank %}
        {{
          section.settings.video
          | video_tag:
            class: 'kopilot-home-video__video',
            controls: false,
            playsinline: true,
            preload: 'metadata',
            image_size: '1280x'
        }}
      {% elsif has_youtube %}
        <div
          class="kopilot-home-video__yt-wrap"
          data-kopilot-home-youtube
          data-youtube-id="{{ yt_id }}"
        >
          <div id="KopilotHomeYt-{{ section.id }}"></div>
        </div>
      {% elsif has_mp4_url %}
        <video class="kopilot-home-video__video" playsinline preload="metadata">
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {% endif %}

      <div class="kopilot-home-video__poster" data-kopilot-home-video-poster>
        <div class="kopilot-home-video__overlay kopilot-home-video__overlay--desktop">
          {% render 'kopilot-image',
            image: section.settings.overlay_image,
            fallback: 'video-overlay.png',
            alt: '',
            width: 2560,
            widths: '1280,1920,2560',
            sizes: '(min-width: 768px) 1280px, 0px'
          %}
        </div>
        <div class="kopilot-home-video__overlay kopilot-home-video__overlay--mobile">
          {% render 'kopilot-image',
            image: section.settings.overlay_image_mobile,
            fallback: 'video-overlay.png',
            alt: '',
            width: 734,
            widths: '367,734',
            sizes: '(max-width: 767px) 367px, 0px'
          %}
        </div>
        <div class="kopilot-home-video__shade" aria-hidden="true"></div>

        <button
          type="button"
          class="kopilot-home-video__play{% unless has_video %} kopilot-home-video__play--no-video{% endunless %}"
          data-kopilot-home-video-play
          aria-label="{{ section.settings.play_label | default: 'Play video' | escape }}"
          {% unless has_video %}aria-disabled="true"{% endunless %}
        >
          {% if section.settings.play_icon != blank %}
            {{
              section.settings.play_icon
              | image_url: width: 210
              | image_tag: loading: 'lazy', alt: '', class: 'kopilot-home-video__play-icon'
            }}
          {% else %}
            <svg class="kopilot-home-video__play-icon" width="91" height="105" viewBox="0 0 91 105" fill="none" aria-hidden="true" focusable="false">
              <path d="M91 52.5L0 0V105L91 52.5Z" fill="white" fill-opacity="0.58"/>
            </svg>
          {% endif %}
        </button>

        {% if section.settings.heading != blank %}
          <div class="kopilot-home-video__heading rte">
            {{ section.settings.heading }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Home Video",
  "tag": "section",
  "class": "kopilot-home-video-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "video_url",
      "id": "youtube_video_url",
      "label": "YouTube Video URL",
      "accept": ["youtube"],
      "info": "Takes priority over overlay images. Used when no Shopify video is selected."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (.mp4)",
      "info": "Used when no Shopify video or YouTube URL is set. YouTube links pasted here also work."
    },
    {
      "type": "image_picker",
      "id": "overlay_image",
      "label": "Overlay image (desktop)",
      "info": "Poster only — hidden when video plays."
    },
    {
      "type": "image_picker",
      "id": "overlay_image_mobile",
      "label": "Overlay image (mobile)",
      "info": "Poster only — hidden when video plays."
    },
    {
      "type": "image_picker",
      "id": "play_icon",
      "label": "Play icon",
      "info": "Defaults to Polygon.svg"
    },
    {
      "type": "text",
      "id": "play_label",
      "label": "Play button label (accessibility)",
      "default": "Play video"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your critical emergency information in one tap.</p>"
    }
  ],
  "presets": [
    {
      "name": "Kopilot Home Video",
      "settings": {
        "heading": "<p>Your critical emergency information in one tap.</p>"
      }
    }
  ]
}
{% endschema %}
