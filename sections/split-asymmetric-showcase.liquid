{%- style -%}
  /* --- Typography --- */
  @font-face { font-family: 'Elza'; font-weight: 300; font-style: normal; }
  @font-face { font-family: 'Outfit'; font-weight: 400; font-style: normal; }
  @font-face { font-family: 'Outfit'; font-weight: 600; font-style: normal; }

  .showcase-{{ section.id }} {
    width: 100%;
    padding: 70px 222px;
    background-color: {{ section.settings.bg_color }};
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .showcase-wrapper {
    display: flex;
    justify-content: center;
    gap: 60px;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* --- Left Column --- */
  .showcase-{{ section.id }} .content-column { width: 433.84px; flex-shrink: 0; }
  .showcase-{{ section.id }} .showcase-heading { font-family: 'Elza', sans-serif; font-size: 60px; margin: 0 0 45px 0; }
  .showcase-{{ section.id }} .showcase-paragraph { font-family: 'Elza', sans-serif; font-size: 20px; line-height: 142%; margin: 0 0 38px 0; }

  /* --- Logo Grid (Fixed to Figma Hug) --- */
  .showcase-{{ section.id }} .logo-grid-wrapper { display: flex; flex-direction: column; gap: 20px; width: 433.84px; }
  .showcase-{{ section.id }} .logo-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .showcase-{{ section.id }} .logo-item { height: 35px; width: auto; object-fit: contain; }

  /* --- Interactive Column --- */
  .showcase-{{ section.id }} .interactive-column { width: 502px; flex-shrink: 0; }
  .showcase-{{ section.id }} .interactive-card { width: 502px; background: #f9f9f9; border-radius: 8px; overflow: hidden; }
  
  .showcase-{{ section.id }} .card-text-content { padding: 30.67px 40px; box-sizing: border-box; }
  
  /* --- Typography Specs --- */
  .showcase-{{ section.id }} .card-name { font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 20px; line-height: 120%; margin: 0 0 4px 0; }
  .showcase-{{ section.id }} .card-sub { font-family: 'Outfit', sans-serif; font-weight: 400; font-size: 16px; line-height: 120%; margin: 0 0 16px 0; color: #666; }
  .showcase-{{ section.id }} .card-quote { font-family: 'Elza', sans-serif; font-weight: 300; font-size: 20px; line-height: 142%; margin: 0 0 20px 0; }

  /* --- Pill Tags --- */
  .showcase-{{ section.id }} .tag-container { display: flex; flex-wrap: wrap; gap: 10px; }
  .showcase-{{ section.id }} .ui-tag { 
    font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 400; line-height: 120%;
    width: 148px; height: 31px;
    padding: 10px 24px;
    border: 1px solid #000000;
    display: inline-flex; align-items: center; justify-content: center;
    box-sizing: border-box;
  }
{%- endstyle -%}

<div class="showcase-{{ section.id }}">
  <div class="showcase-wrapper">
    <div class="content-column">
      <h2 class="showcase-heading">{{ section.settings.heading | escape }}</h2>
      <p class="showcase-paragraph">{{ section.settings.paragraph }}</p>
      
      <div class="logo-grid-wrapper">
        <div class="logo-row">
          {%- for block in section.blocks -%}
            {%- if block.type == 'logo' and block.settings.logo_image != blank -%}
              <img class="logo-item" src="{{ block.settings.logo_image | image_url }}" loading="lazy">
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="interactive-column">
      <div class="interactive-card">
        <div class="card-image-wrapper" style="width: 502px; height: 254px; background: #e0e0e0;">
           {%- if section.settings.card_image != blank -%}
             <img src="{{ section.settings.card_image | image_url: width: 600 }}" style="width:100%; height:100%; object-fit:cover;">
           {%- endif -%}
        </div>
        <div class="card-text-content">
          <h3 class="card-name">{{ section.settings.card_heading | escape }}</h3>
          <p class="card-sub">{{ section.settings.card_subheading | escape }}</p>
          <p class="card-quote">{{ section.settings.card_text | escape }}</p>
          <div class="tag-container">
            {%- for block in section.blocks -%}
              {%- if block.type == 'pill_tag' -%}
                <span class="ui-tag">{{ block.settings.tag_title | escape }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Asymmetric Showcase",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by thousands." },
    { "type": "textarea", "id": "paragraph", "label": "Paragraph", "default": "We work with races, events, organizers, and outdoor communities." },
    { "type": "image_picker", "id": "card_image", "label": "Card Image" },
    { "type": "text", "id": "card_heading", "label": "Card Name", "default": "Name Here" },
    { "type": "text", "id": "card_subheading", "label": "Card Subheading", "default": "- (Maybe a titleholder here?)" },
    { "type": "textarea", "id": "card_text", "label": "Card Quote", "default": "\"[Real community or ambassador story]\"" }
  ],
  "blocks": [
    { "type": "logo", "name": "Logo", "settings": [{ "type": "image_picker", "id": "logo_image", "label": "Logo" }] },
    { "type": "pill_tag", "name": "Tag", "settings": [{ "type": "text", "id": "tag_title", "label": "Tag", "default": "Trans-Rockies" }] }
  ],
  "presets": [{ "name": "Asymmetric Showcase" }]
}
{% endschema %}