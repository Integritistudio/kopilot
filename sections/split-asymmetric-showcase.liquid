{%- style -%}
  /* --- Typography Registration --- */
  @font-face {
    font-family: 'Elza';
    font-weight: 300;
    font-style: normal;
  }
  @font-face {
    font-family: 'Outfit';
    font-weight: 400;
    font-style: normal;
  }

  .showcase-{{ section.id }} {
    width: 100%;
    padding: 70px 222.08px; /* Strict desktop layout parameters */
    background-color: {{ section.settings.bg_color }};
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .showcase-wrapper {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 60px; /* Precise column-to-column distance */
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  /* --- Left Column: Text Content Handling --- */
  .showcase-{{ section.id }} .content-column {
    width: 433.84px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .showcase-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 60px;
    line-height: 1.1;
    color: #000000;
    margin: 0 0 45px 0;
    padding: 0;
  }

  .showcase-{{ section.id }} .showcase-paragraph {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 20px;
    line-height: 140%;
    color: #000000;
    margin: 0 0 38px 0; 
    padding: 0;
    max-width: 377px;
  }

  /* --- Logo Element Stack Rules --- */
  .showcase-{{ section.id }} .logo-grid-wrapper {
    display: flex;
    flex-direction: column;
    gap: 30px;
    width: 100%;
    max-width: 433.84px; 
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .logo-row {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 30px; 
    width: 100%;
  }

  .showcase-{{ section.id }} .logo-item {
    height: auto;
    max-height: 65px;
    object-fit: contain;
  }

  /* --- Right Column: Interactive Frame --- */
  .showcase-{{ section.id }} .interactive-column {
    width: 502px;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .interactive-card {
    width: 100%;
    background: #f9f9f9;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* --- Interactive Image Framework Sizing --- */
  .showcase-{{ section.id }} .card-image-wrapper {
    width: 502px;      
    height: 254px;     
    position: relative;
    overflow: hidden;
    background-color: #e0e0e0;
  }

  .showcase-{{ section.id }} .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .showcase-{{ section.id }} .card-image-wrapper .location-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 110px;
    height: 31px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    gap: 10px;
    box-sizing: border-box;
    background: #ffffff;
    color: #000000;
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0%;
    white-space: nowrap;
  }

  /* --- Text block Parent: Gap 21.52px --- */
  .showcase-{{ section.id }} .card-text-content {
    background:#f1f1f1;
    display: flex;
    flex-direction: column;
    gap: 21.52px;
    width: 502px;
    padding: 30.67px 40px;
    box-sizing: border-box;
  }

  /* --- NEW Inner Wrapper: Gap 10px --- */
  .showcase-{{ section.id }} .card-header-group {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .showcase-{{ section.id }} .card-name {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 20px;
    line-height: 120%;
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
  }

  .showcase-{{ section.id }} .card-subname {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0%;
    color: #000000;
    margin: 0;
  }

  .showcase-{{ section.id }} .card-quote {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 20px;
    line-height: 142%;
    letter-spacing: 0%;
    color: #6E6E6E;
    margin: 0;
  }

  /* --- Tag container --- */
  .showcase-{{ section.id }} .tag-container {
    display: flex;
    flex-wrap: wrap; 
    gap: 10px;
  }

  .showcase-{{ section.id }} .ui-tag {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0%;
    color: #000000;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto; 
    height: 31px;
    padding: 10px 22px; 
    border: 1px solid #000000;
    background: transparent;
    box-sizing: border-box;
    white-space: nowrap;
  }

  /* --- Responsive Framework Adjustments --- */
  @media screen and (max-width: 1199px) {
    .showcase-{{ section.id }} {
      padding: 70px 40px;
    }
    .showcase-{{ section.id }} .showcase-wrapper {
      gap: 40px;
    }
    .showcase-{{ section.id }} .content-column,
    .showcase-{{ section.id }} .interactive-column {
      width: 50%;
      flex-shrink: 1;
    }
    .showcase-{{ section.id }} .card-image-wrapper,
    .showcase-{{ section.id }} .card-text-content {
      width: 100%;
    }
  }

  /* --- Mobile Framework Specification (360px targeted execution) --- */
  @media screen and (max-width: 767px) {
    .showcase-{{ section.id }} {
      padding: 50px 22px;
    }

    .showcase-{{ section.id }} .showcase-wrapper {
      flex-direction: column;
      align-items: center;
      gap: 30px; 
    }

    .showcase-{{ section.id }} .content-column,
    .showcase-{{ section.id }} .interactive-column {
      width: 100%;
      max-width: 322px; 
    }

    .showcase-{{ section.id }} .card-image-wrapper {
      width: 316px;    
      height: 254px;   
      margin-left: auto;
      margin-right: auto;
    }

    .showcase-{{ section.id }} .card-text-content {
      width: 100%;
      padding: 30.67px 40px;
    }

    /* SPECIFIC MOBILE TYPOGRAPHY INJECTIONS */
    .showcase-{{ section.id }} .showcase-heading {
      font-size: 30px;
      line-height: 110%;
      max-width: 276px;
      margin: 0 auto 19px auto;
      text-align: center;
    }

    .showcase-{{ section.id }} .showcase-paragraph {
      font-size: 15px;
      line-height: 100%;
      max-width: 238px;
      margin: 0 auto 30px auto;
      text-align: center;
    }

    /* Explicit mobile enforcement for card elements to match your 360px spec */
    .showcase-{{ section.id }} .location-badge {
      font-size: 16px;
      line-height: 120%;
    }

    .showcase-{{ section.id }} .card-name {
      font-size: 20px;
      line-height: 120%;
    }

    .showcase-{{ section.id }} .card-subname {
      font-size: 16px;
      line-height: 120%;
    }

    .showcase-{{ section.id }} .card-quote {
      font-size: 20px;
      line-height: 142%;
    }

    .showcase-{{ section.id }} .ui-tag {
      font-size: 16px;
      line-height: 120%;
    }

    .showcase-{{ section.id }} .logo-grid-wrapper {
      margin: 0 auto;
      max-width: 322px;
    }

    .showcase-{{ section.id }} .logo-row {
      justify-content: center;
      gap: 16px;
    }

    .showcase-{{ section.id }} .logo-item {
      max-height: 45px;
    }
    .showcase-{{ section.id }} .tag-container {
    display: flex;
    flex-wrap: wrap; 
    gap: 5px;
  }
  }
{%- endstyle -%}

<div class="showcase-{{ section.id }}">
  <div class="showcase-wrapper">
    
    <div class="content-column">
      {%- if section.settings.heading != blank -%}
        <h2 class="showcase-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      
      {%- if section.settings.paragraph != blank -%}
        <p class="showcase-paragraph">{{ section.settings.paragraph }}</p>
      {%- endif -%}

      <div class="logo-grid-wrapper">
        {%- assign total_logo_count = 0 -%}
        <div class="logo-row logo-row-1">
          {%- for block in section.blocks -%}
            {%- if block.type == 'logo' and block.settings.logo_image != blank -%}
              {%- assign total_logo_count = total_logo_count | plus: 1 -%}
              {%- if total_logo_count <= 4 -%}
                <img class="logo-item" 
                     src="{{ block.settings.logo_image | image_url }}" 
                     alt="{{ block.settings.logo_image.alt | escape }}"
                     loading="lazy">
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if total_logo_count > 4 -%}
          {%- assign control_counter = 0 -%}
          <div class="logo-row logo-row-2">
            {%- for block in section.blocks -%}
              {%- if block.type == 'logo' and block.settings.logo_image != blank -%}
                {%- assign control_counter = control_counter | plus: 1 -%}
                {%- if control_counter > 4 -%}
                  <img class="logo-item" 
                       src="{{ block.settings.logo_image | image_url }}" 
                       alt="{{ block.settings.logo_image.alt | escape }}"
                       loading="lazy">
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="interactive-column">
      <div class="interactive-card">
        
        <div class="card-image-wrapper">
          {%- if section.settings.card_image != blank -%}
            <img src="{{ section.settings.card_image | image_url: width: 600 }}" 
                 alt="{{ section.settings.card_image.alt | escape }}" 
                 loading="lazy">
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          {%- if section.settings.badge_text != blank -%}
            <div class="location-badge">{{ section.settings.badge_text | escape }}</div>
          {%- endif -%}
        </div>

        <div class="card-text-content">
          
          <div class="card-header-group">
            {%- if section.settings.card_heading != blank -%}
              <h3 class="card-name">{{ section.settings.card_heading | escape }}</h3>
            {%- endif -%}
            
            {%- if section.settings.card_subheading != blank -%}
              <p class="card-subname">{{ section.settings.card_subheading | escape }}</p>
            {%- endif -%}
          </div>
          
          {%- if section.settings.card_text != blank -%}
            <p class="card-quote">{{ section.settings.card_text }}</p>
          {%- endif -%}

          <div class="tag-container">
            {%- for block in section.blocks -%}
              {%- if block.type == 'pill_tag' -%}
                <span class="ui-tag">{{ block.settings.tag_title | escape }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Asymmetric Showcase",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Block Text",
      "default": "Trusted by thousands."
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph Description Text",
      "default": "We work with races, events, organizers, and outdoor communities who understand that preparation matters."
    },
    {
      "type": "header",
      "content": "Right Side Card Config"
    },
    {
      "type": "image_picker",
      "id": "card_image",
      "label": "Card Feature Image (Auto-Resized)"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Image Badge Text",
      "default": "Location"
    },
    {
      "type": "text",
      "id": "card_heading",
      "label": "Card Heading/Name",
      "default": "Name Here"
    },
    {
      "type": "text",
      "id": "card_subheading",
      "label": "Card Subheading Title",
      "default": "- (Maybe a titleholder here?)"
    },
    {
      "type": "textarea",
      "id": "card_text",
      "label": "Card Quote Content text",
      "default": "\"[Real community or ambassador story — the tag working in the wild.]\""
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Trusted Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Asset Source"
        }
      ]
    },
    {
      "type": "pill_tag",
      "name": "Pill Tag",
      "settings": [
        {
          "type": "text",
          "id": "tag_title",
          "label": "Tag Label Text Content",
          "default": "Trans-Rockies"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Asymmetric Showcase",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "pill_tag" },
        { "type": "pill_tag" },
        { "type": "pill_tag" }
      ]
    }
  ]
}
{% endschema %}