{%- style -%}
  /* --- Typography Registration --- */
  @font-face {
    font-family: 'Elza';
    font-weight: 300;
    font-style: normal;
  }
  @font-face {
    font-family: 'Outfit';
    font-weight: 400;
    font-style: normal;
  }

  .showcase-{{ section.id }} {
    width: 100%;
    padding: 70px 222.08px; /* Strict desktop layout parameters */
    background-color: {{ section.settings.bg_color }};
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .showcase-wrapper {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 60px; /* Precise column-to-column distance */
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  /* --- Left Column: Text Content Handling --- */
  .showcase-{{ section.id }} .content-column {
    width: 433.84px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .showcase-heading {
    font-family: 'Elza', sans-serif;
    font-weight: 300;
    font-size: 48px;
    line-height: 1.1;
    color: #000000;
    margin: 0 0 45px 0; /* Gap between heading and paragraph: 45px */
    padding: 0;
  }

  .showcase-{{ section.id }} .showcase-paragraph {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 140%;
    color: #333333;
    margin: 0 0 38px 0; /* Gap between paragraph and logo element: 38px */
    padding: 0;
  }

  /* --- Logo Element Stack Rules --- */
  .showcase-{{ section.id }} .logo-grid-wrapper {
    display: flex;
    flex-direction: column;
    gap: 30px; /* Vertical gap between stacked logo arrays */
    width: 100%;
    max-width: 322px;
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .logo-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }

  .showcase-{{ section.id }} .logo-item {
    height: auto;
    max-height: 35px;
    object-fit: contain;
  }

  /* --- Right Column: Interactive Frame --- */
  .showcase-{{ section.id }} .interactive-column {
    width: 502px;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .showcase-{{ section.id }} .interactive-card {
    width: 100%;
    background: #f9f9f9;
    border-radius: 8px;
    padding: 30px;
    box-sizing: border-box;
  }

  /* --- Micro-Figma Component Tags implementation --- */
  .showcase-{{ section.id }} .tag-container {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .showcase-{{ section.id }} .ui-tag {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%; /* 11px computed inner box height equivalent */
    color: #000000;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 148px;
    padding: 10px 24px; /* Matches Figma specifications exactly */
    border: 1px solid #000000;
    background: transparent;
    box-sizing: border-box;
    white-space: nowrap;
  }

  /* --- Responsive Framework Adjustments --- */
  @media screen and (max-width: 1199px) {
    .showcase-{{ section.id }} {
      padding: 70px 40px;
    }
    .showcase-{{ section.id }} .showcase-wrapper {
      gap: 40px;
    }
    .showcase-{{ section.id }} .content-column,
    .showcase-{{ section.id }} .interactive-column {
      width: 50%;
      flex-shrink: 1;
    }
  }

  /* --- Mobile Framework Specification (360px targeted execution) --- */
  @media screen and (max-width: 767px) {
    .showcase-{{ section.id }} {
      padding: 70px 22px; /* Set precisely to your required 22px left and right bounds */
    }

    .showcase-{{ section.id }} .showcase-wrapper {
      flex-direction: column;
      align-items: center;
      gap: 50px; /* Adjusted context spacing for vertical block rhythm flow */
    }

    .showcase-{{ section.id }} .content-column,
    .showcase-{{ section.id }} .interactive-column {
      width: 100%;
      max-width: 322px; /* Strictly enforces alignment tracking inside mobile views */
    }

    .showcase-{{ section.id }} .showcase-heading {
      font-size: 32px;
      margin-bottom: 30px;
      text-align: center;
    }

    .showcase-{{ section.id }} .showcase-paragraph {
      text-align: center;
      margin-bottom: 35px;
    }

    .showcase-{{ section.id }} .logo-grid-wrapper {
      margin: 0 auto;
    }

    .showcase-{{ section.id }} .logo-row {
      justify-content: center;
    }
  }
{%- endstyle -%}

<div class="showcase-{{ section.id }}">
  <div class="showcase-wrapper">
    
    <div class="content-column">
      {%- if section.settings.heading != blank -%}
        <h2 class="showcase-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      
      {%- if section.settings.paragraph != blank -%}
        <p class="showcase-paragraph">{{ section.settings.paragraph }}</p>
      {%- endif -%}

      <div class="logo-grid-wrapper">
        <div class="logo-row">
          {%- for block in section.blocks -%}
            {%- if block.type == 'logo' -%}
              {%- if block.settings.logo_image != blank -%}
                <img class="logo-item" 
                     src="{{ block.settings.logo_image | image_url: width: 300 }}" 
                     alt="{{ block.settings.logo_image.alt | escape }}"
                     loading="lazy">
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="interactive-column">
      <div class="interactive-card">
        {%- if section.settings.card_heading != blank -%}
          <h3 style="font-family: 'Elza', sans-serif; font-weight:300; margin: 0 0 15px 0;">{{ section.settings.card_heading | escape }}</h3>
        {%- endif -%}
        
        {%- if section.settings.card_text != blank -%}
          <p style="font-family: 'Outfit', sans-serif; font-size:15px; margin:0 0 20px 0;">{{ section.settings.card_text }}</p>
        {%- endif -%}

        <div class="tag-container">
          {%- for block in section.blocks -%}
            {%- if block.type == 'pill_tag' -%}
              <span class="ui-tag">{{ block.settings.tag_title | escape }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Asymmetric Showcase",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Block Text",
      "default": "Trusted by thousands."
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph Description Text",
      "default": "We work with races, events, organizers, and outdoor communities who understand that preparation matters."
    },
    {
      "type": "header",
      "content": "Right Container Management Settings"
    },
    {
      "type": "text",
      "id": "card_heading",
      "label": "Card Widget Heading",
      "default": "Name Here"
    },
    {
      "type": "textarea",
      "id": "card_text",
      "label": "Card Widget Quote Text",
      "default": "\"[Real community or ambassador story — the tag working in the wild.]\""
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Trusted Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Asset Source"
        }
      ]
    },
    {
      "type": "pill_tag",
      "name": "Pill Tag",
      "settings": [
        {
          "type": "text",
          "id": "tag_title",
          "label": "Tag Label Text Content",
          "default": "Trans-Rockies"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Asymmetric Showcase",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "pill_tag" },
        { "type": "pill_tag" },
        { "type": "pill_tag" }
      ]
    }
  ]
}
{% endschema %}