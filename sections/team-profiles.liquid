<div id="our-team">
  <div id="TeamProfiles-{{ section.id }}" class="team-profiles-section">
  <div class="team-profiles__container" >
    
    {%- if section.settings.heading != blank or section.settings.paragraph != blank -%}
      <div class="team-profiles__header-group">
        {%- if section.settings.heading != blank -%}
          <h2 class="team-profiles__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.paragraph != blank -%}
          <div class="team-profiles__paragraph">
            {{ section.settings.paragraph }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="team-profiles__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'team_member' -%}
          <div class="team-profiles__card" {{ block.shopify_attributes }}>
            <div class="team-profiles__image-wrapper">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 824 | image_tag: 
                  loading: 'lazy', 
                  class: 'team-profiles__img',
                  sizes: '(max-width: 767px) 305px, 412px',
                  alt: block.settings.name | default: 'Team member image'
                }}
              {%- else -%}
                <div class="team-profiles__img-placeholder"></div>
              {%- endif -%}
            </div>
            
            <div class="team-profiles__text-wrapper">
              {%- if block.settings.name != blank -%}
                <h3 class="team-profiles__name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="team-profiles__role">{{ block.settings.role | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>
</div>

{% style %}
  /* Base structural reset isolated strictly to this section instance */
  #TeamProfiles-{{ section.id }}.team-profiles-section {
    background-color: #FFFFFF;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: center;
  }
  #TeamProfiles-{{ section.id }} * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* -------------------------------------------------------------------------
     DESKTOP SPECIFICATIONS (Fluid layout anchored at 1440px Max Canvas)
     ------------------------------------------------------------------------- */
  @media screen and (min-width: 768px) {
    #TeamProfiles-{{ section.id }} .team-profiles__container {
      width: 100%;
      max-width: 1440px;
      padding: 60px 81px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__header-group {
      width: 100%;
      max-width: 776px;
      min-height: 135px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 67px;
      text-align: center;
    }
    /* Specific element + class combinator overrides theme stylesheets safely */
    #TeamProfiles-{{ section.id }} h2.team-profiles__heading {
      font-family: 'Elza', sans-serif;
      font-size: 60px;
      font-weight: 300;
      line-height: 110%;
      letter-spacing: 0%;
      color: #000000;
      margin: 0;
      padding: 0;
      text-transform: none;
    }
    /* Strictly layout elements inside the paragraph wrapper block */
    #TeamProfiles-{{ section.id }} .team-profiles__paragraph p {
      font-family: 'Elza', sans-serif;
      font-size: 20px;
      font-weight: 400;
      line-height: 120%;
      letter-spacing: 0%;
      color: #000000;
      width: 100%;
      margin: 0;
      padding: 0;
      text-align: center;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__grid {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 21px;
      width: 100%;
      max-width: 1278px;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__card {
      width: 412px;
      min-height: 414px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__image-wrapper {
      width: 412px;
      height: 334px;
      overflow: hidden;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__img, 
    #TeamProfiles-{{ section.id }} .team-profiles__img-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__img-placeholder {
      background-color: #C4C4C4;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__text-wrapper {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 5px;
      text-align: center;
    }
    #TeamProfiles-{{ section.id }} h3.team-profiles__name {
      font-family: 'Elza', sans-serif;
      font-size: 30px;
      font-weight: 700;
      line-height: 100%;
      letter-spacing: 0%;
      text-transform: uppercase;
      color: #000000;
      margin: 0;
    }
    #TeamProfiles-{{ section.id }} p.team-profiles__role {
      font-family: 'Elza', sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 100%;
      letter-spacing: 0%;
      color: #595959;
      margin: 0;
    }
  }

  /* -------------------------------------------------------------------------
     MOBILE SPECIFICATIONS (Fluid layout anchored at 360px Canvas)
     ------------------------------------------------------------------------- */
  @media screen and (max-width: 767px) {
    #TeamProfiles-{{ section.id }}.team-profiles-section {
      padding: 70px 0;
      width: 100%;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__container {
      width: 100%;
      max-width: 360px;
      padding: 0 27.5px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 30px;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__header-group {
      width: 274px;
      min-height: 149px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
    #TeamProfiles-{{ section.id }} h2.team-profiles__heading {
      font-family: 'Elza', sans-serif;
      font-size: 30px;
      font-weight: 300;
      line-height: 110%;
      letter-spacing: 0%;
      color: #000000;
      margin: 0;
      padding: 0;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__paragraph p {
      font-family: 'Elza', sans-serif;
      font-size: 15px;
      font-weight: 400;
      line-height: 120%;
      letter-spacing: 0%;
      color: #000000;
      width: 274px;
      margin: 0;
      padding: 0;
      text-align: center;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      width: 305px;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__card {
      width: 305px;
      height: 313.9px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__image-wrapper {
      width: 305px;
      height: 246.9px;
      overflow: hidden;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__img, 
    #TeamProfiles-{{ section.id }} .team-profiles__img-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__img-placeholder {
      background-color: #C4C4C4;
    }
    #TeamProfiles-{{ section.id }} .team-profiles__text-wrapper {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 5px;
      text-align: center;
    }
    #TeamProfiles-{{ section.id }} h3.team-profiles__name {
      font-family: 'Elza', sans-serif;
      font-size: 20px;
      font-weight: 700;
      line-height: 100%;
      letter-spacing: 0%;
      text-transform: uppercase;
      color: #000000;
      margin: 0;
    }
    #TeamProfiles-{{ section.id }} p.team-profiles__role {
      font-family: 'Elza', sans-serif;
      font-size: 15px;
      font-weight: 400;
      line-height: 100%;
      letter-spacing: 0%;
      color: #595959;
      margin: 0;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Team Profiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The people behind it."
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Description Paragraph",
      "default": "<p>We're a small team with backgrounds in the outdoor and powersports industries. Building products for the outdoor community taught us a lot about adventure. KOPILOT.ID was born from what we learned along the way.</p>"
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Member Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "JUSTIN"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Co-founder"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Profiles",
      "blocks": [
        {
          "type": "team_member",
          "settings": {
            "name": "JUSTIN",
            "role": "Co-founder"
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "MARK",
            "role": "Co-founder"
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "BLAKE",
            "role": "Community & Content"
          }
        }
      ]
    }
  ]
}
{% endschema %}