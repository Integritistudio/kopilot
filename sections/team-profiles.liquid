<div id="TeamProfiles-{{ section.id }}" class="team-profiles-section">
  <div class="team-profiles__container">
    
    {%- if section.settings.heading != blank or section.settings.paragraph != blank -%}
      <div class="team-profiles__header-group">
        {%- if section.settings.heading != blank -%}
          <h2 class="team-profiles__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.paragraph != blank -%}
          <div class="team-profiles__paragraph">{{ section.settings.paragraph }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="team-profiles__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'team_member' -%}
          <div class="team-profiles__card" {{ block.shopify_attributes }}>
            <div class="team-profiles__image-wrapper">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 824 | image_tag: 
                  loading: 'lazy', 
                  class: 'team-profiles__img',
                  sizes: '(max-width: 767px) 305px, 412px',
                  alt: block.settings.name | default: 'Team member image'
                }}
              {%- else -%}
                <div class="team-profiles__img-placeholder"></div>
              {%- endif -%}
            </div>
            
            <div class="team-profiles__text-wrapper">
              {%- if block.settings.name != blank -%}
                <h3 class="team-profiles__name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="team-profiles__role">{{ block.settings.role | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% style %}
  /* Base & Structural Defaults */
  #TeamProfiles-{{ section.id }} {
    background-color: #FFFFFF;
    width: 100%;
    box-sizing: border-box;
    font-family: 'Elza', sans-serif;
  }
  #TeamProfiles-{{ section.id }} * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* -------------------------------------------------------------------------
     DESKTOP SPECIFICATIONS (Fluid targeting 1440px Canvas)
     ------------------------------------------------------------------------- */
  @media screen and (min-width: 768px) {
    .team-profiles-section {
      padding: 60px 81px;
    }
    .team-profiles__container {
      max-width: 1278px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .team-profiles__header-group {
      width: 776px;
      min-height: 135px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 67px !important; 
      text-align: center;
    }
    .team-profiles__heading {
      font-size: 60px;
      font-weight: 300;
      line-height: 110%;
      letter-spacing: 0%;
      color: #000000;
    }
    .team-profiles__paragraph {
      font-size: 20px;
      font-weight: 400;
      line-height: 120%;
      letter-spacing: 0%;
      color: #000000;
      width: 776px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .team-profiles__grid {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 21px; /* Exact desktop column layout gap */
      width: 1278px;
    }
    .team-profiles__card {
      width: 412px;
      min-height: 414px;
      display: flex;
      flex-direction: column;
      gap: 20px; /* Exact desktop internal card layout gap */
    }
    .team-profiles__image-wrapper {
      width: 412px;
      height: 334px;
      overflow: hidden;
    }
    .team-profiles__img, 
    .team-profiles__img-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .team-profiles__img-placeholder {
      background-color: #C4C4C4;
    }
    .team-profiles__text-wrapper {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 5px; /* Exact layout gap between name and role */
      text-align: center;
    }
    .team-profiles__name {
      font-size: 30px;
      font-weight: 700;
      line-height: 100%;
      letter-spacing: 0%;
      text-transform: uppercase;
      color: #000000;
    }
    .team-profiles__role {
      font-size: 16px;
      font-weight: 400;
      line-height: 100%;
      letter-spacing: 0%;
      color: #595959;
    }
  }

  /* -------------------------------------------------------------------------
     MOBILE SPECIFICATIONS (Fluid targeting 360px Canvas)
     ------------------------------------------------------------------------- */
  @media screen and (max-width: 767px) {
    .team-profiles-section {
      padding: 70px 0; /* Vertically exact layout padding */
      display: flex;
      justify-content: center;
    }
    .team-profiles__container {
      width: 100%;
      max-width: 360px;
      padding: 0 27.5px; /* Centers the content neatly to honor elements widths */
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 30px; /* Exact mobile section gap between blocks */
    }
    .team-profiles__header-group {
      width: 274px;
      min-height: 149px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
    .team-profiles__heading {
      font-size: 30px;
      font-weight: 300;
      line-height: 110%;
      letter-spacing: 0%;
      color: #000000;
    }
    .team-profiles__paragraph {
      font-size: 15px;
      font-weight: 400;
      line-height: 120%;
      letter-spacing: 0%;
      color: #000000;
      width: 274px;
    }
    .team-profiles__grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px; /* Exact mobile card stack container layout gap */
      width: 305px;
    }
    .team-profiles__card {
      width: 305px;
      height: 313.9px;
      display: flex;
      flex-direction: column;
      gap: 20px; /* Internal content gap stays 20px on mobile */
    }
    .team-profiles__image-wrapper {
      width: 305px;
      height: 246.9px; /* Derived pixel perfect height matching overall card dimensions minus font heights and spacing elements */
      overflow: hidden;
    }
    .team-profiles__img, 
    .team-profiles__img-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .team-profiles__img-placeholder {
      background-color: #C4C4C4;
    }
    .team-profiles__text-wrapper {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 5px;
      text-align: center;
    }
    .team-profiles__name {
      font-size: 20px;
      font-weight: 700;
      line-height: 100%;
      letter-spacing: 0%;
      text-transform: uppercase;
      color: #000000;
    }
    .team-profiles__role {
      font-size: 15px;
      font-weight: 400;
      line-height: 100%;
      letter-spacing: 0%;
      color: #595959;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Team Profiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The people behind it."
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Description Paragraph",
      "default": "<p>We're a small team with backgrounds in the outdoor and powersports industries. Building products for the outdoor community taught us a lot about adventure. KOPILOT.ID was born from what we learned along the way.</p>"
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Member Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "JUSTIN"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Co-founder"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Profiles",
      "blocks": [
        {
          "type": "team_member",
          "settings": {
            "name": "JUSTIN",
            "role": "Co-founder"
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "MARK",
            "role": "Co-founder"
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "BLAKE",
            "role": "Community & Content"
          }
        }
      ]
    }
  ]
}
{% endschema %}