{% style %}
  .kopilot-ambassadors--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 989px) {
    .kopilot-ambassadors--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-ambassadors.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-ambassadors kopilot-ambassadors--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-ambassadors__header">
    {% if section.settings.heading != blank %}
      <h2 class="kopilot-ambassadors__heading kopilot-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="kopilot-ambassadors__text kopilot-body">{{ section.settings.text }}</p>
    {% endif %}
  </div>

  {% assign ambassador_fallbacks = 'kopilot-ambassador-hillary.jpg,kopilot-ambassador-breck.jpg,kopilot-ambassador-kait.jpg' | split: ',' %}

  <div class="kopilot-ambassadors__slider">
    <swiper-section
      data-slides-desktop="3"
      data-slides-tablet="2"
      data-slides-mobile="1.15"
      data-gap="24"
      data-loop="false"
      data-center-mode="false"
    >
      <div class="swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <article class="kopilot-ambassadors__card">
                <div class="kopilot-ambassadors__card-media">
                  {% render 'kopilot-image',
                    image: block.settings.image,
                    fallback: ambassador_fallbacks[forloop.index0],
                    alt: block.settings.name,
                    width: 800
                  %}
                  {% if block.settings.badge != blank %}
                    <span class="kopilot-ambassadors__badge">{{ block.settings.badge }}</span>
                  {% endif %}
                </div>
                <div class="kopilot-ambassadors__card-body">
                  {% if block.settings.name != blank %}
                    <p class="kopilot-ambassadors__name kopilot-body">{{ block.settings.name }}</p>
                  {% endif %}
                  {% if block.settings.role != blank %}
                    <p class="kopilot-ambassadors__role kopilot-body">{{ block.settings.role }}</p>
                  {% endif %}
                  {% if block.settings.quote != blank %}
                    <p class="kopilot-ambassadors__quote kopilot-body">{{ block.settings.quote }}</p>
                  {% endif %}
                </div>
              </article>
            </div>
          {% endfor %}
        </div>
      </div>
    </swiper-section>
  </div>

  {% if section.settings.show_progress %}
    <div class="kopilot-ambassadors__progress">
      <div class="kopilot-ambassadors__progress-bar">
        <div class="kopilot-ambassadors__progress-fill"></div>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Kopilot Ambassadors",
  "tag": "section",
  "class": "kopilot-ambassadors-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Used on race day and every day in between."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "From race days to training days to fun-focused days, KOPILOT.ID gives riders the confidence to push their limits, knowing help will have the information they need if something goes wrong."
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show progress bar",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Ambassador" },
        { "type": "text", "id": "name", "label": "Name", "default": "Hillary Allen" },
        { "type": "text", "id": "role", "label": "Role", "default": "- Team USA // Ultra Marathon Trail Runner" },
        { "type": "textarea", "id": "quote", "label": "Quote" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Ambassadors",
      "blocks": [
        { "type": "card", "settings": { "badge": "Ambassador", "name": "Hillary Allen", "role": "- Team USA // Ultra Marathon Trail Runner" } },
        { "type": "card", "settings": { "badge": "Event", "name": "The Breck Epic", "role": "Renowned Multi-Stage Mountain Bike Race" } },
        { "type": "card", "settings": { "badge": "Ambassador", "name": "Kait Boyle", "role": "- Cyclist" } }
      ]
    }
  ]
}
{% endschema %}
