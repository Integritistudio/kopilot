{% style %}
  .kopilot-ambassadors--{{ section.id }} {
    --kopilot-ambassadors-pad-y: {{ section.settings.padding_top }}px;
  }

  .kopilot-ambassadors--{{ section.id }} .kopilot-ambassadors__inner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-ambassadors--{{ section.id }} {
      --kopilot-ambassadors-pad-y: {{ section.settings.padding_top_mobile }}px;
    }

    .kopilot-ambassadors--{{ section.id }} .kopilot-ambassadors__inner {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-ambassadors.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kopilot-ambassadors.js' | asset_url }}" defer></script>

<section id="kopilot-brand-ambassador" class="kopilot-section kopilot-ambassadors kopilot-ambassadors--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-ambassadors__inner">
    <div class="kopilot-ambassadors__header">
      {% if section.settings.heading != blank %}
        <h2 class="kopilot-ambassadors__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p class="kopilot-ambassadors__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    {% assign ambassador_fallbacks = 'kopilot-ambassador-hillary.jpg,kopilot-ambassador-breck.jpg,kopilot-ambassador-kait.jpg,kopilot-ambassador-karen.jpg,kopilot-ambassador-hillary.jpg,kopilot-ambassador-breck.jpg' | split: ',' %}

    <div class="kopilot-ambassadors__slider-group">
      <div class="kopilot-ambassadors__slider">
        <div class="swiper kopilot-ambassadors__swiper">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% assign fallback_index = forloop.index0 | modulo: ambassador_fallbacks.size %}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <article class="kopilot-ambassadors__card">
                  <div class="kopilot-ambassadors__card-media">
                    {% render 'kopilot-image',
                      image: block.settings.image,
                      fallback: ambassador_fallbacks[fallback_index],
                      alt: block.settings.name,
                      width: 800
                    %}
                    {% if block.settings.badge != blank %}
                      <span class="kopilot-ambassadors__badge">{{ block.settings.badge }}</span>
                    {% endif %}
                  </div>
                  <div class="kopilot-ambassadors__card-body">
                    <div class="kopilot-ambassadors__card-meta">
                      {% if block.settings.name != blank %}
                        <p class="kopilot-ambassadors__name">{{ block.settings.name }}</p>
                      {% endif %}
                      {% if block.settings.role != blank %}
                        <p class="kopilot-ambassadors__role">{{ block.settings.role }}</p>
                      {% endif %}
                    </div>
                    {% if block.settings.quote != blank %}
                      <p class="kopilot-ambassadors__quote">{{ block.settings.quote }}</p>
                    {% endif %}
                  </div>
                </article>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {% if section.settings.show_progress %}
        <div class="kopilot-ambassadors__progress">
          <div class="kopilot-ambassadors__progress-track">
            <div class="kopilot-ambassadors__progress-fill"></div>
          </div>
        </div>
      {% endif %}

      <div class="kopilot-ambassadors__nav" aria-label="Ambassador slider navigation">
        <button type="button" class="kopilot-ambassadors__nav-btn kopilot-ambassadors__nav-btn--prev" aria-label="Previous slide">
          <img src="{{ 'vl.svg' | asset_url }}" alt="" width="13" height="19" loading="lazy">
        </button>
        <button type="button" class="kopilot-ambassadors__nav-btn kopilot-ambassadors__nav-btn--next" aria-label="Next slide">
          <img src="{{ 'vr.svg' | asset_url }}" alt="" width="13" height="19" loading="lazy">
        </button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot Ambassadors",
  "tag": "section",
  "class": "kopilot-ambassadors-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Used on race day and every day in between."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "From race days to training days to fun-focused days, KOPILOT.ID gives riders the confidence to push their limits, knowing help will have the information they need if something goes wrong."
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show progress bar",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Ambassador" },
        { "type": "text", "id": "name", "label": "Name", "default": "Hillary Allen" },
        { "type": "text", "id": "role", "label": "Role", "default": "- Team USA // Ultra Marathon Trail Runner" },
        { "type": "textarea", "id": "quote", "label": "Quote" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kopilot Ambassadors",
      "blocks": [
        { "type": "card", "settings": { "badge": "Ambassador", "name": "Hillary Allen", "role": "- Team USA // Ultra Marathon Trail Runner" } },
        { "type": "card", "settings": { "badge": "Event", "name": "The Breck Epic", "role": "Renowned Multi-Stage Mountain Bike Race" } },
        { "type": "card", "settings": { "badge": "Ambassador", "name": "Kait Boyle", "role": "- Cyclist" } }
      ]
    }
  ]
}
{% endschema %}
