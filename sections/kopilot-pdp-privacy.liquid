{% style %}
  .kopilot-pdp-privacy--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
.kopilot-pdp-privacy__heading_pdp {
  font-family: 'Elza', sans-serif;
  font-weight: 300;
  font-style: normal; 
  font-size: 60px;
  line-height: 1.1; 
  letter-spacing: 0%;
}
div.kopilot-pdp-privacy__text.kopilot-body.rte > p {
  font-size: 20px;
}
  .kopilot-pdp-privacy__text kopilot-body rte p{
    font-weight:400;
    font-size:12px;
    line-height:120%;
    letter-spacing:0%;
  }

  @media screen and (max-width: 767px) {
    .kopilot-pdp-privacy--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-pdp-privacy.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-pdp-privacy kopilot-pdp-privacy--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-pdp-privacy__inner">
    <div class="kopilot-pdp-privacy__icon">
      {% render 'kopilot-image',
        image: section.settings.icon,
        fallback: 'kopilot-pdp-privacy-icon.png',
        alt: '',
        width: 230
      %}
    </div>
    <div class="kopilot-pdp-privacy__content">
      {% if section.settings.heading != blank %}
        <h2 class="kopilot-pdp-privacy__heading_pdp">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="kopilot-pdp-privacy__text kopilot-body rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot PDP privacy",
  "tag": "section",
  "class": "kopilot-pdp-privacy-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built with privacy in mind."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Choose what's visible, update your profile anytime, and manage everything directly from the app. If a tag is ever lost, you can deactivate it instantly.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32
    }
  ],
  "presets": [{ "name": "Kopilot PDP privacy" }]
}
{% endschema %}
