{% style %}
  .kopilot-pdp-privacy--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    display: flex;
    justify-content: center;
    background-color: inherit;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__inner {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1440px;
    padding: 0 80px; /* Adjust this to match your global page container side padding */
    margin: 0 auto;
    box-sizing: border-box;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__icon {
    width: 115px;
    height: 115px;
    flex-shrink: 0;
    margin-right: 99px; /* Exact pixel gap from Figma blueprint */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__icon img,
  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__content {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    flex-grow: 1;
    gap: 20px;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__heading {
    font-family: "Elza", sans-serif;
    font-size: 60px;
    font-weight: 300;
    line-height: 1.1; /* 110% line height */
    margin: 0;
    width: 100%;
    max-width: 465px; /* Exact box boundary from Figma */
    letter-spacing: 0%;
    text-align: left;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__text {
    font-family: "Figtree", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2; /* 120% line height */
    width: 100%;
    max-width: 404px; /* Exact box boundary from Figma */
    letter-spacing: 0%;
    text-align: left;
  }

  .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__text p {
    margin: 0;
  }

  /* Responsive styling to gracefully degrade on smaller screens */
  @media screen and (max-width: 1024px) {
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__inner {
      padding: 0 40px;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__icon {
      margin-right: 40px;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__heading {
      font-size: 44px;
    }
  }

  @media screen and (max-width: 767px) {
    .kopilot-pdp-privacy--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 0 20px;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__icon {
      margin-right: 0;
      width: 80px;
      height: 80px;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__content {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      width: 100%;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__heading {
      font-size: 32px;
      max-width: 100%;
    }
    .kopilot-pdp-privacy--{{ section.id }} .kopilot-pdp-privacy__text {
      font-size: 16px;
      max-width: 100%;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-pdp-privacy.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-pdp-privacy kopilot-pdp-privacy--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-pdp-privacy__inner">
    <div class="kopilot-pdp-privacy__icon">
      {% render 'kopilot-image',
        image: section.settings.icon,
        fallback: 'kopilot-pdp-privacy-icon.png',
        alt: '',
        width: 115
      %}
    </div>
    <div class="kopilot-pdp-privacy__content">
      {% if section.settings.heading != blank %}
        <h2 class="kopilot-pdp-privacy__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="kopilot-pdp-privacy__text kopilot-body rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot PDP privacy",
  "tag": "section",
  "class": "kopilot-pdp-privacy-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built with privacy in mind."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Choose what's visible, update your profile anytime, and manage everything directly from the app. If a tag is ever lost, you can deactivate it instantly.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [{ "name": "Kopilot PDP privacy" }]
}
{% endschema %}