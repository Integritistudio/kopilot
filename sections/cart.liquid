{% style %}
  .main_cart_wrapper--{{ section.id }} {
    padding-top: {{ section.settings.top_spacing }}px;
    padding-bottom: {{ section.settings.bottom_spacing }}px;
  }
{% endstyle %}

{{ 'main-cart.css' | asset_url | stylesheet_tag }}

<cart-drawer>
  <div class="main_cart_wrapper--{{ section.id }} color-{{ section.settings.color_scheme }}">
    <div class="container">
      {% if section.settings.show_breadcrumbs %}
        {% render 'breadcrumbs' %}
      {% endif %}

      <div class="main_cart_contents_wrapper">
        <div class="main_cart_confetti_layer" aria-hidden="true"></div>
        {% if section.settings.show_title %}
          <div class="main_cart_header">
            <h1>
              {{ 'templates.cart.cart' | t }}
              {{ cart.item_count | prepend: '(' | append: ')' }}
            </h1>

            {% if cart != empty %}
              <a
                href="{{ routes.all_products_collection_url }}"
                class="btn"
                aria-label="{{ 'general.continue_shopping' | t }}">
                {{- 'general.continue_shopping' | t -}}
              </a>
            {% endif %}
          </div>
        {% endif %}

        {% if cart != empty %}
        {% render 'free-shipping-bar' %}
        {% endif %}


        {% if cart == empty %}
          <div class="empty_main_cart_wrapper">
            <h2 class="h4">{{ 'drawers.cart_drawer.empty_drawer_heading' | t }}</h2>
            <a
              class="btn"
              href="{{ routes.all_products_collection_url }}"
              aria-label="{{ 'general.continue_shopping' | t }}">
              {{- 'general.continue_shopping' | t -}}
            </a>
          </div>
        {% endif %}

        {% if cart != empty %}
          <div class="main_cart_content_inner">
            {% for item in cart.items %}
              <div class="main_cart_item_block">
                <div class="main_cart_item_img_block">
                  <a href="{{ item.url }}" aria-label="{{ item.title }}">{{ item.title }}</a>
                  {% if item.image != blank %}
                    {{ item.image | image_url: width: 500 | image_tag }}
                  {% else %}
                    {% assign img_index = forloop.index0 | modulo: 3 %}

                    {% if img_index == 0 %}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder_svg' }}
                    {% elsif img_index == 1 %}
                      {{ 'product-2' | placeholder_svg_tag: 'placeholder_svg' }}
                    {% else %}
                      {{ 'product-3' | placeholder_svg_tag: 'placeholder_svg' }}
                    {% endif %}
                  {% endif %}
                </div>

                <div class="main_cart_item_info_block">
                  <p>
                    <a href="{{ item.url }}" aria-label="{{ item.title }}">{{ item.product.title }}</a>
                  </p>
                  <div class="main_cart_item_price">
                    {% if item.original_price != item.final_price %}
                      <div class="main_cart_price_inner">
                        <span>{{ item.final_price | money }}</span>
                        <s>{{ item.original_price | money }}</s>
                      </div>
                      <span class="main_cart_price_discount_list">
                        {%- for discount in item.line_level_discount_allocations -%}
                          <span class="main_cart_item_discount">
                            {{ 'icon-discount.svg' | inline_asset_content }}
                            {{ discount.discount_application.title }}
                          </span>
                        {% endfor %}
                      </span>
                    {% else %}
                      <div class="main_cart_price_inner">
                        <span>{{ item.final_price | money }}</span>
                        {% if item.variant.compare_at_price != blank and item.variant.compare_at_price > 0 and item.variant.compare_at_price > item.variant.price
                        %}
                          <s>{{ item.variant.compare_at_price | money }}</s>
                        {% endif %}
                      </div>
                    {% endif %}

                    {%- if item.variant.available and item.unit_price_measurement -%}
                      <p class="main_cart_unit_price">
                        <span>{{ 'products.product.price.unit_price' | t }}:
                        </span>
                        {{ item.unit_price | money }}
                        <span>/</span>
                        <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                        {%- if item.unit_price_measurement.reference_value != 1 -%}
                          {{- item.unit_price_measurement.reference_value -}}
                        {%- endif -%}
                        {{ item.unit_price_measurement.reference_unit }}
                      </p>
                    {%- endif -%}
                  </div>

                  <div class="main_cart_item_options_wrapper">
                    {% unless item.product.has_only_default_variant %}
                      <p class="main_cart_item_product_options">
                        {% for option in item.options_with_values %}
                          <span>{{- option.value -}}</span>
                          {% unless forloop.last %}
                            <span class="separator">|</span>
                          {% endunless %}
                        {% endfor %}
                      </p>
                    {% endunless %}

                    {% if item.properties.size != 0 %}
                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          <div class="main_cart_item_properties_wrapper">
                            <div class="main_cart_item_property_name">{{ property.first }}:</div>
                            <div class="main_cart_item_property_value">
                              {%- if property.last contains '/uploads/' -%}
                                <a
                                  href="{{ property.last }}"
                                  class="link"
                                  target="_blank"
                                  aria-describedby="a11y-new-window-message">
                                  {{ property.last | split: '/' | last }}
                                </a>
                              {%- else -%}
                                {{ property.last }}
                              {%- endif -%}
                            </div>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    {% endif %}

                    {% if item.selling_plan_allocation != null %}
                      <p class="main_cart_item_selling_plan">
                        {{ item.selling_plan_allocation.selling_plan.name }}
                      </p>
                    {% endif %}
                  </div>

                  <div
                    class="cart_error"
                    data-line="{{ forloop.index }}"
                    hidden>
                    A maximum of 5 items are added due to availability.
                  </div>
                </div>

                <div class="main_cart_item_quantity_block">
                  <cart-quantity-picker data-line="{{ forloop.index }}">
                    <button
                      type="button"
                      class="btn_minus"
                      data-minus
                      aria-label="{{ 'products.product.quantity_decrease' | t }}"
                      data-quantity="{{ item.quantity | minus: 1 }}"
                      data-min="{{ item.quantity }} - {{ item.variant.quantity_rule.min }}"
                      {% if item.quantity == item.variant.quantity_rule.min %}
                      disabled
                      {% endif %}>
                      <span class="cq_hori"></span>
                    </button>

                    <input
                      type="text"
                      name="quantity"
                      min="{{ item.variant.quantity_rule.min }}"
                      data-min="{{ item.variant.quantity_rule.min }}"
                      {% if item.variant.quantity_rule.max %}
                      data-max="{{item.variant.quantity_rule.max }}"
                      max="{{ item.variant.quantity_rule.max }}"
                      {% endif %}
                      step="{{item.variant.quantity_rule.increment }}"
                      value="{{ item.quantity }}"
                      id="Item_quantity-{{ forloop.index }}">
                    <label class="visually-hidden" for="Item_quantity-{{ forloop.index }}">
                      {{- 'products.product.quantity' | t -}}
                    </label>

                    <button
                      type="button"
                      aria-label="{{ 'products.product.quantity_increase' | t }}"
                      class="btn_plus"
                      data-plus
                      data-quantity="{{ item.quantity | plus: 1 }}"
                      {% if item.quantity == item.variant.quantity_rule.max %}
                      disabled
                      {% endif %}>
                      <span class="cq_hori"></span>
                      <span class="cq_vert"></span>
                    </button>
                  </cart-quantity-picker>
                </div>

                <div class="main_cart_item_total_price_block">
                  {% if item.original_line_price != item.final_line_price %}
                    <div class="main_cart_item_price_inner">
                      <span>{{ item.final_line_price | money }}</span>
                      <s>{{ item.original_line_price | money }}</s>
                    </div>
                    <span class="main_cart_item_price_discount_list">
                      {%- for discount in item.line_level_discount_allocations -%}
                        <span class="main_cart_item_discount">
                          {{ 'icon-discount.svg' | inline_asset_content }}
                          {{ discount.discount_application.title }}
                        </span>
                      {% endfor %}
                    </span>
                  {% else %}
                    <div class="main_cart_item_price_inner">
                      <span>{{ item.final_line_price | money }}</span>
                    </div>
                  {% endif %}

                </div>

                <div class="main_cart_item_delete_block">
                  <item-remove data-line="{{ forloop.index }}">
                    <a
                      aria-label="{{- 'drawers.cart_drawer.remove' | t -}}"
                      class="item_remove_btn"
                      href="{{ item.url_to_remove }}"
                      data-remove
                      data-quantity="0">
                      {{ 'icon-trash.svg' | inline_asset_content }}
                    </a>
                  </item-remove>
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="main_cart_items_footer_wrapper">
            <div class="main_cart_items_footer_left">
              {% if settings.show_discount %}
                <cart-discount-input>
                  <div class="main_cart_items_discount_wrapper">
                    <h3 class="small-text">{{ 'sections.cart.discount_heading' | t }}</h3>

                    <div class="main_cart_items_discount_form_wrapper">
                      <form
                        method="post"
                        action="{{ routes.cart_update_url }}"
                        id="cart_discount_form">
                        <div class="main_cart_items_form_inner">
                          <div class="input_field_wrapper">
                            <input
                              id="main_cart_items_form_input"
                              type="text"
                              name="discount"
                              placeholder="{{ 'sections.cart.discount_label' | t }}">
                            <label for="main_cart_items_form_input">
                              {{- 'sections.cart.discount_label' | t | append: ' *' -}}
                            </label>
                          </div>

                          <div class="main_cart_items_form_button">
                            <button
                              class="btn"
                              type="submit"
                              name="cdi_discount_btn"
                              style="--bg-color: {{ settings.discount_btn_bg_color }}; --text-color: {{ settings.discount_btn_text_color }};"
                              >
                              {{ 'sections.cart.apply_discount' | t }} 
                            </button>
                          </div>
                        </div>
                      </form>

                      {% liquid
                        assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
                        for item in cart.items
                          for allocation in item.line_level_discount_allocations
                            if allocation.discount_application.type == 'discount_code'
                              assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
                            endif
                          endfor
                        endfor

                        assign discount_codes = discount_codes | uniq
                      %}

                      {% for discount_code in discount_codes %}
                        <div class="main_cart_items_discount_name">
                          <span class="main_cart_items_icon_discount_wrapper">
                            {{- 'icon-discount.svg' | inline_asset_content -}}
                          </span>
                          {{ discount_code }}
                          <button class="main_cart_items_discount_remove_button" aria-label="{{ 'sections.cart.remove_discount' | t }}">
                            <span data-cart-discount-remove>
                              {{- 'icon-close.svg' | inline_asset_content -}}
                            </span>
                          </button>
                        </div>
                      {% endfor %}

                      <div class="main_cart_items_discount_error cdi_discount_error hidden">
                        <p>{{ 'sections.cart.cart_discount_error' | t }}</p>
                      </div>
                    </div>
                  </div>
                </cart-discount-input>
              {% endif %}

              {% if settings.show_cart_note %}
                <div class="main_cart_items_cart_note_wrapper">
                  <cart-note>
                    <div class="main_cart_items_cart_note_inner cdi_cart_note_inner">
                      <div class="main_cart_items_cart_note_head">
                        <h3 class="small-text">{{ 'sections.cart.cart_note_heading' | t }}</h3>
                        <button class="main_cart_items_cart_note_btn cdi_cart_note_btn">
                          <span class="main_cart_items_cn_hori"></span>
                          <span class="main_cart_items_cn_vert"></span>
                        </button>
                      </div>

                      <div class="main_cart_items_cart_note_content">
                        <div class="main_cart_items_cart_note_content_inner">
                          <textarea
                            name="note"
                            form="cart"
                            id="cart_note-{{ section.id }}"
                            width="100%"
                            rows="6"
                            inert
                            aria-hidden="true"
                            placeholder="{{ 'sections.cart.cart_note_placeholder' | t }}">{{ cart.note }}</textarea>
                        </div>
                      </div>
                    </div>
                  </cart-note>
                </div>
              {% endif %}
            </div>

            {% if settings.show_discount or settings.show_cart_note %}
            <div class="main_cart_items_footer_separator">.</div>
            {% endif %}

            <div class="main_cart_items_footer_right">
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="main_cart_items_cart_level_discount_wrapper" aria-label="{{ 'sections.cart.cart_level_discount_heading' | t }}">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="main_cart_items_cart_level_discount">
                      {{- 'icon-discount.svg' | inline_asset_content -}}
                      <p>
                        {{ discount.title | escape }}
                        (-{{ discount.total_allocated_amount | money }})
                      </p>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <div class="main_cart_items_subtotals_wrapper">
                <div class="main_cart_items_subtotal_inner">
                  <h3 class="h5" class="main_cart_items_subtotal">{{ 'sections.cart.subtotal' | t }}</h3>
                  <h3 class="h5">{{ cart.total_price | money }}</h3>
                </div>

                {% if settings.show_tax_info %}
                  <span class="cart_items_tax_info">
                    {%- if cart.duties_included and cart.taxes_included -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- elsif cart.duties_included == false and cart.taxes_included -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- elsif cart.duties_included and cart.taxes_included == false -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- endif -%}
                  </span>
                {% endif %}
              </div>

              <div class="main_cart_items_action_buttons_wrapper">
                <form action="{{ routes.cart_url }}" method="post">
                  <button
                    class="btn"
                    type="submit"
                    name="checkout">{{ 'sections.cart.checkout' | t }}</button>
                </form>

                {%- if additional_checkout_buttons -%}
                    <div class="main_cart_dynamic_checkout_buttons additional-checkout-buttons">
                      {{ content_for_additional_checkout_buttons }}
                    </div>
                  {%- endif -%}
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</cart-drawer>

{% schema %}
  {
    "name": "Cart",
    "settings": [
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "scheme-1"
      },
      {
        "type": "checkbox",
        "id": "show_breadcrumbs",
        "label": "Show breadcrumbs",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_title",
        "label": "Show title",
        "default": true
      },
      {
        "type": "header",
        "content": "Section spacing"
      }, {
        "type": "range",
        "id": "top_spacing",
        "label": "Top spacing",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 40
      }, {
        "type": "range",
        "id": "bottom_spacing",
        "label": "Bottom spacing",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 40
      }
    ]
  }
{% endschema %}
