{% style %}
  .hero_banner_wrapper--{{ section.id }} {
      padding-top: {{ section.settings.top_spacing }}px;
      padding-bottom: {{ section.settings.bottom_spacing }}px;
      overflow: hidden;
      position: relative;
  }

  @media screen and (max-width: 640px) {
     .hero_banner_wrapper--{{ section.id }} {
      padding-top: {{ section.settings.top_spacing | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.bottom_spacing | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{{ 'hero-banner.css' | asset_url | stylesheet_tag }}

<div class="hero_banner_wrapper--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <hero-banner>
    <div class="hero_banner_inner">
      {% if section.settings.show_ticker_text %}
        <div class="hero_banner_ticker_list">
          {% if section.settings.ticker1 != blank %}
            <div class="ticker-1">{{ section.settings.ticker1 | split: ' ' | slice: 0, 2 | join: ' ' }}</div>
          {% endif %}
          {% if section.settings.ticker2 != blank %}
            <div class="ticker-2">{{ section.settings.ticker2 | split: ' ' | slice: 0, 2 | join: ' ' }}</div>
          {% endif %}
        </div>
      {% endif %}
      <div class="hero_banner_slider_box blocks-{{ section.blocks.size }}">
        {% for block in section.blocks %}
          {% assign index = forloop.index %}
          {% assign ratio = 1 %}
          {% if section.settings.aspect_ratio == 'portrait' %}
            {% assign ratio = 0.7 %}
          {% endif %}
          <div class="hero_banner_block" data-block-index="{{ forloop.index }}">
            <div
              class="hero_banner_block_img ratio"
              style="--aspect-ratio: {{ 1 | divided_by: ratio | times: 100 }}%;"
            >
              {% assign total = section.blocks.size %}
              {% assign ac_total = total | minus: 1 %}
              {% assign start = forloop.index0 %}

              {% for i in (0..ac_total) %}
                {% assign idx = start | plus: i | modulo: total %}
                {% assign img_block = section.blocks[idx] %}
                {% assign product = img_block.settings.product %}

                {% if img_block.settings.img != blank %}
                  {% assign img = img_block.settings.img %}
                {% elsif product != blank %}
                  {% if product.featured_image != blank %}
                    {% assign img = product.featured_image %}
                  {% else %}  
                    {% assign img_idx = index | modulo: 2 %}
                    {% if img_idx == 1 %}
                      {% assign img = 'collection-2' | placeholder_svg_tag: 'placeholder_svg' %}
                    {% else %}
                      {% assign img = 'collection-1' | placeholder_svg_tag: 'placeholder_svg' %}
                    {% endif %}
                  {% endif %}
                {% else %}  
                  {% assign img_idx = index | modulo: 2 %}
                     {% if img_idx == 1 %}
                      {% assign img = 'collection-2' | placeholder_svg_tag: 'placeholder_svg' %}
                    {% else %}
                      {% assign img = 'collection-1' | placeholder_svg_tag: 'placeholder_svg' %}
                    {% endif %}
                {% endif %}

                {% if img_block.settings.img != blank %}
                  <div
                    class="hbb"
                    data-index="{{ i }}"
                    data-real="true"
                    style="--z: {{ total | minus: i }}"
                  >
                    {% if index == 3 %}
                      {% if product != blank %}
                        <a
                          class="overlay_link"
                          href="{{ product.url }}"
                          aria-label="{{ product.title }}"
                          data-hero-side-link
                          tabindex="-1"
                        >
                          {{- product.title -}}
                        </a>
                      {% endif %}
                    {% endif %}
                    {{ img | image_url: width: 800 | image_tag }}

                    {% if index == 3 %}
                      {% if product != blank %}
                        <div class="hbb_product_block">
                          <h3 class="h6">{{ product.title }}</h3>
                          <a
                            aria-label="{{ product.title }}"
                            href="{{ product.url }}"
                            data-hero-center-link
                            tabindex="-1"
                          >
                            {{- 'accessibility.shop_now' | t -}}
                          </a>
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                {% elsif product != blank %}  
                  <div
                    class="hbb"
                    data-index="{{ i }}"
                    data-real="true"
                    style="--z: {{ total | minus: i }}"
                  >
                    {% if index == 3 %}
                      {% if product != blank %}
                        <a
                          class="overlay_link"
                          href="{{ product.url }}"
                          aria-label="{{ product.title }}"
                          data-hero-side-link
                          tabindex="-1"
                        >
                          {{- product.title -}}
                        </a>
                      {% endif %}
                    {% endif %}
                    {{ img | image_url: width: 800 | image_tag }}

                    {% if index == 3 %}
                      {% if product != blank %}
                        <div class="hbb_product_block">
                          <h3 class="h6">{{ product.title }}</h3>
                          <a
                            aria-label="{{ product.title }}"
                            href="{{ product.url }}"
                            data-hero-center-link
                            tabindex="-1"
                          >
                            {{- 'accessibility.shop_now' | t -}}
                          </a>
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                {% else %}
                  <div
                    class="hbb"
                    data-index="{{ i }}"
                    data-real="true"
                    style="--z: {{ total | minus: i }}"
                  >
                    {{ img }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            {% if section.blocks.size > 1 %}
              {% if forloop.index == 2 %}
                <div class="hero_banner_block_text hero-text">
                  {% if section.settings.head != blank %}
                    <h2 class="h3">{{ section.settings.head }}</h2>
                  {% endif %}

                  {% if section.settings.text != blank %}
                    <p>{{ section.settings.text }}</p>
                  {% endif %}

                  {% if section.settings.btn_link != blank or section.settings.btn_label != blank %}
                    <div class="hero_banner_btn">
                      {% if section.settings.btn_link != blank %}
                        <a
                          href="{{ section.settings.btn_link }}"
                          class="btn btn--secondary"
                          aria-label="{{ section.settings.btn_label }}"
                          data-hero-text-link
                          tabindex="-1"
                        >
                          {{- section.settings.btn_label -}}
                        </a>
                      {% else %}
                        <a
                          role="link"
                          class="btn btn--disabled"
                          aria-label="{{ section.settings.btn_label }}"
                          data-hero-text-link
                          tabindex="-1"
                        >
                          {{- section.settings.btn_label -}}
                        </a>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            {% else %}
              <div class="hero_banner_block_text hero-text">
                {% if section.settings.head != blank %}
                  <h2 class="h3">{{ section.settings.head }}</h2>
                {% endif %}

                {% if section.settings.text != blank %}
                  <p>{{ section.settings.text }}</p>
                {% endif %}

                {% if section.settings.btn_link != blank or section.settings.btn_label != blank %}
                  <div class="hero_banner_btn">
                    {% if section.settings.btn_link != blank %}
                      <a
                        href="{{ section.settings.btn_link }}"
                        class="btn btn--secondary"
                        aria-label="{{ section.settings.btn_label }}"
                        data-hero-text-link
                        tabindex="-1"
                      >
                        {{- section.settings.btn_label -}}
                      </a>
                    {% else %}
                      <a
                        role="link"
                        class="btn btn--disabled"
                        aria-label="{{ section.settings.btn_label }}"
                        data-hero-text-link
                        tabindex="-1"
                      >
                        {{- section.settings.btn_label -}}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    {% if section.blocks.size > 1 %}
      <div class="hero_banner_arrows">
        {% if section.settings.show_progress_bar %}
          <div class="hero_banner_pagination">
            <span class="hero_banner_current_slide">{{ '01' }}</span>
            <div class="hero_banner_pagination_progress">
              <div class="hero_banner_pagination_progress_inner"></div>
            </div>
            <span class="hero_banner_total_slide">{{ section.blocks.size | prepend: '0' }}</span>
          </div>
        {% endif %}
        <div class="hero_banner_arrows_inner">
          <button
            aria-label="{{ 'accessibility.prev_btn' | t }}"
            class="hero_arrow prev_arrow"
            data-hero-arrow
            tabindex="-1"
          >
            <span class="svg_wrapper">{{ 'left-arrow.svg' | inline_asset_content }}</span>
          </button>
          <button
            aria-label="{{ 'accessibility.next_btn' | t }}"
            class="hero_arrow next_arrow"
            data-hero-arrow
            tabindex="-1"
          >
            <span class="svg_wrapper">{{ 'right-arrow.svg' | inline_asset_content }}</span>
          </button>
        </div>
      </div>
    {% endif %}
  </hero-banner>
</div>

{% schema %}
{
  "name": "Hero banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 5,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_ticker_text",
      "label": "Show ticker text",
      "default": true
    },
    {
      "type": "text",
      "id": "ticker1",
      "label": "Ticker text 01",
      "default": "TICKER 01",
      "info": "Max. 2 words",
      "visible_if": "{{ section.settings.show_ticker_text }}"
    },
    {
      "type": "text",
      "id": "ticker2",
      "label": "Ticker text 02",
      "default": "TICKER 02",
      "info": "Max. 2 words",
      "visible_if": "{{ section.settings.show_ticker_text }}"
    },
    {
      "type": "text",
      "id": "head",
      "label": "Heading",
      "default": "Hero Banner"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text",
      "default": "Use this section to highlight important content at the top of your page. Add images, promotional text, and optional ticker messaging to showcase campaigns, collections, or brand highlights."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Button Label"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "label": "Show progress bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "name": "Slide",
      "type": "slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        },
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
