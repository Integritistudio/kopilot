{{ 'section-kopilot-tap-split.css' | asset_url | stylesheet_tag }}

<div class="kopilot-tap-section" id="kopilot-tap-section-{{ section.id }}">
  <div class="kopilot-tap-container">
    
    <!-- COLUMN 1: LEFT MEDIA BLOCK -->
    <div class="kopilot-tap-media-col">
      {% if section.settings.gif != blank %}
        <img 
          src="{{ section.settings.gif | img_url: '1500x' }}" 
          alt="{{ section.settings.heading | escape }}" 
          loading="lazy"
          class="kopilot-tap-hero-img"
        >
      {% elsif section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | img_url: '1500x' }}" 
          alt="{{ section.settings.heading | escape }}" 
          loading="lazy"
          class="kopilot-tap-hero-img"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'kopilot-tap-hero-img placeholder-svg' }}
      {% endif %}
    </div>

    <!-- COLUMN 2: RIGHT TEXT CONTENT -->
    <div class="kopilot-tap-text-col">
      <div class="kopilot-tap-content-wrapper">
        <h2 class="kopilot-tap-heading">{{ section.settings.heading }}</h2>
      </div>
    </div>

  </div>
</div>

{% style %}
  /* --- MASTER TYPOGRAPHY & DESIGN TOKENS --- */
  #kopilot-tap-section-{{ section.id }} {
    --heading-font: "Elza", -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: {{ section.settings.bg_color }};
    box-sizing: border-box;
    width: 100%;
    overflow: hidden;
    padding-top: 59px;
    padding-bottom: 59px;
    padding-left: 54px;
    padding-right: 54px;
  }

  .kopilot-tap-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    max-width: 1332px;
    margin: 0 auto;
    gap: 31px;
  }

  .kopilot-tap-media-col {
    width: 672px; 
    height: 672px;
    flex-shrink: 0;
  }

  .kopilot-tap-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kopilot-tap-text-col {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 629px;
  }

  .kopilot-tap-heading {
    font-family: var(--heading-font);
    font-size: 60px; /* Base 1440px size */
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -1px;
    color: #000000;
    margin: 0;
    text-align: left;
  }

  /* --- FLUID & MOBILE RESPONSIVE LAYOUTS --- */
  
  /* Tablets and below: Apply mobile layout rules through 1200px */
  @media screen and (max-width: 1200px) {
    #kopilot-tap-section-{{ section.id }} {
      padding-top: 50px;
      padding-bottom: 0px;
      padding-left: 0;
      padding-right: 0;
    }
    
    .kopilot-tap-container {
      flex-direction: column-reverse;
      align-items: center;
      gap: 26px; /* Mobile gap constraint */
    }

    .kopilot-tap-media-col {
      width: 100%;
      height: 400px;
    }

    .kopilot-tap-text-col {
      max-width: 100%;
      padding-left: 33px;
      padding-right: 33px;
      align-items: center;
    }

    .kopilot-tap-heading {
      text-align: center;
      font-size: clamp(30px, 5vw, 40px); /* Scales smoothly */
    }
  }

  /* Pixel Perfect Mobile Override (Under 426px) */
  @media screen and (max-width: 425px) {
    .kopilot-tap-media-col {
      height: 350px;
    }
    .kopilot-tap-heading {
      font-size: 30px;
      line-height: 1.04;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Kopilot Tap Split",
  "settings": [
    {
      "type": "image_picker",
      "id": "gif",
      "label": "GIF",
      "info": "Takes priority over Square Image when set."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Square Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your critical emergency information in one tap."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Kopilot Tap Split"
    }
  ]
}
{% endschema %}