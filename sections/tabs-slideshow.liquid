{% style %}
  .power-tabs-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.section_bg }};
  }
  .power-tabs-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    overflow: hidden;

    opacity: 0;
    visibility: hidden;
    transition: opacity 0.7s ease, visibility 0.7s ease;

    {% if section.settings.desktop_height == 'adapt' %}
      aspect-ratio: 16/8;
      min-height: auto;
    {% else %}
      min-height: {{ section.settings.desktop_height }}px;
    {% endif %}
  }

  .power-tabs-content-inner {
    max-width: 520px;
    text-align: {{ section.settings.text_align }};
    color: {{ section.settings.text_color }};
  }

  @media screen and (max-width: 767px) {

    .power-tabs-slide {

      {% if section.settings.mobile_height == 'adapt' %}
          aspect-ratio: 4/5;
          min-height: auto;
      {% else %}
          min-height: {{ section.settings.mobile_height }}px;
      {% endif %}
      }

  }
{% endstyle %}

{{ 'tab-slideshow.css' | asset_url | stylesheet_tag }}

<div class="power-tabs-section-{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="power-tabs-wrapper">
    <div class="power-tabs-slider">
      {% for block in section.blocks %}
        <div
          class="power-tabs-slide {% if forloop.first %}active{% endif %}"
          data-slide="{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 2500
              | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1500, 2000, 2500'
            }}
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder_svg main_placeholder_svg' }}
          {% endif %}

          <div class="power-tabs-overlay"></div>

          <div class="power-tabs-content content-{{ section.settings.content_position }}">
            <div class="power-tabs-content-inner">
              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}

              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <a href="{{ block.settings.button_link }}" class="btn btn--{{ block.settings.btn_style }}">
                  {{ block.settings.button_label }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="power-tabs-navigation">
      <div class="power-tabs-nav-wrap">
        {% for block in section.blocks %}
          <button
            class="power-tab-btn {% if forloop.first %}active{% endif %}"
            data-tab="{{ forloop.index }}"
          >
            <span class="power-tab-number">
              {% if forloop.index < 10 %}
                0{{ forloop.index }}
              {% else %}
                {{ forloop.index }}
              {% endif %}
            </span>

            <span class="power-tab-title">
              {{ block.settings.tab_name }}
            </span>
          </button>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('.power-tabs-section-{{ section.id }}');

    if (!section) return;

    const tabs = section.querySelectorAll('.power-tab-btn');
    const slides = section.querySelectorAll('.power-tabs-slide');

    tabs.forEach((tab) => {
      tab.addEventListener('click', function () {
        const id = this.dataset.tab;

        tabs.forEach((btn) => btn.classList.remove('active'));
        slides.forEach((slide) => slide.classList.remove('active'));

        this.classList.add('active');

        section.querySelector('.power-tabs-slide[data-slide="' + id + '"]').classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Tabs slideshow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },

    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },

    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to Image"
        },
        {
          "value": "600",
          "label": "Medium"
        },
        {
          "value": "750",
          "label": "Large"
        },
        {
          "value": "900",
          "label": "Full Screen"
        }
      ],
      "default": "750"
    },

    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to Image"
        },
        {
          "value": "450",
          "label": "Small"
        },
        {
          "value": "600",
          "label": "Medium"
        },
        {
          "value": "750",
          "label": "Large"
        }
      ],
      "default": "600"
    },

    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 40,
      "unit": "px"
    },

    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 40,
      "unit": "px"
    }
  ],

  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },

        {
          "type": "text",
          "id": "tab_name",
          "label": "Tab Name",
          "default": "Tab name"
        },

        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },

        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Add information here"
        },

        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },

        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "btn_style",
          "label": "Button style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            }
          ],
          "default": "primary"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Tabs slideshow",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
