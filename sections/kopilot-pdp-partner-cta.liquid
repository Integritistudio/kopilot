{% style %}
  .kopilot-pdp-partner-cta--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .kopilot-pdp-partner-cta--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'kopilot-base.css' | asset_url | stylesheet_tag }}
{{ 'kopilot-pdp-partner-cta.css' | asset_url | stylesheet_tag }}

<section class="kopilot-section kopilot-pdp-partner-cta kopilot-pdp-partner-cta--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kopilot-pdp-partner-cta__inner">
    {% if section.settings.heading != blank %}
      <h2 class="kopilot-pdp-partner-cta__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="kopilot-pdp-partner-cta__content">
      {% if section.settings.text != blank %}
        <p class="kopilot-pdp-partner-cta__text">{{ section.settings.text }}</p>
      {% endif %}
      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link_url | default: '#' }}" class="kopilot-pdp-partner-cta__link">
          {{ section.settings.link_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kopilot PDP partner CTA",
  "tag": "section",
  "class": "kopilot-pdp-partner-cta-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Partner with KOPILOT.ID"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Bring KOPILOT.ID to your race, event, or gear line with custom-branded NFC emergency tags and direct integration support from our team."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "See partnerships"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [{ "name": "Kopilot PDP partner CTA" }]
}
{% endschema %}
