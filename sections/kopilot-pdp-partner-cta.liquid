<div class="kopilot-partner-section-{{ section.id }}">
  <div class="kopilot-partner-container-{{ section.id }}">
    
    <!-- Left Heading Element -->
    <h2 class="kopilot-partner-heading-{{ section.id }}">
      {{ section.settings.heading }}
    </h2>
    
    <!-- Right Content Column Wrapper -->
    <div class="kopilot-partner-content-{{ section.id }}">
      <p class="kopilot-partner-text-{{ section.id }}">
        {{ section.settings.body_text }}
      </p>
      
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="kopilot-partner-link-{{ section.id }}">
          {{ section.settings.link_text }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  /* Section Layout & Background Wrapper */
  .kopilot-partner-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    width: 100%;
    padding: 50px 0;
    box-sizing: border-box;
  }

  /* Main Inner Flex Container (Frame 2106667295) */
  .kopilot-partner-container-{{ section.id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 0 224px;
    gap: 75px;
    box-sizing: border-box;
  }

  /* Heading Typography (Elza Light 60px) */
  .kopilot-partner-heading-{{ section.id }} {
    font-family: "Elza", sans-serif;
    font-size: 60px;
    font-weight: 300;
    line-height: 1.1;
    color: #000000;
    margin: 0;
    width: 613px;
    max-width: 100%;
    letter-spacing: 0%;
  }

  /* Right Column Layout Frame */
  .kopilot-partner-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    width: 342px;
    max-width: 100%;
  }

  /* Body Text Typography (Figtree Regular 20px) */
  .kopilot-partner-text-{{ section.id }} {
    font-family: "Figtree", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
    color: #000000;
    margin: 0;
    width: 100%;
  }

  /* Link Typography (Elza Text Trial Semibold Uppercase 20px Underline) */
  .kopilot-partner-link-{{ section.id }} {
    font-family: "Elza Text Trial", "Elza", sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.0;
    text-transform: uppercase;
    color: #000000;
    text-decoration: underline;
    display: inline-block;
    width: 197px;
    max-width: 100%;
    box-sizing: border-box;
    transition: opacity 0.2s ease;
  }

  .kopilot-partner-link-{{ section.id }}:hover {
    opacity: 0.7;
  }

  /* Responsive Breakpoints */
  @media (max-width: 1100px) {
    .kopilot-partner-container-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
      padding: 0 40px;
      gap: 32px;
    }
    
    .kopilot-partner-heading-{{ section.id }} {
      font-size: 44px;
      width: 100%;
    }

    .kopilot-partner-content-{{ section.id }} {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .kopilot-partner-container-{{ section.id }} {
      padding: 0 20px;
    }
    
    .kopilot-partner-heading-{{ section.id }} {
      font-size: 36px;
    }
  }
</style>

{% schema %}
{
  "name": "Kopilot Partner Banner",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F1F1F1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Partner with KOPILOT.ID"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Bring KOPILOT.ID to your race, event, or gear line with custom-branded NFC emergency tags and direct integration support from our team."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "See partnerships"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "Kopilot Partner Banner"
    }
  ]
}
{% endschema %}