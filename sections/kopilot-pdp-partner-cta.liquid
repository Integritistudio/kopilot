<div class="kopilot-partner-section-{{ section.id }}">
  <div class="kopilot-partner-container-{{ section.id }}">
    
    <!-- Left Heading Element -->
    <h2 class="kopilot-partner-heading-{{ section.id }}">
      {{ section.settings.heading }}
    </h2>
    
    <!-- Right Content Column Wrapper -->
    <div class="kopilot-partner-content-{{ section.id }}">
      <p class="kopilot-partner-text-{{ section.id }}">
        {{ section.settings.body_text }}
      </p>
      
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="kopilot-partner-link-{{ section.id }}">
          {{ section.settings.link_text }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  /* ==========================================================================
     BASE FLUID STYLES (Applies responsively across intermediate screens)
     ========================================================================= */
  .kopilot-partner-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    width: 100%;
    padding: clamp(31px, 2.5vw, 50px) 0;
    box-sizing: border-box;
  }

  .kopilot-partner-container-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 0 clamp(37px, 14.2vw, 205px);
    gap: clamp(24px, 5.2vw, 75px);
    box-sizing: border-box;
  }

  .kopilot-partner-heading-{{ section.id }} {
    font-family: "Elza", sans-serif;
    font-size: clamp(30px, 20px + 2.78vw, 60px);
    font-weight: 300;
    line-height: 1.1; 
    color: #000000;
    margin: 0;
    width: 100%;
    max-width: 613px;
    white-space: normal; 
    letter-spacing: 0%;
    text-align: center;
  }

  .kopilot-partner-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(12px, 1.2vw, 15px);
    width: 100%;
    max-width: 342px;
  }

  .kopilot-partner-text-{{ section.id }} {
    font-family: "Figtree", sans-serif;
    font-size: clamp(15px, 13.33px + 0.46vw, 20px);
    font-weight: 400;
    line-height: 1.2; 
    color: #000000;
    margin: 0;
    width: 100%;
    text-align: center;
  }

  .kopilot-partner-link-{{ section.id }} {
    font-family: "Figtree", sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    color: #000000;
    text-decoration: underline;
    display: inline-block;
    width: 100%;
    max-width: 289px;
    box-sizing: border-box;
    transition: opacity 0.2s ease;
    text-align: center;
  }

  .kopilot-partner-link-{{ section.id }}:hover {
    opacity: 0.7;
  }

  /* Tablet and Desktop Split Layout Pivot */
  @media screen and (min-width: 768px) and (max-width: 1439px) {
    .kopilot-partner-container-{{ section.id }} {
      flex-direction: row;
      align-items: center;
    }
    .kopilot-partner-heading-{{ section.id }} {
      text-align: left;
    }
    .kopilot-partner-content-{{ section.id }} {
      align-items: flex-start;
    }
    .kopilot-partner-text-{{ section.id }},
    .kopilot-partner-link-{{ section.id }} {
      text-align: left;
    }
    .kopilot-partner-link-{{ section.id }} {
      font-family: "Elza Text Trial", "Elza", sans-serif;
      font-weight: 600;
      line-height: 1.0;
      font-size: clamp(16px, 1.25vw, 20px);
      max-width: 197px;
    }
  }

  /* ==========================================================================
     EXACT DESIGN ARCHORS (Preserves your code exactly at 360px and 1440px)
     ========================================================================= */

  /* Exact 360px Anchor State */
  @media screen and (max-width: 360px) {
    .kopilot-partner-section-{{ section.id }} {
      padding: 0;
    }
    .kopilot-partner-container-{{ section.id }} {
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 360.45px;
      padding: 31px 37px;
      gap: 24px;
      margin: 0 auto;
    }
    .kopilot-partner-content-{{ section.id }} {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 289px;
      max-width: 100%;
      gap: 15px; 
    }
    .kopilot-partner-heading-{{ section.id }} {
      font-family: "Elza", sans-serif;
      font-size: 30px;
      font-weight: 300;
      line-height: 1.1;
      width: 249px;
      max-width: 100%;
      white-space: normal;
      text-align: center;
    }
    .kopilot-partner-text-{{ section.id }} {
      font-family: "Figtree", sans-serif;
      font-size: 15px;
      font-weight: 400;
      line-height: 1.2;
      width: 289px;
      max-width: 100%;
      text-align: center;
    }
    .kopilot-partner-link-{{ section.id }} {
      font-family: "Figtree", sans-serif;
      font-size: 20px;
      font-weight: 700;
      line-height: 1.2;
      text-transform: uppercase;
      text-decoration: underline;
      text-align: center;
      width: 289px;
      max-width: 100%;
    }
  }

  /* Exact 1440px+ Anchor State */
  @media screen and (min-width: 1440px) {
    .kopilot-partner-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
      width: 100%;
      padding-top: 0px !important;
      padding-bottom: 0px !important;
      box-sizing: border-box;
    }
    .kopilot-partner-container-{{ section.id }} {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      max-width: 1440px;
      width: 100%;
      margin: 0 auto;
      padding: 50px 205px;
      gap: 75px;
      box-sizing: border-box;
    }
    .kopilot-partner-heading-{{ section.id }} {
      font-family: "Elza", sans-serif;
      font-size: 60px;
      font-weight: 300;
      line-height: 1.1;
      color: #000000;
      margin: 0;
      width: max-content;
      max-width: 100%;
      white-space: nowrap;
      letter-spacing: 0%;
      text-align: left;
    }
    .kopilot-partner-content-{{ section.id }} {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      width: 342px;
      max-width: 100%;
    }
    .kopilot-partner-text-{{ section.id }} {
      font-family: "Figtree", sans-serif;
      font-size: 20px;
      font-weight: 400;
      line-height: 1.2;
      color: #000000;
      margin: 0;
      width: 100%;
      text-align: left;
    }
    .kopilot-partner-link-{{ section.id }} {
      font-family: "Elza Text Trial", "Elza", sans-serif;
      font-size: 20px;
      font-weight: 600;
      line-height: 1.0;
      text-transform: uppercase;
      color: #000000;
      text-decoration: underline;
      display: inline-block;
      width: 197px;
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Kopilot Partner Banner",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F1F1F1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Partner with KOPILOT.ID"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Bring KOPILOT.ID to your race, event, or gear line with custom-branded NFC emergency tags and direct integration support from our team."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "See partnerships"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "Kopilot Partner Banner"
    }
  ]
}
{% endschema %}