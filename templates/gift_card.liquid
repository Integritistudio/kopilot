{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon_img | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    {%- assign formatted_balance = gift_card.balance | money_without_trailing_zeros | strip_html -%}

    <title>{{ 'gift_cards.issued.title' | t: value: formatted_balance, shop: shop.name }}</title>

    <meta name="description" content="{{ 'gift_cards.issued.subtext' | t }}">

    {% render 'css-variables' %}

    {{ 'styles.css' | asset_url | stylesheet_tag: preload: true }}

    {% render 'meta-tags' %}

    {% render 'color-schemes' %}

    {{ content_for_header }}

    <script src="{{ 'scripts.js' | asset_url }}" defer="defer"></script>
  </head>

  <body>
    <main class="gift_card_template">
      {% section 'gift-card' %}
    </main>

     <script>
    var string = { qrImageAlt: {{ 'gift_cards.issued.qr_image_alt' | t | json }} };
    document.addEventListener('DOMContentLoaded', function() {
     new QRCode( document.querySelector('.gift_card_qr_code_wrapper'), {
      text: document.querySelector('.gift_card_qr_code_wrapper').dataset.identifier,
      width: 124,
      height: 124,
      imageAltText: string.qrImageAlt
      });
    });
    var template = document.getElementsByTagName("template")[0];
    var clonedTemplate = template.content.cloneNode(true);
    var isMessageDisplayed = false;
    var messageWrapper = document.querySelector('.gift_card_copy_success');

    // document
    // .querySelector('.gift_card_copy_btn')
    // .addEventListener('click', () => {
    //   navigator.clipboard.writeText(document.querySelector('.gift_card_code').innerText).then(function () {
    //     if (!isMessageDisplayed) {
    //       document.querySelector('.gift_card_copy_success').appendChild(clonedTemplate);
    //       isMessageDisplayed = true;
    //       messageWrapper.classList.add('show');

    //       setTimeout(() => {
    //         messageWrapper.classList.remove('show');
    //       },3000)
    //     }
    //   });
    // });

    document
  .querySelector('.gift_card_copy_btn')
  .addEventListener('click', () => {

    navigator.clipboard
      .writeText(document.querySelector('.gift_card_code').innerText)
      .then(function () {

        const wrapper = document.querySelector('.gift_card_copy_success');

        // Clear previous message (important)
        wrapper.innerHTML = "";

        // Clone fresh template every time
        const template = document.getElementsByTagName("template")[0];
        const clonedTemplate = template.content.cloneNode(true);

        wrapper.appendChild(clonedTemplate);

        // Restart animation
        wrapper.classList.remove('show');
        void wrapper.offsetWidth; // 🔥 force reflow (important trick)
        wrapper.classList.add('show');

        setTimeout(() => {
          wrapper.classList.remove('show');
        }, 3000);
      });
  });
  </script>
  </body> 
</html>
