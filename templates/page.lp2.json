    "kopilot_faq": {
      "type": "kopilot-faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "Does the person helping me need to download an app?",
            "answer": "<p>No. Any smartphone can read the NFC tag instantly—no app, account, or setup required on their end. The app is only used by you to create and manage your digital medical ID profile.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "Does it need cell service to work?",
            "answer": "<p>No. The NFC tag works completely offline. Your medical information is accessible anywhere—remote trails, mountain terrain, or areas with no reception. That’s exactly what it’s designed for.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "Does it need to be charged?",
            "answer": "<p>No. KOPILOT.ID is a battery-free NFC tag. It draws power from the scanning phone, so it’s always ready with no charging or maintenance required.</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "Where can I attach it to my gear?",
            "answer": "<p>You can attach it to your running vest, hydration pack, helmet, or bike—anywhere you’d place a standard tag. It also comes with mounts for different setups, including goggle, zipper, and carbon helmet options, and stays lightweight and out of the way. </p>"
          }
        },
        "question_cRrMjJ": {
          "type": "question",
          "settings": {
            "question": "Can anyone scan my tag and see my information?",
            "answer": "<p>You control your profile completely. Choose what’s visible, update it anytime, or deactivate your NFC ID tag if needed. If your tag is scanned, you’re notified, and access sessions expire automatically.</p>"
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "How is this different from a GPS tracker or location sharing app?",
            "answer": "<p>GPS devices show where you are. KOPILOT.ID shows who you are—your medical details, conditions, and emergency contacts. It’s an NFC medical ID designed to help others assist you, not just locate you.</p>"
          }
        },
        "q6": {
          "type": "question",
          "settings": {
            "question": "What if I lose my tag?",
            "answer": "<p>You can deactivate your NFC tag instantly from the app. Your information becomes inaccessible from that tag, and you’ll be notified if someone scans it.</p>"
          }
        }
      },
      "block_order": [
        "q1",
        "q2",
