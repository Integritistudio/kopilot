    "kopilot_faq": {
      "type": "kopilot-faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "What is an NFC tag and how does it work?",
            "answer": "<p>An NFC tag is a small chip that can be scanned by most smartphones. When someone taps your KOPILOT.ID tag, it instantly opens your digital medical ID profile with your critical information—no app or signal required.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "Do NFC tags work without cell service?",
            "answer": "<p>Yes. Once your profile is set up, the tag works without cell service or battery power on the tag itself.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "What information can I store on my NFC medical ID?",
            "answer": "<p>You control what you share — medical conditions, allergies, medications, emergency contacts, and more.</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "How do I use an NFC tag like KOPILOT.ID?",
            "answer": "<p>Set up your profile in the app, attach the tag to your gear, and anyone can tap it with a smartphone in an emergency.</p>"
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "Where should I place my NFC emergency tag?",
            "answer": "<p>Helmet, gear, or anywhere first responders are likely to find it. Mounting options are included.</p>"
          }
        },
        "q6": {
          "type": "question",
          "settings": {
            "question": "How long do NFC tags last? Do they need charging?",
            "answer": "<p>NFC tags have no battery and are designed to last for years of regular use.</p>"
          }
        },
        "q7": {
          "type": "question",
          "settings": {
            "question": "Is this useful even if I already ride with safety gear?",
            "answer": "<p>Yes. Safety gear protects your body — KOPILOT.ID ensures responders have the information they need to help you.</p>"
          }
        }
      },
