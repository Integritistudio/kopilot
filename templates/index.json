    "kopilot_faq": {
      "type": "kopilot-faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "What is an NFC tag and how does it work?",
            "answer": "<p>An NFC tag is a small chip that can be scanned by most smartphones. When someone taps your KOPILOT.ID tag, it instantly opens your digital medical ID profile with your critical information—no app or signal required.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "Do NFC tags work without cell service?",
            "answer": "<p>Yes. The NFC tag itself works without cell service or battery. As long as the person scanning has a smartphone, they can access your information even in remote areas.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "What information can I store on my NFC medical ID?",
            "answer": "<p>You can add essential details like allergies, medical conditions, medications, blood type, and emergency contacts — everything a first responder would need to help you quickly.</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "How do I use an NFC tag like KOPILOT.ID?",
            "answer": "<p>You download the app and set up your profile once, then attach the tag to your helmet, gear, or bike. If something happens, anyone can tap it with their phone to access your information instantly.</p>"
          }
        },
        "question_cRrMjJ": {
          "type": "question",
          "settings": {
            "question": "What is an NFC tag and how does it work?",
            "answer": "<p>An NFC tag is a small chip that can be scanned by most smartphones. When someone taps your KOPILOT.ID tag, it instantly opens your digital medical ID profile with your critical information—no app or signal required.</p>"
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "Where should I place my NFC emergency tag?",
            "answer": "<p>Most riders attach it to their helmet, chest protector, pack, or bike—anywhere it’s easy to spot and access in an emergency.</p>"
          }
        },
        "q6": {
          "type": "question",
          "settings": {
            "question": "How long do NFC tags last? Do they need charging?",
            "answer": "<p>NFC tags don’t require a battery and don’t need charging. They’re designed to last for years, making them a reliable piece of outdoor safety gear you can count on every ride.</p>"
          }
        },
        "q7": {
          "type": "question",
          "settings": {
            "question": "Is this useful even if I already ride with safety gear?",
            "answer": "<p>Yes. Traditional safety gear protects you physically, but a digital medical ID helps others help you. It adds a critical layer to your motorcycle emergency kit, especially in remote terrain.</p>"
          }
        }
      },
