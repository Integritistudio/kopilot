    "kopilot_faq": {
      "type": "kopilot-faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "How does KOPILOT.ID work in an emergency?",
            "answer": "<p>If something happens, anyone with a smartphone can tap your KOPILOT.ID NFC tag to instantly access your medical information, allergies, medications, and emergency contacts; no app required.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "Do people need to download an app to scan the tag?",
            "answer": "<p>No. Most modern smartphones can read NFC tags directly from the lock screen or camera. Your emergency profile opens in the browser without requiring a download.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "Does KOPILOT.ID work without cell service?",
            "answer": "<p>Yes. The NFC tag itself works without cell service or battery. As long as the person scanning has a smartphone, they can access your information even in remote areas.</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "What information can I add to my profile?",
            "answer": "<p>You can add essential details like allergies, medical conditions, medications, blood type, and emergency contacts — everything a first responder would need to help you quickly.</p>"
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "Can I manage multiple tags from one account?",
            "answer": "<p>Yes. You can manage multiple tags, gear setups, and family members from a single KOPILOT.ID account in the app.</p>"
          }
        },
        "q6": {
          "type": "question",
          "settings": {
            "question": "Is there a subscription required?",
            "answer": "<p>No. KOPILOT.ID does not require a subscription. Set up your profile once and use your tag without recurring fees.</p>"
          }
        },
        "q7": {
          "type": "question",
          "settings": {
            "question": "What gear can I attach the NFC tag to?",
            "answer": "<p>Most riders attach it to their helmet, chest protector, pack, or bike using the included goggle, zipper, or carbon helmet mounts.</p>"
          }
        },
        "q8": {
          "type": "question",
          "settings": {
            "question": "Why would I buy a multi-pack?",
            "answer": "<p>Multi-packs let you equip more gear, share tags with friends or family, and save up to 20% compared to buying individually.</p>"
          }
        }
      },
