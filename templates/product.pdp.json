    "kopilot_faq_mGbFjB": {
      "type": "kopilot-faq",
      "blocks": {
        "question_zHRRNE": {
          "type": "question",
          "settings": {
            "question": "How does KOPILOT.ID work in an emergency?",
            "answer": "<p>If something happens, anyone with a smartphone can tap your KOPILOT.ID NFC tag to instantly access your medical information, allergies, medications, and emergency contacts; no app required.</p>"
          }
        },
        "question_KDqFhR": {
          "type": "question",
          "settings": {
            "question": "Do people need to download an app to scan the tag?",
            "answer": "<p>No app needed. Your profile opens directly in a smartphone browser when someone taps their phone on the NFC tag.</p>"
          }
        },
        "question_bzFJRJ": {
          "type": "question",
          "settings": {
            "question": "Does KOPILOT.ID work without cell service?",
            "answer": "<p>Yes. KOPILOT.ID is waterproof, battery-free, and designed to work in real-world conditions without charging or cell signal</p>"
          }
        },
        "question_Caw83F": {
          "type": "question",
          "settings": {
            "question": "What information can I add to my profile?",
            "answer": "<p>You can add medical conditions, allergies, medications, emergency contacts, personalized notes, and other important information responders may need in an emergency.</p>"
          }
        },
        "question_8rBjR6": {
          "type": "question",
          "settings": {
            "question": "Can I manage multiple tags from one account?",
            "answer": "<p>Yes. You can manage multiple profiles and tags for family members, friends, or your crew directly from the KOPILOT.ID app.</p>"
          }
        },
        "question_8XBcAV": {
          "type": "question",
          "settings": {
            "question": "Is there a subscription required?",
            "answer": "<p>No monthly subscription is required to use your KOPILOT.ID NFC tag or manage your profile.</p>"
          }
        },
        "question_Cb8Bh4": {
          "type": "question",
          "settings": {
            "question": "What gear can I attach the NFC tag to?",
            "answer": "<p>KOPILOT.ID is designed for helmets, goggles, packs, bikes, jackets, zipper pulls, keychains, and other everyday or outdoor gear using the included mounting options.</p>"
          }
        },
        "question_x9BKr3": {
          "type": "question",
          "settings": {
            "question": "Why should I buy a multi-pack?",
            "answer": "<p>Multi-packs are perfect for families, friends, riding groups, or multiple gear setups, while saving you more on each additional tag.</p>"
          }
        }
      },
