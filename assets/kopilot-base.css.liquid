@import url('https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap');
@import url('{{ 'Elza.css' | asset_url }}');

.kopilot-section {

  --kopilot-font-family: Elza, sans-serif;

  --kopilot-body-font-family: Figtree, sans-serif;

  --kopilot-red: #ef0008;

  --kopilot-dark: #3b3b3b;

  --kopilot-gray: #eee;

  --kopilot-heading-light: 300;

  --kopilot-heading-medium: 500;

  font-family: var(--kopilot-font-family);
  font-synthesis: none;
}



.kopilot-btn {

  display: inline-flex;

  align-items: center;

  justify-content: center;

  padding: 1.6rem 6.2rem;

  background: var(--kopilot-red);

  color: #fff;

  font-family: var(--kopilot-font-family);

  font-size: 1.5rem;

  font-weight: 600;

  letter-spacing: 0.02em;

  text-transform: uppercase;

  text-decoration: none;

  border: none;

  cursor: pointer;

  transition: opacity 0.2s ease;

}



.kopilot-btn:hover {

  opacity: 0.9;

  color: #fff;

}



.kopilot-heading {

  font-family: var(--kopilot-font-family);

  font-weight: 300;

  font-style: normal;

  font-synthesis: none;

  line-height: 1.1;

  letter-spacing: -1px;

}



.kopilot-heading--medium {

  font-family: var(--kopilot-font-family);

  font-weight: 500;

  font-style: normal;

  font-synthesis: none;

  line-height: 1.1;

  letter-spacing: 0px !important;

}



.kopilot-body {

  font-family: var(--kopilot-body-font-family);

  font-weight: 400;

  line-height: 1.2;

  letter-spacing: 0;

}



@media screen and (min-width: 990px) {

  .kopilot-btn {

    padding: 2.1rem 8.3rem;

    font-size: 2.4rem;

  }

}


