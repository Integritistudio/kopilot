          {% elsif cblock.settings.collection3.featured_image != blank %}
            {{ cblock.settings.collection3.featured_image | image_url: width: 800 | image_tag }}
          {% else %}
            {{ 'collection-3' | placeholder_svg_tag: 'placeholder_svg' }}
          {% endif %}
        </div>

        <div class="cblock_title menu_{{ font_family }}">
            <p><a href="{{ cblock.settings.collection3.url }}" aria-label="{{ cblock.settings.collection3.title }}">{{ cblock.settings.collection3.title }}</a></p>
        </div>
      </div>
    {% endif %}

    {% if cblock.settings.collection4 != blank %}
      <div class="cblock cblock4">
        <div class="cblock_img ratio-{{ cblock.settings.coll1_ratio }}">
          <a href="{{ cblock.settings.collection4.url }}" aria-label="{{ cblock.settings.collection4.title }}">
            {{- cblock.settings.collection4.title -}}
          </a>

          {% if cblock.settings.coll4_img != blank %}
            {{ cblock.settings.coll4_img | image_url: width: 800 | image_tag }}
          {% elsif cblock.settings.collection4.featured_image != blank %}
            {{ cblock.settings.collection4.featured_image | image_url: width: 800 | image_tag }}
          {% else %}
            {{ 'collection-4' | placeholder_svg_tag: 'placeholder_svg' }}
          {% endif %}
        </div>
        <div class="cblock_title menu_{{ font_family }}">
            <p><a href="{{ cblock.settings.collection4.url }}" aria-label="{{ cblock.settings.collection4.title }}">{{ cblock.settings.collection4.title }}</a></p>
        </div>
      </div>
    {% endif %}
  </div>
{% endif %}
