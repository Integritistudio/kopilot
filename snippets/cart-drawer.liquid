<cart-drawer>
  <div
    class="drawer_wrapper cart_drawer_wrapper color-{{ settings.drawer_color_scheme }}"
    id="cart_drawer"
    inert
    aria-hidden="true">
    <div class="drawer_wrapper_inner cart_drawer_inner" tabindex="-1">
      <div class="cart_drawer_confetti_layer" aria-hidden="true"></div>

      <div class="drawer_header cart_drawer_header">
        <h2 class="cart_drawer_heading">Your Cart</h2>

        <div class="drawer_close_btn_wrapper">
          <button class="drawer_close_btn" aria-label="{{ 'accessibility.close' | t }}">
            <div class="svg_wrapper">{{ 'icon-close.svg' | inline_asset_content }}</div>
          </button>
        </div>
      </div>

      {% if cart != empty %}
        {% render 'free-shipping-bar' %}
      {% endif %}

      <div class="cart_drawer_content_wrapper" data-lenis-prevent>
        {% if cart == empty %}
          <div class="empty_cart_drawer_wrapper">
            <h3 class="h4">{{ 'drawers.cart_drawer.empty_drawer_heading' | t }}</h3>
            <a
              class="btn"
              href="{{ routes.all_products_collection_url }}"
              aria-label="{{ 'general.continue_shopping' | t }}">
              {{- 'general.continue_shopping' | t -}}
            </a>
          </div>
        {% else %}
          <div class="cart_drawer_body">
            <div class="cart_drawer_content_inner">
              {% for item in cart.items %}
                {%- liquid
                  assign cart_img = item.image
                  if item.product.featured_image != blank
                    assign cart_img = item.product.featured_image
                  endif
                  if item.product.images.size > 0
                    assign cart_img = item.product.images.first
                  endif

                  assign pack_qty = 1
                  if item.variant.metafields.custom.quantity != blank
                    assign pack_qty = item.variant.metafields.custom.quantity | plus: 0
                  else
                    assign title_downcase = item.variant.title | downcase
                    if title_downcase contains '3'
                      assign pack_qty = 3
                    elsif title_downcase contains '2'
                      assign pack_qty = 2
                    endif
                  endif
                -%}

                <div class="cart_drawer_item_block" data-pack-qty="{{ pack_qty }}">
                  <div class="cdi_block_inner">
                    <div class="cart_drawer_item_img_block">
                      <a href="{{ item.url }}" aria-label="{{ item.product.title | escape }}"></a>
                      {% if cart_img != blank %}
                        {{ cart_img | image_url: width: 400 | image_tag: loading: 'lazy', alt: item.product.title }}
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder_svg' }}
                      {% endif %}
                      <div class="cart_drawer_item_badge" aria-hidden="true">
                        Special offer. Save up to 20% on multi-packs.
                      </div>
                    </div>

                    <div class="cart_drawer_item_info_block">
                      <div class="cdi_top_row">
                        <div class="cdi_title">
                          <p>
                            <a href="{{ item.url }}">The piece of gear you don't think about until you need it.</a>
                          </p>
                        </div>
                        <div class="cdi_price">
                          {% if item.original_price != item.final_price %}
                            <div class="cdi_price_inner">
                              <span>{{ item.final_price | money }}</span>
                              <s>{{ item.original_price | money }}</s>
                            </div>
                          {% else %}
                            <div class="cdi_price_inner">
                              <span>{{ item.final_price | money }}</span>
                              {% if item.variant.compare_at_price != blank
                                and item.variant.compare_at_price > item.variant.price
                              %}
                                <s>{{ item.variant.compare_at_price | money }}</s>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                      </div>

                      <div class="cdi_mid_row">
                        <div class="cdi_options_wrapper">
                          {% unless item.product.has_only_default_variant %}
                            <p class="cdi_product_options">
                              {% for option in item.options_with_values %}
                                <span>{{- option.value -}}</span>
                              {% endfor %}
                            </p>
                          {% else %}
                            <p class="cdi_product_options">
                              <span>{{ item.quantity }} {% if item.quantity == 1 %}Product{% else %}Products{% endif %}</span>
                            </p>
                          {% endunless %}

                          {% if item.properties.size != 0 %}
                            {%- for property in item.properties -%}
                              {%- assign property_first_char = property.first | slice: 0 -%}
                              {%- if property.last != blank and property_first_char != '_' -%}
                                <div class="cdi_properties_wrapper">
                                  <div class="cdi_property_name">{{ property.first }}:</div>
                                  <div class="cdi_property_value">
                                    {%- if property.last contains '/uploads/' -%}
                                      <a href="{{ property.last }}" class="link" target="_blank">
                                        {{ property.last | split: '/' | last }}
                                      </a>
                                    {%- else -%}
                                      {{ property.last }}
                                    {%- endif -%}
                                  </div>
                                </div>
                              {%- endif -%}
                            {%- endfor -%}
                          {% endif %}

                          {% if item.selling_plan_allocation != null %}
                            <p class="cdi_selling_plan">
                              {{ item.selling_plan_allocation.selling_plan.name }}
                            </p>
                          {% endif %}
                        </div>

                        <div class="cdi_item_remove">
                          <item-remove data-line="{{ forloop.index }}">
                            <a
                              aria-label="{{- 'drawers.cart_drawer.remove' | t -}}"
                              class="item_remove_btn"
                              href="{{ item.url_to_remove }}"
                              data-remove
                              data-quantity="0">
                              {{ 'icon-trash.svg' | inline_asset_content }}
                            </a>
                          </item-remove>
                        </div>
                      </div>

                      <div class="cdi_quantity_picker">
                        <cart-quantity-picker data-line="{{ forloop.index }}">
                          <button
                            type="button"
                            class="btn_minus"
                            data-minus
                            aria-label="{{ 'products.product.quantity_decrease' | t }}"
                            data-quantity="{{ item.quantity | minus: 1 }}"
                            data-min="{{ item.quantity }} - {{ item.variant.quantity_rule.min }}"
                            {% if item.quantity == item.variant.quantity_rule.min %}
                            disabled
                            {% endif %}>
                            <svg class="cq_icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                              <path d="M2.5 6h7" stroke="#000" stroke-width="1.25" stroke-linecap="square"/>
                            </svg>
                          </button>

                          <input
                            type="text"
                            name="quantity"
                            min="{{ item.variant.quantity_rule.min }}"
                            data-min="{{ item.variant.quantity_rule.min }}"
                            {% if item.variant.quantity_rule.max %}
                            data-max="{{ item.variant.quantity_rule.max }}"
                            max="{{ item.variant.quantity_rule.max }}"
                            {% endif %}
                            step="{{ item.variant.quantity_rule.increment }}"
                            value="{{ item.quantity }}"
                            id="Item_quantity-{{ forloop.index }}">
                          <label class="visually-hidden" for="Item_quantity-{{ forloop.index }}">
                            {{- 'products.product.quantity' | t -}}
                          </label>

                          <button
                            type="button"
                            aria-label="{{ 'products.product.quantity_increase' | t }}"
                            class="btn_plus"
                            data-plus
                            data-quantity="{{ item.quantity | plus: 1 }}"
                            {% if item.quantity == item.variant.quantity_rule.max %}
                            disabled
                            {% endif %}>
                            <svg class="cq_icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                              <path d="M2.5 6h7M6 2.5v7" stroke="#000" stroke-width="1.25" stroke-linecap="square"/>
                            </svg>
                          </button>
                        </cart-quantity-picker>
                      </div>
                    </div>
                  </div>

                  <div
                    class="cart_drawer_error"
                    data-line="{{ forloop.index }}"
                    hidden>
                    A maximum of 5 items are added due to availability.
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="cart_drawer_footer">
            <div class="cart_drawer_footer_inner">
              {%- comment -%}
                Pack upsell:
                - Total tags = 1 → Set of 3 only (keep 1 Tag + add Set of 3)
                - Total tags = 2 → Add 1 Tag upsell (upgrade Set of 2 → Set of 3)
                - Set of 3 variant present OR total tags >= 3 → hide upsell
              {%- endcomment -%}
              {%- liquid
                assign upsell_item = nil
                assign upsell_line = 0
                assign total_tags = 0
                assign has_set_of_3 = false
                assign is_qty_pack_setup = false
                assign set_of_3_variant_id = nil
                assign one_tag_variant = nil

                for item in cart.items
                  assign seen_1 = false
                  assign seen_2 = false
                  assign seen_3 = false
                  assign distinct_packs = 0

                  for v in item.product.variants
                    assign vq = 1
                    if v.metafields.custom.quantity != blank
                      assign vq = v.metafields.custom.quantity | plus: 0
                    else
                      assign vtd = v.title | downcase
                      if vtd contains 'set of 3' or vtd contains '3 tag' or vtd contains '3-pack' or vtd contains '3 pack'
                        assign vq = 3
                      elsif vtd contains 'set of 2' or vtd contains '2 tag' or vtd contains '2-pack' or vtd contains '2 pack'
                        assign vq = 2
                      elsif vtd contains '1 tag' or vtd == 'default title'
                        assign vq = 1
                      elsif vtd contains '3'
                        assign vq = 3
                      elsif vtd contains '2'
                        assign vq = 2
                      endif
                    endif
                    if vq == 1 and seen_1 == false
                      assign seen_1 = true
                      assign distinct_packs = distinct_packs | plus: 1
                    endif
                    if vq == 2 and seen_2 == false
                      assign seen_2 = true
                      assign distinct_packs = distinct_packs | plus: 1
                    endif
                    if vq == 3 and seen_3 == false
                      assign seen_3 = true
                      assign distinct_packs = distinct_packs | plus: 1
                    endif
                  endfor

                  if item.product.has_only_default_variant or item.product.variants.size <= 1 or distinct_packs <= 1
                    assign item_is_qty_setup = true
                    assign variant_pack = item.quantity
                    if variant_pack > 3
                      assign variant_pack = 3
                    endif
                    assign item_total = item.quantity
                  else
                    assign item_is_qty_setup = false
                    assign variant_pack = 1
                    if item.variant.metafields.custom.quantity != blank
                      assign variant_pack = item.variant.metafields.custom.quantity | plus: 0
                    else
                      assign td = item.variant.title | downcase
                      if td contains 'set of 3' or td contains '3 tag' or td contains '3-pack' or td contains '3 pack'
                        assign variant_pack = 3
                      elsif td contains 'set of 2' or td contains '2 tag' or td contains '2-pack' or td contains '2 pack'
                        assign variant_pack = 2
                      elsif td contains '3'
                        assign variant_pack = 3
                      elsif td contains '2'
                        assign variant_pack = 2
                      endif
                    endif
                    assign item_total = variant_pack | times: item.quantity
                  endif

                  if variant_pack >= 3
                    assign has_set_of_3 = true
                  endif

                  assign total_tags = total_tags | plus: item_total

                  if upsell_item == nil or variant_pack == 2
                    assign upsell_item = item
                    assign upsell_line = forloop.index
                    assign is_qty_pack_setup = item_is_qty_setup
                  endif
                endfor

                if upsell_item != nil and is_qty_pack_setup == false
                  for v in upsell_item.product.variants
                    assign vq = 1
                    if v.metafields.custom.quantity != blank
                      assign vq = v.metafields.custom.quantity | plus: 0
                    else
                      assign vtd = v.title | downcase
                      if vtd contains 'set of 3' or vtd contains '3 tag' or vtd contains '3-pack' or vtd contains '3 pack'
                        assign vq = 3
                      elsif vtd contains 'set of 2' or vtd contains '2 tag' or vtd contains '2-pack' or vtd contains '2 pack'
                        assign vq = 2
                      elsif vtd contains '1 tag' or vtd == 'default title'
                        assign vq = 1
                      elsif vtd contains '3'
                        assign vq = 3
                      elsif vtd contains '2'
                        assign vq = 2
                      endif
                    endif
                    if vq == 3 and set_of_3_variant_id == nil
                      assign set_of_3_variant_id = v.id
                    endif
                    if vq == 1 and one_tag_variant == nil
                      assign one_tag_variant = v
                    endif
                  endfor
                endif

                assign upsell_tier = 0
                if has_set_of_3 or total_tags >= 3
                  assign upsell_tier = 3
                elsif total_tags == 2
                  assign upsell_tier = 2
                elsif total_tags == 1
                  assign upsell_tier = 1
                endif
              -%}

              {%- if upsell_item != nil and upsell_tier > 0 and upsell_tier < 3 -%}
                <div class="cart_drawer_upsell">
                  <div class="cart_drawer_upsell_head">
                    <p class="cart_drawer_upsell_title">
                      {%- if upsell_tier == 2 -%}
                        Save even more by upgrading to Set of 3.
                      {%- else -%}
                        Save more when you add extra tags.
                      {%- endif -%}
                    </p>
                  </div>

                  <div class="cart_drawer_upsell_list">
                    {%- if is_qty_pack_setup -%}
                      {%- if upsell_tier == 1 -%}
                        {%- assign offer_price = upsell_item.variant.price | times: 3 -%}
                        <div class="cart_drawer_upsell_card">
                          <div class="cart_drawer_upsell_copy">
                            <div class="cart_drawer_upsell_label_row">
                              <p class="cart_drawer_upsell_label">Set of 3</p>
                            </div>
                            <p class="cart_drawer_upsell_price">
                              <span class="cart_drawer_upsell_price_sale">{{ offer_price | money }}</span>
                            </p>
                          </div>
                          <cart-pack-upgrade
                            data-key="{{ upsell_item.key }}"
                            data-line="{{ upsell_line }}"
                            data-variant-id="{{ upsell_item.variant_id }}"
                            data-quantity="3"
                            data-mode="add"
                            data-product-id="{{ upsell_item.product.id }}">
                            <button type="button" class="cart_drawer_upsell_btn">Upgrade</button>
                          </cart-pack-upgrade>
                        </div>
                      {%- elsif upsell_tier == 2 -%}
                        {%- assign offer_price = upsell_item.variant.price -%}
                        <div class="cart_drawer_upsell_card">
                          <div class="cart_drawer_upsell_copy">
                            <div class="cart_drawer_upsell_label_row">
                              <p class="cart_drawer_upsell_label">1 TAG</p>
                            </div>
                            <p class="cart_drawer_upsell_price">
                              <span class="cart_drawer_upsell_price_sale">{{ offer_price | money }}</span>
                            </p>
                          </div>
                          <cart-pack-upgrade
                            data-key="{{ upsell_item.key }}"
                            data-line="{{ upsell_line }}"
                            data-variant-id="{{ upsell_item.variant_id }}"
                            data-quantity="3"
                            data-mode="replace"
                            data-same-variant="true"
                            data-product-id="{{ upsell_item.product.id }}">
                            <button type="button" class="cart_drawer_upsell_btn">Upgrade</button>
                          </cart-pack-upgrade>
                        </div>
                      {%- endif -%}
                    {%- else -%}
                      {%- if upsell_tier == 2 and one_tag_variant != nil and set_of_3_variant_id != nil -%}
                        {%- liquid
                          assign v = one_tag_variant
                          assign save_pct = 0
                          if v.compare_at_price > v.price
                            assign save_pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round
                          endif
                        -%}
                        <div class="cart_drawer_upsell_card">
                          <div class="cart_drawer_upsell_copy">
                            <div class="cart_drawer_upsell_label_row">
                              <p class="cart_drawer_upsell_label">1 TAG</p>
                              {%- if save_pct > 0 -%}
                                <span class="cart_drawer_upsell_badge">Save {{ save_pct }}%</span>
                              {%- endif -%}
                            </div>
                            <p class="cart_drawer_upsell_price">
                              <span class="cart_drawer_upsell_price_sale">{{ v.price | money }}</span>
                              {%- if v.compare_at_price > v.price -%}
                                <s class="cart_drawer_upsell_price_compare">{{ v.compare_at_price | money }}</s>
                              {%- endif -%}
                            </p>
                          </div>
                          <cart-pack-upgrade
                            data-key="{{ upsell_item.key }}"
                            data-line="{{ upsell_line }}"
                            data-variant-id="{{ set_of_3_variant_id }}"
                            data-quantity="1"
                            data-mode="replace"
                            data-product-id="{{ upsell_item.product.id }}">
                            <button type="button" class="cart_drawer_upsell_btn">Upgrade</button>
                          </cart-pack-upgrade>
                        </div>
                      {%- else -%}
                        {%- for v in upsell_item.product.variants -%}
                          {%- liquid
                            assign vq = 1
                            if v.metafields.custom.quantity != blank
                              assign vq = v.metafields.custom.quantity | plus: 0
                            else
                              assign vtd = v.title | downcase
                              if vtd contains 'set of 3' or vtd contains '3 tag' or vtd contains '3-pack' or vtd contains '3 pack'
                                assign vq = 3
                              elsif vtd contains 'set of 2' or vtd contains '2 tag' or vtd contains '2-pack' or vtd contains '2 pack'
                                assign vq = 2
                              elsif vtd contains '1 tag' or vtd == 'default title'
                                assign vq = 1
                              elsif vtd contains '3'
                                assign vq = 3
                              elsif vtd contains '2'
                                assign vq = 2
                              endif
                            endif

                            assign show_offer = false
                            if upsell_tier == 1 and vq == 3
                              assign show_offer = true
                            endif

                            assign save_pct = 0
                            if v.compare_at_price > v.price
                              assign save_pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round
                            endif

                            assign offer_label = ''
                            if v.metafields.custom.variant_name.value != blank
                              assign offer_label = v.metafields.custom.variant_name.value
                            elsif v.metafields.custom.variant_name != blank
                              assign offer_label = v.metafields.custom.variant_name
                            elsif v.metafields.custom.title.value != blank
                              assign offer_label = v.metafields.custom.title.value
                            elsif v.metafields.custom.title != blank
                              assign offer_label = v.metafields.custom.title
                            elsif vq == 2
                              assign offer_label = 'Set of 2'
                            elsif vq == 3
                              assign offer_label = 'Set of 3'
                            else
                              assign offer_label = v.title
                            endif

                            assign offer_label_down = offer_label | downcase
                            if offer_label_down contains 'set of 3' or offer_label_down contains '3 tag' or vq == 3
                              assign offer_label = 'Set of 3'
                            elsif offer_label_down contains 'set of 2' or offer_label_down contains '2 tag' or vq == 2
                              assign offer_label = 'Set of 2'
                            elsif offer_label_down contains '1 tag' or vq == 1
                              assign offer_label = '1 TAG'
                            endif
                          -%}

                          {%- if show_offer -%}
                            <div class="cart_drawer_upsell_card">
                              <div class="cart_drawer_upsell_copy">
                                <div class="cart_drawer_upsell_label_row">
                                  <p class="cart_drawer_upsell_label">{{ offer_label }}</p>
                                  {%- if save_pct > 0 -%}
                                    <span class="cart_drawer_upsell_badge">Save {{ save_pct }}%</span>
                                  {%- endif -%}
                                </div>
                                <p class="cart_drawer_upsell_price">
                                  <span class="cart_drawer_upsell_price_sale">{{ v.price | money }}</span>
                                  {%- if v.compare_at_price > v.price -%}
                                    <s class="cart_drawer_upsell_price_compare">{{ v.compare_at_price | money }}</s>
                                  {%- endif -%}
                                </p>
                              </div>
                              <cart-pack-upgrade
                                data-key="{{ upsell_item.key }}"
                                data-line="{{ upsell_line }}"
                                data-variant-id="{{ v.id }}"
                                data-quantity="1"
                                data-mode="add"
                                data-product-id="{{ upsell_item.product.id }}">
                                <button type="button" class="cart_drawer_upsell_btn">Upgrade</button>
                              </cart-pack-upgrade>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="cdi_cart_level_discount_wrapper" aria-label="{{ 'sections.cart.cart_level_discount_heading' | t }}">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="cdi_cart_level_discount">
                      {{- 'icon-discount.svg' | inline_asset_content -}}
                      <p>
                        {{ discount.title | escape }}
                        (-{{ discount.total_allocated_amount | money }})
                      </p>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <div class="cdi_subtotals_wrapper">
                <div class="cdi_subtotal_inner">
                  <span class="cdi_subtotal_label">Subtotal</span>
                  <span class="cdi_subtotal_value">{{ cart.total_price | money }}</span>
                </div>
              </div>

              <div class="cdi_action_buttons_wrapper">
                <form action="{{ routes.cart_url }}" method="post">
                  <button class="btn cart_drawer_checkout_btn" type="submit" name="checkout">
                    Checkout
                  </button>
                </form>
              </div>

              <div class="cart_drawer_guarantee">
                <span class="cart_drawer_guarantee_icon" aria-hidden="true">
                  <svg width="17" height="19" viewBox="0 0 18 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M16.24 10.81a7.5 7.5 0 1 0-11.4-.94" stroke="#000" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M12.7 9.09A2.5 2.5 0 0 1 10.86 10.34c-1.19 0-2.15-1.15-2.15-2.57V6.3c0-1.42.96-2.57 2.15-2.57.78 0 1.47.5 1.84 1.25M7.51 7.03h3.56" stroke="#000" stroke-width="0.85" stroke-linecap="round"/>
                    <path d="M.43 11.76h2.26c.28 0 .55.06.8.18l1.93.93c.25.12.52.18.8.18h.98c.95 0 1.73.75 1.73 1.67 0 .04-.03.07-.06.08l-2.4.66a2 2 0 0 1-1 .13l-2.06-1M8.92 14.12l4.34-1.33c.38-.12.78-.11 1.16.02.37.13.7.37.92.69.35.48.21 1.17-.3 1.47l-7.1 4.1a2 2 0 0 1-.72.24 2 2 0 0 1-.76-.06L.43 17.44" stroke="#000" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="cart_drawer_guarantee_text">30-day money-back guarantee</span>
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</cart-drawer>
