<cart-drawer>
  <div
    class="drawer_wrapper cart_drawer_wrapper color-{{ settings.drawer_color_scheme }}"
    id="cart_drawer"
    inert
    aria-hidden="true">
    <div class="drawer_wrapper_inner cart_drawer_inner" tabindex="-1">
      <div class="cart_drawer_confetti_layer" aria-hidden="true"></div>

      <div class="drawer_header cart_drawer_header">
        <h2 class="cart_drawer_heading">
          {{ 'drawers.cart_drawer.heading' | t }}
        </h2>

        <div class="drawer_close_btn_wrapper">
          <button class="drawer_close_btn" aria-label="{{ 'accessibility.close' | t }}">
            <div class="svg_wrapper">{{ 'icon-close.svg' | inline_asset_content }}</div>
          </button>
        </div>
      </div>

      {% if cart != empty %}
        {% render 'free-shipping-bar' %}
      {% endif %}

      <div class="cart_drawer_content_wrapper" data-lenis-prevent>
        {% if cart == empty %}
          <div class="empty_cart_drawer_wrapper">
            <h3 class="h4">{{ 'drawers.cart_drawer.empty_drawer_heading' | t }}</h3>
            <a
              class="btn"
              href="{{ routes.all_products_collection_url }}"
              aria-label="{{ 'general.continue_shopping' | t }}">
              {{- 'general.continue_shopping' | t -}}
            </a>
          </div>
        {% else %}
          <div class="cart_drawer_body">
            <div class="cart_drawer_content_inner">
              {% for item in cart.items %}
                {%- liquid
                  assign cart_img = item.image
                  if item.product.featured_image != blank
                    assign cart_img = item.product.featured_image
                  endif
                  if item.product.images.size > 0
                    assign cart_img = item.product.images.first
                  endif

                  assign pack_qty = 1
                  if item.variant.metafields.custom.quantity != blank
                    assign pack_qty = item.variant.metafields.custom.quantity | plus: 0
                  else
                    assign title_downcase = item.variant.title | downcase
                    if title_downcase contains '3'
                      assign pack_qty = 3
                    elsif title_downcase contains '2'
                      assign pack_qty = 2
                    endif
                  endif
                -%}

                <div class="cart_drawer_item_block" data-pack-qty="{{ pack_qty }}">
                  <div class="cdi_block_inner">
                    <div class="cart_drawer_item_img_block">
                      <a href="{{ item.url }}" aria-label="{{ item.product.title | escape }}"></a>
                      {% if cart_img != blank %}
                        {{ cart_img | image_url: width: 400 | image_tag: loading: 'lazy', alt: item.product.title }}
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder_svg' }}
                      {% endif %}
                      <div class="cart_drawer_item_badge" aria-hidden="true">
                        {{ 'drawers.cart_drawer.special_offer_badge' | t }}
                      </div>
                    </div>

                    <div class="cart_drawer_item_info_block">
                      <div class="cdi_top_row">
                        <div class="cdi_title">
                          <p>
                            <a href="{{ item.url }}">{{ item.product.title }}</a>
                          </p>
                        </div>
                        <div class="cdi_price">
                          {% if item.original_price != item.final_price %}
                            <div class="cdi_price_inner">
                              <span>{{ item.final_price | money }}</span>
                              <s>{{ item.original_price | money }}</s>
                            </div>
                          {% else %}
                            <div class="cdi_price_inner">
                              <span>{{ item.final_price | money }}</span>
                              {% if item.variant.compare_at_price != blank
                                and item.variant.compare_at_price > item.variant.price
                              %}
                                <s>{{ item.variant.compare_at_price | money }}</s>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                      </div>

                      <div class="cdi_mid_row">
                        <div class="cdi_options_wrapper">
                          {% unless item.product.has_only_default_variant %}
                            <p class="cdi_product_options">
                              {% for option in item.options_with_values %}
                                <span>{{- option.value -}}</span>
                              {% endfor %}
                            </p>
                          {% else %}
                            <p class="cdi_product_options">
                              <span>{{ item.quantity }} {% if item.quantity == 1 %}{{ 'drawers.cart_drawer.product_singular' | t }}{% else %}{{ 'drawers.cart_drawer.product_plural' | t }}{% endif %}</span>
                            </p>
                          {% endunless %}

                          {% if item.properties.size != 0 %}
                            {%- for property in item.properties -%}
                              {%- assign property_first_char = property.first | slice: 0 -%}
                              {%- if property.last != blank and property_first_char != '_' -%}
                                <div class="cdi_properties_wrapper">
                                  <div class="cdi_property_name">{{ property.first }}:</div>
                                  <div class="cdi_property_value">
                                    {%- if property.last contains '/uploads/' -%}
                                      <a href="{{ property.last }}" class="link" target="_blank">
                                        {{ property.last | split: '/' | last }}
                                      </a>
                                    {%- else -%}
                                      {{ property.last }}
                                    {%- endif -%}
                                  </div>
                                </div>
                              {%- endif -%}
                            {%- endfor -%}
                          {% endif %}

                          {% if item.selling_plan_allocation != null %}
                            <p class="cdi_selling_plan">
                              {{ item.selling_plan_allocation.selling_plan.name }}
                            </p>
                          {% endif %}
                        </div>

                        <div class="cdi_item_remove">
                          <item-remove data-line="{{ forloop.index }}">
                            <a
                              aria-label="{{- 'drawers.cart_drawer.remove' | t -}}"
                              class="item_remove_btn"
                              href="{{ item.url_to_remove }}"
                              data-remove
                              data-quantity="0">
                              {{ 'cart-drawer-trash.svg' | inline_asset_content }}
                            </a>
                          </item-remove>
                        </div>
                      </div>

                      <div class="cdi_quantity_picker">
                        <cart-quantity-picker data-line="{{ forloop.index }}">
                          <button
                            type="button"
                            class="btn_minus"
                            data-minus
                            aria-label="{{ 'products.product.quantity_decrease' | t }}"
                            data-quantity="{{ item.quantity | minus: 1 }}"
                            data-min="{{ item.quantity }} - {{ item.variant.quantity_rule.min }}"
                            {% if item.quantity == item.variant.quantity_rule.min %}
                            disabled
                            {% endif %}>
                            <span class="cq_hori"></span>
                          </button>

                          <input
                            type="text"
                            name="quantity"
                            min="{{ item.variant.quantity_rule.min }}"
                            data-min="{{ item.variant.quantity_rule.min }}"
                            {% if item.variant.quantity_rule.max %}
                            data-max="{{ item.variant.quantity_rule.max }}"
                            max="{{ item.variant.quantity_rule.max }}"
                            {% endif %}
                            step="{{ item.variant.quantity_rule.increment }}"
                            value="{{ item.quantity }}"
                            id="Item_quantity-{{ forloop.index }}">
                          <label class="visually-hidden" for="Item_quantity-{{ forloop.index }}">
                            {{- 'products.product.quantity' | t -}}
                          </label>

                          <button
                            type="button"
                            aria-label="{{ 'products.product.quantity_increase' | t }}"
                            class="btn_plus"
                            data-plus
                            data-quantity="{{ item.quantity | plus: 1 }}"
                            {% if item.quantity == item.variant.quantity_rule.max %}
                            disabled
                            {% endif %}>
                            <span class="cq_hori"></span>
                            <span class="cq_vert"></span>
                          </button>
                        </cart-quantity-picker>
                      </div>
                    </div>
                  </div>

                  <div
                    class="cart_drawer_error"
                    data-line="{{ forloop.index }}"
                    hidden>
                    A maximum of 5 items are added due to availability.
                  </div>
                </div>
              {% endfor %}
            </div>

            {%- comment -%} Pack upgrade offers (1 tag → Set of 2 / Set of 3; Set of 2 → Set of 3; Set of 3 → none) {%- endcomment -%}
            {%- liquid
              assign upsell_item = nil
              assign upsell_line = 0
              assign upsell_pack = 0

              for item in cart.items
                assign pq = 1
                if item.variant.metafields.custom.quantity != blank
                  assign pq = item.variant.metafields.custom.quantity | plus: 0
                else
                  assign td = item.variant.title | downcase
                  if td contains '3'
                    assign pq = 3
                  elsif td contains '2'
                    assign pq = 2
                  endif
                endif

                assign has_higher = false
                for v in item.product.variants
                  assign vq = 1
                  if v.metafields.custom.quantity != blank
                    assign vq = v.metafields.custom.quantity | plus: 0
                  else
                    assign vtd = v.title | downcase
                    if vtd contains '3'
                      assign vq = 3
                    elsif vtd contains '2'
                      assign vq = 2
                    endif
                  endif
                  if vq > pq
                    assign has_higher = true
                  endif
                endfor

                if has_higher and pq >= upsell_pack
                  assign upsell_item = item
                  assign upsell_line = forloop.index
                  assign upsell_pack = pq
                endif
              endfor
            -%}

            {%- if upsell_item != nil and upsell_pack < 3 -%}
              <div class="cart_drawer_upsell">
                <div class="cart_drawer_upsell_head">
                  <p class="cart_drawer_upsell_title">{{ 'drawers.cart_drawer.upsell_heading' | t }}</p>
                </div>

                <div class="cart_drawer_upsell_list">
                  {%- for v in upsell_item.product.variants -%}
                    {%- liquid
                      assign vq = 1
                      if v.metafields.custom.quantity != blank
                        assign vq = v.metafields.custom.quantity | plus: 0
                      else
                        assign vtd = v.title | downcase
                        if vtd contains '3'
                          assign vq = 3
                        elsif vtd contains '2'
                          assign vq = 2
                        endif
                      endif

                      assign add_count = vq | minus: upsell_pack
                      assign show_offer = false
                      if vq > upsell_pack
                        if upsell_pack == 1 and vq <= 3
                          assign show_offer = true
                        endif
                        if upsell_pack == 2 and vq == 3
                          assign show_offer = true
                        endif
                      endif

                      assign save_pct = 0
                      if v.compare_at_price > v.price
                        assign save_pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round
                      endif
                    -%}

                    {%- if show_offer and add_count > 0 -%}
                      <div class="cart_drawer_upsell_card">
                        <div class="cart_drawer_upsell_copy">
                          <div class="cart_drawer_upsell_label_row">
                            <p class="cart_drawer_upsell_label">
                              {%- if add_count == 1 -%}
                                {{ 'drawers.cart_drawer.upsell_add_one' | t }}
                              {%- else -%}
                                {{ 'drawers.cart_drawer.upsell_add_two' | t }}
                              {%- endif -%}
                            </p>
                            {%- if save_pct > 0 -%}
                              <span class="cart_drawer_upsell_badge">Save {{ save_pct }}%</span>
                            {%- endif -%}
                          </div>
                          <p class="cart_drawer_upsell_price">
                            <span class="cart_drawer_upsell_price_sale">{{ v.price | money }}</span>
                            {%- if v.compare_at_price > v.price -%}
                              <s class="cart_drawer_upsell_price_compare">{{ v.compare_at_price | money }}</s>
                            {%- endif -%}
                          </p>
                        </div>
                        <cart-pack-upgrade
                          data-line="{{ upsell_line }}"
                          data-variant-id="{{ v.id }}"
                          data-product-id="{{ upsell_item.product.id }}">
                          <button type="button" class="cart_drawer_upsell_btn">
                            {{ 'drawers.cart_drawer.upsell_upgrade' | t }}
                          </button>
                        </cart-pack-upgrade>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>

          <div class="cart_drawer_footer">
            <div class="cart_drawer_footer_inner">
              {% if settings.show_discount %}
                <cart-discount-input>
                  <div class="cdi_discount_wrapper">
                    <h3 class="small-text">{{ 'sections.cart.discount_heading' | t }}</h3>
                    <div class="cdi_discount_form_wrapper">
                      <form method="post" action="{{ routes.cart_update_url }}" id="cart_discount_form">
                        <div class="cdi_form_inner">
                          <div class="input_field_wrapper">
                            <input
                              id="cdi_form_input"
                              type="text"
                              name="discount"
                              placeholder="{{ 'sections.cart.discount_label' | t }}">
                            <label for="cdi_form_input">
                              {{- 'sections.cart.discount_label' | t | append: ' *' -}}
                            </label>
                          </div>
                          <div class="cdi_form_button">
                            <button
                              class="btn"
                              type="submit"
                              name="cdi_discount_btn"
                              style="--bg-color: {{ settings.discount_btn_bg_color }}; --text-color: {{ settings.discount_btn_text_color }};">
                              {{ 'sections.cart.apply_discount' | t }}
                            </button>
                          </div>
                        </div>
                      </form>

                      {% liquid
                        assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
                        for item in cart.items
                          for allocation in item.line_level_discount_allocations
                            if allocation.discount_application.type == 'discount_code'
                              assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
                            endif
                          endfor
                        endfor
                        assign discount_codes = discount_codes | uniq
                      %}

                      {% for discount_code in discount_codes %}
                        <div class="cdi_discount_name">
                          <span class="cdi_icon_discount_wrapper">
                            {{- 'icon-discount.svg' | inline_asset_content -}}
                          </span>
                          {{ discount_code }}
                          <button class="cdi_discount_remove_button" aria-label="{{ 'sections.cart.remove_discount' | t }}">
                            <span data-cart-discount-remove>
                              {{- 'icon-close.svg' | inline_asset_content -}}
                            </span>
                          </button>
                        </div>
                      {% endfor %}

                      <div class="cdi_discount_error hidden">
                        <p>{{ 'sections.cart.cart_discount_error' | t }}</p>
                      </div>
                    </div>
                  </div>
                </cart-discount-input>
              {% endif %}

              {% if settings.show_cart_note %}
                <div class="cdi_cart_note_wrapper">
                  <cart-note>
                    <div class="cdi_cart_note_inner">
                      <div class="cdi_cart_note_head">
                        <h3 class="small-text">{{ 'sections.cart.cart_note_heading' | t }}</h3>
                        <button class="cdi_cart_note_btn" type="button">
                          <span class="cdi_cn_hori"></span>
                          <span class="cdi_cn_vert"></span>
                        </button>
                      </div>
                      <div class="cdi_cart_note_content">
                        <div class="cdi_cart_note_content_inner">
                          <label for="cart_note-drawer" class="visually-hidden">{{ 'sections.cart.cart_note_placeholder' | t }}</label>
                          <textarea
                            name="note"
                            form="cart"
                            id="cart_note-drawer"
                            width="100%"
                            rows="6"
                            inert
                            aria-hidden="true"
                            placeholder="{{ 'sections.cart.cart_note_placeholder' | t }}">{{ cart.note }}</textarea>
                        </div>
                      </div>
                    </div>
                  </cart-note>
                </div>
              {% endif %}

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="cdi_cart_level_discount_wrapper" aria-label="{{ 'sections.cart.cart_level_discount_heading' | t }}">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="cdi_cart_level_discount">
                      {{- 'icon-discount.svg' | inline_asset_content -}}
                      <p>
                        {{ discount.title | escape }}
                        (-{{ discount.total_allocated_amount | money }})
                      </p>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <div class="cdi_subtotals_wrapper">
                <div class="cdi_subtotal_inner">
                  <span class="cdi_subtotal_label">{{ 'sections.cart.subtotal' | t }}</span>
                  <span class="cdi_subtotal_value">{{ cart.total_price | money }}</span>
                </div>
              </div>

              <div class="cdi_action_buttons_wrapper">
                <a
                  href="{{ routes.cart_url }}"
                  aria-label="{{ 'sections.cart.view_cart' | t }}"
                  class="cdi_view_cart_btn btn btn--secondary">
                  {{- 'sections.cart.view_cart' | t -}}
                </a>

                <form action="{{ routes.cart_url }}" method="post">
                  <button class="btn cart_drawer_checkout_btn" type="submit" name="checkout">
                    {{ 'sections.cart.checkout' | t }}
                  </button>
                </form>
              </div>

              <div class="cart_drawer_guarantee">
                <span class="cart_drawer_guarantee_icon" aria-hidden="true">
                  {{ 'cart-drawer-guarantee.svg' | inline_asset_content }}
                </span>
                <span class="cart_drawer_guarantee_text">{{ 'drawers.cart_drawer.money_back' | t }}</span>
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</cart-drawer>
