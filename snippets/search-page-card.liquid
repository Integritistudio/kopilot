{% assign ratio = 1 %}
{% if aspect_ratio == 'portrait' %}
  {% assign ratio = 0.8 %}
{% elsif aspect_ratio == 'adapt' %}
  {% if product.selected_or_first_available_variant.featured_image != blank %}
    {% assign ratio = product.selected_or_first_available_variant.featured_image.aspect_ratio %}
  {% elsif product.featured_image != blank %}
    {% assign ratio = product.featured_image.aspect_ratio %}
  {% else %}
    {% assign ratio = 1 %}
  {% endif %}
{% endif %}

<div class="page_card_wrapper">
  <div
    class="page_card_img ratio{% if show_card_bg %} has_bg{% endif %}"
    style="--aspect-ratio: {{ 1 | divided_by: ratio | times: 100 }}%; {% if show_card_bg %}--card-bg: {{ card_bg }}{% endif %}"
  >
    {% if page.image != blank %}
      <a aria-label="{{ page.title }}" href="{{ page.url }}">
        {{ page.image | image_url: width: 1200 | image_tag: class: 'main_ac_image' }}
      </a>
    {% else %}
      {% assign ac_index = index | modulo: 2 %}
      <a aria-label="{{ page.title }}" href="{{ page.url }}">
        {% if ac_index == 1 %}
          {{ 'product-2' | placeholder_svg_tag: 'placeholder_svg' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder_svg' }}
        {% endif %}
      </a>
    {% endif %}
  </div>

  <div class="page_card_info pc_info--{{ card_align }}" style="--text-align: {{ card_align }}">
    <h4 class="small-text">{{ page.title | link_to: page.url }}</h4>    
  </div>
</div>
