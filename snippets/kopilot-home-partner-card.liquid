{% doc %}
Renders a partner spotlight card for kopilot-home-partner-cta.
@param {block} block - Section block
@param {image} [media_image] - Optional explicit image override
{% enddoc %}

{%- liquid
  assign card_image = media_image
  if card_image == blank
    assign card_image = block.settings.image
  endif
  if card_image == blank
    assign card_image = block.settings.logo
  endif

  assign card_alt = block.settings.image_alt | default: block.settings.name | default: ''
-%}

<article class="kopilot-home-partner-cta__card" {{ block.shopify_attributes }}>
  <div class="kopilot-home-partner-cta__card-media">
    <div
      class="kopilot-home-partner-cta__card-media-bg"
      {% if card_image != blank %}
        style="background-image: url('{{ card_image | image_url: width: 800 }}');"
      {% endif %}
      role="img"
      {% if card_alt != blank %}aria-label="{{ card_alt | escape }}"{% else %}aria-hidden="true"{% endif %}
    >
      {% if card_image != blank %}
        <img
          class="kopilot-home-partner-cta__card-media-img"
          src="{{ card_image | image_url: width: 800 }}"
          alt="{{ card_alt | escape }}"
          width="800"
          height="400"
          loading="lazy"
        >
      {% endif %}
    </div>
  </div>

  <div class="kopilot-home-partner-cta__card-body">
    <div class="kopilot-home-partner-cta__card-copy">
      {% if block.settings.name != blank or block.settings.role != blank %}
        <div class="kopilot-home-partner-cta__card-meta">
          {% if block.settings.name != blank %}
            <span class="kopilot-home-partner-cta__card-name">{{ block.settings.name }}</span>
          {% endif %}
          {% if block.settings.role != blank %}
            <span class="kopilot-home-partner-cta__card-role">{{ block.settings.role }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.quote != blank %}
        <p class="kopilot-home-partner-cta__card-quote">{{ block.settings.quote }}</p>
      {% endif %}
    </div>

    {% if block.settings.stat != blank %}
      <p class="kopilot-home-partner-cta__card-stat">{{ block.settings.stat }}</p>
    {% endif %}
  </div>
</article>
